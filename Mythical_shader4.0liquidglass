local activeThemeLabel; local rainbowActive=false; local glassRotThread=nil

local function applyTheme(index)
    local theme=COLOR_THEMES[index]; State.currentThemeIndex=index
    if activeThemeLabel then
        tw(activeThemeLabel,{TextColor3=theme.primary},SMOOTH)
        activeThemeLabel.Text="Active: "..theme.name
    end
    refreshTabButtons(); refreshAllSliders()

    local isDarkTheme=theme.dark or theme.clear
    if theme.glass or theme.clear then
        GlassHighlight.Visible=true; GlassViewport.Visible=theme.liquid==true
        local bgC=isDarkTheme and UI.C_BG2 or Color3.fromRGB(230,240,252)
        tw(MainFrame,{BackgroundColor3=bgC,BackgroundTransparency=1-State.uiOpacity},SMOOTH)
        UIStroke.Thickness=1.8
        SidebarLine.BackgroundColor3=isDarkTheme and Color3.fromRGB(100,100,155) or Color3.fromRGB(160,205,240)
        Sidebar.BackgroundColor3=isDarkTheme and Color3.fromRGB(8,8,14) or Color3.fromRGB(224,236,252)
        szStroke.Color=theme.primary; minStroke.Color=theme.primary
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end) end
        glassRotThread=task.spawn(function()
            while State.currentThemeIndex==index
                and (COLOR_THEMES[State.currentThemeIndex].glass or COLOR_THEMES[State.currentThemeIndex].clear) do
                pcall(function()
                    UIGradientStroke.Rotation=(tick()*16)%360
                    local h=((tick()*18)%360)/360; local c=Color3.fromHSV(h,0.38,1)
                    UIGradientStroke.Color=ColorSequence.new({
                        ColorSequenceKeypoint.new(0,Color3.fromRGB(188,215,248)),
                        ColorSequenceKeypoint.new(0.5,c),
                        ColorSequenceKeypoint.new(1,Color3.fromRGB(168,205,245)),
                    })
                end)
                task.wait(0.05)
            end
        end)
    else
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end); glassRotThread=nil end
        GlassHighlight.Visible=false; GlassViewport.Visible=false
        tw(MainFrame,{BackgroundColor3=Color3.fromRGB(236,238,248),BackgroundTransparency=0.1},SMOOTH)
        UIStroke.Thickness=1.2; UIGradientStroke.Rotation=0
        SidebarLine.BackgroundColor3=Color3.fromRGB(200,195,228)
        Sidebar.BackgroundColor3=Color3.fromRGB(230,230,248)
        szStroke.Color=Color3.fromRGB(180,170,218); minStroke.Color=Color3.fromRGB(180,170,212)
        UIGradientStroke.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,Color3.fromRGB(200,180,242)),
            ColorSequenceKeypoint.new(0.5,theme.secondary),
            ColorSequenceKeypoint.new(1,Color3.fromRGB(200,180,242)),
        })
        UIGradientStroke.Transparency=NumberSequence.new({
            NumberSequenceKeypoint.new(0,0.42); NumberSequenceKeypoint.new(0.5,0.08); NumberSequenceKeypoint.new(1,0.42)
        })
    end
    applyBorderStyle(State.borderStyle,theme.primary)
end

