    SkyBtn.Font=Enum.Font.SourceSans SkyBtn.TextSize=12
    Instance.new("UICorner",SkyBtn).CornerRadius=UDim.new(0,6)
    Instance.new("UIStroke",SkyBtn).Color=Color3.fromRGB(80,60,110)
    spring(SkyBtn)
    SkyBtn.MouseButton1Click:Connect(function() applySkyPreset(preset) end)
    skyIdx=skyIdx+1
end
