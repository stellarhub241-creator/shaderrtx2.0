local function applySkyPreset(preset)
    if not preset then return end
    pcall(function() skyGuardConn:Disconnect() end)
    pcall(function() for _,child in ipairs(Lighting:GetChildren()) do if child:IsA("Sky") then child:Destroy() end end end)
    task.wait(0.05)
    local sky=Instance.new("Sky",Lighting); sky.Name="StellarSky"
    pcall(function()
        sky.SkyboxBk=preset.bk; sky.SkyboxDn=preset.dn; sky.SkyboxFt=preset.ft
        sky.SkyboxLf=preset.lf; sky.SkyboxRt=preset.rt; sky.SkyboxUp=preset.up
        sky.StarCount=preset.star; sky.CelestialBodiesShown=true
        if preset.moonSize then sky.MoonAngularSize=preset.moonSize end
        if not State.heavenlyEnabled then Lighting.ClockTime=preset.time end
        if preset.brightness then Lighting.Brightness=preset.brightness end
        if preset.ambient then Lighting.OutdoorAmbient=preset.ambient end
    end); connectSkyGuard()
end

local function makeSkyBtn(parent,text,y)
    local b=Instance.new("TextButton",parent); b.Size=UDim2.new(1,-14,0,28); b.Position=UDim2.new(0,UI.PAD_X,0,y)
    b.BackgroundColor3=Color3.fromRGB(38,38,50); b.BackgroundTransparency=0.4; b.Text=text; b.TextColor3=UI.COL_SUBTEXT
    b.Font=UI.FONT_BODY; b.TextSize=UI.SIZE_BODY; Instance.new("UICorner",b).CornerRadius=UI.CORNER_SM
    Instance.new("UIStroke",b).Color=UI.COL_STROKE; spring(b); return b
end

