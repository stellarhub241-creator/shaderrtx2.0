createToggle(TabGfx,"Depth of Field",       1, State.dofEnabled,   function(val) State.dofEnabled=val; local d=Lighting:FindFirstChild("StellarDOF"); if d then d.Enabled=val end end)
createToggle(TabGfx,"4K PBR Reflectance",   2, State.pbrEnabled,   function(val) State.pbrEnabled=val; if val then task.spawn(runPBRScan) else for _,v in pairs(workspace:GetDescendants()) do pcall(function() if v:IsA("BasePart") or v:IsA("MeshPart") then v.Reflectance=0 end end) end end end)
createToggle(TabGfx,"Anti-Blue Gloss",      3, State.antiBlueGloss,function(val) State.antiBlueGloss=val; if State.pbrEnabled then task.spawn(runPBRScan) end end)
createToggle(TabGfx,"🌄 Dawn Mode",         4, false,function(val) State.dawnEnabled=val; State.sunsetEnabled=false; State.nostalgiaEnabled=false; reapplyActiveMode() end)
createToggle(TabGfx,"🌅 Sunset Mode",       5, false,function(val) State.sunsetEnabled=val; State.dawnEnabled=false; State.nostalgiaEnabled=false; reapplyActiveMode() end)
createToggle(TabGfx,"🌧 Rain Mode",         6, false,function(val) State.rainEnabled=val; reapplyActiveMode(); if val then createRainParticles() else clearRainParticles() end end)
createToggle(TabGfx,"👼 Heavenly Mode",     7, false,function(val) State.heavenlyEnabled=val; reapplyActiveMode() end)
createToggle(TabGfx,"☠️ Horror Fog",        8, false,function(val) State.horrorFogEnabled=val; reapplyActiveMode() end)
createToggle(TabGfx,"💙 Horror Blue",       9, false,function(val) State.horrorBlue=val; reapplyActiveMode() end)
createToggle(TabGfx,"💨 Wind Effect",      10, false,function(val) State.windEnabled=val; if val then startWind() else clearWind() end end)
createToggle(TabGfx,"📼 Nostalgia 2016",   11, false,function(val) State.nostalgiaEnabled=val; State.dawnEnabled=false; State.sunsetEnabled=false; reapplyActiveMode() end)

LiveTimeLabel=Instance.new("TextLabel",TabGfx)
LiveTimeLabel.Size=UDim2.new(1,-UI.PAD*2,0,24)
LiveTimeLabel.Position=UDim2.new(0,UI.PAD,0,11*UI.ROW_H+UI.PAD)
LiveTimeLabel.BackgroundColor3=Color3.fromRGB(10,10,20); LiveTimeLabel.BackgroundTransparency=0.28
LiveTimeLabel.Text="Status: Loaded"; LiveTimeLabel.TextColor3=Color3.fromRGB(140,255,165)
LiveTimeLabel.TextSize=11; LiveTimeLabel.Font=Enum.Font.Code; LiveTimeLabel.TextXAlignment=Enum.TextXAlignment.Center
Instance.new("UICorner",LiveTimeLabel).CornerRadius=UI.RADIUS_SM
