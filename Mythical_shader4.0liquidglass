    DAWN     = { brightness=1.6,  exposure=0.15,  shadow=0.2,  ambient=Color3.fromRGB(50,35,55),    atmoColor=Color3.fromRGB(180,120,160), atmoDecay=Color3.fromRGB(80,40,80),    atmoGlare=1.0, atmoHaze=1.8, atmoDensity=0.3,  contrast=0.25, saturation=0.4,  tint=Color3.fromRGB(255,210,220), bloom=0.5,  bloomSize=18, bloomThreshold=0.7,  dofFar=0.3, sunRays=0.2  },
    DAY      = { brightness=1.5,  exposure=0.1,   shadow=0.3,  ambient=Color3.fromRGB(50,50,60),    atmoColor=Color3.fromRGB(185,215,255), atmoDecay=Color3.fromRGB(110,120,140), atmoGlare=1.2, atmoHaze=1.2, atmoDensity=0.25, contrast=0.35, saturation=0.45, tint=Color3.fromRGB(255,235,200), bloom=0.35, bloomSize=16, bloomThreshold=0.85, dofFar=0.2, sunRays=0.25 },
    GOLDEN   = { brightness=2.2,  exposure=0.2,   shadow=0.2,  ambient=Color3.fromRGB(80,50,30),    atmoColor=Color3.fromRGB(255,130,50),  atmoDecay=Color3.fromRGB(150,60,10),   atmoGlare=2.0, atmoHaze=2.0, atmoDensity=0.35, contrast=0.35, saturation=0.7,  tint=Color3.fromRGB(255,200,130), bloom=0.5,  bloomSize=18, bloomThreshold=0.65, dofFar=0.4, sunRays=0.45 },
    NIGHT    = { brightness=1.8,  exposure=0.18,  shadow=0.25, ambient=Color3.fromRGB(20,28,55),    atmoColor=Color3.fromRGB(20,35,80),    atmoDecay=Color3.fromRGB(10,15,40),    atmoGlare=0.5, atmoHaze=1.5, atmoDensity=0.35, contrast=0.35, saturation=0.4,  tint=Color3.fromRGB(200,220,255), bloom=1.0,  bloomSize=22, bloomThreshold=0.4,  dofFar=0.4, sunRays=0.1  },
    RAIN     = { brightness=0.75, exposure=-0.1,  shadow=0.5,  ambient=Color3.fromRGB(38,43,55),    atmoColor=Color3.fromRGB(110,125,150), atmoDecay=Color3.fromRGB(55,62,78),    atmoGlare=0.15,atmoHaze=2.8, atmoDensity=0.45, contrast=0.08, saturation=-0.15,tint=Color3.fromRGB(190,208,232), bloom=0.3,  bloomSize=12, bloomThreshold=0.9,  dofFar=0.4, sunRays=0.0  },
    HEAVENLY = { brightness=1.6,  exposure=0.12,  shadow=0.15, ambient=Color3.fromRGB(160,170,220), atmoColor=Color3.fromRGB(200,220,255), atmoDecay=Color3.fromRGB(160,185,240), atmoGlare=1.4, atmoHaze=1.0, atmoDensity=0.12, contrast=0.15, saturation=0.35, tint=Color3.fromRGB(240,238,220), bloom=0.55, bloomSize=20, bloomThreshold=0.6,  dofFar=0.1, sunRays=0.35 },
    CINEMATIC= { brightness=0.9,  exposure=-0.2,  shadow=0.7,  ambient=Color3.fromRGB(18,18,22),    atmoColor=Color3.fromRGB(60,60,80),    atmoDecay=Color3.fromRGB(20,20,30),    atmoGlare=0.0, atmoHaze=1.0, atmoDensity=0.3,  contrast=0.6,  saturation=-0.1, tint=Color3.fromRGB(200,210,230), bloom=0.08, bloomSize=8,  bloomThreshold=0.98, dofFar=0.55,sunRays=0.05 },
}

local function applyProfile(p)
    if isFpsBoostOn or horrorFogEnabled or rainEnabled or heavenlyEnabled or cinematicEnabled then return end
    Lighting.Brightness           = p.brightness
    Lighting.ExposureCompensation = p.exposure
    Lighting.ShadowSoftness       = p.shadow
    Lighting.OutdoorAmbient       = p.ambient
    Atmosphere.Color              = p.atmoColor
    Atmosphere.Decay              = p.atmoDecay
    Atmosphere.Glare              = p.atmoGlare
    Atmosphere.Haze               = p.atmoHaze
    Atmosphere.Density            = p.atmoDensity
    ColorCorrection.Contrast      = p.contrast
    ColorCorrection.Saturation    = p.saturation
    ColorCorrection.TintColor     = p.tint
    Bloom.Intensity               = p.bloom
    Bloom.Size                    = p.bloomSize
    Bloom.Threshold               = p.bloomThreshold
    DOF.FarIntensity              = p.dofFar
    SunRays.Intensity             = p.sunRays
end

local function lerpN(a,b,t) return a+(b-a)*t end
local function lerpC(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end
local function lerpProfile(a,b,t)
    return {
        brightness=lerpN(a.brightness,b.brightness,t), exposure=lerpN(a.exposure,b.exposure,t),
        shadow=lerpN(a.shadow,b.shadow,t), ambient=lerpC(a.ambient,b.ambient,t),
        atmoColor=lerpC(a.atmoColor,b.atmoColor,t), atmoDecay=lerpC(a.atmoDecay,b.atmoDecay,t),
        atmoGlare=lerpN(a.atmoGlare,b.atmoGlare,t), atmoHaze=lerpN(a.atmoHaze,b.atmoHaze,t),
        atmoDensity=lerpN(a.atmoDensity,b.atmoDensity,t), contrast=lerpN(a.contrast,b.contrast,t),
        saturation=lerpN(a.saturation,b.saturation,t), tint=lerpC(a.tint,b.tint,t),
        bloom=lerpN(a.bloom,b.bloom,t), bloomSize=lerpN(a.bloomSize,b.bloomSize,t),
        bloomThreshold=lerpN(a.bloomThreshold,b.bloomThreshold,t),
        dofFar=lerpN(a.dofFar,b.dofFar,t), sunRays=lerpN(a.sunRays,b.sunRays,t),
    }
end

-- ==================== RAIN PARTICLES [v4.8 fix] ====================
local rainFolder     = nil
local rainConnections = {}

local function clearRainParticles()
    for _, c in pairs(rainConnections) do pcall(function() c:Disconnect() end) end
    rainConnections = {}
    if rainFolder and rainFolder.Parent then rainFolder:Destroy() end
    rainFolder = nil
end

local function createRainParticles()
    clearRainParticles()
    rainFolder      = Instance.new("Folder", workspace)
    rainFolder.Name = "StellarRain"
    local camera    = workspace.CurrentCamera
    local parts, ripples = {}, {}

    -- Reduced count for optimization
    for i = 1, 70 do
        local p = Instance.new("Part")
        p.Size         = Vector3.new(0.03, math.random(12,22)*0.1, 0.03)
        p.Material     = Enum.Material.Neon
        p.Color        = Color3.fromRGB(math.random(170,210), math.random(210,235), 255)
        p.Transparency = math.random(60,82)/100
        p.CastShadow   = false
        p.Anchored     = true
        p.CanCollide   = false
        p.Parent       = rainFolder
        table.insert(parts, p)
    end

    -- Reduced ripple count
    for i = 1, 12 do
        local r = Instance.new("Part")
        r.Size         = Vector3.new(0.1, 0.06, 0.1)
        r.Material     = Enum.Material.Neon
        r.Color        = Color3.fromRGB(180,215,255)
        r.Transparency = 0.88
        r.CastShadow   = false
        r.Anchored     = true
        r.CanCollide   = false
        r.Shape        = Enum.PartType.Cylinder
        r.Parent       = rainFolder
        table.insert(ripples, r)
    end

    local conn = RunService.RenderStepped:Connect(function(dt)
        if not rainFolder or not rainFolder.Parent then return end
        local camCF  = camera.CFrame
        local camPos = camCF.Position
        local windX, windZ = 0.18, 0.06

        for i, p in ipairs(parts) do
            if not p.Parent then continue end
            local spread = 35
            local phase  = i * 0.73
            local fall   = (tick()*16 + phase*2.8) % 32
            local x = camPos.X + math.sin(phase)*spread
            local y = camPos.Y + 20 - fall
            local z = camPos.Z + math.cos(phase)*spread
            p.CFrame = CFrame.new(x, y, z) * CFrame.Angles(windX, 0, windZ)
        end

        for i, r in ipairs(ripples) do
            if not r.Parent then continue end
            local t     = (tick()*0.7 + i*0.65) % 1
            local scale = 0.3 + t*3.2
            local alpha = 1 - t
            local phase = i * 1.13
            local rx    = camPos.X + math.sin(phase)*22
            local rz    = camPos.Z + math.cos(phase)*22
            local rayOrigin = Vector3.new(rx, camPos.Y + 10, rz)
            local ray       = workspace:Raycast(rayOrigin, Vector3.new(0, -60, 0))
            local ry        = ray and ray.Position.Y + 0.05 or camPos.Y - 10
            r.CFrame        = CFrame.new(rx, ry, rz) * CFrame.Angles(0, 0, math.pi/2)
            r.Size          = Vector3.new(0.06, scale, scale)
            r.Transparency  = 0.72 + alpha*0.22
            r.Color         = Color3.fromRGB(
                math.floor(lerpN(155,200,alpha)),
                math.floor(lerpN(195,230,alpha)),
                255
            )
        end
    end)
    table.insert(rainConnections, conn)
end

local function resetFogLighting()
    Lighting.FogStart             = originalFogStart
    Lighting.FogEnd               = originalFogEnd
    Lighting.FogColor             = originalFogColor
    Lighting.Ambient              = originalAmbient
    Lighting.Brightness           = originalBrightness
    Lighting.ExposureCompensation = originalExposure
end

local ModeText       = "Status: Loading..."
local BorderColorNow = Color3.fromRGB(180,0,255)
local rainbowHue     = 0

task.spawn(function()
    while task.wait(0.2) do
        if not horrorFogEnabled and not rainEnabled and not heavenlyEnabled and not cinematicEnabled then
            local t = Lighting.ClockTime
            if t >= 5 and t < 6 then
                applyProfile(lerpProfile(PROFILES.NIGHT,PROFILES.DAWN,(t-5)/1))
                ModeText = "Status: Dawn"        
                BorderColorNow = Color3.fromRGB(255,180,200)
            elseif t >= 6 and t < 15 then
                applyProfile(PROFILES.DAY)
                ModeText = "Status: Day"         
                BorderColorNow = Color3.fromRGB(255,220,100)
            elseif t >= 15 and t < 19 then
                applyProfile(lerpProfile(PROFILES.DAY,PROFILES.GOLDEN,(t-15)/4))
                ModeText = "Status: Golden Hour" 
                BorderColorNow = Color3.fromRGB(255,160,80)
            elseif t >= 19 and t < 21 then
                applyProfile(lerpProfile(PROFILES.GOLDEN,PROFILES.NIGHT,(t-19)/2))
                ModeText = "Status: Sunset"      
                BorderColorNow = Color3.fromRGB(150,180,255)
            else
                applyProfile(PROFILES.NIGHT)
                ModeText = "Status: Night"       
                BorderColorNow = Color3.fromRGB(100,180,255)
            end
        end
    end
end)

local function applyPBROnPart(v)
    if not pbrEnabled or isFpsBoostOn then return end
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.CastShadow = true
        local m = v.Material
        local r = 0
        if m == Enum.Material.Concrete then r = 0.15
        elseif m == Enum.Material.SmoothPlastic then r = 0.35
        elseif m == Enum.Material.Cobblestone then r = 0.08
        elseif m == Enum.Material.Wood or m == Enum.Material.WoodPlanks then r = 0.03
        elseif m == Enum.Material.Marble then r = 0.55
        elseif m == Enum.Material.Granite then r = 0.3
        elseif m == Enum.Material.Metal or m == Enum.Material.DiamondPlate then r = 0.65
        elseif m == Enum.Material.Glass then r = 0.8
        elseif m == Enum.Material.Neon then r = 0.85
        elseif m == Enum.Material.Ice then r = 0.7
        elseif m == Enum.Material.Sand then r = 0.02
        elseif m == Enum.Material.Grass then r = 0.0
        end
        if antiBlueGloss then
            local c   = v.Color
            local lum = (c.R*0.299)+(c.G*0.587)+(c.B*0.114)
            v.Reflectance = lum < 0.18 and r*(lum*3.5) or r
        else
            v.Reflectance = r
        end
    end
end

local function runPBRScan()
    local count = 0
    for _, v in pairs(workspace:GetDescendants()) do
        applyPBROnPart(v)
        count = count + 1
        if count % 200 == 0 then task.wait() end
    end
end
task.spawn(runPBRScan)
workspace.DescendantAdded:Connect(function(v)
    task.delay(0.1, function() applyPBROnPart(v) end)
end)

