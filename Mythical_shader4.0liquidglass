local cinTracks={}

local function makeSlider(parent,yLbl,labelText,yTrack,fillColor,knobColor,defRel)
    local lbl=Instance.new("TextLabel",parent)
    lbl.Size=UDim2.new(1,-16,0,13) lbl.Position=UDim2.new(0,8,0,yLbl) lbl.BackgroundTransparency=1
    lbl.Text=labelText lbl.TextColor3=Color3.fromRGB(165,170,195) lbl.TextSize=10 lbl.Font=Enum.Font.SourceSans lbl.TextXAlignment=Enum.TextXAlignment.Left
    local track=Instance.new("Frame",parent)
    track.Size=UDim2.new(1,-16,0,7) track.Position=UDim2.new(0,8,0,yTrack)
    track.BackgroundColor3=Color3.fromRGB(30,25,45) track.BackgroundTransparency=0.7 track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(0,4)
    local fill=Instance.new("Frame",track)
    fill.Size=UDim2.new(defRel,0,1,0) fill.BackgroundColor3=fillColor fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(0,4)
    local knob=Instance.new("TextButton",track)
    knob.Size=UDim2.new(0,14,0,14) knob.Position=UDim2.new(defRel,-7,0.5,-7)
    knob.BackgroundColor3=knobColor knob.Text="" knob.BorderSizePixel=0 knob.ZIndex=5
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
    applySpringPhysics(knob)
    return track,fill,knob
end

local function bindStableSlider(track,fill,knob,condFn,changeFn)
    local dragging=false
    knob.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=true i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then dragging=false end end) end end)
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=true i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then dragging=false end end) end end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            if condFn and not condFn() then return end
            local rel=math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
            fill.Size=UDim2.new(rel,0,1,0) knob.Position=UDim2.new(rel,-7,0.5,-7) changeFn(rel)
        end end)
end

local CinTitle=Instance.new("TextLabel",TabCinema)
CinTitle.Size=UDim2.new(1,-16,0,16) CinTitle.Position=UDim2.new(0,8,0,4) CinTitle.BackgroundTransparency=1
CinTitle.Text="🎬 Cinematic Mode" CinTitle.TextColor3=Color3.fromRGB(200,200,200) CinTitle.TextSize=11 CinTitle.Font=Enum.Font.SourceSansBold CinTitle.TextXAlignment=Enum.TextXAlignment.Left

createToggle(TabCinema,"Cinematic Mode",1,cinematicEnabled,function(val)
    cinematicEnabled=val
    if val then
        horrorFogEnabled=false rainEnabled=false heavenlyEnabled=false clearRainParticles()
        ModeText="Status: Cinematic" BorderColorNow=Color3.fromRGB(120,120,180)
        local p=PROFILES.CINEMATIC
        Lighting.Brightness=p.brightness Lighting.ExposureCompensation=p.exposure Lighting.ShadowSoftness=p.shadow Lighting.OutdoorAmbient=p.ambient
        Atmosphere.Color=p.atmoColor Atmosphere.Decay=p.atmoDecay Atmosphere.Glare=p.atmoGlare Atmosphere.Haze=p.atmoHaze Atmosphere.Density=p.atmoDensity
        ColorCorrection.Contrast=p.contrast ColorCorrection.Saturation=p.saturation ColorCorrection.TintColor=p.tint
        Bloom.Intensity=p.bloom Bloom.Size=p.bloomSize Bloom.Threshold=p.bloomThreshold DOF.FarIntensity=p.dofFar SunRays.Intensity=p.sunRays
        Lighting.GlobalShadows=true Lighting.ShadowSoftness=0.65
        Lighting.FogStart=80 Lighting.FogEnd=500 Lighting.FogColor=Color3.fromRGB(20,22,30)
        workspace.CurrentCamera.FieldOfView=70
        for _,tr in pairs(cinTracks) do tr.BackgroundTransparency=0.25 end
    else
        resetFogLighting() ModeText="Status: Normal"
        workspace.CurrentCamera.FieldOfView=originalFOV
        for _,tr in pairs(cinTracks) do tr.BackgroundTransparency=0.7 end
    end
end)

