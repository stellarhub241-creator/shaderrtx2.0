BoostInfo.Text="Replaces materials & disables shadows temporarily" BoostInfo.TextColor3=Color3.fromRGB(160,160,175) BoostInfo.TextSize=10 BoostInfo.Font=Enum.Font.SourceSans BoostInfo.TextWrapped=true
local BoostButton=Instance.new("TextButton",TabOptimize)
BoostButton.Size=UDim2.new(1,-16,0,44) BoostButton.Position=UDim2.new(0,8,0,50)
BoostButton.BackgroundColor3=Color3.fromRGB(255,60,100) BoostButton.BackgroundTransparency=0.3
BoostButton.Text="ENABLE FPS BOOST" BoostButton.TextColor3=Color3.fromRGB(255,255,255) BoostButton.Font=Enum.Font.SourceSansBold BoostButton.TextSize=13
Instance.new("UICorner",BoostButton).CornerRadius=UDim.new(0,8) Instance.new("UIStroke",BoostButton).Color=Color3.fromRGB(255,255,255)
applySpringPhysics(BoostButton)
local function triggerFPSBoost(on)
    isFpsBoostOn=on
    if on then
        local n=0 for _,v in pairs(workspace:GetDescendants()) do if v:IsA("BasePart") or v:IsA("MeshPart") then if not originalMaterials[v] then originalMaterials[v]=v.Material originalShadows[v]=v.CastShadow end v.Material=Enum.Material.SmoothPlastic v.CastShadow=false v.Reflectance=0 elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency=1 end n=n+1 if n%250==0 then task.wait() end end
        Terrain.Decoration=false Lighting.GlobalShadows=false
    else
        local n=0 for v,mat in pairs(originalMaterials) do if v and v.Parent then v.Material=mat v.CastShadow=originalShadows[v] or false end n=n+1 if n%250==0 then task.wait() end end
        for _,v in pairs(workspace:GetDescendants()) do if v:IsA("Decal") or v:IsA("Texture") then v.Transparency=0 end end
        Terrain.Decoration=true Lighting.GlobalShadows=true table.clear(originalMaterials) table.clear(originalShadows) task.spawn(runPBRScan)
    end
end
BoostButton.MouseButton1Click:Connect(function()
    local s=not isFpsBoostOn
    if s then pcall(function() TweenService:Create(BoostButton,TweenInfo.new(0.25,Enum.EasingStyle.Back),{BackgroundColor3=Color3.fromRGB(0,220,100)}):Play() end) BoostButton.Text="DISABLE FPS BOOST" task.spawn(function() triggerFPSBoost(true) end)
    else pcall(function() TweenService:Create(BoostButton,TweenInfo.new(0.25,Enum.EasingStyle.Back),{BackgroundColor3=Color3.fromRGB(255,60,100)}):Play() end) BoostButton.Text="ENABLE FPS BOOST" task.spawn(function() triggerFPSBoost(false) end) end
end)
autoCanvas(TabOptimize,3,30,6,20)

