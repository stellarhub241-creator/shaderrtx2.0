local function lerpN(a,b,t) return a+(b-a)*t end
local function lerpC(a,b,t)
    if not a or not b then return a or b or Color3.new(1,1,1) end
    return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
end

local PROFILES = {
    DAY      = {brightness=1.5, exposure=0.1,  shadow=0.3,  ambient=Color3.fromRGB(50,50,60),    atmoColor=Color3.fromRGB(185,215,255), atmoDecay=Color3.fromRGB(110,120,140), atmoGlare=1.2, atmoHaze=1.2, atmoDensity=0.25, contrast=0.35, saturation=0.45, tint=Color3.fromRGB(255,235,200), bloom=0.35,bloomSize=16,bloomThreshold=0.85,dofFar=0.2, sunRays=0.25},
    NIGHT    = {brightness=1.8, exposure=0.18, shadow=0.25, ambient=Color3.fromRGB(20,28,55),    atmoColor=Color3.fromRGB(20,35,80),    atmoDecay=Color3.fromRGB(10,15,40),    atmoGlare=0.5, atmoHaze=1.5, atmoDensity=0.35, contrast=0.35, saturation=0.4,  tint=Color3.fromRGB(200,220,255), bloom=1.0, bloomSize=22,bloomThreshold=0.4, dofFar=0.4, sunRays=0.1},
    DAWN     = {brightness=1.6, exposure=0.15, shadow=0.2,  ambient=Color3.fromRGB(50,35,55),    atmoColor=Color3.fromRGB(180,120,160), atmoDecay=Color3.fromRGB(80,40,80),    atmoGlare=1.0, atmoHaze=1.8, atmoDensity=0.3,  contrast=0.25, saturation=0.4,  tint=Color3.fromRGB(255,210,220), bloom=0.5, bloomSize=18,bloomThreshold=0.7, dofFar=0.3, sunRays=0.2},
    GOLDEN   = {brightness=2.2, exposure=0.2,  shadow=0.2,  ambient=Color3.fromRGB(80,50,30),    atmoColor=Color3.fromRGB(255,130,50),  atmoDecay=Color3.fromRGB(150,60,10),   atmoGlare=2.0, atmoHaze=2.0, atmoDensity=0.35, contrast=0.35, saturation=0.7,  tint=Color3.fromRGB(255,200,130), bloom=0.5, bloomSize=18,bloomThreshold=0.65,dofFar=0.4, sunRays=0.45},
    RAIN     = {brightness=0.7, exposure=-0.1, shadow=0.5,  ambient=Color3.fromRGB(38,43,55),    atmoColor=Color3.fromRGB(110,125,150), atmoDecay=Color3.fromRGB(55,62,78),    atmoGlare=0.1, atmoHaze=2.8, atmoDensity=0.45, contrast=0.08, saturation=-0.15,tint=Color3.fromRGB(190,208,232), bloom=0.3, bloomSize=12,bloomThreshold=0.9, dofFar=0.4, sunRays=0.0},
    HEAVENLY = {brightness=2.5, exposure=0.22, shadow=0.1,  ambient=Color3.fromRGB(180,190,240), atmoColor=Color3.fromRGB(210,228,255), atmoDecay=Color3.fromRGB(170,195,248), atmoGlare=2.2, atmoHaze=0.6, atmoDensity=0.08, contrast=0.1,  saturation=0.5,  tint=Color3.fromRGB(255,248,228), bloom=1.2, bloomSize=28,bloomThreshold=0.45,dofFar=0.05,sunRays=0.6},
    HORROR_G = {brightness=0.28,exposure=-0.45,shadow=0.95, ambient=Color3.fromRGB(5,18,3),      atmoColor=Color3.fromRGB(12,40,8),     atmoDecay=Color3.fromRGB(3,12,2),      atmoGlare=0.0, atmoHaze=5.5, atmoDensity=0.70, contrast=0.72, saturation=-0.45,tint=Color3.fromRGB(70,130,55),   bloom=0.55,bloomSize=28,bloomThreshold=0.55,dofFar=0.8, sunRays=0.0},
    HORROR_B = {brightness=0.22,exposure=-0.6, shadow=0.99, ambient=Color3.fromRGB(2,3,25),      atmoColor=Color3.fromRGB(4,5,35),      atmoDecay=Color3.fromRGB(1,2,18),      atmoGlare=0.0, atmoHaze=6.0, atmoDensity=0.78, contrast=0.82, saturation=-0.88,tint=Color3.fromRGB(40,50,180),   bloom=0.35,bloomSize=40,bloomThreshold=0.72,dofFar=0.9, sunRays=0.0},
    NOSTALGIA= {brightness=1.45,exposure=0.18, shadow=0.38, ambient=Color3.fromRGB(120,80,145),  atmoColor=Color3.fromRGB(230,175,215), atmoDecay=Color3.fromRGB(175,115,195), atmoGlare=1.2, atmoHaze=2.8, atmoDensity=0.38, contrast=0.18, saturation=0.22, tint=Color3.fromRGB(255,220,235), bloom=0.65,bloomSize=20,bloomThreshold=0.68,dofFar=0.22,sunRays=0.28},
}

local _transitionConn = nil
local function applyLightingSmooth(targetP, duration)
    if not targetP then return end
    duration = duration or 1.2
    if _transitionConn then pcall(function() _transitionConn:Disconnect() end) end
    local cur = {
        brightness=Lighting.Brightness, exposure=Lighting.ExposureCompensation,
        shadow=Lighting.ShadowSoftness, ambient=Lighting.OutdoorAmbient,
        atmoColor=Atmosphere.Color, atmoDecay=Atmosphere.Decay,
        atmoGlare=Atmosphere.Glare, atmoHaze=Atmosphere.Haze, atmoDensity=Atmosphere.Density,
        contrast=ColorCorrection.Contrast, saturation=ColorCorrection.Saturation, tint=ColorCorrection.TintColor,
        bloom=Bloom.Intensity, bloomSize=Bloom.Size, bloomThresh=Bloom.Threshold,
        dofFar=DOF.FarIntensity, sunRays=SunRays.Intensity,
    }
    local startT = tick()
    _transitionConn = RunService.Heartbeat:Connect(function()
        local t = math.clamp((tick()-startT)/duration, 0, 1)
        local e = StellarEngineA.smoothstep5(t)
        pcall(function()
            Lighting.Brightness=lerpN(cur.brightness,targetP.brightness,e)
            Lighting.ExposureCompensation=lerpN(cur.exposure,targetP.exposure,e)
            Lighting.ShadowSoftness=lerpN(cur.shadow,targetP.shadow,e)
            Lighting.OutdoorAmbient=lerpC(cur.ambient,targetP.ambient,e)
            Atmosphere.Color=lerpC(cur.atmoColor,targetP.atmoColor,e)
            Atmosphere.Decay=lerpC(cur.atmoDecay,targetP.atmoDecay,e)
            Atmosphere.Glare=lerpN(cur.atmoGlare,targetP.atmoGlare,e)
            Atmosphere.Haze=lerpN(cur.atmoHaze,targetP.atmoHaze,e)
            Atmosphere.Density=lerpN(cur.atmoDensity,targetP.atmoDensity,e)
            ColorCorrection.Contrast=lerpN(cur.contrast,targetP.contrast,e)
            ColorCorrection.Saturation=lerpN(cur.saturation,targetP.saturation,e)
            ColorCorrection.TintColor=lerpC(cur.tint,targetP.tint,e)
            Bloom.Intensity=lerpN(cur.bloom,targetP.bloom,e)
            Bloom.Size=lerpN(cur.bloomSize,targetP.bloomSize,e)
            Bloom.Threshold=lerpN(cur.bloomThresh,targetP.bloomThreshold,e)
            DOF.FarIntensity=lerpN(cur.dofFar,targetP.dofFar,e)
            SunRays.Intensity=lerpN(cur.sunRays,targetP.sunRays,e)
        end)
        if t>=1 then pcall(function() _transitionConn:Disconnect() end); _transitionConn=nil end
    end)
end

local function applyCinematicBlend()
    if not State.cinematicEnabled then return end
    pcall(function()
        ColorCorrection.Contrast=math.max(ColorCorrection.Contrast,0.6)
        ColorCorrection.Saturation=ColorCorrection.Saturation-0.1
        DOF.FarIntensity=math.max(DOF.FarIntensity,0.55)
        Bloom.Threshold=math.min(Bloom.Threshold+0.08,0.99)
        Lighting.ShadowSoftness=math.max(Lighting.ShadowSoftness,0.65)
    end)
end

local function resetFogLighting()
    pcall(function()
        if not State.nostalgiaEnabled then
            Lighting.FogStart=State.originalFogStart; Lighting.FogEnd=State.originalFogEnd
            Lighting.FogColor=State.originalFogColor; Lighting.Ambient=State.originalAmbient
            Lighting.Brightness=State.originalBrightness
            Lighting.ExposureCompensation=State.originalExposure
            Lighting.ShadowSoftness=State.originalShadow
            Lighting.OutdoorAmbient=State.originalOutdoor
        end
    end)
end

local function reapplyActiveMode()
    if State.nostalgiaEnabled then
        applyLightingSmooth(PROFILES.NOSTALGIA,1.0)
        pcall(function() Lighting.ClockTime=17.2; Lighting.FogStart=180; Lighting.FogEnd=2200; Lighting.FogColor=Color3.fromRGB(210,160,225); Lighting.Ambient=Color3.fromRGB(120,80,145) end)
    elseif State.horrorBlue then
        applyLightingSmooth(PROFILES.HORROR_B,1.2)
        pcall(function() Lighting.FogStart=2; Lighting.FogEnd=45; Lighting.FogColor=Color3.fromRGB(2,3,22); Lighting.Ambient=Color3.fromRGB(2,3,22) end)
    elseif State.horrorFogEnabled then
        applyLightingSmooth(PROFILES.HORROR_G,1.2)
        pcall(function() Lighting.FogStart=3; Lighting.FogEnd=60; Lighting.FogColor=Color3.fromRGB(5,20,3); Lighting.Ambient=Color3.fromRGB(5,20,3) end)
    elseif State.dawnEnabled then
        applyLightingSmooth(PROFILES.DAWN,1.0); pcall(function() Lighting.ClockTime=5.5 end)
    elseif State.sunsetEnabled then
        applyLightingSmooth(PROFILES.GOLDEN,1.0); pcall(function() Lighting.ClockTime=19 end)
    elseif State.rainEnabled then
        applyLightingSmooth(PROFILES.RAIN,0.8)
        pcall(function() Lighting.FogStart=20; Lighting.FogEnd=200; Lighting.FogColor=Color3.fromRGB(110,122,142) end)
    elseif State.heavenlyEnabled then
        applyLightingSmooth(PROFILES.HEAVENLY,1.5)
        pcall(function() Lighting.FogStart=500; Lighting.FogEnd=2000; Lighting.FogColor=Color3.fromRGB(225,235,255); Lighting.ClockTime=12 end)
    else
        resetFogLighting()
    end
    applyCinematicBlend()
end
-- ================================================================
-- SECTION 10: RAIN
-- ================================================================
local rainFolder=nil; local rainConns={}; local rainParts={}; local rainRipples={}
local rainPhysData={}

local function clearRainParticles()
    for _,c in pairs(rainConns) do pcall(function() c:Disconnect() end) end
    rainConns={}
    if rainFolder and rainFolder.Parent then pcall(function() rainFolder:Destroy() end) end
    rainFolder=nil; rainParts={}; rainRipples={}; rainPhysData={}
end

local function createRainParticles()
    clearRainParticles()
    local q = ParticleBudget:getQuality("rain")
    rainFolder=Instance.new("Folder",workspace); rainFolder.Name="StellarRain"
    local cam=workspace.CurrentCamera
    local count=math.clamp(math.floor((State.rainParticleCount or 60)*q),8,150)
    for i=1,count do
        local p=Instance.new("Part")
        p.Size=Vector3.new(0.045,math.random(18,30)*0.1,0.045)
        p.Material=Enum.Material.Glass; p.Reflectance=math.random(70,90)/100
        p.Color=Color3.fromRGB(math.random(200,230),math.random(225,245),255)
        p.Transparency=math.random(55,72)/100; p.CastShadow=false; p.Anchored=true; p.CanCollide=false
        p.Parent=rainFolder; table.insert(rainParts,p)
        local cp=cam.CFrame.Position
        table.insert(rainPhysData,{
            active=true, part=p,
            x=cp.X+math.random(-32,32), y=cp.Y+math.random(5,22), z=cp.Z+math.random(-32,32),
            vx=math.random(-2,2)*0.1, vy=0, vz=math.random(-1,1)*0.1,
            life=0, maxLife=math.random(15,25)*0.1, phase=i*0.73,
        })
    end
    local ripCount=math.max(5,math.floor(count*0.15))
    for i=1,ripCount do
        local r=Instance.new("Part"); r.Size=Vector3.new(0.1,0.05,0.1); r.Material=Enum.Material.Glass
        r.Reflectance=0.7; r.Color=Color3.fromRGB(180,215,255); r.Transparency=0.82
        r.CastShadow=false; r.Anchored=true; r.CanCollide=false; r.Shape=Enum.PartType.Cylinder
        r.Parent=rainFolder; table.insert(rainRipples,r)
    end
    local frame=0
    local conn=RunService.Heartbeat:Connect(function(dt)
        frame=frame+1; if frame%2~=0 then return end
        if not rainFolder or not rainFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()
        StellarEngineB:batchParticleStep(rainPhysData,dt*2,0.85,0.04)
        for i,p in ipairs(rainPhysData) do
            if p and p.active and rainParts[i] and rainParts[i].Parent then
                if p.life > p.maxLife or p.y < cp.Y-28 then
                    p.x=cp.X+math.random(-32,32); p.y=cp.Y+math.random(12,22)
                    p.z=cp.Z+math.random(-32,32); p.vy=0; p.life=0
                end
                local tx,_,tz = StellarEngineA.turbulence(p.x,p.y,p.z,t,0.08,0.12)
                pcall(function()
                    rainParts[i].Reflectance=0.65+math.sin(t*3+(p.phase or 0))*0.25
                    rainParts[i].CFrame=CFrame.new(p.x+(tx or 0),p.y,p.z+(tz or 0))*CFrame.Angles(0.18,0,0.04)
                end)
            end
        end
        for i,r in ipairs(rainRipples) do
            if r and r.Parent then
                pcall(function()
                    local rt=(t*0.7+i*0.65)%1; local sc=0.3+rt*3.5; local ph=i*1.13
                    local rx=cp.X+math.sin(ph)*22; local rz=cp.Z+math.cos(ph)*22
                    local ray=workspace:Raycast(Vector3.new(rx,cp.Y+8,rz),Vector3.new(0,-50,0))
                    local ry=ray and ray.Position.Y+0.05 or cp.Y-8
                    r.CFrame=CFrame.new(rx,ry,rz)*CFrame.Angles(0,0,math.pi/2)
                    r.Size=Vector3.new(0.05,sc,sc); r.Transparency=0.65+(1-rt)*0.28
                    r.Color=Color3.fromRGB(math.floor(lerpN(150,210,1-rt)),math.floor(lerpN(190,235,1-rt)),255)
                end)
            end
        end
    end)
    table.insert(rainConns,conn)
    StellarAI:watch("rain_folder",function() return rainFolder end,"RainFolder",
        function() if State.rainEnabled then createRainParticles() end end, 3)
end

-- ================================================================
-- SECTION 11: SAKURA
-- ================================================================
local sakuraFolder=nil; local sakuraConns={}; local sakuraParts={}; local sakuraPhysData={}

local function clearSakura()
    for _,c in pairs(sakuraConns) do pcall(function() c:Disconnect() end) end
    sakuraConns={}
    if sakuraFolder and sakuraFolder.Parent then pcall(function() sakuraFolder:Destroy() end) end
    sakuraFolder=nil; sakuraParts={}; sakuraPhysData={}
end

local function createSakura()
    clearSakura()
    local q = ParticleBudget:getQuality("sakura")
    sakuraFolder=Instance.new("Folder",workspace); sakuraFolder.Name="StellarSakura"
    local cam=workspace.CurrentCamera
    local count=math.clamp(math.floor((State.sakuraCount or 45)*q),6,80)
    for i=1,count do
        local p=Instance.new("Part",sakuraFolder)
        p.Size=Vector3.new(0.5,0.5,0.5); p.Shape=Enum.PartType.Ball
        p.Material=Enum.Material.SmoothPlastic; p.Transparency=1
        p.CastShadow=false; p.Anchored=true; p.CanCollide=false
        local bb=Instance.new("BillboardGui",p)
        bb.Size=UDim2.new(0,math.random(14,22),0,math.random(14,22))
        bb.AlwaysOnTop=false; bb.LightInfluence=0.6; bb.MaxDistance=200
        local img=Instance.new("ImageLabel",bb)
        img.Size=UDim2.new(1,0,1,0); img.BackgroundTransparency=1
        img.Image="rbxassetid://13214811345"
        img.ImageColor3=Color3.fromRGB(math.random(235,255),math.random(165,210),math.random(185,220))
        img.ImageTransparency=math.random(0,15)/100
        local cp=cam.CFrame.Position
        local pd={
            active=true, part=p, img=img,
            x=cp.X+math.random(-32,32), y=cp.Y+math.random(5,25), z=cp.Z+math.random(-32,32),
            vx=math.random(-8,8)*0.01, vy=0, vz=math.random(-8,8)*0.01,
            life=math.random()*6, maxLife=math.random(60,120)*0.1,
            rot=math.random(0,360), rotSpeed=math.random(-80,80),
            sway=math.random()*math.pi*2, swaySpeed=math.random()*1.5+0.4,
        }
        table.insert(sakuraPhysData,pd); table.insert(sakuraParts,pd)
    end
    local conn=RunService.Heartbeat:Connect(function(dt)
        if not sakuraFolder or not sakuraFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()
        StellarEngineB:batchParticleStep(sakuraPhysData,dt,0.18,0.22)
        for _,s in ipairs(sakuraPhysData) do
            if s and s.active and s.part and s.part.Parent then
                if s.life > s.maxLife or s.y < cp.Y-30 then
                    s.x=cp.X+math.random(-35,35); s.y=cp.Y+math.random(15,30)
                    s.z=cp.Z+math.random(-35,35); s.vy=0; s.life=0
                    s.maxLife=math.random(60,120)*0.1
                end
                local tx,_,tz = StellarEngineA.turbulence(s.x*0.04,s.y*0.04,s.z*0.04,t,1.0,0.7)
                s.x = s.x + (tx or 0)*dt
                s.z = s.z + (tz or 0)*dt
                s.rot = (s.rot or 0) + (s.rotSpeed or 0)*dt
                local alpha = StellarEngineA.particleFade((s.life or 0)/(s.maxLife or 1),0.12,0.20)
                pcall(function()
                    s.part.CFrame=CFrame.new(s.x,s.y,s.z)*CFrame.Angles(0,math.rad(s.rot),0)
                    s.img.ImageTransparency=1-alpha*0.92
                end)
            end
        end
    end)
    table.insert(sakuraConns,conn)
    StellarAI:watch("sakura_folder",function() return sakuraFolder end,"SakuraFolder",
        function() if State.sakuraEnabled then createSakura() end end, 4)
end

-- ================================================================
-- SECTION 12: WIND
-- ================================================================
local windConns={}; local windParts={}

local function clearWind()
    for _,c in pairs(windConns) do pcall(function() c:Disconnect() end) end
    windConns={}
    for _,d in pairs(windParts) do
        pcall(function() if d.part and d.part.Parent then d.part.CFrame=d.origin end end)
    end
    windParts={}
end

local function startWind()
    clearWind()
    local cam=workspace.CurrentCamera; local collected=0
    for _,v in ipairs(workspace:GetDescendants()) do
        if collected>=200 then break end
        pcall(function()
            if not (v:IsA("BasePart") or v:IsA("MeshPart")) then return end
            if not v.Anchored then return end
            local pn=v.Parent and v.Parent.Name or ""
            if pn=="StellarRain" or pn=="StellarSakura" or pn=="StellarMeteor" or pn=="StellarSun" then return end
            local sz=v.Size
            if sz.X>6 or sz.Z>6 or sz.Y>18 then return end
            if (v.Position-cam.CFrame.Position).Magnitude>120 then return end
            table.insert(windParts,{part=v,origin=v.CFrame,phase=math.random()*math.pi*2,freq=0.8+math.random()*1.2,amp=0.008+math.random()*0.022})
            collected=collected+1
        end)
    end
    if #windParts==0 then StellarAI:log("[Wind] no parts"); return end
    local conn=RunService.Heartbeat:Connect(function(dt)
        if not State.windEnabled then return end
        local t=tick()
        for _,d in pairs(windParts) do
            pcall(function()
                if d.part and d.part.Parent then
                    local wave=math.sin(t*(d.freq or 1)+(d.phase or 0))*(d.amp or 0.01)*(State.windStrength or 0.5)
                    local wave2=StellarEngineA.smoothNoise(t*(d.freq or 1)*0.5,(d.phase or 0),0)*(d.amp or 0.01)*(State.windStrength or 0.5)*0.35
                    d.part.CFrame=d.origin*CFrame.Angles(wave,wave2*0.3,wave*0.55)
                end
            end)
        end
    end)
    table.insert(windConns,conn)
end

-- ================================================================
-- SECTION 13: METEOR
-- ================================================================
local meteorFolder=nil; local meteorConns={}; local meteorRunning=false

local function clearMeteor()
    meteorRunning=false
    for _,c in pairs(meteorConns) do pcall(function() c:Disconnect() end) end
    meteorConns={}
    if meteorFolder and meteorFolder.Parent then pcall(function() meteorFolder:Destroy() end) end
    meteorFolder=nil
end

local function spawnOneMeteor()
    if not meteorFolder or not meteorFolder.Parent then return end
    local q   = ParticleBudget:getQuality("meteor")
    local cam = workspace.CurrentCamera; local cp=cam.CFrame.Position
    local angle=math.random()*math.pi*2; local dist=math.random(500,800)
    local sx=cp.X+math.cos(angle)*dist; local sy=cp.Y+math.random(300,500); local sz=cp.Z+math.sin(angle)*dist
    local tx=cp.X+math.cos(angle+math.pi)*dist; local ty=cp.Y-math.random(50,100); local tz2=cp.Z+math.sin(angle+math.pi)*dist
    local dirV=(Vector3.new(tx,ty,tz2)-Vector3.new(sx,sy,sz))
    local dirLen=dirV.Magnitude
    if dirLen==0 then return end
    local dirU=dirV*(1/dirLen)
    local speed=math.random(250,450); local len=math.random(50,120)

    local head=Instance.new("Part",meteorFolder); head.Size=Vector3.new(5,5,5); head.Material=Enum.Material.Neon
    head.Color=State.meteorColor; head.Transparency=0; head.CastShadow=false; head.Anchored=true; head.CanCollide=false
    Instance.new("SpecialMesh",head).MeshType=Enum.MeshType.Sphere
    local pLight=Instance.new("PointLight",head); pLight.Color=State.meteorColor; pLight.Range=300; pLight.Brightness=4*q; pLight.Shadows=true

    local body=Instance.new("Part",meteorFolder); body.Size=Vector3.new(2.5,2.5,len); body.Material=Enum.Material.Neon
    body.Color=StellarEngineA.lerpColorHSV(State.meteorColor,Color3.fromRGB(255,255,255),0.4)
    body.Transparency=0.15; body.CastShadow=false; body.Anchored=true; body.CanCollide=false

    local tail=Instance.new("Part",meteorFolder); tail.Size=Vector3.new(1.5,1.5,len*2.8); tail.Material=Enum.Material.Neon
    tail.Color=StellarEngineA.lerpColorHSV(State.meteorColor,Color3.fromRGB(255,255,255),0.68)
    tail.Transparency=0.42; tail.CastShadow=false; tail.Anchored=true; tail.CanCollide=false

    local tail2=Instance.new("Part",meteorFolder); tail2.Size=Vector3.new(0.6,0.6,len*5.5); tail2.Material=Enum.Material.Neon
    tail2.Color=Color3.fromRGB(255,255,255); tail2.Transparency=0.75; tail2.CastShadow=false; tail2.Anchored=true; tail2.CanCollide=false

    local glow=Instance.new("Part",meteorFolder); glow.Size=Vector3.new(22,22,22); glow.Material=Enum.Material.Neon
    glow.Color=State.meteorColor; glow.Transparency=0.78; glow.CastShadow=false; glow.Anchored=true; glow.CanCollide=false
    Instance.new("SpecialMesh",glow).MeshType=Enum.MeshType.Sphere

    local pe=Instance.new("ParticleEmitter",head); pe.Texture="rbxassetid://2273224484"
    pe.Rate=math.floor(400*q); pe.Lifetime=NumberRange.new(0.15,0.6); pe.Speed=NumberRange.new(8,35)
    pe.SpreadAngle=Vector2.new(60,60)
    pe.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(0.3,State.meteorColor),ColorSequenceKeypoint.new(0.7,Color3.fromRGB(255,200,80)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,100,0))})
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,4.0),NumberSequenceKeypoint.new(0.4,2.0),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1; pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)})
    pe.EmissionDirection=Enum.NormalId.Back; pe.RotSpeed=NumberRange.new(-180,180); pe.Rotation=NumberRange.new(0,360)

    local pe2=Instance.new("ParticleEmitter",body); pe2.Texture="rbxassetid://6060542021"
    pe2.Rate=math.floor(150*q); pe2.Lifetime=NumberRange.new(0.1,0.4); pe2.Speed=NumberRange.new(2,12)
    pe2.SpreadAngle=Vector2.new(25,25)
    pe2.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,220,100)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,120,20)),ColorSequenceKeypoint.new(1,Color3.fromRGB(180,50,0))})
    pe2.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,2.0),NumberSequenceKeypoint.new(1,0)})
    pe2.LightEmission=0.8; pe2.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.1),NumberSequenceKeypoint.new(1,1)})
    pe2.EmissionDirection=Enum.NormalId.Back

    local life=0; local maxLife=5.5; local isFading=false
    local meteorConn
    meteorConn=RunService.Heartbeat:Connect(function(dt)
        life=life+dt
        if life>=maxLife-0.5 and not isFading then
            isFading=true; pe.Enabled=false; pe2.Enabled=false
            pcall(function()
                TweenService:Create(glow,TweenInfo.new(0.2,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=Vector3.new(80,80,80),Transparency=0}):Play()
                TweenService:Create(pLight,TweenInfo.new(0.2),{Range=500,Brightness=8}):Play()
                TweenService:Create(head,TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(body,TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(tail,TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(tail2,TweenInfo.new(0.5),{Transparency=1}):Play()
            end)
        end
        if life>=maxLife then
            pcall(function() head:Destroy(); body:Destroy(); tail:Destroy(); tail2:Destroy(); glow:Destroy() end)
            pcall(function() meteorConn:Disconnect() end); return
        end
        local np=Vector3.new(sx,sy,sz)+dirU*speed*life
        local curveOff=StellarEngineA.smoothNoise(life*0.8,0,0)*8
        local fnp=Vector3.new(np.X+curveOff, np.Y, np.Z+curveOff*0.5)
        pcall(function()
            if not isFading then
                head.CFrame=CFrame.new(fnp)
                local mid1=fnp-dirU*(len*0.5)
                local mid2=fnp-dirU*(len*1.5)
                local mid3=fnp-dirU*(len*3.2)
                body.CFrame=CFrame.new(mid1,mid1+dirU)*CFrame.Angles(math.pi/2,0,0)
                tail.CFrame=CFrame.new(mid2,mid2+dirU)*CFrame.Angles(math.pi/2,0,0)
                tail2.CFrame=CFrame.new(mid3,mid3+dirU)*CFrame.Angles(math.pi/2,0,0)
                local pulse=StellarEngineA.coronaPulse(life,1)*22
                glow.CFrame=CFrame.new(fnp); glow.Size=Vector3.new(pulse,pulse,pulse)
            else
                head.CFrame=CFrame.new(head.CFrame.Position+dirU*speed*0.08*dt)
                glow.CFrame=head.CFrame
                TweenService:Create(glow,TweenInfo.new(0.3),{Transparency=1,Size=Vector3.new(0,0,0)}):Play()
            end
        end)
    end)
    table.insert(meteorConns,meteorConn)
end

local function startMeteor()
    clearMeteor(); meteorRunning=true
    meteorFolder=Instance.new("Folder",workspace); meteorFolder.Name="StellarMeteor"
    task.spawn(function()
        while meteorRunning do
            spawnOneMeteor()
            task.wait(math.random()*(State.meteorInterval or 3)+0.5)
        end
    end)
    StellarAI:watch("meteor_folder",function() return meteorFolder end,"MeteorFolder",
        function() if State.meteorEnabled then startMeteor() end end, 2)
end

-- ================================================================
-- SECTION 14: SUN
-- ================================================================
local sunFolder=nil; local sunConns={}

local function clearSunray()
    for _,c in pairs(sunConns) do pcall(function() c:Disconnect() end) end
    sunConns={}
    if sunFolder and sunFolder.Parent then pcall(function() sunFolder:Destroy() end) end
    sunFolder=nil
end

local function startSunray()
    clearSunray()
    local q = ParticleBudget:getQuality("sun")
    sunFolder=Instance.new("Folder",workspace); sunFolder.Name="StellarSun"
    local cam=workspace.CurrentCamera

    local core=Instance.new("Part",sunFolder); core.Size=Vector3.new(100,100,100); core.Material=Enum.Material.Neon
    core.Color=Color3.fromRGB(255,248,180); core.Transparency=0; core.CastShadow=false; core.Anchored=true; core.CanCollide=false
    Instance.new("SpecialMesh",core).MeshType=Enum.MeshType.Sphere

    local innerCore=Instance.new("Part",sunFolder); innerCore.Size=Vector3.new(60,60,60); innerCore.Material=Enum.Material.Neon
    innerCore.Color=Color3.fromRGB(255,255,220); innerCore.Transparency=0.25; innerCore.CastShadow=false; innerCore.Anchored=true; innerCore.CanCollide=false
    Instance.new("SpecialMesh",innerCore).MeshType=Enum.MeshType.Sphere

    local sunLight=Instance.new("PointLight",core); sunLight.Color=Color3.fromRGB(255,220,150); sunLight.Brightness=6*q; sunLight.Range=1200; sunLight.Shadows=false

    local coronaData={
        {sz=130,col=Color3.fromRGB(255,240,180),tr=0.45},
        {sz=175,col=Color3.fromRGB(255,228,100),tr=0.58},
        {sz=240,col=Color3.fromRGB(255,195,55), tr=0.70},
        {sz=330,col=Color3.fromRGB(255,155,28), tr=0.82},
        {sz=450,col=Color3.fromRGB(255,108,8),  tr=0.90},
        {sz=600,col=Color3.fromRGB(255,60,0),   tr=0.94},
        {sz=800,col=Color3.fromRGB(200,20,0),   tr=0.97},
    }
    local coronaParts={}
    for _,l in ipairs(coronaData) do
        local c=Instance.new("Part",sunFolder); c.Size=Vector3.new(l.sz,l.sz,l.sz); c.Material=Enum.Material.Neon
        c.Color=l.col; c.Transparency=l.tr+(1-q)*0.08; c.CastShadow=false; c.Anchored=true; c.CanCollide=false
        Instance.new("SpecialMesh",c).MeshType=Enum.MeshType.Sphere
        table.insert(coronaParts,{part=c,baseSz=l.sz,baseTr=l.tr,baseCol=l.col})
    end

    local flareCount=math.floor(8*q)
    local flareParts={}
    for i=1,flareCount do
        local f=Instance.new("Part",sunFolder); f.Size=Vector3.new(3,3,math.random(80,200)); f.Material=Enum.Material.Neon
        f.Color=Color3.fromRGB(255,200,60); f.Transparency=0.55; f.CastShadow=false; f.Anchored=true; f.CanCollide=false
        table.insert(flareParts,{part=f,angle=i*(math.pi*2/flareCount),speed=0.3+math.random()*0.5})
    end

    local RAY_COUNT=math.floor(24*q)
    local rays={}
    for i=1,RAY_COUNT do
        local rdx,rdy,rdz = StellarEngineA.fibSphere(i,RAY_COUNT)
        local r=Instance.new("Part",sunFolder)
        local rLen=math.random(400,900)
        r.Size=Vector3.new(i<=14 and 6 or 3.5, i<=14 and 6 or 3.5, rLen)
        r.Material=Enum.Material.Neon; r.Color=Color3.fromRGB(255,230,130); r.Transparency=0.62
        r.CastShadow=false; r.Anchored=true; r.CanCollide=false
        table.insert(rays,{part=r,rdx=rdx,rdy=rdy,rdz=rdz,rLen=rLen,kind=i<=14 and "main" or "sub",phase=i*0.4})
    end

    local ambientGlow=Instance.new("Part",sunFolder); ambientGlow.Size=Vector3.new(900,900,900); ambientGlow.Material=Enum.Material.Neon
    ambientGlow.Color=Color3.fromRGB(255,140,30); ambientGlow.Transparency=0.97; ambientGlow.CastShadow=false; ambientGlow.Anchored=true; ambientGlow.CanCollide=false
    Instance.new("SpecialMesh",ambientGlow).MeshType=Enum.MeshType.Sphere

    local heatPE=Instance.new("ParticleEmitter",core)
    heatPE.Texture="rbxassetid://2273224484"; heatPE.Rate=math.floor(60*q); heatPE.Lifetime=NumberRange.new(0.5,1.5)
    heatPE.Speed=NumberRange.new(20,60); heatPE.SpreadAngle=Vector2.new(180,180)
    heatPE.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,240,150)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,180,50)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,80,0))})
    heatPE.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,8),NumberSequenceKeypoint.new(0.4,4),NumberSequenceKeypoint.new(1,0)})
    heatPE.LightEmission=1; heatPE.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.2),NumberSequenceKeypoint.new(1,1)})

    local t0=tick()
    local conn=RunService.Heartbeat:Connect(function()
        if not sunFolder or not sunFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()-t0; local ag=t*0.018
        local sunPos=cp+Vector3.new(math.cos(ag)*800, 400+math.sin(t*0.1)*35, math.sin(ag)*800)
        local corePulse=StellarEngineA.coronaPulse(t,0)
        local innerPulse=StellarEngineA.coronaPulse(t,1)*0.95
        pcall(function()
            local csz=100*corePulse; core.CFrame=CFrame.new(sunPos); core.Size=Vector3.new(csz,csz,csz)
            local isz=60*innerPulse; innerCore.CFrame=CFrame.new(sunPos); innerCore.Size=Vector3.new(isz,isz,isz)
            innerCore.Color=StellarEngineA.lerpColorHSV(Color3.fromRGB(255,255,220),Color3.fromRGB(255,200,80),(math.sin(t*2)+1)*0.5)
            ambientGlow.CFrame=CFrame.new(sunPos); ambientGlow.Transparency=0.965+math.sin(t*0.7)*0.025

            for idx,lc in ipairs(coronaParts) do
                local lp=StellarEngineA.coronaPulse(t,idx)
                lc.part.CFrame=CFrame.new(sunPos)
                local sz=lc.baseSz*lp; lc.part.Size=Vector3.new(sz,sz,sz)
                lc.part.Transparency=lc.baseTr+math.sin(t*1.1+idx*0.4)*0.03
                local hShift=((t*4+idx*12)%360)/360
                lc.part.Color=StellarEngineA.lerpColorHSV(lc.baseCol,safeFromHSV(0.05+hShift*0.04,0.9,1),0.04)
            end

            for _,fl in ipairs(flareParts) do
                local a=fl.angle+t*(fl.speed or 0.4)
                local fdist=130+math.sin(t*1.2+fl.angle)*20
                local fx=sunPos.X+math.cos(a)*fdist; local fz=sunPos.Z+math.sin(a)*fdist
                fl.part.CFrame=CFrame.new(fx,sunPos.Y,fz)*CFrame.Angles(0,a+math.pi/2,math.pi/2)
                fl.part.Transparency=0.45+math.abs(math.sin(t*2+fl.angle))*0.35
            end

            for _,r in ipairs(rays) do
                local theta=t*0.32+(r.phase or 0)
                local cosT,sinT=math.cos(theta),math.sin(theta)
                local rdx2=(r.rdx or 0)*cosT-(r.rdz or 0)*sinT
                local rdz2=(r.rdx or 0)*sinT+(r.rdz or 0)*cosT
                local rLen=r.rLen or 500
                local rMag=math.sqrt(rdx2*rdx2+(r.rdy or 0)*(r.rdy or 0)+rdz2*rdz2)
                if rMag>0 then
                    local rux=rdx2/rMag; local ruy=(r.rdy or 0)/rMag; local ruz=rdz2/rMag
                    local midPt=sunPos+Vector3.new(rux,ruy,ruz)*(rLen*0.5)
                    local endPt=sunPos+Vector3.new(rux,ruy,ruz)*rLen
                    r.part.CFrame=CFrame.new(midPt,endPt)
                    r.part.Transparency=(r.kind=="main" and 0.58 or 0.68)+math.abs(math.sin(t*1.8+(r.phase or 0)))*0.20
                    local hOff=((t*5+(r.phase or 0)*15)%360)/360
                    r.part.Color=safeFromHSV(0.07+hOff*0.06,0.88,1)
                end
            end
            sunLight.Brightness=6*q*(0.9+math.sin(t*1.4)*0.1)
        end)
    end)
    table.insert(sunConns,conn)
    StellarAI:watch("sun_folder",function() return sunFolder end,"SunFolder",
        function() if State.sunrayEnabled then startSunray() end end, 1)
end

-- ================================================================
-- SECTION 15: NEON EDGE
-- ================================================================
local neonEdgeConns={}
local NeonGlowFrame=Instance.new("Frame")
NeonGlowFrame.Size=UDim2.new(1,0,1,0); NeonGlowFrame.BackgroundTransparency=1; NeonGlowFrame.ZIndex=0; NeonGlowFrame.Visible=false
Instance.new("UICorner",NeonGlowFrame).CornerRadius=UDim.new(0,16)
local NeonStroke=Instance.new("UIStroke",NeonGlowFrame); NeonStroke.Thickness=6
local NeonGrad=Instance.new("UIGradient",NeonStroke)
NeonGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(180,0,255)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(0,220,255)),ColorSequenceKeypoint.new(1,Color3.fromRGB(180,0,255))})

local function clearNeonEdge()
    for _,c in pairs(neonEdgeConns) do pcall(function() c:Disconnect() end) end
    neonEdgeConns={}; NeonGlowFrame.Visible=false
end

local function startNeonEdge(sg)
    clearNeonEdge(); NeonGlowFrame.Parent=sg; NeonGlowFrame.Visible=true
    local conn=RunService.RenderStepped:Connect(function()
        local t=tick(); local theme=COLOR_THEMES[State.currentThemeIndex]
        if not theme then return end
        local h=((t*28)%360)/360; local col=safeFromHSV(h,0.85,1)
        pcall(function()
            NeonGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,theme.primary),ColorSequenceKeypoint.new(0.5,col),ColorSequenceKeypoint.new(1,theme.secondary)})
            NeonGrad.Rotation=(t*40)%360; NeonStroke.Transparency=0.2+math.abs(math.sin(t*3))*0.2
        end)
    end)
    table.insert(neonEdgeConns,conn)
end

-- ================================================================
-- SECTION 16: TIME LOOP
-- ================================================================
local ModeText="Loading..."; local BorderColorNow=Color3.fromRGB(180,0,255)
local rainbowHue=0; local LiveTimeLabel

task.spawn(function()
    while task.wait(0.25) do
        if not State.horrorFogEnabled and not State.horrorBlue and not State.rainEnabled
            and not State.heavenlyEnabled and not State.dawnEnabled and not State.sunsetEnabled
            and not State.nostalgiaEnabled then
            local t=Lighting.ClockTime
            if t>=6 and t<19 then applyLightingSmooth(PROFILES.DAY,0.5); ModeText="Day"; BorderColorNow=Color3.fromRGB(255,220,100)
            else applyLightingSmooth(PROFILES.NIGHT,0.5); ModeText="Night"; BorderColorNow=Color3.fromRGB(100,180,255) end
            applyCinematicBlend()
        end
    end
end)

-- ================================================================
-- SECTION 17: PBR
-- ================================================================
local function applyPBROnPart(v)
    if not State.pbrEnabled or State.isFpsBoostOn then return end
    if not v or not v.Parent then return end
    if not (v:IsA("BasePart") or v:IsA("MeshPart")) then return end
    local pn=v.Parent and v.Parent.Name or ""
    if pn=="StellarRain" or pn=="StellarSakura" or pn=="StellarMeteor" or pn=="StellarSun" then return end
    v.CastShadow=true
    local m=v.Material; local r=0
    if m==Enum.Material.Concrete then r=0.15 elseif m==Enum.Material.SmoothPlastic then r=0.35
    elseif m==Enum.Material.Cobblestone then r=0.08 elseif m==Enum.Material.Wood or m==Enum.Material.WoodPlanks then r=0.03
    elseif m==Enum.Material.Marble then r=0.55 elseif m==Enum.Material.Granite then r=0.3
    elseif m==Enum.Material.Metal or m==Enum.Material.DiamondPlate then r=0.65
    elseif m==Enum.Material.Glass then r=0.8 elseif m==Enum.Material.Neon then r=0.85
    elseif m==Enum.Material.Ice then r=0.7 elseif m==Enum.Material.Sand then r=0.02 end
    if State.antiBlueGloss then
        local c=v.Color; local lum=(c.R*0.299)+(c.G*0.587)+(c.B*0.114)
        v.Reflectance=lum<0.18 and r*(lum*3.5) or r
    else v.Reflectance=r end
end

local function runPBRScan()
    local n=0; local cam=workspace.CurrentCamera
    for _,v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if (v:IsA("BasePart") or v:IsA("MeshPart")) and (v.Position-cam.CFrame.Position).Magnitude<200 then applyPBROnPart(v) end
        end)
        n=n+1; if n%200==0 then task.wait() end
    end
end
task.spawn(runPBRScan)
workspace.DescendantAdded:Connect(function(v) task.delay(0.2,function() pcall(function() applyPBROnPart(v) end) end) end)

-- ================================================================
-- SECTION 18: FPS BOOST
-- ================================================================
local function triggerFPSBoost(on)
    State.isFpsBoostOn=on
    if on then
        local n=0
        for _,v in pairs(workspace:GetDescendants()) do
            pcall(function()
                local pn=v.Parent and v.Parent.Name or ""
                if (v:IsA("BasePart") or v:IsA("MeshPart")) and pn~="StellarRain" and pn~="StellarSakura" and pn~="StellarMeteor" and pn~="StellarSun" then
                    if not State.originalMaterials[v] then State.originalMaterials[v]=v.Material; State.originalShadows[v]=v.CastShadow end
                    v.Material=Enum.Material.SmoothPlastic; v.CastShadow=false; v.Reflectance=0
                elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency=1 end
            end); n=n+1; if n%300==0 then task.wait() end
        end
        pcall(function() Terrain.Decoration=false; Lighting.GlobalShadows=false end)
    else
        local n=0
        for v,mat in pairs(State.originalMaterials) do
            pcall(function() if v and v.Parent then v.Material=mat; v.CastShadow=State.originalShadows[v] or false end end)
            n=n+1; if n%300==0 then task.wait() end
        end
        for _,v in pairs(workspace:GetDescendants()) do pcall(function() if v:IsA("Decal") or v:IsA("Texture") then v.Transparency=0 end end) end
        pcall(function() Terrain.Decoration=true; Lighting.GlobalShadows=true end)
        table.clear(State.originalMaterials); table.clear(State.originalShadows); task.spawn(runPBRScan)
    end
end
-- ================================================================
-- SECTION 19: UI FRAMEWORK
-- ================================================================
local ScreenGui=Instance.new("ScreenGui",CoreGui); ScreenGui.Name="STELLARHUB_MYTHICAL"
ScreenGui.ResetOnSpawn=false; ScreenGui.IgnoreGuiInset=true

local SMOOTH      = TweenInfo.new(0.22,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
local SMOOTH_BACK = TweenInfo.new(0.28,Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local SMOOTH_FAST = TweenInfo.new(0.12,Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function tw(obj,props,info) pcall(function() TweenService:Create(obj,info or SMOOTH,props):Play() end) end

local function spring(btn)
    if not btn then return end
    pcall(function()
        local us=btn:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",btn); us.Scale=1.0
        btn.MouseEnter:Connect(function() pcall(function() tw(us,{Scale=1.09},SMOOTH_BACK); tw(btn,{BackgroundTransparency=0.05},SMOOTH_FAST) end) end)
        btn.MouseLeave:Connect(function() pcall(function() tw(us,{Scale=1.0},SMOOTH); tw(btn,{BackgroundTransparency=0.32},SMOOTH_FAST) end) end)
        btn.InputBegan:Connect(function(i) if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=0.93},SMOOTH_FAST) end) end end)
        btn.InputEnded:Connect(function(i) if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=1.0},SMOOTH_BACK) end) end end)
    end)
end

local function addBounceOnHold(frame)
    if not frame then return end
    local holdThread=nil
    frame.InputBegan:Connect(function(input)
        if isTouchOrMouse(input.UserInputType) then
            if holdThread then pcall(function() task.cancel(holdThread) end) end
            holdThread=task.delay(0.28,function()
                if isInputBlocked() then holdThread=nil; return end
                pcall(function()
                    local us=frame:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",frame); us.Scale=1
                    tw(us,{Scale=1.14},TweenInfo.new(0.1,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)); task.wait(0.1)
                    tw(us,{Scale=1.0},TweenInfo.new(0.3,Enum.EasingStyle.Bounce,Enum.EasingDirection.Out))
                end); holdThread=nil
            end)
            input.Changed:Connect(function()
                if input.UserInputState==Enum.UserInputState.End then
                    if holdThread then pcall(function() task.cancel(holdThread) end); holdThread=nil end
                end
            end)
        end
    end)
end

