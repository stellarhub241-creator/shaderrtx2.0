local borderSectionH = 38 + math.ceil(#BORDER_STYLES/2)*28 + 10

-- UI Opacity Slider
local opacityY = themeBaseY + borderSectionH + 8
local opacityTitleL = Instance.new("TextLabel",TabTheme)
opacityTitleL.Size=UDim2.new(1,-16,0,14); opacityTitleL.Position=UDim2.new(0,8,0,opacityY)
opacityTitleL.BackgroundTransparency=1; opacityTitleL.Text="🔲 UI Glass Opacity"
opacityTitleL.TextColor3=Color3.fromRGB(200,200,255); opacityTitleL.TextSize=11
opacityTitleL.Font=Enum.Font.SourceSansBold; opacityTitleL.TextXAlignment=Enum.TextXAlignment.Left

makeBallSlider(TabTheme, opacityY+16, "Opacity (0%=invisible)", State.uiOpacity, function(r)
