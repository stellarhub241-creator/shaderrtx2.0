local ThemeTitle=Instance.new("TextLabel",TabTheme)
ThemeTitle.Size=UDim2.new(1,-16,0,18) ThemeTitle.Position=UDim2.new(0,8,0,4)
ThemeTitle.BackgroundTransparency=1 ThemeTitle.Text="💎 UI Color Theme"
ThemeTitle.TextColor3=Color3.fromRGB(200,200,212) ThemeTitle.TextSize=11
ThemeTitle.Font=Enum.Font.SourceSansBold ThemeTitle.TextXAlignment=Enum.TextXAlignment.Left

local activeThemeLabel=Instance.new("TextLabel",TabTheme)
activeThemeLabel.Size=UDim2.new(1,-16,0,14) activeThemeLabel.Position=UDim2.new(0,8,0,22)
activeThemeLabel.BackgroundTransparency=1 activeThemeLabel.Text="Active: Purple"
activeThemeLabel.TextColor3=Color3.fromRGB(180,0,255) activeThemeLabel.TextSize=10
activeThemeLabel.Font=Enum.Font.Code activeThemeLabel.TextXAlignment=Enum.TextXAlignment.Left

local rainbowActive=false local glassRotThread=nil

local function applyTheme(index)
    local theme=COLOR_THEMES[index] currentThemeIndex=index
    tween(activeThemeLabel,{TextColor3=theme.primary},SMOOTH)
    activeThemeLabel.Text="Active: "..theme.name
    tween(UIStroke,{Color=theme.primary},SMOOTH)
    refreshTabButtons() refreshAllSliders()
    tween(MinBtn,{TextColor3=Color3.fromRGB(255,220,80)},SMOOTH)
    BorderColorNow=theme.primary

    if theme.glass then
        GlassRefraction.Visible=true GlassHighlight.Visible=true GlassViewport.Visible=true
        tween(MainFrame,{BackgroundColor3=Color3.fromRGB(7,13,20),BackgroundTransparency=0.1},SMOOTH)
        UIStroke.Thickness=2.0 SidebarLine.BackgroundColor3=Color3.fromRGB(155,205,238)
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end) end
        glassRotThread=task.spawn(function()
            while currentThemeIndex==index and COLOR_THEMES[currentThemeIndex].glass do
                pcall(function()
                    UIGradientStroke.Rotation=(tick()*16)%360
                    local h=((tick()*20)%360)/360
                    local c=Color3.fromHSV(h,0.28,1)
                    UIGradientStroke.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(200,235,255)),ColorSequenceKeypoint.new(0.5,c),ColorSequenceKeypoint.new(1,Color3.fromRGB(180,220,255))})
                end)
                task.wait(0.05)
            end
        end)
    else
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end) glassRotThread=nil end
        GlassRefraction.Visible=false GlassHighlight.Visible=false GlassViewport.Visible=false
        tween(MainFrame,{BackgroundColor3=Color3.fromRGB(9,7,15),BackgroundTransparency=0.22},SMOOTH)
        UIStroke.Thickness=1.5 UIGradientStroke.Rotation=0
        SidebarLine.BackgroundColor3=Color3.fromRGB(60,40,90)
        UIGradientStroke.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,theme.primary),ColorSequenceKeypoint.new(0.5,theme.secondary),ColorSequenceKeypoint.new(1,theme.primary)})
    end
end

for i,theme in ipairs(COLOR_THEMES) do
    local TB=Instance.new("TextButton",TabTheme)
    TB.Size=UDim2.new(1,-16,0,27) TB.Position=UDim2.new(0,8,0,(i-1)*32+42)
    TB.BackgroundColor3=theme.glass and Color3.fromRGB(155,205,238) or theme.primary
    TB.BackgroundTransparency=theme.glass and 0.48 or 0.2
    TB.Text=theme.name TB.TextColor3=Color3.fromRGB(255,255,255)
    TB.Font=Enum.Font.SourceSansBold TB.TextSize=11
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,7)
    local ts=Instance.new("UIStroke",TB) ts.Color=Color3.fromRGB(255,255,255) ts.Transparency=0.62
    spring(TB)
    TB.MouseButton1Click:Connect(function()
        if theme.name=="Rainbow" then rainbowActive=true else rainbowActive=false applyTheme(i) end
    end)
end
