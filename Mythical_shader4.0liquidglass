local FPBot=Instance.new("Frame",FPop); FPBot.Size=UDim2.new(1,0,0,12); FPBot.Position=UDim2.new(0,0,1,-12); FPBot.BackgroundColor3=Color3.fromRGB(28,28,40); FPBot.BackgroundTransparency=0.22; FPBot.BorderSizePixel=0; FPBot.ZIndex=22
