UserInputService.InputChanged:Connect(function(i) if fpRsz and (i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch")) then local d=i.Position-fpRS; FPop.Size=UDim2.new(0,math.clamp(fpRSz.X+d.X,80,400),0,math.clamp(fpRSz.Y+d.Y,50,300)) end end)
local fpD,fpDS,fpDP=false,nil,nil
