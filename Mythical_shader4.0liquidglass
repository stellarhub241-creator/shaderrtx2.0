-- SECTION 34: THEME TAB
-- ================================================================
local ThTit=Instance.new("TextLabel",tTheme); ThTit.Size=UDim2.new(1,-14,0,18); ThTit.Position=UDim2.new(0,7,0,4); ThTit.BackgroundTransparency=1; ThTit.Text="💎 UI Color Theme"; ThTit.TextColor3=Color3.fromRGB(200,200,255); ThTit.TextSize=11; ThTit.Font=Enum.Font.SourceSansBold; ThTit.TextXAlignment=Enum.TextXAlignment.Left
local ThAct=Instance.new("TextLabel",tTheme); ThAct.Size=UDim2.new(1,-14,0,14); ThAct.Position=UDim2.new(0,7,0,22); ThAct.BackgroundTransparency=1; ThAct.Text="Active: Dark Glass"; ThAct.TextColor3=Color3.fromRGB(100,120,255); ThAct.TextSize=10; ThAct.Font=Enum.Font.Code; ThAct.TextXAlignment=Enum.TextXAlignment.Left
local rbActive=false; local glThread=nil
local function applyTheme(idx)
    local th=THEMES[idx]; St.themeIdx=idx
    tw(ThAct,{TextColor3=th.pri},TW0); ThAct.Text="Active: "..th.name
    refreshTBtns(); refreshSliders()
    if th.glass or th.clear then
        GH.Visible=true; GV.Visible=th.liquid==true
        local bg=(th.dark or th.clear) and Color3.fromRGB(12,12,18) or Color3.fromRGB(232,240,252)
        tw(MF,{BackgroundColor3=bg,BackgroundTransparency=1-St.uiOp},TW0); US.Thickness=1.8
        SBLine.BackgroundColor3=(th.dark or th.clear) and Color3.fromRGB(100,100,150) or Color3.fromRGB(165,205,240)
        SB.BackgroundColor3=(th.dark or th.clear) and Color3.fromRGB(8,8,14) or Color3.fromRGB(226,236,252)
        szStr.Color=th.pri; mStr.Color=th.pri
        if glThread then pcall(function() task.cancel(glThread) end) end
        glThread=task.spawn(function()
            while St.themeIdx==idx and (THEMES[St.themeIdx].glass or THEMES[St.themeIdx].clear) do
                pcall(function() UG.Rotation=(tick()*16)%360; local h=((tick()*18)%360)/360; local c=Color3.fromHSV(h,0.38,1); UG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(190,215,248)),ColorSequenceKeypoint.new(0.5,c),ColorSequenceKeypoint.new(1,Color3.fromRGB(170,205,245))}) end); task.wait(0.05)
            end
        end)
    else
        if glThread then pcall(function() task.cancel(glThread) end); glThread=nil end
        GH.Visible=false; GV.Visible=false
        tw(MF,{BackgroundColor3=Color3.fromRGB(238,240,248),BackgroundTransparency=0.1},TW0); US.Thickness=1.2; UG.Rotation=0
        SBLine.BackgroundColor3=Color3.fromRGB(200,195,225); SB.BackgroundColor3=Color3.fromRGB(232,232,248)
        szStr.Color=Color3.fromRGB(180,170,215); mStr.Color=Color3.fromRGB(180,170,210)
        UG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(200,180,240)),ColorSequenceKeypoint.new(0.5,th.sec),ColorSequenceKeypoint.new(1,Color3.fromRGB(200,180,240))})
        UG.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.4),NumberSequenceKeypoint.new(0.5,0.1),NumberSequenceKeypoint.new(1,0.4)})
    end
    applyBorder(St.borderStyle,th.pri)
end
for i,th in ipairs(THEMES) do
    local B=Instance.new("TextButton",tTheme); B.Size=UDim2.new(1,-14,0,27); B.Position=UDim2.new(0,7,0,(i-1)*32+42)
    B.BackgroundColor3=(th.glass or th.clear) and Color3.fromRGB(55,55,75) or th.pri; B.BackgroundTransparency=(th.glass or th.clear) and 0.48 or 0.16
    B.Text=th.name; B.TextColor3=Color3.fromRGB(255,255,255); B.Font=Enum.Font.SourceSansBold; B.TextSize=11
    Instance.new("UICorner",B).CornerRadius=UDim.new(0,8); local ts=Instance.new("UIStroke",B); ts.Color=Color3.fromRGB(255,255,255); ts.Transparency=0.62; spring(B)
    B.MouseButton1Click:Connect(function() rbActive=th.rainbow==true; applyTheme(i) end)
end
local thBaseY=#THEMES*32+42
