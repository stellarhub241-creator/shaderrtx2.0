UserInputService.InputChanged:Connect(function(i) if fpD and (i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch")) then local d=i.Position-fpDS; local vp=workspace.CurrentCamera.ViewportSize; FPop.Position=UDim2.new(0,math.clamp(fpDP.X.Offset+d.X,6,vp.X-FPop.Size.X.Offset-6),0,math.clamp(fpDP.Y.Offset+d.Y,6,vp.Y-FPop.Size.Y.Offset-6)) end end)
local function getUS2() return FPop:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPop) end
FPC.MouseButton1Click:Connect(function() pcall(function() local s=getUS2(); s.Scale=1; tw(s,{Scale=0},TweenInfo.new(0.13,Enum.EasingStyle.Back,Enum.EasingDirection.In)) end); task.delay(0.11,function() FPop.Visible=false end); ShowFPS.Text="📊 Show FPS Monitor" end)
