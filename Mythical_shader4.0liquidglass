    if isTouchOrMouse(i.UserInputType) then
        fpResizing=true; isAnyResizeActive=true; fpResStart=i.Position
        fpResSize=Vector2.new(FPSPopup.Size.X.Offset,FPSPopup.Size.Y.Offset)
        i.Changed:Connect(function() if i.UserInputState.Name=="End" then fpResizing=false; isAnyResizeActive=false end end)
    end
end)
