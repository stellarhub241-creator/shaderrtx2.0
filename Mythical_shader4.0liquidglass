MinBtn.Text="⭐"; MinBtn.TextColor3=Color3.fromRGB(255,200,50)
MinBtn.Font=Enum.Font.Code; MinBtn.TextSize=14; MinBtn.ZIndex=6
Instance.new("UICorner",MinBtn).CornerRadius=UDim.new(0,7)
local minStroke=Instance.new("UIStroke",MinBtn); minStroke.Color=Color3.fromRGB(100,120,200); minStroke.Thickness=1
spring(MinBtn)

local SizeBtn=Instance.new("TextButton",TitleBar)
SizeBtn.Size=UDim2.new(0,48,0,22); SizeBtn.Position=UDim2.new(1,-88,0.5,-11)
SizeBtn.BackgroundColor3=Color3.fromRGB(28,28,38); SizeBtn.BackgroundTransparency=0.25
SizeBtn.TextColor3=Color3.fromRGB(240,240,255); SizeBtn.Font=Enum.Font.Code; SizeBtn.TextSize=10; SizeBtn.ZIndex=6
Instance.new("UICorner",SizeBtn).CornerRadius=UDim.new(0,6)
local szStroke=Instance.new("UIStroke",SizeBtn); szStroke.Color=Color3.fromRGB(100,120,200); szStroke.Thickness=1
spring(SizeBtn)

