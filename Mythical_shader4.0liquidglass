-- ลาก popup
local pDrag,pDragStart,pStartPos=false,nil,nil
PopupHeader.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        pDrag=true pDragStart=i.Position pStartPos=FPSPopup.Position
        i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then pDrag=false end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if pDrag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local d=i.Position-pDragStart
        local vp=workspace.CurrentCamera.ViewportSize
        local pw=FPSPopup.Size.X.Offset local ph=FPSPopup.Size.Y.Offset
        local nx=math.clamp(pStartPos.X.Offset+d.X,6,vp.X-pw-6)
        local ny=math.clamp(pStartPos.Y.Offset+d.Y,6,vp.Y-ph-6)
        FPSPopup.Position=UDim2.new(0,nx,0,ny)
    end
end)

-- resize popup
local pResize,pResizeStart,pResizeSize=false,nil,nil
PopupResize.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        pResize=true pResizeStart=i.Position pResizeSize=Vector2.new(FPSPopup.Size.X.Offset,FPSPopup.Size.Y.Offset)
        i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then pResize=false end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if pResize and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local d=i.Position-pResizeStart
        local nW=math.clamp(pResizeSize.X+d.X,44,300) local nH=math.clamp(pResizeSize.Y+d.Y,38,200)
        PopupTitle.Visible=nW>=65 PopupCapLabel.Visible=nH>=56
        PopupCloseBtn.Visible=nW>=65 PopupHeader.BackgroundTransparency=nH>=56 and 0.4 or 1
        pcall(function() TweenService:Create(FPSPopup,TweenInfo.new(0.04,Enum.EasingStyle.Quad),{Size=UDim2.new(0,nW,0,nH)}):Play() end)
    end
end)

