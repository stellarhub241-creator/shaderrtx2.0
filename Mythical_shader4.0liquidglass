-- ================================================================
-- SECTION 28: SKYBOX TAB (bulletproof fix)
-- ================================================================
local function applySkyPreset(preset)
    -- [FIX] disconnect guard ชั่วคราว สร้าง Sky ใหม่ แล้ว reconnect
    if skyGuardConn then skyGuardConn:Disconnect() end
    pcall(function()
        for _,child in ipairs(Lighting:GetChildren()) do
            if child:IsA("Sky") then child:Destroy() end
        end
    end)
    task.wait(0.05)
    local sky=Instance.new("Sky",Lighting) sky.Name="StellarSky"
    pcall(function() sky.SkyboxBk=preset.bk sky.SkyboxDn=preset.dn sky.SkyboxFt=preset.ft
        sky.SkyboxLf=preset.lf sky.SkyboxRt=preset.rt sky.SkyboxUp=preset.up
        sky.StarCount=preset.star sky.CelestialBodiesShown=true
        if preset.moonSize then sky.MoonAngularSize=preset.moonSize end
        if not heavenlyEnabled then Lighting.ClockTime=preset.time end
        if preset.brightness then Lighting.Brightness=preset.brightness end
        if preset.ambient then Lighting.OutdoorAmbient=preset.ambient end
    end)
    -- reconnect guard
    skyGuardConn=Lighting.ChildAdded:Connect(function(child)
        if child:IsA("Sky") and child.Name~="StellarSky" then
            task.defer(function() pcall(function() child:Destroy() end) end)
        end
    end)
end

local ResetSkyBtn=Instance.new("TextButton",TabSky)
ResetSkyBtn.Size=UDim2.new(1,-16,0,26) ResetSkyBtn.Position=UDim2.new(0,8,0,6)
ResetSkyBtn.BackgroundColor3=Color3.fromRGB(55,38,78) ResetSkyBtn.BackgroundTransparency=0.2
ResetSkyBtn.Text="↺ Reset to Default Sky" ResetSkyBtn.TextColor3=Color3.fromRGB(200,200,222)
ResetSkyBtn.Font=Enum.Font.SourceSansBold ResetSkyBtn.TextSize=11
Instance.new("UICorner",ResetSkyBtn).CornerRadius=UDim.new(0,7) spring(ResetSkyBtn)
ResetSkyBtn.MouseButton1Click:Connect(function()
    if skyGuardConn then skyGuardConn:Disconnect() end
    pcall(function()
        for _,child in ipairs(Lighting:GetChildren()) do
            if child:IsA("Sky") then child:Destroy() end
        end
        task.wait(0.05)
        local sky=Instance.new("Sky",Lighting) sky.Name="StellarSky"
        sky.SunTextureId="rbxassetid://1079349813" sky.SunAngularSize=21
        sky.MoonTextureId="rbxassetid://6444320592" sky.MoonAngularSize=11
        sky.StarCount=8000 sky.CelestialBodiesShown=true
    end)
    skyGuardConn=Lighting.ChildAdded:Connect(function(child)
        if child:IsA("Sky") and child.Name~="StellarSky" then
            task.defer(function() pcall(function() child:Destroy() end) end)
        end
    end)
end)

