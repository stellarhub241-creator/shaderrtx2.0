-- ================================================================
-- SECTION 21: TABS
-- ================================================================
local function makeTab()
    local s = Instance.new("ScrollingFrame", ContentArea)
    s.Size = UDim2.new(1, 0, 1, 0) 
    s.BackgroundTransparency = 1 
    s.BorderSizePixel = 0
    s.ScrollBarThickness = 3 
    s.ScrollBarImageColor3 = Color3.fromRGB(160, 0, 235)
    s.CanvasSize = UDim2.new(0, 0, 0, 600) 
    s.ScrollingDirection = Enum.ScrollingDirection.Y
    s.ElasticBehavior = Enum.ElasticBehavior.Always 
    s.Visible = false 
    s.ClipsDescendants = true
    return s
end

local TabGfx      = makeTab() 
local TabSky      = makeTab()
local TabBoost    = makeTab() 
local TabTheme    = makeTab()
local TabFPS      = makeTab() 
local TabCinema   = makeTab()
local TabParticle = makeTab()

local TAB_DEFS = {
    {text="Graphics",  icon="🎨", tab=TabGfx},
    {text="Skybox",    icon="🌌", tab=TabSky},
    {text="Boost",     icon="⚡", tab=TabBoost},
    {text="Theme",     icon="💎", tab=TabTheme},
    {text="FPS Cap",   icon="📊", tab=TabFPS},
    {text="Cinema",    icon="🎬", tab=TabCinema},
