-- SECTION 21: UI FRAMEWORK
-- ================================================================
local ScreenGui=Instance.new("ScreenGui",CoreGui)
ScreenGui.Name="STELLARHUB_MYTHICAL"; ScreenGui.ResetOnSpawn=false; ScreenGui.IgnoreGuiInset=true

local SMOOTH      = TweenInfo.new(0.28,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
local SMOOTH_BACK = TweenInfo.new(0.32,Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local SMOOTH_FAST = TweenInfo.new(0.14,Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local SMOOTH_TAB  = TweenInfo.new(0.26,Enum.EasingStyle.Quint,Enum.EasingDirection.Out)

local function tw(obj,props,info) pcall(function() TweenService:Create(obj,info or SMOOTH,props):Play() end) end

local function spring(btn)
    pcall(function()
        local us=btn:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",btn); us.Scale=1.0
        btn.MouseEnter:Connect(function() pcall(function() tw(us,{Scale=1.09},SMOOTH_BACK); tw(btn,{BackgroundTransparency=0.05},SMOOTH_FAST) end) end)
        btn.MouseLeave:Connect(function() pcall(function() tw(us,{Scale=1.0},SMOOTH); tw(btn,{BackgroundTransparency=0.3},SMOOTH_FAST) end) end)
        btn.InputBegan:Connect(function(i) if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=0.91},SMOOTH_FAST) end) end end)
        btn.InputEnded:Connect(function(i) if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=1.0},SMOOTH_BACK) end) end end)
    end)
end

local function addBounceOnHold(frame)
    local holdThread=nil
    frame.InputBegan:Connect(function(input)
        if isTouchOrMouse(input.UserInputType) then
            if holdThread then pcall(function() task.cancel(holdThread) end) end
            holdThread=task.delay(0.28,function()
                if isInputBlocked() then holdThread=nil; return end
                pcall(function()
                    local us=frame:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",frame); us.Scale=1
                    tw(us,{Scale=1.14},TweenInfo.new(0.1,Enum.EasingStyle.Quad,Enum.EasingDirection.Out))
                    task.wait(0.1)
                    tw(us,{Scale=1.0},TweenInfo.new(0.32,Enum.EasingStyle.Bounce,Enum.EasingDirection.Out))
                end); holdThread=nil
            end)
            input.Changed:Connect(function()
                if input.UserInputState==Enum.UserInputState.End then
                    if holdThread then pcall(function() task.cancel(holdThread) end); holdThread=nil end
                end
            end)
        end
    end)
end

