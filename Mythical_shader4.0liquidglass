-- ================================================================
-- SECTION 7: MATH & UTILITIES
-- ================================================================
local function lerpN(a, b, t) return a + (b - a) * t end
local function lerpC(a, b, t) return Color3.new(a.R + (b.R - a.R)*t, a.G + (b.G - a.G)*t, a.B + (b.B - a.B)*t) end

local function applyLighting(p)
    pcall(function()
        Lighting.Brightness             = p.brightness 
        Lighting.ExposureCompensation   = p.exposure
        Lighting.ShadowSoftness         = p.shadow 
        Lighting.OutdoorAmbient         = p.ambient
        Atmosphere.Color                = p.atmoColor 
        Atmosphere.Decay                = p.atmoDecay
        Atmosphere.Glare                = p.atmoGlare 
        Atmosphere.Haze                 = p.atmoHaze 
        Atmosphere.Density              = p.atmoDensity
        ColorCorrection.Contrast        = p.contrast 
        ColorCorrection.Saturation      = p.saturation 
        ColorCorrection.TintColor       = p.tint
        Bloom.Intensity                 = p.bloom 
        Bloom.Size                      = p.bloomSize 
        Bloom.Threshold                 = p.bloomThreshold
        DOF.FarIntensity                = p.dofFar 
        SunRays.Intensity               = p.sunRays
    end)
end

local cinContrast   = 0.6 
local cinSaturation = -0.1 
local cinDofFar     = 0.55 
local cinShadow     = 0.65

local function applyCinematicBlend()
    if not State.cinematicEnabled then return end
    pcall(function()
        ColorCorrection.Contrast   = math.max(ColorCorrection.Contrast, cinContrast)
        ColorCorrection.Saturation = ColorCorrection.Saturation + cinSaturation
        DOF.FarIntensity           = math.max(DOF.FarIntensity, cinDofFar)
        Bloom.Threshold            = math.min(Bloom.Threshold + 0.08, 0.99)
        Lighting.ShadowSoftness    = math.max(Lighting.ShadowSoftness, cinShadow)
    end)
end

local function resetFogLighting()
    pcall(function()
        if not State.nostalgiaEnabled then
            Lighting.FogStart             = State.originalFogStart 
            Lighting.FogEnd               = State.originalFogEnd 
            Lighting.FogColor             = State.originalFogColor 
            Lighting.Ambient              = State.originalAmbient 
            Lighting.Brightness           = State.originalBrightness 
            Lighting.ExposureCompensation = State.originalExposure 
            Lighting.ShadowSoftness       = State.originalShadow 
            Lighting.OutdoorAmbient       = State.originalOutdoor
        end
    end)
end

local function reapplyActiveMode()
    if State.nostalgiaEnabled then
        applyLighting(PROFILES.NOSTALGIA)
        pcall(function() 
            Lighting.ClockTime = 17.6 
            Lighting.FogStart  = 150 
            Lighting.FogEnd    = 2500 
            Lighting.FogColor  = Color3.fromRGB(255, 130, 210) 
            Lighting.Ambient   = Color3.fromRGB(90, 40, 120) 
        end)
    elseif State.horrorFogEnabled then
        local p = State.horrorBlue and PROFILES.HORROR_B or PROFILES.HORROR_G
        applyLighting(p)
        local fc = State.horrorBlue and Color3.fromRGB(4, 5, 14) or Color3.fromRGB(8, 14, 4)
        pcall(function() 
            Lighting.FogStart = 4 
            Lighting.FogEnd   = 80 
            Lighting.FogColor = fc 
            Lighting.Ambient  = fc 
        end)
    elseif State.dawnEnabled then 
        applyLighting(PROFILES.DAWN) 
        pcall(function() Lighting.ClockTime = 5.5 end)
    elseif State.sunsetEnabled then 
        applyLighting(PROFILES.GOLDEN) 
        pcall(function() Lighting.ClockTime = 19 end)
    elseif State.rainEnabled then 
        applyLighting(PROFILES.RAIN) 
        pcall(function() 
            Lighting.FogStart = 20 
            Lighting.FogEnd   = 200 
            Lighting.FogColor = Color3.fromRGB(110, 122, 142) 
        end)
    elseif State.heavenlyEnabled then 
        applyLighting(PROFILES.HEAVENLY) 
        pcall(function() 
            Lighting.FogStart = 500 
            Lighting.FogEnd   = 2000 
            Lighting.FogColor = Color3.fromRGB(225, 235, 255) 
            Lighting.ClockTime = 12 
        end)
    else 
        resetFogLighting() 
    end
    applyCinematicBlend()
end

-- ================================================================
-- SECTION 8: RAIN SYSTEM
-- ================================================================
local rainFolder  = nil 
local rainConns   = {} 
local rainParts   = {} 
local rainRipples = {}

local function clearRainParticles()
    for _, c in pairs(rainConns) do pcall(function() c:Disconnect() end) end
    rainConns = {}
    if rainFolder and rainFolder.Parent then pcall(function() rainFolder:Destroy() end) end
    rainFolder = nil 
    rainParts = {} 
    rainRipples = {}
end

local function createRainParticles()
    clearRainParticles()
    rainFolder = Instance.new("Folder", workspace) 
    rainFolder.Name = "StellarRain"
    
    local cam = workspace.CurrentCamera
    local count = math.clamp(State.rainParticleCount, 10, 150)
    
    for i = 1, count do
        local p = Instance.new("Part")
        p.Size = Vector3.new(0.045, math.random(18, 30) * 0.1, 0.045)
        p.Material = Enum.Material.Glass 
        p.Reflectance = math.random(70, 90) / 100
        p.Color = Color3.fromRGB(math.random(200, 230), math.random(225, 245), 255)
        p.Transparency = math.random(55, 72) / 100
        p.CastShadow = false 
        p.Anchored = true 
        p.CanCollide = false 
        p.Parent = rainFolder
        table.insert(rainParts, p)
    end
    
    local rippleCount = math.max(6, math.floor(count * 0.18))
    for i = 1, rippleCount do
        local r = Instance.new("Part")
        r.Size = Vector3.new(0.1, 0.05, 0.1) 
        r.Material = Enum.Material.Glass 
        r.Reflectance = 0.7
        r.Color = Color3.fromRGB(180, 215, 255) 
        r.Transparency = 0.82
        r.CastShadow = false 
        r.Anchored = true 
        r.CanCollide = false
        r.Shape = Enum.PartType.Cylinder 
        r.Parent = rainFolder
        table.insert(rainRipples, r)
    end
    
    local frame = 0
    local conn = RunService.Heartbeat:Connect(function()
        frame = frame + 1 
        if frame % 2 ~= 0 then return end
        if not rainFolder or not rainFolder.Parent then return end
        
        local cp = cam.CFrame.Position 
        local t = tick()
        
        for i, p in ipairs(rainParts) do
            if p and p.Parent then
                local ph = i * 0.73 
                local fall = (t * 16 + ph * 2.8) % 32
                pcall(function() 
                    p.Reflectance = 0.65 + math.sin(t * 3 + ph) * 0.25 
                    p.CFrame = CFrame.new(cp.X + math.sin(ph)*34, cp.Y + 20 - fall, cp.Z + math.cos(ph)*34) * CFrame.Angles(0.18, 0, 0.06) 
                end)
            end
        end
        
        for i, r in ipairs(rainRipples) do
            if r and r.Parent then
                pcall(function()
                    local rt = (t * 0.7 + i * 0.65) % 1 
                    local sc = 0.3 + rt * 3.5 
                    local ph = i * 1.13
                    local rx = cp.X + math.sin(ph) * 22 
                    local rz = cp.Z + math.cos(ph) * 22
                    local ray = workspace:Raycast(Vector3.new(rx, cp.Y + 8, rz), Vector3.new(0, -50, 0))
                    local ry = ray and ray.Position.Y + 0.05 or cp.Y - 8
                    
                    r.CFrame = CFrame.new(rx, ry, rz) * CFrame.Angles(0, 0, math.pi/2)
                    r.Size = Vector3.new(0.05, sc, sc) 
                    r.Transparency = 0.65 + (1 - rt) * 0.28
                    r.Reflectance = 0.6 + math.sin(t * 2 + i) * 0.3
                    r.Color = Color3.fromRGB(math.floor(lerpN(150, 210, 1 - rt)), math.floor(lerpN(190, 235, 1 - rt)), 255)
                end)
            end
        end
    end)
    table.insert(rainConns, conn)
end

-- ================================================================
-- SECTION 9: SAKURA
-- ================================================================
local sakuraFolder = nil 
local sakuraConns  = {}

local function clearSakura()
    for _, c in pairs(sakuraConns) do pcall(function() c:Disconnect() end) end
    sakuraConns = {}
    if sakuraFolder and sakuraFolder.Parent then pcall(function() sakuraFolder:Destroy() end) end
    sakuraFolder = nil
end

local function createSakura()
    clearSakura()
    sakuraFolder = Instance.new("Folder", workspace) 
    sakuraFolder.Name = "StellarSakura"
    local cam = workspace.CurrentCamera

    local emitter = Instance.new("Part", sakuraFolder)
    emitter.Size = Vector3.new(60, 1, 60)
    emitter.Anchored = true 
    emitter.CanCollide = false
    emitter.Transparency = 1 
    emitter.CastShadow = false 
    emitter.Name = "SakuraEmitter"

    local pe = Instance.new("ParticleEmitter", emitter)
    pe.Texture = "rbxassetid://13214811345"
    pe.Rate = math.clamp(State.sakuraCount * 1.2, 12, 90)
    pe.Lifetime = NumberRange.new(4, 8)
    pe.Speed = NumberRange.new(0.5, 3)
    pe.SpreadAngle = Vector2.new(60, 60)
    pe.RotSpeed = NumberRange.new(-80, 80)
    pe.Rotation = NumberRange.new(0, 360)
    pe.LightEmission = 0.2
    pe.LightInfluence = 0.8
    
    pe.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.05),
        NumberSequenceKeypoint.new(0.7, 0.15),
        NumberSequenceKeypoint.new(1, 1),
    })
    pe.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(0.1, 1.1),
        NumberSequenceKeypoint.new(0.9, 0.9),
        NumberSequenceKeypoint.new(1, 0),
    })
    pe.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 230, 242)),
        ColorSequenceKeypoint.new(0.35, Color3.fromRGB(255, 192, 218)),
        ColorSequenceKeypoint.new(0.7, Color3.fromRGB(248, 160, 195)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(235, 140, 180)),
    })
    
    pe.Acceleration = Vector3.new(0.4, -0.8, 0.2)
    pe.EmissionDirection = Enum.NormalId.Top
    pe.VelocityInheritance = 0

    local conn = RunService.Heartbeat:Connect(function()
        if not sakuraFolder or not sakuraFolder.Parent then return end
        if not emitter or not emitter.Parent then return end
        pcall(function() 
            local cp = cam.CFrame.Position 
            emitter.CFrame = CFrame.new(cp.X, cp.Y + 10, cp.Z) 
        end)
    end)
    table.insert(sakuraConns, conn)
end

-- ================================================================
-- SECTION 10: WIND SYSTEM
-- ================================================================
local windConns = {} 
local windParts = {}

local function clearWind()
    for _, c in pairs(windConns) do pcall(function() c:Disconnect() end) end
    windConns = {}
    for _, d in pairs(windParts) do
        pcall(function() if d.part and d.part.Parent then d.part.CFrame = d.origin end end)
    end
    windParts = {}
end

local function startWind()
    clearWind()
    local cam = workspace.CurrentCamera
    
    for _, v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if (v:IsA("BasePart") or v:IsA("MeshPart")) and v.Anchored then
                local sz = v.Size
                local pn = v.Parent and v.Parent.Name or ""
                if sz.X < 4 and sz.Z < 4 and sz.Y < 12 
                    and (v.Position - cam.CFrame.Position).Magnitude < 150 
                    and pn ~= "StellarRain" and pn ~= "StellarSakura" 
                    and pn ~= "StellarMeteor" and pn ~= "StellarSun" then
                    table.insert(windParts, {part = v, origin = v.CFrame, phase = math.random() * math.pi * 2, freq = 0.8 + math.random() * 0.8, amp = 0.012 + math.random() * 0.018})
                end
            end
        end)
    end
    
    local conn = RunService.Heartbeat:Connect(function()
        if not State.windEnabled then return end
        local t = tick()
        for _, d in pairs(windParts) do
            pcall(function()
                if d.part and d.part.Parent then
                    local wave = math.sin(t * d.freq + d.phase) * d.amp * State.windStrength
                    local wave2 = math.cos(t * d.freq * 0.7 + d.phase) * d.amp * State.windStrength * 0.5
                    d.part.CFrame = d.origin * CFrame.Angles(wave, wave2 * 0.3, wave * 0.5)
                end
            end)
        end
    end)
    table.insert(windConns, conn)
end

-- ================================================================
-- SECTION 11: METEOR (UPGRADED MAJESTIC SYSTEM)
-- ================================================================
local meteorFolder  = nil 
local meteorConns   = {} 
local meteorRunning = false

local function clearMeteor()
    meteorRunning = false
    for _, c in pairs(meteorConns) do pcall(function() c:Disconnect() end) end
    meteorConns = {}
    if meteorFolder and meteorFolder.Parent then pcall(function() meteorFolder:Destroy() end) end
    meteorFolder = nil
end

local function spawnOneMeteor()
    if not meteorFolder or not meteorFolder.Parent then return end
    
    local cam = workspace.CurrentCamera
    local cp = cam.CFrame.Position

    -- [PRO UPGRADE] Spawns much further away for majestic scale
    local angle = math.random() * math.pi * 2
    local dist = math.random(500, 800) 
    
    local sx = cp.X + math.cos(angle) * dist
    local sy = cp.Y + math.random(300, 500) 
    local sz = cp.Z + math.sin(angle) * dist

    local target = Vector3.new(
        cp.X + math.cos(angle + math.pi) * dist, 
        cp.Y - math.random(50, 100), 
        cp.Z + math.sin(angle + math.pi) * dist
    )
    
    local dir = (target - Vector3.new(sx, sy, sz)).Unit
    local speed = math.random(250, 450)
    local len = math.random(50, 120)

    -- Giant Head
    local head = Instance.new("Part", meteorFolder)
    head.Size = Vector3.new(4, 4, 4)
    head.Material = Enum.Material.Neon 
    head.Color = State.meteorColor
    head.Transparency = 0 
    head.CastShadow = false 
    head.Anchored = true 
    head.CanCollide = false
    Instance.new("SpecialMesh", head).MeshType = Enum.MeshType.Sphere
    
    -- Epic PointLight
    local pLight = Instance.new("PointLight", head)
    pLight.Color = State.meteorColor
    pLight.Range = 250
    pLight.Brightness = 3
    pLight.Shadows = true

    -- Thick Body
    local body = Instance.new("Part", meteorFolder)
    body.Size = Vector3.new(2, 2, len)
    body.Material = Enum.Material.Neon
    body.Color = lerpC(State.meteorColor, Color3.fromRGB(255, 255, 255), 0.45)
    body.Transparency = 0.18 
    body.CastShadow = false 
    body.Anchored = true 
    body.CanCollide = false

    -- Long Tail
    local tail = Instance.new("Part", meteorFolder)
    tail.Size = Vector3.new(1, 1, len * 2.5)
    tail.Material = Enum.Material.Neon
    tail.Color = lerpC(State.meteorColor, Color3.fromRGB(255, 255, 255), 0.75)
    tail.Transparency = 0.5 
    tail.CastShadow = false 
    tail.Anchored = true 
    tail.CanCollide = false

    -- Ghost Tail
    local tail2 = Instance.new("Part", meteorFolder)
    tail2.Size = Vector3.new(0.5, 0.5, len * 5)
    tail2.Material = Enum.Material.Neon
    tail2.Color = Color3.fromRGB(255, 255, 255)
    tail2.Transparency = 0.8 
    tail2.CastShadow = false 
    tail2.Anchored = true 
    tail2.CanCollide = false

    -- Majestic Glow
    local glow = Instance.new("Part", meteorFolder)
    glow.Size = Vector3.new(20, 20, 20)
    glow.Material = Enum.Material.Neon 
    glow.Color = State.meteorColor
    glow.Transparency = 0.8 
    glow.CastShadow = false 
    glow.Anchored = true 
    glow.CanCollide = false
    Instance.new("SpecialMesh", glow).MeshType = Enum.MeshType.Sphere

    -- High-Res Sparks
    local pe = Instance.new("ParticleEmitter", head)
    pe.Texture = "rbxassetid://6101261905"
    pe.Rate = 500 
    pe.Lifetime = NumberRange.new(0.2, 0.8)
    pe.Speed = NumberRange.new(10, 40) 
    pe.SpreadAngle = Vector2.new(45, 45)
    pe.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, State.meteorColor),
        ColorSequenceKeypoint.new(0.4, Color3.fromRGB(255, 245, 180)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
    })
    pe.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 3.5),
        NumberSequenceKeypoint.new(0.5, 1.5),
        NumberSequenceKeypoint.new(1, 0)
    })
    pe.LightEmission = 1.0
    pe.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(1, 1)
    })
    pe.EmissionDirection = Enum.NormalId.Back

    local life = 0 
    local maxLife = 5.0
    local isFading = false

    local conn = RunService.Heartbeat:Connect(function(dt)
        life = life + dt
        
        -- [PRO UPGRADE] Smooth Fade Out / Flash at the end
        if life >= maxLife - 0.5 and not isFading then
            isFading = true
            pe.Enabled = false
            pcall(function()
                -- Flash effect
                TweenService:Create(glow, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Size = Vector3.new(60, 60, 60), 
                    Transparency = 0
                }):Play()
                TweenService:Create(pLight, TweenInfo.new(0.2), {Range = 400, Brightness = 6}):Play()
                
                -- Fade out parts
                TweenService:Create(head, TweenInfo.new(0.5), {Transparency = 1}):Play()
                TweenService:Create(body, TweenInfo.new(0.5), {Transparency = 1}):Play()
                TweenService:Create(tail, TweenInfo.new(0.5), {Transparency = 1}):Play()
                TweenService:Create(tail2, TweenInfo.new(0.5), {Transparency = 1}):Play()
            end)
        end
        
        if life >= maxLife then
            pcall(function() 
                head:Destroy() 
                body:Destroy() 
                tail:Destroy() 
                tail2:Destroy() 
                glow:Destroy() 
            end)
            return
        end
        
        local np = Vector3.new(sx, sy, sz) + dir * speed * life
        
        pcall(function()
            if not isFading then
                head.CFrame = CFrame.new(np)
                body.CFrame = CFrame.lookAt(np - dir * (len * 0.5), np - dir * (len * 0.5) + dir) * CFrame.Angles(math.pi/2, 0, 0)
                tail.CFrame = CFrame.lookAt(np - dir * (len * 1.4), np - dir * (len * 1.4) + dir) * CFrame.Angles(math.pi/2, 0, 0)
                tail2.CFrame= CFrame.lookAt(np - dir * (len * 3.0), np - dir * (len * 3.0) + dir) * CFrame.Angles(math.pi/2, 0, 0)
                
                local pulse = 1 + math.sin(life * 25) * 0.15
                glow.CFrame = CFrame.new(np) 
                glow.Size = Vector3.new(20 * pulse, 20 * pulse, 20 * pulse)
            else
                -- Just let them drift slightly while fading
                head.CFrame = head.CFrame + (dir * speed * 0.1 * dt)
                glow.CFrame = head.CFrame
                TweenService:Create(glow, TweenInfo.new(0.3), {Transparency = 1, Size = Vector3.new(0,0,0)}):Play()
            end
        end)
    end)
    table.insert(meteorConns, conn)
end

local function startMeteor()
    clearMeteor()
    meteorRunning = true
    meteorFolder = Instance.new("Folder", workspace) 
    meteorFolder.Name = "StellarMeteor"
    
    task.spawn(function()
        while meteorRunning do
            spawnOneMeteor()
            task.wait(math.random() * State.meteorInterval + 0.5)
        end
    end)
end

-- ================================================================
-- SECTION 12: SUN OBJECT (UPGRADED MASSIVE CELESTIAL)
-- ================================================================
local sunFolder = nil 
local sunConns  = {}

local function clearSunray()
    for _, c in pairs(sunConns) do pcall(function() c:Disconnect() end) end
    sunConns = {}
    if sunFolder and sunFolder.Parent then pcall(function() sunFolder:Destroy() end) end
    sunFolder = nil
end

local function startSunray()
    clearSunray()
    sunFolder = Instance.new("Folder", workspace) 
    sunFolder.Name = "StellarSun"
    local cam = workspace.CurrentCamera

    -- [PRO UPGRADE] Massive Sun Core
    local core = Instance.new("Part", sunFolder)
    core.Size = Vector3.new(100, 100, 100) 
    core.Material = Enum.Material.Neon
    core.Color = Color3.fromRGB(255, 248, 180) 
    core.Transparency = 0 
    core.CastShadow = false 
    core.Anchored = true 
    core.CanCollide = false
    Instance.new("SpecialMesh", core).MeshType = Enum.MeshType.Sphere
    
    local sunLight = Instance.new("PointLight", core)
    sunLight.Color = Color3.fromRGB(255, 220, 150)
    sunLight.Brightness = 5
    sunLight.Range = 1000
    sunLight.Shadows = false

    -- Huge Corona Layers
    local layers = {
        {sz=140, col=Color3.fromRGB(255, 220, 100), tr=0.6},
        {sz=190, col=Color3.fromRGB(255, 190, 60),  tr=0.75},
        {sz=260, col=Color3.fromRGB(255, 150, 30),  tr=0.88},
        {sz=380, col=Color3.fromRGB(255, 100, 10),  tr=0.95},
    }
    
    local coronaParts = {}
    for _, l in ipairs(layers) do
        local c = Instance.new("Part", sunFolder)
        c.Size = Vector3.new(l.sz, l.sz, l.sz) 
        c.Material = Enum.Material.Neon
        c.Color = l.col 
        c.Transparency = l.tr 
        c.CastShadow = false 
        c.Anchored = true 
        c.CanCollide = false
        Instance.new("SpecialMesh", c).MeshType = Enum.MeshType.Sphere
        table.insert(coronaParts, {part=c, baseSz=l.sz, baseTr=l.tr})
    end

    -- Epic Sun Rays
    local rays = {}
    for i = 1, 12 do
        local ray = Instance.new("Part", sunFolder)
        ray.Size = Vector3.new(4, 4, math.random(400, 800))
        ray.Material = Enum.Material.Neon
        ray.Color = Color3.fromRGB(255, 235, 140) 
        ray.Transparency = 0.7
        ray.CastShadow = false 
        ray.Anchored = true 
        ray.CanCollide = false
        table.insert(rays, {part=ray, angle=(i/12)*math.pi*2, tilt=math.random()*0.8})
    end

    local t0 = tick()
    local conn = RunService.Heartbeat:Connect(function()
        if not sunFolder or not sunFolder.Parent then return end
        
        local cp = cam.CFrame.Position
        local t = tick() - t0
        local ag = t * 0.02 -- Slower rotation for massive scale
        
        -- Placed 800 studs away
        local sunPos = cp + Vector3.new(math.cos(ag) * 800, 400 + math.sin(t * 0.1) * 30, math.sin(ag) * 800)
        local pulse = 1 + math.sin(t * 1.5) * 0.03
        
        pcall(function()
            core.CFrame = CFrame.new(sunPos)
            
            for _, lc in ipairs(coronaParts) do
                lc.part.CFrame = CFrame.new(sunPos)
                lc.part.Size = Vector3.new(lc.baseSz * pulse, lc.baseSz * pulse, lc.baseSz * pulse)
                lc.part.Transparency = lc.baseTr + (math.sin(t * 1.2) * 0.03)
            end
            
            for _, r in ipairs(rays) do
                local ra = r.angle + t * 0.4
                local rx = sunPos + Vector3.new(math.cos(ra) * 50, math.sin(r.tilt) * 20, math.sin(ra) * 50)
                r.part.CFrame = CFrame.lookAt(rx, sunPos) * CFrame.Angles(math.pi/2, 0, 0)
                r.part.Transparency = 0.65 + math.sin(t * 2 + r.angle) * 0.2
            end
        end)
    end)
    table.insert(sunConns, conn)
end

