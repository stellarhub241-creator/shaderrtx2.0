local FPSt=Instance.new("TextLabel",FPBot); FPSt.Size=UDim2.new(0.5,0,1,0); FPSt.Position=UDim2.new(0.5,0,0,0); FPSt.BackgroundTransparency=1; FPSt.Text="ok"; FPSt.TextColor3=Color3.fromRGB(0,200,100); FPSt.TextSize=8; FPSt.Font=Enum.Font.Code; FPSt.TextXAlignment=Enum.TextXAlignment.Right; FPSt.ZIndex=23
local FPR=Instance.new("TextButton",FPop); FPR.Size=UDim2.new(0,14,0,14); FPR.Position=UDim2.new(1,-14,1,-14); FPR.BackgroundTransparency=1; FPR.Text="◢"; FPR.TextColor3=Color3.fromRGB(255,255,255); FPR.TextSize=10; FPR.ZIndex=24
local fpRsz,fpRS,fpRSz=false,nil,nil
