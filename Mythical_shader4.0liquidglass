local function connectSkyGuard()
    if skyGuardConn then pcall(function() skyGuardConn:Disconnect() end) end
    skyGuardConn=Lighting.ChildAdded:Connect(function(child)
        if child:IsA("Sky") and child.Name~="StellarSky" then
            task.defer(function() pcall(function() child:Destroy() end) end)
        end
    end)
end
