ThemeTitle.Font=Enum.Font.SourceSansBold ThemeTitle.TextXAlignment=Enum.TextXAlignment.Left

local activeThemeLabel=Instance.new("TextLabel",TabTheme)
activeThemeLabel.Size=UDim2.new(1,-16,0,14) activeThemeLabel.Position=UDim2.new(0,8,0,22)
activeThemeLabel.BackgroundTransparency=1 activeThemeLabel.Text="Active: Purple"
activeThemeLabel.TextColor3=Color3.fromRGB(180,0,255) activeThemeLabel.TextSize=10
activeThemeLabel.Font=Enum.Font.Code activeThemeLabel.TextXAlignment=Enum.TextXAlignment.Left

local rainbowActive=false
local glassRotThread=nil

local function applyTheme(index)
    local theme=COLOR_THEMES[index]
    currentThemeIndex=index
    activeThemeLabel.Text="Active: "..theme.name
    activeThemeLabel.TextColor3=theme.primary
    pcall(function()
        UIGradientStroke.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,theme.primary),
            ColorSequenceKeypoint.new(0.5,theme.secondary),
            ColorSequenceKeypoint.new(1,theme.primary),
        })
    end)
    refreshTabButtons()
    pcall(function() TweenService:Create(MinBtn,TweenInfo.new(0.28),{TextColor3=theme.secondary}):Play() end)
    BorderColorNow=theme.primary

    if theme.glass then
        GlassRefraction.Visible=true GlassHighlight.Visible=true
        MainFrame.BackgroundColor3=Color3.fromRGB(8,14,22)
        MainFrame.BackgroundTransparency=0.18
        UIStroke.Thickness=2.2
        SidebarLine.BackgroundColor3=Color3.fromRGB(160,210,240)
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end) end
        glassRotThread=task.spawn(function()
            while currentThemeIndex==index and COLOR_THEMES[currentThemeIndex].glass do
                pcall(function()
                    UIGradientStroke.Rotation=(tick()*16)%360
                    local h=((tick()*20)%360)/360
                    local c=Color3.fromHSV(h,0.3,1)
                    UIGradientStroke.Color=ColorSequence.new({
                        ColorSequenceKeypoint.new(0,Color3.fromRGB(200,235,255)),
                        ColorSequenceKeypoint.new(0.5,c),
                        ColorSequenceKeypoint.new(1,Color3.fromRGB(180,220,255)),
                    })
                end)
                task.wait(0.05)
            end
        end)
    else
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end) glassRotThread=nil end
        GlassRefraction.Visible=false GlassHighlight.Visible=false
        MainFrame.BackgroundColor3=Color3.fromRGB(10,8,16)
        MainFrame.BackgroundTransparency=0.32
        UIStroke.Thickness=1.8 UIGradientStroke.Rotation=0
        SidebarLine.BackgroundColor3=Color3.fromRGB(60,40,90)
        UIGradientStroke.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,theme.primary),
            ColorSequenceKeypoint.new(0.5,theme.secondary),
            ColorSequenceKeypoint.new(1,theme.primary),
        })
    end
end

