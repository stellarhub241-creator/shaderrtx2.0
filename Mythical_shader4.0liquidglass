-- ================================================================
-- SECTION 21: BORDER SYSTEM (clean)
-- ================================================================
local UIStroke=Instance.new("UIStroke",MainFrame)
UIStroke.Thickness=1.8; UIStroke.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
local UIGradientStroke=Instance.new("UIGradient",UIStroke)

local BORDER_STYLES={
    {id="none",     label="◻ None"},
    {id="solid",    label="▣ Solid"},
    {id="gradient", label="◈ Gradient"},
    {id="neon",     label="✦ Neon"},
    {id="glow",     label="◉ Glow"},
    {id="shimmer",  label="◇ Shimmer"},
}

local _borderConn=nil
local function applyBorderStyle(styleId,color)
    State.borderStyle=styleId
    if color then State.borderColor=color end
    local c=State.borderColor
    if _borderConn then pcall(function() _borderConn:Disconnect() end); _borderConn=nil end
    UIStroke.Enabled=true

    if styleId=="none" then
        UIStroke.Enabled=false

    elseif styleId=="solid" then
        UIStroke.Thickness=2.0
        UIGradientStroke.Color=ColorSequence.new(c)
        UIGradientStroke.Transparency=NumberSequence.new(0)
        UIGradientStroke.Rotation=0

    elseif styleId=="gradient" then
        UIStroke.Thickness=1.8
        UIGradientStroke.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,Color3.fromRGB(200,180,240)),
            ColorSequenceKeypoint.new(0.33,c),
            ColorSequenceKeypoint.new(0.66,Color3.fromRGB(0,190,230)),
            ColorSequenceKeypoint.new(1,Color3.fromRGB(200,180,240)),
        })
        UIGradientStroke.Transparency=NumberSequence.new({
            NumberSequenceKeypoint.new(0,0.42); NumberSequenceKeypoint.new(0.5,0.06); NumberSequenceKeypoint.new(1,0.42)
        })

    elseif styleId=="neon" then
        UIStroke.Thickness=3.0
        _borderConn=RunService.RenderStepped:Connect(function()
            local t=tick(); local h=((t*30)%360)/360
            local col=Color3.fromHSV(h,0.92,1); local col2=Color3.fromHSV((h+0.33)%1,0.92,1)
            pcall(function()
                UIGradientStroke.Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,c),
                    ColorSequenceKeypoint.new(0.5,col),
                    ColorSequenceKeypoint.new(1,col2),
                })
                UIGradientStroke.Rotation=(t*50)%360
                UIGradientStroke.Transparency=NumberSequence.new(0.1+math.abs(math.sin(t*3))*0.18)
            end)
        end)

    elseif styleId=="glow" then
        UIStroke.Thickness=2.8
        UIGradientStroke.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),
            ColorSequenceKeypoint.new(0.5,c),
            ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255)),
        })
        UIGradientStroke.Transparency=NumberSequence.new({
            NumberSequenceKeypoint.new(0,0.55); NumberSequenceKeypoint.new(0.5,0.0); NumberSequenceKeypoint.new(1,0.55)
        })
        _borderConn=RunService.RenderStepped:Connect(function()
            pcall(function() UIGradientStroke.Rotation=(tick()*12)%360 end)
        end)

    elseif styleId=="shimmer" then
        UIStroke.Thickness=2.2
        _borderConn=RunService.RenderStepped:Connect(function()
            local t=tick()
            local offset=math.clamp(StellarEngineA:pulse(t,0.55)+0.01,0.01,0.99)
            pcall(function()
                UIGradientStroke.Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),
                    ColorSequenceKeypoint.new(offset,c),
                    ColorSequenceKeypoint.new(1,Color3.fromRGB(220,220,255)),
                })
                UIGradientStroke.Rotation=(t*18)%360
                UIGradientStroke.Transparency=NumberSequence.new(0.05)
            end)
        end)
    end
end

