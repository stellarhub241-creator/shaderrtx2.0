local FPS_MIN,FPS_MAX,sliderDrag=10,120,false
local function setFpsCap(fps)
    targetFpsCap=math.clamp(math.round(fps),FPS_MIN,FPS_MAX)
    local t=(targetFpsCap-FPS_MIN)/(FPS_MAX-FPS_MIN)
    pcall(function()
        TweenService:Create(SliderFill,TweenInfo.new(0.14,Enum.EasingStyle.Quad),{Size=UDim2.new(t,0,1,0)}):Play()
        TweenService:Create(SliderKnob,TweenInfo.new(0.14,Enum.EasingStyle.Quad),{Position=UDim2.new(t,-8,0.5,-8)}):Play()
    end)
    FPSValueLabel.Text="Cap: "..targetFpsCap.." FPS"
    pcall(function() if setfpscap then setfpscap(targetFpsCap) end end)
end

SliderKnob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sliderDrag=true i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then sliderDrag=false end end) end end)
SliderTrack.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sliderDrag=true i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then sliderDrag=false end end) end end)
UserInputService.InputChanged:Connect(function(i)
    if sliderDrag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local rel=math.clamp((i.Position.X-SliderTrack.AbsolutePosition.X)/SliderTrack.AbsoluteSize.X,0,1)
        setFpsCap(FPS_MIN+rel*(FPS_MAX-FPS_MIN))
    end
end)

