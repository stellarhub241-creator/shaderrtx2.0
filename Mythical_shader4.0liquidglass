    {BY+76, "Brightness/Exposure",       BY+91,  Color3.fromRGB(255,195,80), Color3.fromRGB(255,250,190),0.45, function(r) Lighting.ExposureCompensation=lerpN(-2,1,r) end},
    {BY+114,"Shadow Softness",           BY+129, Color3.fromRGB(130,130,130),Color3.fromRGB(210,210,210),0.65, function(r) Lighting.ShadowSoftness=r end},
    {BY+152,"Saturation",                BY+167, Color3.fromRGB(100,220,180),Color3.fromRGB(180,255,235),0.4,  function(r) ColorCorrection.Saturation=lerpN(-1,1,r) end},
    {BY+190,"Bloom Intensity",           BY+205, Color3.fromRGB(255,240,80), Color3.fromRGB(255,255,190),0.08, function(r) Bloom.Intensity=r*2 end},
    {BY+228,"Atmosphere Haze",           BY+243, Color3.fromRGB(140,175,220),Color3.fromRGB(195,218,255),0.3,  function(r) Atmosphere.Haze=r*5 end},
    -- [v4.9.2] Fog sliders
