for i,def in ipairs(TAB_DEFS) do
    local Btn=Instance.new("TextButton",Sidebar)
    Btn.Size=UDim2.new(1,-8,0,BTN_H) Btn.Position=UDim2.new(0,4,0,(i-1)*BTN_GAP+6)
    Btn.BackgroundColor3=Color3.fromRGB(18,14,28) Btn.BackgroundTransparency=0.45
    Btn.Text=def.icon.." "..def.text Btn.TextColor3=Color3.fromRGB(160,160,175)
    Btn.Font=Enum.Font.SourceSansBold Btn.TextSize=10
    Instance.new("UICorner",Btn).CornerRadius=UDim.new(0,7)
    local bs=Instance.new("UIStroke",Btn)
    bs.Thickness=1 bs.Color=Color3.fromRGB(55,40,80) bs.Transparency=0.5
    spring(Btn)
    table.insert(tabButtons,{btn=Btn,tab=def.tab})
end
Sidebar.CanvasSize=UDim2.new(0,0,0,#TAB_DEFS*BTN_GAP+20)

local function refreshTabButtons()
    local theme=COLOR_THEMES[currentThemeIndex]
    for _,bd in pairs(tabButtons) do
        local s=bd.btn:FindFirstChildOfClass("UIStroke")
        if bd.tab==activeTab then
            if theme.glass then
                bd.btn.BackgroundColor3=Color3.fromRGB(160,210,240)
                bd.btn.BackgroundTransparency=0.62
                bd.btn.TextColor3=Color3.fromRGB(200,240,255)
                if s then s.Color=Color3.fromRGB(180,225,255) s.Transparency=0.2 end
            else
                bd.btn.BackgroundColor3=theme.primary
                bd.btn.BackgroundTransparency=0.15
                bd.btn.TextColor3=Color3.fromRGB(255,255,255)
                if s then s.Color=theme.secondary s.Transparency=0.3 end
            end
        else
            bd.btn.BackgroundColor3=Color3.fromRGB(18,14,28)
            bd.btn.BackgroundTransparency=0.45
            bd.btn.TextColor3=Color3.fromRGB(160,160,175)
            if s then s.Color=Color3.fromRGB(55,40,80) s.Transparency=0.5 end
        end
    end
end

local function switchTab(targetTab)
    if activeTab==targetTab then return end
    if activeTab then
        local old=activeTab
        pcall(function()
            TweenService:Create(old,TweenInfo.new(0.16,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Position=UDim2.new(-0.12,0,0,0)}):Play()
        end)
        task.delay(0.1,function() if old then old.Visible=false old.Position=UDim2.new(0,0,0,0) end end)
    end
    activeTab=targetTab
    refreshTabButtons()
    targetTab.Position=UDim2.new(0.12,0,0,0)
    targetTab.Visible=true
    pcall(function()
        TweenService:Create(targetTab,TweenInfo.new(0.26,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(0,0,0,0)}):Play()
    end)
end

for _,bd in pairs(tabButtons) do
    bd.btn.MouseButton1Click:Connect(function() switchTab(bd.tab) end)
end
switchTab(TabGfx)

-- ================================================================
-- SECTION 19: DRAG
-- [FIX] ลาก MainFrame ไม่ทำให้ cinema slider เลื่อน
--       ใช้ isDraggingMainFrame guard
-- ================================================================
local dragToggle,dragStart,startPos,isDragging=false,nil,nil,false
local isDraggingMainFrame=false  -- [FIX] guard ป้องกัน slider เลื่อนตาม

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        dragToggle=true dragStart=input.Position startPos=MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then
                dragToggle=false isDragging=false isDraggingMainFrame=false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not dragToggle then return end
    if input.UserInputType~=Enum.UserInputType.MouseMovement and input.UserInputType~=Enum.UserInputType.Touch then return end
    local delta=input.Position-dragStart
    if not isDragging and (math.abs(delta.X)>4 or math.abs(delta.Y)>4) then
        isDragging=true isDraggingMainFrame=true
    end
    if isDragging then
        local vp=workspace.CurrentCamera.ViewportSize
        local fw=MainFrame.Size.X.Offset local fh=MainFrame.Size.Y.Offset
        MainFrame.Position=UDim2.new(0,math.clamp(startPos.X.Offset+delta.X,6,vp.X-fw-6),0,math.clamp(startPos.Y.Offset+delta.Y,6,vp.Y-fh-6))
    end
end)

