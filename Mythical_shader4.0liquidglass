local function applySkyPreset(preset)
    pcall(function() skyGuardConn:Disconnect() end)
    pcall(function() 
        for _, child in ipairs(Lighting:GetChildren()) do 
            if child:IsA("Sky") then child:Destroy() end 
        end 
    end) 
    task.wait(0.05)
    
    local sky = Instance.new("Sky", Lighting) 
    sky.Name = "StellarSky"
    
    pcall(function() 
        sky.SkyboxBk = preset.bk 
        sky.SkyboxDn = preset.dn 
        sky.SkyboxFt = preset.ft 
        sky.SkyboxLf = preset.lf 
        sky.SkyboxRt = preset.rt 
        sky.SkyboxUp = preset.up 
        sky.StarCount = preset.star 
        sky.CelestialBodiesShown = true 
        if preset.moonSize then sky.MoonAngularSize = preset.moonSize end 
        if not State.heavenlyEnabled then Lighting.ClockTime = preset.time end 
        if preset.brightness then Lighting.Brightness = preset.brightness end 
        if preset.ambient then Lighting.OutdoorAmbient = preset.ambient end 
    end)
    connectSkyGuard()
end

local function makeSkyBtn(parent, text, y)
    local b = Instance.new("TextButton", parent) 
    b.Size = UDim2.new(1, -16, 0, 28) 
    b.Position = UDim2.new(0, 8, 0, y) 
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 50) 
    b.BackgroundTransparency = 0.4 
    b.Text = text 
    b.TextColor3 = Color3.fromRGB(220, 220, 255) 
    b.Font = Enum.Font.SourceSans 
    b.TextSize = 12 
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 7) 
    local sk = Instance.new("UIStroke", b) 
    sk.Color = Color3.fromRGB(100, 120, 200) 
    sk.Thickness = 1 
    spring(b) 
    return b
end

