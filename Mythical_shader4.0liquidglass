local function applyProfile(p)
    if isFpsBoostOn or horrorFogEnabled or rainEnabled or heavenlyEnabled then return end
    Lighting.Brightness            = p.brightness
    Lighting.ExposureCompensation  = p.exposure
    Lighting.ShadowSoftness        = p.shadow
    Lighting.OutdoorAmbient        = p.ambient
    Atmosphere.Color               = p.atmoColor
    Atmosphere.Decay               = p.atmoDecay
    Atmosphere.Glare               = p.atmoGlare
    Atmosphere.Haze                = p.atmoHaze
    Atmosphere.Density             = p.atmoDensity
    ColorCorrection.Contrast       = p.contrast
    ColorCorrection.Saturation     = p.saturation
    ColorCorrection.TintColor      = p.tint
    Bloom.Intensity                = p.bloom
    Bloom.Size                     = p.bloomSize
    Bloom.Threshold                = p.bloomThreshold
    DOF.FarIntensity               = p.dofFar
    SunRays.Intensity              = p.sunRays
end

local function lerpN(a,b,t) return a+(b-a)*t end
local function lerpC(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end
local function lerpProfile(a,b,t)
    return {
        brightness=lerpN(a.brightness,b.brightness,t), exposure=lerpN(a.exposure,b.exposure,t),
        shadow=lerpN(a.shadow,b.shadow,t), ambient=lerpC(a.ambient,b.ambient,t),
        atmoColor=lerpC(a.atmoColor,b.atmoColor,t), atmoDecay=lerpC(a.atmoDecay,b.atmoDecay,t),
        atmoGlare=lerpN(a.atmoGlare,b.atmoGlare,t), atmoHaze=lerpN(a.atmoHaze,b.atmoHaze,t),
        atmoDensity=lerpN(a.atmoDensity,b.atmoDensity,t), contrast=lerpN(a.contrast,b.contrast,t),
        saturation=lerpN(a.saturation,b.saturation,t), tint=lerpC(a.tint,b.tint,t),
        bloom=lerpN(a.bloom,b.bloom,t), bloomSize=lerpN(a.bloomSize,b.bloomSize,t),
        bloomThreshold=lerpN(a.bloomThreshold,b.bloomThreshold,t),
        dofFar=lerpN(a.dofFar,b.dofFar,t), sunRays=lerpN(a.sunRays,b.sunRays,t),
    }
end

-- ==================== RAIN PARTICLE SYSTEM ====================
local rainFolder = nil
local rainConnections = {}

local function clearRainParticles()
    for _, c in pairs(rainConnections) do pcall(function() c:Disconnect() end) end
    rainConnections = {}
    if rainFolder and rainFolder.Parent then rainFolder:Destroy() end
    rainFolder = nil
end

local function createRainParticles()
    clearRainParticles()
    rainFolder = Instance.new("Folder", workspace)
    rainFolder.Name = "StellarRain"
    local camera = workspace.CurrentCamera
    local RAIN_COUNT = 80
    local parts = {}
    for i = 1, RAIN_COUNT do
        local p = Instance.new("Part")
        p.Name             = "RainDrop"..i
        p.Size             = Vector3.new(0.04, math.random(8,18)*0.1, 0.04)
        p.Material         = Enum.Material.Neon
        p.Color            = Color3.fromRGB(math.random(160,200), math.random(200,230), 255)
        p.Transparency     = math.random(55,80)/100
        p.CastShadow       = false
        p.Anchored         = true
        p.CanCollide       = false
        p.Parent           = rainFolder
        table.insert(parts, p)
    end
    local RIPPLE_COUNT = 12
    local ripples = {}
    for i = 1, RIPPLE_COUNT do
        local r = Instance.new("Part")
        r.Name         = "Ripple"..i
        r.Size         = Vector3.new(0.5, 0.05, 0.5)
        r.Material     = Enum.Material.Neon
        r.Color        = Color3.fromRGB(180,210,255)
        r.Transparency = 0.85
        r.CastShadow   = false
        r.Anchored     = true
        r.CanCollide   = false
        r.Shape        = Enum.PartType.Cylinder
        r.Parent       = rainFolder
        table.insert(ripples, r)
    end
    local conn = RunService.RenderStepped:Connect(function(dt)
        if not rainFolder or not rainFolder.Parent then return end
        local camPos = camera.CFrame.Position
        for i, p in ipairs(parts) do
            if not p.Parent then continue end
            local spread = 30
            local x = camPos.X + math.sin(i*1.3)*spread + math.sin(tick()*0.3+i)*3
            local y = camPos.Y + 18 - ((tick()*14 + i*2.1) % 28)
            local z = camPos.Z + math.cos(i*1.7)*spread + math.cos(tick()*0.25+i)*3
            p.CFrame = CFrame.new(x, y, z) * CFrame.Angles(0.1, 0, 0)
        end
        for i, r in ipairs(ripples) do
            if not r.Parent then continue end
            local t = (tick()*0.8 + i*0.9) % 1
            local scale = 0.4 + t*2.5
            local alpha = 1 - t
            local rx = camPos.X + math.sin(i*2.1)*20
            local rz = camPos.Z + math.cos(i*1.9)*20
            local ray = workspace:Raycast(Vector3.new(rx, camPos.Y+5, rz), Vector3.new(0,-30,0))
            local ry = ray and ray.Position.Y + 0.05 or camPos.Y - 8
            r.CFrame = CFrame.new(rx, ry, rz) * CFrame.Angles(0, 0, math.pi/2)
            r.Size = Vector3.new(0.05, scale, scale)
            r.Transparency = 0.7 + alpha*0.25
            r.Color = Color3.fromRGB(
                math.floor(lerpN(160,200,alpha)),
                math.floor(lerpN(190,225,alpha)),
                255
            )
        end
    end)
    table.insert(rainConnections, conn)
end

-- ==================== MODE RESET HELPER ====================
local function resetFogLighting()
    Lighting.FogStart  = originalFogStart
    Lighting.FogEnd    = originalFogEnd
    Lighting.FogColor  = originalFogColor
    Lighting.Ambient   = originalAmbient
end

local ModeText       = "Status: Loading..."
local BorderColorNow = Color3.fromRGB(180,0,255)
local rainbowHue     = 0

task.spawn(function()
    while task.wait(0.2) do
        if not horrorFogEnabled and not rainEnabled and not heavenlyEnabled then
            local t = Lighting.ClockTime
            if t >= 5 and t < 6 then
                applyProfile(lerpProfile(PROFILES.NIGHT,PROFILES.DAWN,(t-5)/1))
                ModeText = "Status: Dawn"         BorderColorNow = Color3.fromRGB(255,180,200)
            elseif t >= 6 and t < 15 then
                applyProfile(PROFILES.DAY)
                ModeText = "Status: Day"          BorderColorNow = Color3.fromRGB(255,220,100)
            elseif t >= 15 and t < 19 then
                applyProfile(lerpProfile(PROFILES.DAY,PROFILES.GOLDEN,(t-15)/4))
                ModeText = "Status: Golden Hour"  BorderColorNow = Color3.fromRGB(255,160,80)
            elseif t >= 19 and t < 21 then
                applyProfile(lerpProfile(PROFILES.GOLDEN,PROFILES.NIGHT,(t-19)/2))
                ModeText = "Status: Sunset"       BorderColorNow = Color3.fromRGB(150,180,255)
            else
                applyProfile(PROFILES.NIGHT)
                ModeText = "Status: Night"        BorderColorNow = Color3.fromRGB(100,180,255)
            end
        end
    end
end)

local function applyPBROnPart(v)
    if not pbrEnabled or isFpsBoostOn then return end
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.CastShadow = true
        local m = v.Material
        local r = 0
        if m == Enum.Material.Concrete then r = 0.15
        elseif m == Enum.Material.SmoothPlastic then r = 0.35
        elseif m == Enum.Material.Cobblestone then r = 0.08
        elseif m == Enum.Material.Wood or m == Enum.Material.WoodPlanks then r = 0.03
        elseif m == Enum.Material.Marble then r = 0.55
        elseif m == Enum.Material.Granite then r = 0.3
        elseif m == Enum.Material.Metal or m == Enum.Material.DiamondPlate then r = 0.65
        elseif m == Enum.Material.Glass then r = 0.8
        elseif m == Enum.Material.Neon then r = 0.85
        elseif m == Enum.Material.Ice then r = 0.7
        elseif m == Enum.Material.Sand then r = 0.02
        elseif m == Enum.Material.Grass then r = 0.0
        end
        if antiBlueGloss then
            local c   = v.Color
            local lum = (c.R*0.299)+(c.G*0.587)+(c.B*0.114)
            v.Reflectance = lum < 0.18 and r*(lum*3.5) or r
        else
            v.Reflectance = r
        end
    end
end

local function runPBRScan()
    local count = 0
    for _, v in pairs(workspace:GetDescendants()) do
        applyPBROnPart(v)
        count = count + 1
        if count % 200 == 0 then task.wait() end
    end
end
task.spawn(runPBRScan)
workspace.DescendantAdded:Connect(function(v)
    task.delay(0.1, function() applyPBROnPart(v) end)
end)

