    DAWN     = {brightness=1.6, exposure=0.15, shadow=0.2,  ambient=Color3.fromRGB(50,35,55),    atmoColor=Color3.fromRGB(180,120,160), atmoDecay=Color3.fromRGB(80,40,80),    atmoGlare=1.0, atmoHaze=1.8, atmoDensity=0.3,  contrast=0.25, saturation=0.4,  tint=Color3.fromRGB(255,210,220), bloom=0.5, bloomSize=18,bloomThreshold=0.7, dofFar=0.3, sunRays=0.2},
    GOLDEN   = {brightness=2.2, exposure=0.2,  shadow=0.2,  ambient=Color3.fromRGB(80,50,30),    atmoColor=Color3.fromRGB(255,130,50),  atmoDecay=Color3.fromRGB(150,60,10),   atmoGlare=2.0, atmoHaze=2.0, atmoDensity=0.35, contrast=0.35, saturation=0.7,  tint=Color3.fromRGB(255,200,130), bloom=0.5, bloomSize=18,bloomThreshold=0.65,dofFar=0.4, sunRays=0.45},
    RAIN     = {brightness=0.7, exposure=-0.1, shadow=0.5,  ambient=Color3.fromRGB(38,43,55),    atmoColor=Color3.fromRGB(110,125,150), atmoDecay=Color3.fromRGB(55,62,78),    atmoGlare=0.1, atmoHaze=2.8, atmoDensity=0.45, contrast=0.08, saturation=-0.15,tint=Color3.fromRGB(190,208,232), bloom=0.3, bloomSize=12,bloomThreshold=0.9, dofFar=0.4, sunRays=0.0},
    HEAVENLY = {brightness=2.5, exposure=0.22, shadow=0.1,  ambient=Color3.fromRGB(180,190,240), atmoColor=Color3.fromRGB(210,228,255), atmoDecay=Color3.fromRGB(170,195,248), atmoGlare=2.2, atmoHaze=0.6, atmoDensity=0.08, contrast=0.1,  saturation=0.5,  tint=Color3.fromRGB(255,248,228), bloom=1.2, bloomSize=28,bloomThreshold=0.45,dofFar=0.05,sunRays=0.6},

    -- [FIX 5] Horror เพิ่ม atmosphere ใหม่ สีเขียวเลือด + fog หนัก + bloom เขียว
    HORROR_G = {brightness=0.28,exposure=-0.45,shadow=0.95, ambient=Color3.fromRGB(5,18,3),      atmoColor=Color3.fromRGB(12,40,8),     atmoDecay=Color3.fromRGB(3,12,2),      atmoGlare=0.0, atmoHaze=5.5, atmoDensity=0.70, contrast=0.72, saturation=-0.45,tint=Color3.fromRGB(70,130,55),   bloom=0.55,bloomSize=28,bloomThreshold=0.55,dofFar=0.8, sunRays=0.0},

    -- [FIX 5] Horror Blue น้ำเงินลึก เย็นชา ไม่มีอะไร
    HORROR_B = {brightness=0.22,exposure=-0.6, shadow=0.99, ambient=Color3.fromRGB(2,3,25),      atmoColor=Color3.fromRGB(4,5,35),      atmoDecay=Color3.fromRGB(1,2,18),      atmoGlare=0.0, atmoHaze=6.0, atmoDensity=0.78, contrast=0.82, saturation=-0.88,tint=Color3.fromRGB(40,50,180),   bloom=0.35,bloomSize=40,bloomThreshold=0.72,dofFar=0.9, sunRays=0.0},

    -- Nostalgia 2016 Tumblr aesthetic
    NOSTALGIA= {brightness=1.45,exposure=0.18, shadow=0.38, ambient=Color3.fromRGB(120,80,145),  atmoColor=Color3.fromRGB(230,175,215), atmoDecay=Color3.fromRGB(175,115,195), atmoGlare=1.2, atmoHaze=2.8, atmoDensity=0.38, contrast=0.18, saturation=0.22, tint=Color3.fromRGB(255,220,235), bloom=0.65,bloomSize=20,bloomThreshold=0.68,dofFar=0.22,sunRays=0.28},
}

local function applyLighting(p)
    pcall(function()
        Lighting.Brightness=p.brightness; Lighting.ExposureCompensation=p.exposure
        Lighting.ShadowSoftness=p.shadow; Lighting.OutdoorAmbient=p.ambient
        Atmosphere.Color=p.atmoColor; Atmosphere.Decay=p.atmoDecay
        Atmosphere.Glare=p.atmoGlare; Atmosphere.Haze=p.atmoHaze; Atmosphere.Density=p.atmoDensity
        ColorCorrection.Contrast=p.contrast; ColorCorrection.Saturation=p.saturation; ColorCorrection.TintColor=p.tint
        Bloom.Intensity=p.bloom; Bloom.Size=p.bloomSize; Bloom.Threshold=p.bloomThreshold
        DOF.FarIntensity=p.dofFar; SunRays.Intensity=p.sunRays
    end)
end

local function applyCinematicBlend()
    if not State.cinematicEnabled then return end
    pcall(function()
        ColorCorrection.Contrast=math.max(ColorCorrection.Contrast,0.6)
        ColorCorrection.Saturation=ColorCorrection.Saturation-0.1
        DOF.FarIntensity=math.max(DOF.FarIntensity,0.55)
        Bloom.Threshold=math.min(Bloom.Threshold+0.08,0.99)
        Lighting.ShadowSoftness=math.max(Lighting.ShadowSoftness,0.65)
    end)
end

local function resetFogLighting()
    pcall(function()
        if not State.nostalgiaEnabled then
            Lighting.FogStart=State.originalFogStart; Lighting.FogEnd=State.originalFogEnd
            Lighting.FogColor=State.originalFogColor; Lighting.Ambient=State.originalAmbient
            Lighting.Brightness=State.originalBrightness; Lighting.ExposureCompensation=State.originalExposure
            Lighting.ShadowSoftness=State.originalShadow; Lighting.OutdoorAmbient=State.originalOutdoor
        end
    end)
end

local function reapplyActiveMode()
    if State.nostalgiaEnabled then
        applyLighting(PROFILES.NOSTALGIA)
        pcall(function()
            Lighting.ClockTime=17.2; Lighting.FogStart=180; Lighting.FogEnd=2200
            Lighting.FogColor=Color3.fromRGB(210,160,225); Lighting.Ambient=Color3.fromRGB(120,80,145)
        end)
    elseif State.horrorBlue then
        -- [FIX 7] อิสระ ไม่ต้องรอ fog
        applyLighting(PROFILES.HORROR_B)
        pcall(function()
            Lighting.FogStart=2; Lighting.FogEnd=45
            Lighting.FogColor=Color3.fromRGB(2,3,22); Lighting.Ambient=Color3.fromRGB(2,3,22)
        end)
    elseif State.horrorFogEnabled then
        applyLighting(PROFILES.HORROR_G)
        -- [FIX 5] เพิ่ม blood-green fog effect
        pcall(function()
            Lighting.FogStart=3; Lighting.FogEnd=60
            Lighting.FogColor=Color3.fromRGB(5,20,3); Lighting.Ambient=Color3.fromRGB(5,20,3)
        end)
    elseif State.dawnEnabled then
        applyLighting(PROFILES.DAWN); pcall(function() Lighting.ClockTime=5.5 end)
    elseif State.sunsetEnabled then
        applyLighting(PROFILES.GOLDEN); pcall(function() Lighting.ClockTime=19 end)
    elseif State.rainEnabled then
        applyLighting(PROFILES.RAIN)
        pcall(function() Lighting.FogStart=20; Lighting.FogEnd=200; Lighting.FogColor=Color3.fromRGB(110,122,142) end)
    elseif State.heavenlyEnabled then
        applyLighting(PROFILES.HEAVENLY)
        pcall(function() Lighting.FogStart=500; Lighting.FogEnd=2000; Lighting.FogColor=Color3.fromRGB(225,235,255); Lighting.ClockTime=12 end)
    else
        resetFogLighting()
    end
    applyCinematicBlend()
end

-- ================================================================
-- SECTION 9: RAIN SYSTEM
-- ================================================================
local rainFolder=nil; local rainConns={}; local rainParts={}; local rainRipples={}

local function clearRainParticles()
    for _,c in pairs(rainConns) do pcall(function() c:Disconnect() end) end
    rainConns={}
    if rainFolder and rainFolder.Parent then pcall(function() rainFolder:Destroy() end) end
    rainFolder=nil; rainParts={}; rainRipples={}
end

local function createRainParticles()
    clearRainParticles()
    rainFolder=Instance.new("Folder",workspace); rainFolder.Name="StellarRain"
    local cam=workspace.CurrentCamera
    local count=math.clamp(State.rainParticleCount,10,150)
    for i=1,count do
        local p=Instance.new("Part"); p.Size=Vector3.new(0.045,math.random(18,30)*0.1,0.045)
        p.Material=Enum.Material.Glass; p.Reflectance=math.random(70,90)/100
        p.Color=Color3.fromRGB(math.random(200,230),math.random(225,245),255)
        p.Transparency=math.random(55,72)/100; p.CastShadow=false; p.Anchored=true; p.CanCollide=false
        p.Parent=rainFolder; table.insert(rainParts,p)
    end
    local rippleCount=math.max(6,math.floor(count*0.18))
    for i=1,rippleCount do
        local r=Instance.new("Part"); r.Size=Vector3.new(0.1,0.05,0.1); r.Material=Enum.Material.Glass
        r.Reflectance=0.7; r.Color=Color3.fromRGB(180,215,255); r.Transparency=0.82
        r.CastShadow=false; r.Anchored=true; r.CanCollide=false; r.Shape=Enum.PartType.Cylinder
        r.Parent=rainFolder; table.insert(rainRipples,r)
    end
    local frame=0
    local conn=RunService.Heartbeat:Connect(function()
        frame=frame+1; if frame%2~=0 then return end
        if not rainFolder or not rainFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()
        for i,p in ipairs(rainParts) do
            if p and p.Parent then
                local ph=i*0.73; local fall=(t*16+ph*2.8)%32
                pcall(function()
                    p.Reflectance=0.65+math.sin(t*3+ph)*0.25
                    p.CFrame=CFrame.new(cp.X+math.sin(ph)*34,cp.Y+20-fall,cp.Z+math.cos(ph)*34)*CFrame.Angles(0.18,0,0.06)
                end)
            end
        end
        for i,r in ipairs(rainRipples) do
            if r and r.Parent then
                pcall(function()
                    local rt=(t*0.7+i*0.65)%1; local sc=0.3+rt*3.5; local ph=i*1.13
                    local rx=cp.X+math.sin(ph)*22; local rz=cp.Z+math.cos(ph)*22
                    local ray=workspace:Raycast(Vector3.new(rx,cp.Y+8,rz),Vector3.new(0,-50,0))
                    local ry=ray and ray.Position.Y+0.05 or cp.Y-8
                    r.CFrame=CFrame.new(rx,ry,rz)*CFrame.Angles(0,0,math.pi/2)
                    r.Size=Vector3.new(0.05,sc,sc); r.Transparency=0.65+(1-rt)*0.28
                    r.Reflectance=0.6+math.sin(t*2+i)*0.3
                    r.Color=Color3.fromRGB(math.floor(lerpN(150,210,1-rt)),math.floor(lerpN(190,235,1-rt)),255)
                end)
            end
        end
    end)
    table.insert(rainConns,conn)
end

-- ================================================================
-- SECTION 10: [FIX 1] SAKURA — Part-based ตกจริง เห็นจริง
-- ================================================================
local sakuraFolder=nil; local sakuraConns={}; local sakuraParts={}

local function clearSakura()
    for _,c in pairs(sakuraConns) do pcall(function() c:Disconnect() end) end
    sakuraConns={}
    if sakuraFolder and sakuraFolder.Parent then pcall(function() sakuraFolder:Destroy() end) end
    sakuraFolder=nil; sakuraParts={}
end

local function createSakura()
    clearSakura()
    sakuraFolder=Instance.new("Folder",workspace); sakuraFolder.Name="StellarSakura"
    local cam=workspace.CurrentCamera
    local count=math.clamp(State.sakuraCount,8,80)

    -- [FIX 1] ใช้ Part + BillboardGui แทน ParticleEmitter
    -- ทำให้เห็นจากทุกมุม + ควบคุม physics ได้เอง
    for i=1,count do
        local p=Instance.new("Part",sakuraFolder)
        p.Size=Vector3.new(0.5,0.5,0.5)
        p.Shape=Enum.PartType.Ball
        p.Material=Enum.Material.SmoothPlastic
        p.Transparency=1   -- Part โปร่งใส เอา billboard แสดงแทน
        p.CastShadow=false; p.Anchored=true; p.CanCollide=false

        -- BillboardGui แสดงกลีบดอก
        local bb=Instance.new("BillboardGui",p)
        bb.Size=UDim2.new(0,math.random(14,22),0,math.random(14,22))
        bb.AlwaysOnTop=false; bb.LightInfluence=0.6; bb.MaxDistance=200

        local img=Instance.new("ImageLabel",bb)
        img.Size=UDim2.new(1,0,1,0); img.BackgroundTransparency=1
        -- Roblox default circle shape ใช้แทน sakura texture
        img.Image="rbxassetid://13214811345"
        local r=math.random(235,255); local g=math.random(165,210)
        img.ImageColor3=Color3.fromRGB(r,g,math.random(185,220))
        img.ImageTransparency=math.random(0,20)/100

        -- Physics state ต่อ particle
        local cp=cam.CFrame.Position
        table.insert(sakuraParts,{
            part=p, img=img,
            x=cp.X+math.random(-30,30),
            y=cp.Y+math.random(5,25),
            z=cp.Z+math.random(-30,30),
            vy=math.random(20,50)*0.01,   -- velocity Y (negative = ตก)
            vx=math.random(-15,15)*0.01,  -- drift X
            vz=math.random(-15,15)*0.01,  -- drift Z
            rot=math.random(0,360),
            rotSpeed=math.random(-90,90),
            sway=math.random()*math.pi*2,
            swaySpeed=math.random()*2+0.5,
            life=math.random()*8,
            maxLife=math.random(6,12),
            size=math.random(14,22),
        })
    end

    local conn=RunService.Heartbeat:Connect(function(dt)
        if not sakuraFolder or not sakuraFolder.Parent then return end
        local cp=cam.CFrame.Position
        local t=tick()

        for _,s in ipairs(sakuraParts) do
            if s.part and s.part.Parent then
                s.life=s.life+dt

                -- reset เมื่อตกเกินหรือหมดอายุ
                if s.life>s.maxLife or s.y<cp.Y-30 then
                    s.x=cp.X+math.random(-35,35)
                    s.y=cp.Y+math.random(15,30)
                    s.z=cp.Z+math.random(-35,35)
                    s.vy=math.random(20,50)*0.01
                    s.vx=math.random(-15,15)*0.01
                    s.vz=math.random(-15,15)*0.01
                    s.life=0
                    s.maxLife=math.random(6,12)
                end

                -- [StellarEngine] ใช้ smoothNoise สำหรับ sway
                local swayX=StellarEngine.smoothNoise(t*s.swaySpeed+s.sway, 0, 0)*0.8
                local swayZ=StellarEngine.smoothNoise(0, t*s.swaySpeed+s.sway, 0)*0.8

                s.x=s.x+s.vx*dt*60+swayX*dt
                s.z=s.z+s.vz*dt*60+swayZ*dt
                s.y=s.y-s.vy*dt*60  -- ตกลง
                s.rot=s.rot+s.rotSpeed*dt

                -- fade in/out ตาม life
                local lifeRatio=s.life/s.maxLife
                local alpha
                if lifeRatio<0.15 then
                    alpha=lifeRatio/0.15
                elseif lifeRatio>0.75 then
                    alpha=(1-lifeRatio)/0.25
                else
                    alpha=1
                end

                pcall(function()
                    s.part.CFrame=CFrame.new(s.x,s.y,s.z)*CFrame.Angles(0,math.rad(s.rot),0)
                    s.img.ImageTransparency=1-alpha*0.92
                end)
            end
        end
    end)
    table.insert(sakuraConns,conn)

    -- StellarAI watch sakura
    StellarAI:watch("sakura_folder",
        function() return sakuraFolder end,
        "SakuraFolder"
    )
end

-- ================================================================
-- SECTION 11: [FIX 3] WIND SYSTEM — ทำงานได้จริง
-- ================================================================
local windConns={}; local windParts={}

local function clearWind()
    for _,c in pairs(windConns) do pcall(function() c:Disconnect() end) end
    windConns={}
    -- restore original CFrame ก่อน
    for _,d in pairs(windParts) do
        pcall(function()
            if d.part and d.part.Parent then d.part.CFrame=d.origin end
        end)
    end
    windParts={}
end

local function startWind()
    clearWind()
    local cam=workspace.CurrentCamera
    local collected=0

    -- scan เฉพาะ part ที่เหมาะสม
    for _,v in ipairs(workspace:GetDescendants()) do
        if collected>=200 then break end  -- limit ป้องกัน lag
        local ok=pcall(function()
            if not (v:IsA("BasePart") or v:IsA("MeshPart")) then return end
            if not v.Anchored then return end
            local pn=v.Parent and v.Parent.Name or ""
            if pn=="StellarRain" or pn=="StellarSakura" or pn=="StellarMeteor" or pn=="StellarSun" then return end
            local sz=v.Size
            if sz.X>6 or sz.Z>6 or sz.Y>18 then return end
            if (v.Position-cam.CFrame.Position).Magnitude>120 then return end
            table.insert(windParts,{
                part=v,
                origin=v.CFrame:Clone() or v.CFrame,  -- ← เก็บ snapshot ณ เวลานั้น
                phase=math.random()*math.pi*2,
                freq=0.8+math.random()*1.2,
                amp=0.008+math.random()*0.022,
            })
            collected=collected+1
        end)
    end

    if #windParts==0 then
        -- ถ้าไม่เจอ part เลย log และออก
        StellarAI:log("[Wind] no eligible parts found in range")
        return
    end

    StellarAI:log("[Wind] started with "..#windParts.." parts")

    local conn=RunService.Heartbeat:Connect(function(dt)
        if not State.windEnabled then return end
        local t=tick()
        for _,d in pairs(windParts) do
            pcall(function()
                if d.part and d.part.Parent then
                    -- [StellarEngine] ใช้ bezier wave pattern แทน sin เดี่ยว
                    local wave=math.sin(t*d.freq+d.phase)*d.amp*State.windStrength
                    local wave2=StellarEngine.smoothNoise(t*d.freq*0.5,d.phase,0)*d.amp*State.windStrength*0.4
                    d.part.CFrame=d.origin*CFrame.Angles(wave,wave2*0.3,wave*0.6)
                end
            end)
        end
    end)
    table.insert(windConns,conn)
end

-- ================================================================
-- SECTION 12: [FIX 6] METEOR — particle texture ใหม่ trail สวย
-- ================================================================
local meteorFolder=nil; local meteorConns={}; local meteorRunning=false

local function clearMeteor()
    meteorRunning=false
    for _,c in pairs(meteorConns) do pcall(function() c:Disconnect() end) end
    meteorConns={}
    if meteorFolder and meteorFolder.Parent then pcall(function() meteorFolder:Destroy() end) end
    meteorFolder=nil
end

local function spawnOneMeteor()
    if not meteorFolder or not meteorFolder.Parent then return end
    local cam=workspace.CurrentCamera; local cp=cam.CFrame.Position
    local angle=math.random()*math.pi*2; local dist=math.random(500,800)
    local sx=cp.X+math.cos(angle)*dist; local sy=cp.Y+math.random(300,500); local sz=cp.Z+math.sin(angle)*dist
    local target=Vector3.new(cp.X+math.cos(angle+math.pi)*dist,cp.Y-math.random(50,100),cp.Z+math.sin(angle+math.pi)*dist)
    local dir=(target-Vector3.new(sx,sy,sz)).Unit; local speed=math.random(250,450); local len=math.random(50,120)

    -- Head
    local head=Instance.new("Part",meteorFolder); head.Size=Vector3.new(5,5,5); head.Material=Enum.Material.Neon
    head.Color=State.meteorColor; head.Transparency=0; head.CastShadow=false; head.Anchored=true; head.CanCollide=false
    Instance.new("SpecialMesh",head).MeshType=Enum.MeshType.Sphere

    local pLight=Instance.new("PointLight",head); pLight.Color=State.meteorColor; pLight.Range=300; pLight.Brightness=4; pLight.Shadows=true

    -- [FIX 6] Trail body gradient สีสวย
    local body=Instance.new("Part",meteorFolder); body.Size=Vector3.new(2.5,2.5,len); body.Material=Enum.Material.Neon
    body.Color=StellarEngine.lerpColorHSV(State.meteorColor,Color3.fromRGB(255,255,255),0.4)
    body.Transparency=0.15; body.CastShadow=false; body.Anchored=true; body.CanCollide=false

    local tail=Instance.new("Part",meteorFolder); tail.Size=Vector3.new(1.5,1.5,len*2.8); tail.Material=Enum.Material.Neon
    tail.Color=StellarEngine.lerpColorHSV(State.meteorColor,Color3.fromRGB(255,255,255),0.68)
    tail.Transparency=0.42; tail.CastShadow=false; tail.Anchored=true; tail.CanCollide=false

    local tail2=Instance.new("Part",meteorFolder); tail2.Size=Vector3.new(0.6,0.6,len*5.5); tail2.Material=Enum.Material.Neon
    tail2.Color=Color3.fromRGB(255,255,255); tail2.Transparency=0.75; tail2.CastShadow=false; tail2.Anchored=true; tail2.CanCollide=false

    local glow=Instance.new("Part",meteorFolder); glow.Size=Vector3.new(22,22,22); glow.Material=Enum.Material.Neon
    glow.Color=State.meteorColor; glow.Transparency=0.78; glow.CastShadow=false; glow.Anchored=true; glow.CanCollide=false
    Instance.new("SpecialMesh",glow).MeshType=Enum.MeshType.Sphere

    -- [FIX 6] Particle 1: sparks แตกออก — ใช้ texture ดาว
    local pe=Instance.new("ParticleEmitter",head)
    pe.Texture="rbxassetid://2273224484"  -- star particle
    pe.Rate=400; pe.Lifetime=NumberRange.new(0.15,0.6); pe.Speed=NumberRange.new(8,35)
    pe.SpreadAngle=Vector2.new(60,60)
    pe.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),
        ColorSequenceKeypoint.new(0.3,State.meteorColor),
        ColorSequenceKeypoint.new(0.7,Color3.fromRGB(255,200,80)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(255,100,0)),
    })
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,4.0),NumberSequenceKeypoint.new(0.4,2.0),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1; pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)})
    pe.EmissionDirection=Enum.NormalId.Back; pe.RotSpeed=NumberRange.new(-180,180); pe.Rotation=NumberRange.new(0,360)

    -- [FIX 6] Particle 2: ember trail ใช้ fire texture
    local pe2=Instance.new("ParticleEmitter",body)
    pe2.Texture="rbxassetid://6060542021"  -- ember/fire
    pe2.Rate=150; pe2.Lifetime=NumberRange.new(0.1,0.4); pe2.Speed=NumberRange.new(2,12)
    pe2.SpreadAngle=Vector2.new(25,25)
    pe2.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(255,220,100)),
        ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,120,20)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(180,50,0)),
    })
    pe2.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,2.0),NumberSequenceKeypoint.new(1,0)})
    pe2.LightEmission=0.8; pe2.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.1),NumberSequenceKeypoint.new(1,1)})
    pe2.EmissionDirection=Enum.NormalId.Back

    local life=0; local maxLife=5.5; local isFading=false

    -- [FIX 8] self-disconnect หลัง maxLife
    local meteorConn
    meteorConn=RunService.Heartbeat:Connect(function(dt)
        life=life+dt
        if life>=maxLife-0.5 and not isFading then
            isFading=true; pe.Enabled=false; pe2.Enabled=false
            pcall(function()
                TweenService:Create(glow,TweenInfo.new(0.2,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=Vector3.new(80,80,80),Transparency=0}):Play()
                TweenService:Create(pLight,TweenInfo.new(0.2),{Range=500,Brightness=8}):Play()
                TweenService:Create(head, TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(body, TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(tail, TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(tail2,TweenInfo.new(0.5),{Transparency=1}):Play()
            end)
        end
        if life>=maxLife then
            pcall(function() head:Destroy(); body:Destroy(); tail:Destroy(); tail2:Destroy(); glow:Destroy() end)
            pcall(function() meteorConn:Disconnect() end)  -- [FIX 8]
            return
        end
        local np=Vector3.new(sx,sy,sz)+dir*speed*life
        pcall(function()
            if not isFading then
                head.CFrame=CFrame.new(np)
                body.CFrame=CFrame.lookAt(np-dir*(len*0.5),np-dir*(len*0.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail.CFrame=CFrame.lookAt(np-dir*(len*1.5),np-dir*(len*1.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail2.CFrame=CFrame.lookAt(np-dir*(len*3.2),np-dir*(len*3.2)+dir)*CFrame.Angles(math.pi/2,0,0)
                local pulse=1+math.sin(life*28)*0.18
                glow.CFrame=CFrame.new(np); glow.Size=Vector3.new(22*pulse,22*pulse,22*pulse)
            else
                head.CFrame=head.CFrame+dir*speed*0.08*dt; glow.CFrame=head.CFrame
                TweenService:Create(glow,TweenInfo.new(0.3),{Transparency=1,Size=Vector3.new(0,0,0)}):Play()
            end
        end)
    end)
    table.insert(meteorConns,meteorConn)
end

local function startMeteor()
    clearMeteor(); meteorRunning=true
    meteorFolder=Instance.new("Folder",workspace); meteorFolder.Name="StellarMeteor"
    task.spawn(function()
        while meteorRunning do
            spawnOneMeteor(); task.wait(math.random()*State.meteorInterval+0.5)
        end
    end)
end

-- ================================================================
-- SECTION 13: [FIX 2] SUN OBJECT — rays กระจายทุกทิศ
-- ================================================================
local sunFolder=nil; local sunConns={}

local function clearSunray()
    for _,c in pairs(sunConns) do pcall(function() c:Disconnect() end) end
    sunConns={}
    if sunFolder and sunFolder.Parent then pcall(function() sunFolder:Destroy() end) end
    sunFolder=nil
end

local function startSunray()
    clearSunray()
    sunFolder=Instance.new("Folder",workspace); sunFolder.Name="StellarSun"
    local cam=workspace.CurrentCamera

    local core=Instance.new("Part",sunFolder); core.Size=Vector3.new(100,100,100); core.Material=Enum.Material.Neon
    core.Color=Color3.fromRGB(255,248,180); core.Transparency=0; core.CastShadow=false; core.Anchored=true; core.CanCollide=false
    Instance.new("SpecialMesh",core).MeshType=Enum.MeshType.Sphere
    local sunLight=Instance.new("PointLight",core); sunLight.Color=Color3.fromRGB(255,220,150); sunLight.Brightness=5; sunLight.Range=1000; sunLight.Shadows=false

    local coronaData={{sz=145,col=Color3.fromRGB(255,228,100),tr=0.55},{sz=200,col=Color3.fromRGB(255,195,55),tr=0.70},{sz=280,col=Color3.fromRGB(255,155,28),tr=0.84},{sz=400,col=Color3.fromRGB(255,108,8),tr=0.93},{sz=560,col=Color3.fromRGB(255,60,0),tr=0.96}}
    local coronaParts={}
    for _,l in ipairs(coronaData) do
        local c=Instance.new("Part",sunFolder); c.Size=Vector3.new(l.sz,l.sz,l.sz); c.Material=Enum.Material.Neon
        c.Color=l.col; c.Transparency=l.tr; c.CastShadow=false; c.Anchored=true; c.CanCollide=false
        Instance.new("SpecialMesh",c).MeshType=Enum.MeshType.Sphere
        table.insert(coronaParts,{part=c,baseSz=l.sz,baseTr=l.tr})
    end

    -- [FIX 2] Rays กระจาย 3 มิติ ทุกทิศ ไม่ใช่แค่บน/ล่าง
    -- ใช้ fibonacci sphere distribution สำหรับ spread ที่สม่ำเสมอ
    local RAY_COUNT=20
    local rays={}
    for i=1,RAY_COUNT do
        -- [FIX 2] fibonacci sphere: golden angle
        local phi=math.acos(1 - 2*i/(RAY_COUNT+1))         -- polar angle 0→π
        local theta=(math.pi*(1+math.sqrt(5)))*(i-1)        -- azimuth golden angle
        local r=Instance.new("Part",sunFolder)
        local rLen=math.random(400,850)
        r.Size=Vector3.new(i<=12 and 5 or 3, i<=12 and 5 or 3, rLen)
        r.Material=Enum.Material.Neon; r.Color=Color3.fromRGB(255,230,130); r.Transparency=0.65
        r.CastShadow=false; r.Anchored=true; r.CanCollide=false
        table.insert(rays,{
            part=r,
            phi=phi,      -- เก็บมุม sphere
            theta=theta,
            rLen=rLen,
            kind=i<=12 and "main" or "sub",
        })
    end

    local ambientGlow=Instance.new("Part",sunFolder); ambientGlow.Size=Vector3.new(700,700,700); ambientGlow.Material=Enum.Material.Neon
    ambientGlow.Color=Color3.fromRGB(255,140,30); ambientGlow.Transparency=0.97; ambientGlow.CastShadow=false; ambientGlow.Anchored=true; ambientGlow.CanCollide=false
    Instance.new("SpecialMesh",ambientGlow).MeshType=Enum.MeshType.Sphere

    local t0=tick()
    local conn=RunService.Heartbeat:Connect(function()
        if not sunFolder or not sunFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()-t0; local ag=t*0.018
        local sunPos=cp+Vector3.new(math.cos(ag)*800,400+math.sin(t*0.1)*35,math.sin(ag)*800)
        local pulse=1+math.sin(t*1.4)*0.035

        pcall(function()
            core.CFrame=CFrame.new(sunPos); core.Size=Vector3.new(100*pulse,100*pulse,100*pulse)
            ambientGlow.CFrame=CFrame.new(sunPos); ambientGlow.Transparency=0.96+math.sin(t*0.7)*0.02

            for _,lc in ipairs(coronaParts) do
                lc.part.CFrame=CFrame.new(sunPos)
                local sz=lc.baseSz*pulse; lc.part.Size=Vector3.new(sz,sz,sz)
                lc.part.Transparency=lc.baseTr+math.sin(t*1.2+lc.baseSz*0.01)*0.025
            end

            -- [FIX 2] Ray direction จาก fibonacci sphere + rotation
            for _,r in ipairs(rays) do
                local theta=r.theta+t*0.35   -- หมุนช้าๆ
                -- แปลง spherical → cartesian direction
                local dx=math.sin(r.phi)*math.cos(theta)
                local dy=math.cos(r.phi)           -- ← Y คือขั้ว ทำให้กระจายครบ 3 มิติ
                local dz=math.sin(r.phi)*math.sin(theta)
                local rayDir=Vector3.new(dx,dy,dz).Unit
                local midPt=sunPos+rayDir*(r.rLen*0.5)
                r.part.CFrame=CFrame.lookAt(midPt,midPt+rayDir)
                r.part.Transparency=(r.kind=="main" and 0.60 or 0.70)+math.abs(math.sin(t*2+r.phi))*0.22
                -- สีไล่ตาม angle
                local hShift=((t*6+r.phi*20)%360)/360
                r.part.Color=Color3.fromHSV(0.08+hShift*0.05,0.85,1)
            end
        end)
    end)
    table.insert(sunConns,conn)
end

