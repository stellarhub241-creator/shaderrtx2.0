local SkyApply=Instance.new("TextButton",tSky); SkyApply.Size=UDim2.new(1,-14,0,28); SkyApply.Position=UDim2.new(0,7,0,skyBY+34); SkyApply.BackgroundColor3=THEMES[1].pri; SkyApply.BackgroundTransparency=0.28; SkyApply.Text="✦ Apply Custom ID"; SkyApply.TextColor3=Color3.fromRGB(255,255,255); SkyApply.Font=Enum.Font.SourceSansBold; SkyApply.TextSize=12; Instance.new("UICorner",SkyApply).CornerRadius=UDim.new(0,8); spring(SkyApply)
