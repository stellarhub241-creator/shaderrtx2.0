local TabFPS=createScrollTab() local TabCinema=createScrollTab()
local allTabs={TabGfx,TabSky,TabOptimize,TabTheme,TabFPS,TabCinema}

local function applySpringPhysics(button)
    pcall(function()
        local us=button:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",button)
        us.Scale=1.0
        button.MouseEnter:Connect(function() pcall(function() TweenService:Create(us,TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.06}):Play() TweenService:Create(button,TweenInfo.new(0.2,Enum.EasingStyle.Quad),{BackgroundTransparency=0.15}):Play() end) end)
        button.MouseLeave:Connect(function() pcall(function() TweenService:Create(us,TweenInfo.new(0.25,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Scale=1.0}):Play() TweenService:Create(button,TweenInfo.new(0.2,Enum.EasingStyle.Quad),{BackgroundTransparency=0.4}):Play() end) end)
        button.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then pcall(function() TweenService:Create(us,TweenInfo.new(0.1,Enum.EasingStyle.Quad),{Scale=0.94}):Play() end) end end)
        button.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then pcall(function() TweenService:Create(us,TweenInfo.new(0.2,Enum.EasingStyle.Back),{Scale=1.0}):Play() end) end end)
    end)
end

local tabButtons={} local activeTab=nil

local function switchTab(tabFrame,btn)
    if activeTab==tabFrame then return end
    activeTab=tabFrame
    for _,t in pairs(allTabs) do if t~=tabFrame then t.Visible=false end end
    for _,b in pairs(tabButtons) do b.BackgroundColor3=Color3.fromRGB(20,16,30) b.BackgroundTransparency=0.4 b.TextColor3=Color3.fromRGB(180,180,180) end
    tabFrame.Position=UDim2.new(0,25,0,0) tabFrame.Visible=true
    pcall(function() TweenService:Create(tabFrame,TweenInfo.new(0.35,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(0,0,0,0)}):Play() end)
    btn.BackgroundColor3=COLOR_THEMES[currentThemeIndex].primary btn.BackgroundTransparency=0.2 btn.TextColor3=Color3.fromRGB(255,255,255)
end

local TAB_DEFS = {
    {text="Graphics",tab=nil}, {text="Skybox",tab=nil}, {text="Boost",tab=nil},
    {text="Theme",tab=nil},    {text="FPS Cap",tab=nil},{text="Cinema",tab=nil},
}
TAB_DEFS[1].tab=TabGfx TAB_DEFS[2].tab=TabSky TAB_DEFS[3].tab=TabOptimize
TAB_DEFS[4].tab=TabTheme TAB_DEFS[5].tab=TabFPS TAB_DEFS[6].tab=TabCinema

local BTN_H=22 local BTN_GAP=27

local function rebuildSidebarButtons(availH)
    -- ล้าง button เดิม
    for _,b in pairs(tabButtons) do b:Destroy() end
    tabButtons={}
    activeTab=nil

    local maxFit = math.max(1, math.floor((availH-6) / BTN_GAP))
    -- แสดงได้กี่ปุ่ม
    local shown = math.min(#TAB_DEFS, maxFit)

    for i=1,shown do
        local def=TAB_DEFS[i]
        local Btn=Instance.new("TextButton",Sidebar)
        Btn.Size=UDim2.new(1,-8,0,BTN_H) Btn.Position=UDim2.new(0,4,0,(i-1)*BTN_GAP+4)
        Btn.BackgroundColor3=Color3.fromRGB(20,16,30) Btn.BackgroundTransparency=0.4
        Btn.Text=def.text Btn.TextColor3=Color3.fromRGB(180,180,180)
        Btn.Font=Enum.Font.SourceSansBold Btn.TextSize=10
        Instance.new("UICorner",Btn).CornerRadius=UDim.new(0,6)
        applySpringPhysics(Btn)
        local capturedTab=def.tab
        Btn.MouseButton1Click:Connect(function() switchTab(capturedTab,Btn) end)
        table.insert(tabButtons,Btn)
    end

    Sidebar.CanvasSize=UDim2.new(0,0,0,shown*BTN_GAP+8)

    -- switch ไป tab แรกที่มี
    if #tabButtons>0 then switchTab(TAB_DEFS[1].tab,tabButtons[1]) end
end

-- DRAG
local dragToggle,dragStart,startPos,isDragging,longPressThread=false,nil,nil,false,nil
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        dragToggle=true dragStart=input.Position startPos=MainFrame.Position
        if longPressThread then pcall(function() task.cancel(longPressThread) end) longPressThread=nil end
        longPressThread=task.delay(0.4,function()
            if not isDragging then pcall(function()
                local ox=MainFrame.Size.X.Offset local oy=MainFrame.Size.Y.Offset
                TweenService:Create(MainFrame,TweenInfo.new(0.15,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size=UDim2.new(0,ox*0.92,0,oy*0.92)}):Play()
                task.wait(0.15)
                TweenService:Create(MainFrame,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,ox,0,oy)}):Play()
            end) end
            longPressThread=nil
        end)
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then
                dragToggle=false isDragging=false
                if longPressThread then pcall(function() task.cancel(longPressThread) end) longPressThread=nil end
            end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) and dragToggle then
        local delta=input.Position-dragStart
        if not isDragging and (math.abs(delta.X)>3 or math.abs(delta.Y)>3) then
            isDragging=true
            if longPressThread then pcall(function() task.cancel(longPressThread) end) longPressThread=nil end
        end
        if isDragging then MainFrame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y) end
    end
end)

-- MINIMIZE
local isMinimized=false
MinBtn.MouseButton1Click:Connect(function()
    isMinimized=not isMinimized
    if isMinimized then
        TitleLabel.Visible=false Sidebar.Visible=false ContentArea.Visible=false MinBtn.Text="+"
        MainFrame:TweenSize(UDim2.new(0,70,0,26),Enum.EasingDirection.Out,Enum.EasingStyle.Back,0.4,true)
        MinBtn.Position=UDim2.new(1,-24,0.5,-10)
    else
        MinBtn.Text="-"
        MainFrame:TweenSize(UDim2.new(0,320,0,260),Enum.EasingDirection.Out,Enum.EasingStyle.Back,0.5,true)
        MinBtn.Position=UDim2.new(1,-32,0.5,-12)
        task.delay(0.25,function() Sidebar.Visible=true ContentArea.Visible=true TitleLabel.Visible=true end)
    end
end)

-- TOGGLE HELPER
local function createToggle(parent,text,order,defaultVal,callback)
    local F=Instance.new("Frame",parent)
    F.Size=UDim2.new(1,-16,0,30) F.Position=UDim2.new(0,8,0,(order-1)*36+6) F.BackgroundTransparency=1
    local L=Instance.new("TextLabel",F)
    L.Size=UDim2.new(0.65,0,1,0) L.BackgroundTransparency=1 L.Text=text
    L.TextColor3=Color3.fromRGB(220,220,220) L.TextSize=11 L.Font=Enum.Font.SourceSans L.TextXAlignment=Enum.TextXAlignment.Left
    local TB=Instance.new("TextButton",F)
    TB.Size=UDim2.new(0,44,0,20) TB.Position=UDim2.new(1,-44,0.5,-10)
    TB.BackgroundColor3=defaultVal and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(40,30,55)
    TB.BackgroundTransparency=0.2 TB.Text=defaultVal and "ON" or "OFF"
    TB.TextColor3=Color3.fromRGB(255,255,255) TB.Font=Enum.Font.SourceSansBold TB.TextSize=10
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,10)
    applySpringPhysics(TB)
    local cur=defaultVal
    TB.MouseButton1Click:Connect(function()
        cur=not cur
        pcall(function() TweenService:Create(TB,TweenInfo.new(0.25,Enum.EasingStyle.Back),{BackgroundColor3=cur and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(40,30,55)}):Play() end)
        TB.Text=cur and "ON" or "OFF" callback(cur)
    end)
    return TB
end

local function autoCanvas(scroll,itemCount,itemH,spacing,padding)
    scroll.CanvasSize=UDim2.new(0,0,0,padding+itemCount*(itemH+spacing))
end

