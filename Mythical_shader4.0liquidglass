local ScreenGui=Instance.new("ScreenGui",CoreGui)
ScreenGui.Name="STELLARHUB_MYTHICAL" ScreenGui.ResetOnSpawn=false ScreenGui.IgnoreGuiInset=true

-- smooth tween helper (ลื่นขึ้น)
local SMOOTH=TweenInfo.new(0.22,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
local SMOOTH_BACK=TweenInfo.new(0.28,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
local SMOOTH_FAST=TweenInfo.new(0.14,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)

local function tween(obj,props,info) pcall(function() TweenService:Create(obj,info or SMOOTH,props):Play() end) end

local function spring(btn)
    pcall(function()
        local us=btn:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",btn)
        us.Scale=1.0
        btn.MouseEnter:Connect(function() pcall(function()
            tween(us,{Scale=1.08},SMOOTH_BACK)
            tween(btn,{BackgroundTransparency=0.08},SMOOTH_FAST)
        end) end)
        btn.MouseLeave:Connect(function() pcall(function()
            tween(us,{Scale=1.0},SMOOTH)
            tween(btn,{BackgroundTransparency=0.35},SMOOTH_FAST)
        end) end)
        btn.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                pcall(function() tween(us,{Scale=0.93},SMOOTH_FAST) end)
            end
        end)
        btn.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                pcall(function() tween(us,{Scale=1.0},SMOOTH_BACK) end)
            end
        end)
    end)
end

local function addBounceOnHold(frame)
    local holdThread=nil
    frame.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
            if holdThread then pcall(function() task.cancel(holdThread) end) end
            holdThread=task.delay(0.28,function()
                pcall(function()
                    local us=frame:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",frame)
                    us.Scale=1
                    tween(us,{Scale=1.14},TweenInfo.new(0.1,Enum.EasingStyle.Quad,Enum.EasingDirection.Out))
                    task.wait(0.1)
                    tween(us,{Scale=1.0},TweenInfo.new(0.28,Enum.EasingStyle.Bounce,Enum.EasingDirection.Out))
                end)
                holdThread=nil
            end)
            input.Changed:Connect(function()
                if input.UserInputState==Enum.UserInputState.End then
                    if holdThread then pcall(function() task.cancel(holdThread) end) holdThread=nil end
                end
            end)
        end
    end)
end

