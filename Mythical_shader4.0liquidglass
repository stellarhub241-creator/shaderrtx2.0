BoostButton.BackgroundColor3 = Color3.fromRGB(255,60,100) BoostButton.BackgroundTransparency = 0.3
BoostButton.Text = "ENABLE FPS BOOST" BoostButton.TextColor3 = Color3.fromRGB(255,255,255)
BoostButton.Font = Enum.Font.SourceSansBold BoostButton.TextSize = 14 BoostButton.ZIndex = 6
Instance.new("UICorner",BoostButton).CornerRadius = UDim.new(0,8)
