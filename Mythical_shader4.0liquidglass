-- [v4.9.1] Popup physics: velocity + bounce ชนขอบ
local popupVelX, popupVelY = 0, 0
local popupPhysicsActive = false

local function throwPopup(vx, vy)
    popupVelX=vx popupVelY=vy popupPhysicsActive=true
end

-- [v4.9.1] กดค้าง popup → บุบ
local popupHoldThread=nil
PopupHeader.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        if popupHoldThread then pcall(function() task.cancel(popupHoldThread) end) end
        popupHoldThread=task.delay(0.35,function()
            -- บุบ
            pcall(function()
                local us=FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup)
                us.Scale=1
                TweenService:Create(us,TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Scale=0.88}):Play()
                task.wait(0.12)
                TweenService:Create(us,TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.0}):Play()
            end)
            popupHoldThread=nil
        end)
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then
                if popupHoldThread then pcall(function() task.cancel(popupHoldThread) end) popupHoldThread=nil end
            end
        end)
    end
end)

-- Drag popup
local popupDrag,popupDragStart,popupStartPos,popupLastPos,popupLastTime=false,nil,nil,nil,0
PopupHeader.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        popupDrag=true popupDragStart=i.Position popupStartPos=FPSPopup.Position
        popupLastPos=i.Position popupLastTime=tick() popupPhysicsActive=false popupVelX=0 popupVelY=0
        i.Changed:Connect(function()
            if i.UserInputState==Enum.UserInputState.End then
                popupDrag=false
                -- คำนวณ velocity จาก delta
                local dt=math.max(tick()-popupLastTime,0.01)
                if popupLastPos then
                    local curPos=FPSPopup.Position
                    throwPopup(popupVelX*0.8, popupVelY*0.8)
                end
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if popupDrag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local d=i.Position-popupDragStart
        FPSPopup.Position=UDim2.new(popupStartPos.X.Scale,popupStartPos.X.Offset+d.X,popupStartPos.Y.Scale,popupStartPos.Y.Offset+d.Y)
        -- คำนวณ velocity
        local now=tick()
        local dt=math.max(now-popupLastTime,0.001)
        if popupLastPos then
            popupVelX=(i.Position.X-popupLastPos.X)/dt
            popupVelY=(i.Position.Y-popupLastPos.Y)/dt
        end
        popupLastPos=i.Position popupLastTime=now
    end
end)

-- [v4.9.1] physics loop: bounce ชนขอบจอ
local FRICTION = 0.88
RunService.RenderStepped:Connect(function(dt)
    if not popupPhysicsActive or popupDrag then return end
    if math.abs(popupVelX)<0.5 and math.abs(popupVelY)<0.5 then popupPhysicsActive=false return end

    local vp=workspace.CurrentCamera.ViewportSize
    local pw=FPSPopup.Size.X.Offset local ph=FPSPopup.Size.Y.Offset
    local px=FPSPopup.Position.X.Offset local py=FPSPopup.Position.Y.Offset

    px=px+popupVelX*dt py=py+popupVelY*dt
    popupVelX=popupVelX*FRICTION popupVelY=popupVelY*FRICTION

    -- bounce ซ้าย-ขวา
    if px < 0 then px=0 popupVelX=math.abs(popupVelX)*0.6
        pcall(function() local us=FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup) us.Scale=1 TweenService:Create(us,TweenInfo.new(0.08,Enum.EasingStyle.Quad),{Scale=0.93}):Play() task.delay(0.08,function() pcall(function() TweenService:Create(us,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.0}):Play() end) end) end)
    end
    if px+pw > vp.X then px=vp.X-pw popupVelX=-math.abs(popupVelX)*0.6
        pcall(function() local us=FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup) us.Scale=1 TweenService:Create(us,TweenInfo.new(0.08,Enum.EasingStyle.Quad),{Scale=0.93}):Play() task.delay(0.08,function() pcall(function() TweenService:Create(us,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.0}):Play() end) end) end)
    end
    -- bounce บน-ล่าง
    if py < 0 then py=0 popupVelY=math.abs(popupVelY)*0.6
        pcall(function() local us=FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup) us.Scale=1 TweenService:Create(us,TweenInfo.new(0.08,Enum.EasingStyle.Quad),{Scale=0.93}):Play() task.delay(0.08,function() pcall(function() TweenService:Create(us,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.0}):Play() end) end) end)
    end
    if py+ph > vp.Y then py=vp.Y-ph popupVelY=-math.abs(popupVelY)*0.6
        pcall(function() local us=FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup) us.Scale=1 TweenService:Create(us,TweenInfo.new(0.08,Enum.EasingStyle.Quad),{Scale=0.93}):Play() task.delay(0.08,function() pcall(function() TweenService:Create(us,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.0}):Play() end) end) end)
    end

    FPSPopup.Position=UDim2.new(0,px,0,py)
end)

-- Resize popup
local popupResizing,popupResizeStart,popupResizeSize=false,nil,nil
PopupResize.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then popupResizing=true popupResizeStart=i.Position popupResizeSize=Vector2.new(FPSPopup.Size.X.Offset,FPSPopup.Size.Y.Offset) i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then popupResizing=false end end) end end)
UserInputService.InputChanged:Connect(function(i)
    if popupResizing and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local d=i.Position-popupResizeStart
        local nW=math.clamp(popupResizeSize.X+d.X,44,300) local nH=math.clamp(popupResizeSize.Y+d.Y,38,200)
        PopupTitle.Visible=nW>=60 PopupCapLabel.Visible=nH>=55
        PopupCloseBtn.Visible=nW>=60 PopupHeader.BackgroundTransparency=nH>=55 and 0.4 or 1
        pcall(function() TweenService:Create(FPSPopup,TweenInfo.new(0.04,Enum.EasingStyle.Quad),{Size=UDim2.new(0,nW,0,nH)}):Play() end)
    end
end)

PopupCloseBtn.MouseButton1Click:Connect(function()
    pcall(function() local s=FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup) s.Scale=1 TweenService:Create(s,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Scale=0}):Play() end)
    task.delay(0.16,function() FPSPopup.Visible=false end) ShowFPSPopupBtn.Text="📊 Show FPS Monitor"
end)
ShowFPSPopupBtn.MouseButton1Click:Connect(function()
    if FPSPopup.Visible then
        pcall(function() local s=FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup) s.Scale=1 TweenService:Create(s,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Scale=0}):Play() end)
        task.delay(0.16,function() FPSPopup.Visible=false end) ShowFPSPopupBtn.Text="📊 Show FPS Monitor"
    else
        FPSPopup.Visible=true local s=FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup) s.Scale=0
        pcall(function() TweenService:Create(s,TweenInfo.new(0.32,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1}):Play() end)
        ShowFPSPopupBtn.Text="📊 Hide FPS Monitor"
    end
end)

-- ==================== GRID SIZE ====================
local camera=workspace.CurrentCamera local GRID=64
local SIZE_PRESETS={{label="1×1",w=1,h=1},{label="1×2",w=1,h=2},{label="2×2",w=2,h=2},{label="4×4",w=4,h=4},{label="8×8",w=8,h=8},{label="24×24",w=24,h=24}}
local currentSizeIndex=5
SizeBtn.Text=SIZE_PRESETS[currentSizeIndex].label
applySpringPhysics(SizeBtn)

local function gridPx(slots,axis) local vp=camera.ViewportSize return math.floor((axis=="x" and vp.X or vp.Y)/GRID*slots) end

-- [v4.9.1] updateUIVisibility ลด minimum → แสดง UI ได้เล็กลงกว่าเดิม
local function updateUIVisibility(w,h)
    -- [v4.9.1] minimum เล็กลง: sidebar แสดงที่ w>=80, content ที่ w>=100
    local showSidebar  = w >= 80  and h >= 80
    local showContent  = w >= 100 and h >= 80
    Sidebar.Visible    = showSidebar
    ContentArea.Visible= showContent
    TitleLabel.Visible = w >= 70
    SizeBtn.Visible    = w >= 90
    -- rebuild sidebar buttons ตามความสูงที่มี
    if showSidebar then
        rebuildSidebarButtons(h - 35)
    end
end

local function applyGridSize(preset)
    local pw=gridPx(preset.w,"x") local ph=gridPx(preset.h,"y")
    updateUIVisibility(pw,ph)
    pcall(function() TweenService:Create(MainFrame,TweenInfo.new(0.45,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,math.max(pw,50),0,math.max(ph,28))}):Play() end)
end

SizeBtn.MouseButton1Click:Connect(function()
    currentSizeIndex=(currentSizeIndex%#SIZE_PRESETS)+1 local preset=SIZE_PRESETS[currentSizeIndex]
    SizeBtn.Text=preset.label applyGridSize(preset)
end)

-- RESIZE MAIN
local ResizeHandle=Instance.new("TextButton",MainFrame)
ResizeHandle.Size=UDim2.new(0,20,0,20) ResizeHandle.Position=UDim2.new(1,-20,1,-20)
ResizeHandle.BackgroundTransparency=1 ResizeHandle.Text="◢" ResizeHandle.TextColor3=Color3.fromRGB(200,200,255) ResizeHandle.TextTransparency=0.5 ResizeHandle.TextSize=13 ResizeHandle.Font=Enum.Font.SourceSansBold ResizeHandle.ZIndex=10

local isResizing,resizeStart,resizeSize0=false,nil,nil
ResizeHandle.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        isResizing=true resizeStart=i.Position resizeSize0=Vector2.new(MainFrame.Size.X.Offset,MainFrame.Size.Y.Offset)
        pcall(function() TweenService:Create(ResizeHandle,TweenInfo.new(0.15),{TextTransparency=0}):Play() end)
        i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then isResizing=false pcall(function() TweenService:Create(ResizeHandle,TweenInfo.new(0.15),{TextTransparency=0.5}):Play() end) end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if isResizing and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local delta=i.Position-resizeStart
        local nW=math.clamp(resizeSize0.X+delta.X,50,800) local nH=math.clamp(resizeSize0.Y+delta.Y,28,600)
        SizeBtn.Text="Custom" updateUIVisibility(nW,nH)
        pcall(function() TweenService:Create(MainFrame,TweenInfo.new(0.04,Enum.EasingStyle.Quad),{Size=UDim2.new(0,nW,0,nH)}):Play() end)
    end
end)

local lastVP=camera.ViewportSize
task.spawn(function() while task.wait(1) do local vp=camera.ViewportSize if vp~=lastVP then lastVP=vp if SizeBtn.Text~="Custom" then applyGridSize(SIZE_PRESETS[currentSizeIndex]) end end end end)

-- RENDER LOOP
local nextUpdate,frameCount,lastBorderColor=0,0,nil
rainbowHue=0
RunService.RenderStepped:Connect(function(dt)
    frameCount=frameCount+1 nextUpdate=nextUpdate+dt
    if rainbowActive then
        rainbowHue=(rainbowHue+dt*80)%360
        local col=Color3.fromHSV(rainbowHue/360,1,1) local col2=Color3.fromHSV(((rainbowHue+120)%360)/360,1,1)
        pcall(function() UIGradientStroke.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col),ColorSequenceKeypoint.new(0.5,col2),ColorSequenceKeypoint.new(1,col)}) end)
        BorderColorNow=col activeThemeLabel.TextColor3=col
    end
    if nextUpdate>=0.5 then
        local fps=math.round(frameCount/nextUpdate)
        LiveTimeLabel.Text=ModeText LiveTimeLabel.TextColor3=BorderColorNow
        if FPSPopup.Visible then
            PopupFPSBig.Text=tostring(fps)
            PopupCapLabel.Text="cap:"..(targetFpsCap==165 and "165⚡" or tostring(targetFpsCap))
            local r=math.clamp(fps/math.max(targetFpsCap,1),0,1)
            PopupFPSBig.TextColor3=Color3.fromRGB(math.floor(lerpN(255,0,r)),math.floor(lerpN(60,255,r)),math.floor(lerpN(60,180,r)))
        end
        if not rainbowActive and BorderColorNow~=lastBorderColor then
            lastBorderColor=BorderColorNow
            pcall(function() TweenService:Create(UIStroke,TweenInfo.new(0.4),{Color=BorderColorNow}):Play() TweenService:Create(FPSPopupStroke,TweenInfo.new(0.4),{Color=BorderColorNow}):Play() end)
        end
        frameCount=0 nextUpdate=0
    end
end)

applyGridSize(SIZE_PRESETS[currentSizeIndex])
print("✅ MYTHICAL SHADER v4.9.1: Fog sliders + Stable sliders + Sidebar scroll + Popup physics!")
