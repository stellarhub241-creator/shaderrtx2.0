local Bloom           = Instance.new("BloomEffect", Lighting)
local SunRays         = Instance.new("SunRaysEffect", Lighting)
local DOF             = Instance.new("DepthOfFieldEffect", Lighting)
DOF.Name="StellarDOF"; DOF.NearIntensity=0; DOF.FocusDistance=35; DOF.InFocusRadius=20; DOF.Enabled=true

local skyGuardConn
local function connectSkyGuard()
    if skyGuardConn then pcall(function() skyGuardConn:Disconnect() end) end
    skyGuardConn = Lighting.ChildAdded:Connect(function(child)
        if child:IsA("Sky") and child.Name~="StellarSky" then
            task.defer(function() pcall(function() child:Destroy() end) end)
        end
    end)
end
connectSkyGuard()

-- ================================================================
-- SECTION 9: LIGHTING PROFILES + TRANSITION
