    HORROR_B = {brightness=0.22,exposure=-0.6, shadow=0.99, ambient=Color3.fromRGB(2,3,25),      atmoColor=Color3.fromRGB(4,5,35),      atmoDecay=Color3.fromRGB(1,2,18),      atmoGlare=0.0, atmoHaze=6.0, atmoDensity=0.78, contrast=0.82, saturation=-0.88,tint=Color3.fromRGB(40,50,180),   bloom=0.35,bloomSize=40, bloomThreshold=0.72,dofFar=0.9, sunRays=0.0},
    NOSTALGIA= {brightness=1.45,exposure=0.18, shadow=0.38, ambient=Color3.fromRGB(120,80,145),  atmoColor=Color3.fromRGB(230,175,215), atmoDecay=Color3.fromRGB(175,115,195), atmoGlare=1.2, atmoHaze=2.8, atmoDensity=0.38, contrast=0.18, saturation=0.22, tint=Color3.fromRGB(255,220,235), bloom=0.65,bloomSize=20, bloomThreshold=0.68,dofFar=0.22,sunRays=0.28},
}

local function applyLighting(p)
    pcall(function()
        Lighting.Brightness=p.brightness; Lighting.ExposureCompensation=p.exposure
        Lighting.ShadowSoftness=p.shadow; Lighting.OutdoorAmbient=p.ambient
        Atmosphere.Color=p.atmoColor; Atmosphere.Decay=p.atmoDecay
        Atmosphere.Glare=p.atmoGlare; Atmosphere.Haze=p.atmoHaze; Atmosphere.Density=p.atmoDensity
        ColorCorrection.Contrast=p.contrast; ColorCorrection.Saturation=p.saturation; ColorCorrection.TintColor=p.tint
        Bloom.Intensity=p.bloom; Bloom.Size=p.bloomSize; Bloom.Threshold=p.bloomThreshold
        DOF.FarIntensity=p.dofFar; SunRays.Intensity=p.sunRays
    end)
end

local function applyCinematicBlend()
    if not State.cinematicEnabled then return end
    pcall(function()
        ColorCorrection.Contrast=math.max(ColorCorrection.Contrast,0.6)
        ColorCorrection.Saturation=ColorCorrection.Saturation-0.1
        DOF.FarIntensity=math.max(DOF.FarIntensity,0.55)
        Bloom.Threshold=math.min(Bloom.Threshold+0.08,0.99)
        Lighting.ShadowSoftness=math.max(Lighting.ShadowSoftness,0.65)
    end)
end

local function resetFogLighting()
    pcall(function()
        if not State.nostalgiaEnabled then
            Lighting.FogStart=State.originalFogStart; Lighting.FogEnd=State.originalFogEnd
            Lighting.FogColor=State.originalFogColor; Lighting.Ambient=State.originalAmbient
            Lighting.Brightness=State.originalBrightness; Lighting.ExposureCompensation=State.originalExposure
            Lighting.ShadowSoftness=State.originalShadow; Lighting.OutdoorAmbient=State.originalOutdoor
        end
    end)
end

local function reapplyActiveMode()
    if State.nostalgiaEnabled then
        applyLighting(PROFILES.NOSTALGIA)
        pcall(function() Lighting.ClockTime=17.2; Lighting.FogStart=180; Lighting.FogEnd=2200; Lighting.FogColor=Color3.fromRGB(210,160,225); Lighting.Ambient=Color3.fromRGB(120,80,145) end)
    elseif State.horrorBlue then
        applyLighting(PROFILES.HORROR_B)
        pcall(function() Lighting.FogStart=2; Lighting.FogEnd=45; Lighting.FogColor=Color3.fromRGB(2,3,22); Lighting.Ambient=Color3.fromRGB(2,3,22) end)
    elseif State.horrorFogEnabled then
        applyLighting(PROFILES.HORROR_G)
        pcall(function() Lighting.FogStart=3; Lighting.FogEnd=60; Lighting.FogColor=Color3.fromRGB(5,20,3); Lighting.Ambient=Color3.fromRGB(5,20,3) end)
    elseif State.dawnEnabled then
        applyLighting(PROFILES.DAWN); pcall(function() Lighting.ClockTime=5.5 end)
    elseif State.sunsetEnabled then
        applyLighting(PROFILES.GOLDEN); pcall(function() Lighting.ClockTime=19 end)
    elseif State.rainEnabled then
        applyLighting(PROFILES.RAIN)
        pcall(function() Lighting.FogStart=20; Lighting.FogEnd=200; Lighting.FogColor=Color3.fromRGB(110,122,142) end)
    elseif State.heavenlyEnabled then
        applyLighting(PROFILES.HEAVENLY)
        pcall(function() Lighting.FogStart=500; Lighting.FogEnd=2000; Lighting.FogColor=Color3.fromRGB(225,235,255); Lighting.ClockTime=12 end)
    else resetFogLighting() end
    applyCinematicBlend()
end

-- ================================================================
-- SECTION 10: RAIN
-- ================================================================
local rainFolder=nil; local rainConns={}; local rainParts={}; local rainRipples={}

local function clearRainParticles()
    for _,c in pairs(rainConns) do pcall(function() c:Disconnect() end) end
    rainConns={}
    if rainFolder and rainFolder.Parent then pcall(function() rainFolder:Destroy() end) end
    rainFolder=nil; rainParts={}; rainRipples={}
end

local function createRainParticles()
    clearRainParticles()
    rainFolder=Instance.new("Folder",workspace); rainFolder.Name="StellarRain"
    local cam=workspace.CurrentCamera
    local count=math.clamp(State.rainParticleCount,10,150)
    for i=1,count do
        local p=Instance.new("Part"); p.Size=Vector3.new(0.045,lerpN(1.8,3.0,math.random())*1,0.045)
        p.Material=Enum.Material.Glass; p.Reflectance=math.random(70,90)/100
        p.Color=Color3.fromRGB(math.random(200,230),math.random(225,245),255)
        p.Transparency=math.random(55,72)/100; p.CastShadow=false; p.Anchored=true; p.CanCollide=false
        p.Parent=rainFolder; table.insert(rainParts,p)
    end
    local rippleCount=math.max(6,math.floor(count*0.18))
    for i=1,rippleCount do
        local r=Instance.new("Part"); r.Size=Vector3.new(0.1,0.05,0.1); r.Material=Enum.Material.Glass
        r.Reflectance=0.7; r.Color=Color3.fromRGB(180,215,255); r.Transparency=0.82
        r.CastShadow=false; r.Anchored=true; r.CanCollide=false; r.Shape=Enum.PartType.Cylinder
        r.Parent=rainFolder; table.insert(rainRipples,r)
    end
    local frame=0
    local conn=RunService.Heartbeat:Connect(function()
        frame=frame+1; if frame%2~=0 then return end
        if not rainFolder or not rainFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()
        for i,p in ipairs(rainParts) do
            if p and p.Parent then
                local ph=i*0.73; local fall=(t*16+ph*2.8)%32
                pcall(function()
                    p.Reflectance=0.65+math.sin(t*3+ph)*0.25
                    p.CFrame=CFrame.new(cp.X+math.sin(ph)*34,cp.Y+20-fall,cp.Z+math.cos(ph)*34)*CFrame.Angles(0.18,0,0.06)
                end)
            end
        end
        for i,r in ipairs(rainRipples) do
            if r and r.Parent then
                pcall(function()
                    local rt=(t*0.7+i*0.65)%1; local sc=0.3+rt*3.5; local ph=i*1.13
                    local rx=cp.X+math.sin(ph)*22; local rz=cp.Z+math.cos(ph)*22
                    local ray=workspace:Raycast(Vector3.new(rx,cp.Y+8,rz),Vector3.new(0,-50,0))
                    local ry=ray and ray.Position.Y+0.05 or cp.Y-8
                    r.CFrame=CFrame.new(rx,ry,rz)*CFrame.Angles(0,0,math.pi/2)
                    r.Size=Vector3.new(0.05,sc,sc); r.Transparency=0.65+(1-rt)*0.28
                    r.Reflectance=0.6+math.sin(t*2+i)*0.3
                    r.Color=Color3.fromRGB(math.floor(lerpN(150,210,1-rt)),math.floor(lerpN(190,235,1-rt)),255)
                end)
            end
        end
    end)
    table.insert(rainConns,conn)
end

-- ================================================================
-- SECTION 11: SAKURA (Part+Neon ตกจริง — ไม่ใช้ BillboardGui)
-- ================================================================
local sakuraFolder=nil; local sakuraConns={}; local sakuraData={}

local SAKURA_COLORS = {
    Color3.fromRGB(255,210,230),
    Color3.fromRGB(255,185,215),
    Color3.fromRGB(252,165,200),
    Color3.fromRGB(248,145,185),
    Color3.fromRGB(255,225,240),
}

local SAKURA_SHAPES = {
    Enum.PartType.Block,
    Enum.PartType.Ball,
}

local function clearSakura()
    for _,c in pairs(sakuraConns) do pcall(function() c:Disconnect() end) end
    sakuraConns={}
    if sakuraFolder and sakuraFolder.Parent then pcall(function() sakuraFolder:Destroy() end) end
    sakuraFolder=nil; sakuraData={}
end

local function createSakura()
    clearSakura()
    sakuraFolder=Instance.new("Folder",workspace); sakuraFolder.Name="StellarSakura"
    local cam=workspace.CurrentCamera
    local count=math.clamp(State.sakuraCount,8,80)
    local cp=cam.CFrame.Position

    for i=1,count do
        -- [FIX] ใช้ Part Neon เพราะ executor ส่วนใหญ่รองรับ
        local p=Instance.new("Part",sakuraFolder)
        -- กลีบดอกซากุระ = Block บางๆ หรือ Wedge
        local w=math.random(4,9)*0.1
        local h=math.random(2,5)*0.1
        p.Size=Vector3.new(w, h, w*0.7)
        p.Material=Enum.Material.Neon
        p.Color=SAKURA_COLORS[math.random(#SAKURA_COLORS)]
        p.Transparency=math.random(5,25)/100
        p.CastShadow=false; p.Anchored=true; p.CanCollide=false

        -- SpecialMesh ให้ดูเป็นกลีบ
        local mesh=Instance.new("SpecialMesh",p)
        mesh.MeshType=Enum.MeshType.Wedge
        mesh.Scale=Vector3.new(1,0.3,1)

        -- PointLight เบาๆ ให้ bloom
        local pl=Instance.new("PointLight",p)
        pl.Color=p.Color; pl.Range=4; pl.Brightness=0.4; pl.Shadows=false

        -- Physics state
        local startX=cp.X+math.random(-40,40)
        local startY=cp.Y+math.random(8,28)
        local startZ=cp.Z+math.random(-40,40)

        table.insert(sakuraData,{
            part=p,
            x=startX, y=startY, z=startZ,
            vy=0,
            gravity=-1.8 - math.random()*1.2,   -- gravity ลงต่างกัน
            swayAmp=0.8+math.random()*1.2,
            swayFreq=0.4+math.random()*0.6,
            rotX=math.random()*360,
            rotY=math.random()*360,
            rotZ=math.random()*360,
            rotSpeedX=(math.random()-0.5)*120,
            rotSpeedY=(math.random()-0.5)*180,
            rotSpeedZ=(math.random()-0.5)*90,
            phase=i*0.618*math.pi*2,
            life=math.random()*10,
            maxLife=lerpN(8,16,math.random()),
            baseTransp=math.random(5,25)/100,
        })
    end

    StellarAI:watch("sakura",
        function() return sakuraFolder end,
        "SakuraFolder",
        function() if State.sakuraEnabled then createSakura() end end
    )

    local conn=RunService.Heartbeat:Connect(function(dt)
        if not sakuraFolder or not sakuraFolder.Parent then return end
        StellarEngineA:beginPass("sakura")
        local cp2=cam.CFrame.Position
        local t=tick()

        for _,s in ipairs(sakuraData) do
            if s.part and s.part.Parent then
                s.life=s.life+dt

                -- reset เมื่อตกเกินหรือหมดอายุ
                if s.y < cp2.Y-35 or s.life > s.maxLife then
                    s.x=cp2.X+math.random(-40,40)
                    s.y=cp2.Y+math.random(10,30)
                    s.z=cp2.Z+math.random(-40,40)
                    s.vy=0; s.life=0
                    s.maxLife=lerpN(8,16,math.random())
                    s.rotX=math.random()*360
                    s.rotY=math.random()*360
                    s.rotZ=math.random()*360
                end

                -- [StellarEngineA] physics
                local nx,ny,nz,nvy=StellarEngineA:calcSakuraPos(
                    s.x, s.y, s.z, s.vy,
                    s.gravity, s.swayAmp, s.swayFreq,
                    t, s.phase, dt
                )
                s.x=nx; s.y=ny; s.z=nz; s.vy=nvy

                -- rotation
                s.rotX=(s.rotX+s.rotSpeedX*dt)%360
                s.rotY=(s.rotY+s.rotSpeedY*dt)%360
                s.rotZ=(s.rotZ+s.rotSpeedZ*dt)%360

                -- fade alpha
                local lifeRatio=s.life/s.maxLife
                local alpha
                if lifeRatio < 0.12 then alpha=lifeRatio/0.12
                elseif lifeRatio > 0.78 then alpha=(1-lifeRatio)/0.22
                else alpha=1 end

                pcall(function()
                    s.part.CFrame=CFrame.new(s.x,s.y,s.z)*CFrame.Angles(
                        math.rad(s.rotX),math.rad(s.rotY),math.rad(s.rotZ)
                    )
                    s.part.Transparency=1-(alpha*(1-s.baseTransp))
                end)
            end
        end
        StellarEngineA:endPass("sakura")
    end)
    table.insert(sakuraConns,conn)
end

-- ================================================================
-- SECTION 12: WIND
-- ================================================================
local windConns={}; local windParts={}

local function clearWind()
    for _,c in pairs(windConns) do pcall(function() c:Disconnect() end) end
    windConns={}
    for _,d in pairs(windParts) do
        pcall(function() if d.part and d.part.Parent then d.part.CFrame=d.origin end end)
    end
    windParts={}
end

local function startWind()
    clearWind()
    local cam=workspace.CurrentCamera
    local collected=0
    for _,v in ipairs(workspace:GetDescendants()) do
        if collected>=180 then break end
        pcall(function()
            if not(v:IsA("BasePart") or v:IsA("MeshPart")) then return end
            if not v.Anchored then return end
            local pn=v.Parent and v.Parent.Name or ""
            if pn=="StellarRain" or pn=="StellarSakura" or pn=="StellarMeteor" or pn=="StellarSun" then return end
            if v.Size.X>6 or v.Size.Z>6 or v.Size.Y>18 then return end
            if (v.Position-cam.CFrame.Position).Magnitude>120 then return end
            table.insert(windParts,{
                part=v, origin=v.CFrame,
                phase=math.random()*math.pi*2,
                freq=0.8+math.random()*1.2,
                amp=0.008+math.random()*0.022,
            })
            collected=collected+1
        end)
    end
    local conn=RunService.Heartbeat:Connect(function(dt)
        if not State.windEnabled then return end
        local t=tick()
        for _,d in pairs(windParts) do
            pcall(function()
                if d.part and d.part.Parent then
                    local wave=math.sin(t*d.freq+d.phase)*d.amp*State.windStrength
                    local wave2=StellarEngineA:smoothNoise(t*d.freq*0.5,d.phase,0)*d.amp*State.windStrength*0.4
                    d.part.CFrame=d.origin*CFrame.Angles(wave,wave2*0.3,wave*0.6)
                end
            end)
        end
    end)
    table.insert(windConns,conn)
end

-- ================================================================
-- SECTION 13: METEOR (bezier curve + สวยขึ้น)
-- ================================================================
local meteorFolder=nil; local meteorConns={}; local meteorRunning=false

local function clearMeteor()
    meteorRunning=false
    for _,c in pairs(meteorConns) do pcall(function() c:Disconnect() end) end
    meteorConns={}
    if meteorFolder and meteorFolder.Parent then pcall(function() meteorFolder:Destroy() end) end
    meteorFolder=nil
end

local function spawnOneMeteor()
    if not meteorFolder or not meteorFolder.Parent then return end
    local cam=workspace.CurrentCamera; local cp=cam.CFrame.Position
    local angle=math.random()*math.pi*2; local dist=math.random(500,800)
    local p0=Vector3.new(cp.X+math.cos(angle)*dist, cp.Y+math.random(300,500), cp.Z+math.sin(angle)*dist)
    local p2=Vector3.new(cp.X+math.cos(angle+math.pi)*dist, cp.Y-math.random(50,100), cp.Z+math.sin(angle+math.pi)*dist)
    -- [NEW] bezier control point ทำให้วิถีโค้ง
    local p1=Vector3.new(
        (p0.X+p2.X)/2 + math.random(-100,100),
        (p0.Y+p2.Y)/2 + math.random(50,200),
        (p0.Z+p2.Z)/2 + math.random(-100,100)
    )

    local speed=math.random(220,400); local len=math.random(60,140)
    local mc=State.meteorColor

    local function mkPart(sz,tr,col)
        local pt=Instance.new("Part",meteorFolder)
        pt.Size=sz; pt.Material=Enum.Material.Neon; pt.Color=col
        pt.Transparency=tr; pt.CastShadow=false; pt.Anchored=true; pt.CanCollide=false
        return pt
    end

    local head=mkPart(Vector3.new(5,5,5),         0,   mc);  Instance.new("SpecialMesh",head).MeshType=Enum.MeshType.Sphere
    local body=mkPart(Vector3.new(2.8,2.8,len),   0.12, StellarEngineA:lerpCHSV(mc,Color3.fromRGB(255,255,255),0.4))
    local tail=mkPart(Vector3.new(1.6,1.6,len*3), 0.4,  StellarEngineA:lerpCHSV(mc,Color3.fromRGB(255,255,255),0.7))
    local tail2=mkPart(Vector3.new(0.7,0.7,len*6),0.72, Color3.fromRGB(255,255,255))
    local glow=mkPart(Vector3.new(24,24,24),       0.78, mc);  Instance.new("SpecialMesh",glow).MeshType=Enum.MeshType.Sphere

    -- [NEW] outer glow
    local outerGlow=mkPart(Vector3.new(55,55,55),0.94,StellarEngineA:lerpCHSV(mc,Color3.fromRGB(255,200,100),0.3))
    Instance.new("SpecialMesh",outerGlow).MeshType=Enum.MeshType.Sphere

    local pLight=Instance.new("PointLight",head); pLight.Color=mc; pLight.Range=320; pLight.Brightness=5; pLight.Shadows=true

    -- Sparks
    local pe=Instance.new("ParticleEmitter",head)
    pe.Texture="rbxassetid://2273224484"; pe.Rate=500; pe.Lifetime=NumberRange.new(0.1,0.5)
    pe.Speed=NumberRange.new(6,30); pe.SpreadAngle=Vector2.new(55,55)
    pe.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),
        ColorSequenceKeypoint.new(0.25,mc),
        ColorSequenceKeypoint.new(0.65,Color3.fromRGB(255,200,80)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(255,80,0)),
    })
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,4.5),NumberSequenceKeypoint.new(0.4,2),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1; pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)})
    pe.EmissionDirection=Enum.NormalId.Back; pe.RotSpeed=NumberRange.new(-180,180)

    -- Ember trail
    local pe2=Instance.new("ParticleEmitter",body)
    pe2.Texture="rbxassetid://6060542021"; pe2.Rate=160; pe2.Lifetime=NumberRange.new(0.1,0.35)
    pe2.Speed=NumberRange.new(2,10); pe2.SpreadAngle=Vector2.new(22,22)
    pe2.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(255,230,120)),
        ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,120,20)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(160,40,0)),
    })
    pe2.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,2.2),NumberSequenceKeypoint.new(1,0)})
    pe2.LightEmission=0.8; pe2.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.1),NumberSequenceKeypoint.new(1,1)})
    pe2.EmissionDirection=Enum.NormalId.Back

    local life=0; local maxLife=6.0; local isFading=false
    local meteorConn
    meteorConn=RunService.Heartbeat:Connect(function(dt)
        life=life+dt
        if life>=maxLife-0.6 and not isFading then
            isFading=true; pe.Enabled=false; pe2.Enabled=false
            pcall(function()
                TweenService:Create(outerGlow,TweenInfo.new(0.2),{Size=Vector3.new(180,180,180),Transparency=0.6}):Play()
                TweenService:Create(glow,TweenInfo.new(0.2),{Size=Vector3.new(90,90,90),Transparency=0}):Play()
                TweenService:Create(pLight,TweenInfo.new(0.2),{Range=600,Brightness=10}):Play()
                for _,pt in ipairs({head,body,tail,tail2}) do TweenService:Create(pt,TweenInfo.new(0.5),{Transparency=1}):Play() end
            end)
        end
        if life>=maxLife then
            pcall(function() head:Destroy(); body:Destroy(); tail:Destroy(); tail2:Destroy(); glow:Destroy(); outerGlow:Destroy() end)
            pcall(function() meteorConn:Disconnect() end)
            return
        end
        -- [StellarEngineA] bezier trajectory
        local tRatio=math.min(life/maxLife,1)
        local np=StellarEngineA:calcMeteorPos(p0,p1,p2,tRatio)
        local dir=(p2-p0).Unit

        pcall(function()
            if not isFading then
                head.CFrame=CFrame.new(np)
                body.CFrame=CFrame.lookAt(np-dir*(len*0.5),np-dir*(len*0.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail.CFrame=CFrame.lookAt(np-dir*(len*1.6),np-dir*(len*1.6)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail2.CFrame=CFrame.lookAt(np-dir*(len*3.5),np-dir*(len*3.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                local pulse=1+math.sin(life*30)*0.2
                glow.CFrame=CFrame.new(np); glow.Size=Vector3.new(24*pulse,24*pulse,24*pulse)
                outerGlow.CFrame=CFrame.new(np)
                outerGlow.Transparency=0.92+math.sin(life*4)*0.04
                -- color shift ตาม time
                local hShift=((life*12)%360)/360
                head.Color=Color3.fromHSV(hShift*0.08,0.9,1)
                glow.Color=head.Color
                pLight.Color=head.Color
            end
        end)
    end)
    table.insert(meteorConns,meteorConn)
end

local function startMeteor()
    clearMeteor(); meteorRunning=true
    meteorFolder=Instance.new("Folder",workspace); meteorFolder.Name="StellarMeteor"
    task.spawn(function()
        while meteorRunning do
            spawnOneMeteor(); task.wait(math.max(0.4,math.random()*State.meteorInterval))
        end
    end)
end

-- ================================================================
-- SECTION 14: SUN (สวยขึ้น — corona + chromatic rays + lens flare)
-- ================================================================
local sunFolder=nil; local sunConns={}

local function clearSunray()
    for _,c in pairs(sunConns) do pcall(function() c:Disconnect() end) end
    sunConns={}
    if sunFolder and sunFolder.Parent then pcall(function() sunFolder:Destroy() end) end
    sunFolder=nil
end

local function startSunray()
    clearSunray()
    sunFolder=Instance.new("Folder",workspace); sunFolder.Name="StellarSun"
    local cam=workspace.CurrentCamera

    local function mkSphere(parent,sz,col,tr)
        local p=Instance.new("Part",parent); p.Size=Vector3.new(sz,sz,sz)
        p.Material=Enum.Material.Neon; p.Color=col; p.Transparency=tr
        p.CastShadow=false; p.Anchored=true; p.CanCollide=false
        Instance.new("SpecialMesh",p).MeshType=Enum.MeshType.Sphere
        return p
    end

    -- Core layers (ซ้อนหลายชั้น)
    local core    = mkSphere(sunFolder, 100, Color3.fromRGB(255,252,200), 0)
    local core2   = mkSphere(sunFolder,  80, Color3.fromRGB(255,255,255), 0.1)  -- ขาวสว่างตรงกลาง
    local core3   = mkSphere(sunFolder, 115, Color3.fromRGB(255,240,140), 0.3)  -- halo ชั้นแรก

    local sunLight=Instance.new("PointLight",core)
    sunLight.Color=Color3.fromRGB(255,225,160); sunLight.Brightness=6; sunLight.Range=1200; sunLight.Shadows=false

    -- [NEW] Secondary light สีอุ่น
    local sunLight2=Instance.new("PointLight",core2)
    sunLight2.Color=Color3.fromRGB(255,180,80); sunLight2.Brightness=3; sunLight2.Range=600; sunLight2.Shadows=false

    -- Corona layers (5 ชั้นไล่สี)
    local coronaData={
        {sz=150, col=Color3.fromRGB(255,232,110), tr=0.52},
        {sz=210, col=Color3.fromRGB(255,198,60),  tr=0.68},
        {sz=290, col=Color3.fromRGB(255,158,30),  tr=0.80},
        {sz=410, col=Color3.fromRGB(255,110,10),  tr=0.90},
        {sz=570, col=Color3.fromRGB(255,65,0),    tr=0.95},
        -- [NEW] outermost chromatic glow
        {sz=780, col=Color3.fromRGB(200,80,255),  tr=0.98},
    }
    local coronaParts={}
    for _,l in ipairs(coronaData) do
        local c=mkSphere(sunFolder,l.sz,l.col,l.tr)
        table.insert(coronaParts,{part=c,baseSz=l.sz,baseTr=l.tr,baseCol=l.col})
    end

    -- Ambient glow
    local ambGlow=mkSphere(sunFolder,900,Color3.fromRGB(255,140,30),0.975)

    -- [NEW] Inner flare cross (4 spikes เล็กๆ)
    local flares={}
    for i=1,4 do
        local f=Instance.new("Part",sunFolder)
        f.Size=Vector3.new(2,2,math.random(80,160))
        f.Material=Enum.Material.Neon; f.Color=Color3.fromRGB(255,255,200)
        f.Transparency=0.55; f.CastShadow=false; f.Anchored=true; f.CanCollide=false
        table.insert(flares,{part=f, angle=(i/4)*math.pi*2})
    end

    -- Fibonacci sphere rays (20 main + 12 sub)
    local RAY_MAIN=20; local RAY_SUB=12
    local rays={}
    for i=1,RAY_MAIN+RAY_SUB do
        local isMain = i<=RAY_MAIN
        local r=Instance.new("Part",sunFolder)
        r.Size=Vector3.new(isMain and 6 or 3, isMain and 6 or 3, math.random(isMain and 500 or 250, isMain and 950 or 600))
        r.Material=Enum.Material.Neon; r.Color=Color3.fromRGB(255,230,130)
        r.Transparency=isMain and 0.60 or 0.72
        r.CastShadow=false; r.Anchored=true; r.CanCollide=false
        local total = RAY_MAIN+RAY_SUB
        local phi   = math.acos(1-2*i/(total+1))
        local theta = math.pi*(1+math.sqrt(5))*(i-1)
        table.insert(rays,{part=r,phi=phi,theta=theta,isMain=isMain,rLen=r.Size.Z})
    end

    local t0=tick(); local springVel=0; local springVal=1
    local conn=RunService.Heartbeat:Connect(function(dt)
        if not sunFolder or not sunFolder.Parent then return end
        StellarEngineA:beginPass("sun")
        local cp=cam.CFrame.Position
        local t=tick()-t0; local ag=t*0.018
        local sunPos=cp+Vector3.new(math.cos(ag)*800, 400+math.sin(t*0.1)*40, math.sin(ag)*800)

        -- [StellarEngineA] spring pulse
        local targetPulse=1+StellarEngineA:pulse(t,0.6)*0.06
        springVal,springVel=StellarEngineA:springStep(springVal,springVel,targetPulse,120,14,dt)
        local pulse=springVal

        pcall(function()
            -- core layers
            core.CFrame=CFrame.new(sunPos); core.Size=Vector3.new(100*pulse,100*pulse,100*pulse)
            core2.CFrame=CFrame.new(sunPos); core2.Size=Vector3.new(80*pulse,80*pulse,80*pulse)
            core3.CFrame=CFrame.new(sunPos); core3.Size=Vector3.new(115*pulse,115*pulse,115*pulse)
            core3.Transparency=0.3+StellarEngineA:pulse(t,0.8)*0.12

            ambGlow.CFrame=CFrame.new(sunPos)
            ambGlow.Transparency=0.974+math.sin(t*0.6)*0.022

            -- corona
            for _,lc in ipairs(coronaParts) do
                lc.part.CFrame=CFrame.new(sunPos)
                local sz=lc.baseSz*pulse
                lc.part.Size=Vector3.new(sz,sz,sz)
                lc.part.Transparency=lc.baseTr+math.sin(t*1.2+lc.baseSz*0.008)*0.025
                -- chromatic shift ชั้นนอกสุด
                if lc.baseSz >= 570 then
                    local h=((t*5)%360)/360
                    lc.part.Color=Color3.fromHSV(h,0.7,1)
                end
            end

            -- inner flare cross
            for _,f in ipairs(flares) do
                local fa=f.angle+t*0.8
                local fDir=Vector3.new(math.cos(fa),math.sin(fa*0.3),math.sin(fa))
                f.part.CFrame=CFrame.lookAt(sunPos,sunPos+fDir)*CFrame.Angles(math.pi/2,0,0)
                f.part.Transparency=0.5+StellarEngineA:pulse(t,1.2,f.angle)*0.3
                f.part.Color=Color3.fromHSV(((t*15+f.angle*30)%360)/360, 0.3, 1)
            end

            -- fibonacci rays
            for i,r in ipairs(rays) do
                local dir=StellarEngineA:calcRayDir(i,RAY_MAIN+RAY_SUB,t,0.35)
                local midPt=sunPos+dir*(r.rLen*0.5)
                r.part.CFrame=CFrame.lookAt(midPt,midPt+dir)
                r.part.Transparency=(r.isMain and 0.58 or 0.70)+math.abs(math.sin(t*2+r.phi))*0.25
                local hue=((t*7+r.phi*22+r.theta*5)%360)/360
                r.part.Color=Color3.fromHSV(
                    0.07+hue*0.08,
                    0.85-hue*0.2,
                    1
                )
            end
        end)
        StellarEngineA:endPass("sun")
    end)
    table.insert(sunConns,conn)
end

-- ================================================================
-- SECTION 15: TIME LOOP
-- ================================================================
local ModeText="Status: Loading..."; local BorderColorNow=Color3.fromRGB(180,0,255)
local rainbowHue=0; local LiveTimeLabel=nil

task.spawn(function()
    while task.wait(0.25) do
        if not State.horrorFogEnabled and not State.horrorBlue and not State.rainEnabled
            and not State.heavenlyEnabled and not State.dawnEnabled and not State.sunsetEnabled
            and not State.nostalgiaEnabled then
            local t=Lighting.ClockTime
            if t>=6 and t<19 then applyLighting(PROFILES.DAY); ModeText="Day"; BorderColorNow=Color3.fromRGB(255,220,100)
            else applyLighting(PROFILES.NIGHT); ModeText="Night"; BorderColorNow=Color3.fromRGB(100,180,255) end
            applyCinematicBlend()
        end
    end
end)

-- ================================================================
-- SECTION 16: PBR
-- ================================================================
local function applyPBROnPart(v)
    if not State.pbrEnabled or State.isFpsBoostOn then return end
    if not v or not v.Parent then return end
    if not(v:IsA("BasePart") or v:IsA("MeshPart")) then return end
    local pn=v.Parent and v.Parent.Name or ""
    if pn=="StellarRain" or pn=="StellarSakura" or pn=="StellarMeteor" or pn=="StellarSun" then return end
    v.CastShadow=true; local m=v.Material; local r=0
    if m==Enum.Material.Concrete then r=0.15 elseif m==Enum.Material.SmoothPlastic then r=0.35
    elseif m==Enum.Material.Cobblestone then r=0.08 elseif m==Enum.Material.Wood or m==Enum.Material.WoodPlanks then r=0.03
    elseif m==Enum.Material.Marble then r=0.55 elseif m==Enum.Material.Granite then r=0.3
    elseif m==Enum.Material.Metal or m==Enum.Material.DiamondPlate then r=0.65
    elseif m==Enum.Material.Glass then r=0.8 elseif m==Enum.Material.Neon then r=0.85
    elseif m==Enum.Material.Ice then r=0.7 elseif m==Enum.Material.Sand then r=0.02 end
    if State.antiBlueGloss then
        local c=v.Color; local lum=c.R*0.299+c.G*0.587+c.B*0.114
        v.Reflectance=lum<0.18 and r*(lum*3.5) or r
    else v.Reflectance=r end
end

local function runPBRScan()
    local n=0; local cam=workspace.CurrentCamera
    for _,v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if(v:IsA("BasePart") or v:IsA("MeshPart")) and (v.Position-cam.CFrame.Position).Magnitude<200 then applyPBROnPart(v) end
        end)
        n=n+1; if n%200==0 then task.wait() end
    end
end
task.spawn(runPBRScan)
workspace.DescendantAdded:Connect(function(v) task.delay(0.2,function() pcall(function() applyPBROnPart(v) end) end) end)

-- ================================================================
-- SECTION 17: FPS BOOST
-- ================================================================
local function triggerFPSBoost(on)
    State.isFpsBoostOn=on
    if on then
        local n=0
        for _,v in pairs(workspace:GetDescendants()) do
            pcall(function()
                local pn=v.Parent and v.Parent.Name or ""
                if(v:IsA("BasePart") or v:IsA("MeshPart")) and pn~="StellarRain" and pn~="StellarSakura" and pn~="StellarMeteor" and pn~="StellarSun" then
                    if not State.originalMaterials[v] then State.originalMaterials[v]=v.Material; State.originalShadows[v]=v.CastShadow end
                    v.Material=Enum.Material.SmoothPlastic; v.CastShadow=false; v.Reflectance=0
                elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency=1 end
            end); n=n+1; if n%300==0 then task.wait() end
        end
        pcall(function() Terrain.Decoration=false; Lighting.GlobalShadows=false end)
    else
        local n=0
        for v,mat in pairs(State.originalMaterials) do
            pcall(function() if v and v.Parent then v.Material=mat; v.CastShadow=State.originalShadows[v] or false end end)
            n=n+1; if n%300==0 then task.wait() end
        end
        for _,v in pairs(workspace:GetDescendants()) do pcall(function() if v:IsA("Decal") or v:IsA("Texture") then v.Transparency=0 end end) end
        pcall(function() Terrain.Decoration=true; Lighting.GlobalShadows=true end)
        table.clear(State.originalMaterials); table.clear(State.originalShadows); task.spawn(runPBRScan)
    end
end

-- StellarEngineB Heartbeat (CPU queue — ก่อน render)
RunService.Heartbeat:Connect(function()
    StellarEngineB:flush()
    StellarEngineA:resetFrame()
end)
-- ================================================================
-- SECTION 18: UI ANIMATION FRAMEWORK
-- ================================================================
local ScreenGui=Instance.new("ScreenGui",CoreGui)
ScreenGui.Name="STELLARHUB_MYTHICAL"; ScreenGui.ResetOnSpawn=false; ScreenGui.IgnoreGuiInset=true

local SMOOTH     =TweenInfo.new(0.22,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
local SMOOTH_BACK=TweenInfo.new(0.28,Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local SMOOTH_FAST=TweenInfo.new(0.12,Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function tw(obj,props,info)
    pcall(function() TweenService:Create(obj,info or SMOOTH,props):Play() end)
end

local function spring(btn)
    pcall(function()
        local us=btn:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",btn)
        us.Scale=1.0
        btn.MouseEnter:Connect(function()
            pcall(function() tw(us,{Scale=1.08},SMOOTH_BACK); tw(btn,{BackgroundTransparency=0.05},SMOOTH_FAST) end)
        end)
        btn.MouseLeave:Connect(function()
            pcall(function() tw(us,{Scale=1.0},SMOOTH); tw(btn,{BackgroundTransparency=0.32},SMOOTH_FAST) end)
        end)
        btn.InputBegan:Connect(function(i)
            if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=0.93},SMOOTH_FAST) end) end
        end)
        btn.InputEnded:Connect(function(i)
            if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=1.0},SMOOTH_BACK) end) end
        end)
    end)
end

local function addBounceOnHold(frame)
    local holdThread=nil
    frame.InputBegan:Connect(function(input)
        if isTouchOrMouse(input.UserInputType) then
            if holdThread then pcall(function() task.cancel(holdThread) end) end
            holdThread=task.delay(0.28,function()
                if isInputBlocked() then holdThread=nil; return end
                pcall(function()
                    local us=frame:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",frame)
                    us.Scale=1
                    tw(us,{Scale=1.12},TweenInfo.new(0.1,Enum.EasingStyle.Quad,Enum.EasingDirection.Out))
                    task.wait(0.1)
                    tw(us,{Scale=1.0},TweenInfo.new(0.28,Enum.EasingStyle.Bounce,Enum.EasingDirection.Out))
                end)
                holdThread=nil
            end)
            input.Changed:Connect(function()
                if input.UserInputState==Enum.UserInputState.End then
                    if holdThread then pcall(function() task.cancel(holdThread) end); holdThread=nil end
                end
            end)
        end
    end)
end

