end)

local presets={30,60,90,120,144,165}
local presetRow=Instance.new("Frame",TabFPS); presetRow.Size=UDim2.new(1,-14,0,22); presetRow.Position=UDim2.new(0,UI.PAD_X,0,122); presetRow.BackgroundTransparency=1
for i,fps in ipairs(presets) do
    local pb=Instance.new("TextButton",presetRow); pb.Size=UDim2.new(1/#presets,-2,1,0); pb.Position=UDim2.new((i-1)/#presets,1,0,0)
    pb.BackgroundColor3=fps==165 and Color3.fromRGB(220,158,0) or Color3.fromRGB(28,28,40); pb.BackgroundTransparency=0.28
    pb.Text=fps==165 and "165!" or tostring(fps); pb.TextColor3=fps==165 and Color3.fromRGB(255,255,255) or UI.COL_SUBTEXT
    pb.Font=UI.FONT_CODE; pb.TextSize=9; Instance.new("UICorner",pb).CornerRadius=UDim.new(0,5); spring(pb)
    pb.MouseButton1Click:Connect(function()
        State.targetFpsCap=fps; FPSValueLabel.Text="Cap: "..fps.." FPS"
        AITargetLabel.Text="🤖 AI target: "..fps.."fps"
        StellarAI.targetFPS=fps; StellarAI._degradeStep=0
        pcall(function() if setfpscap then setfpscap(fps) end end)
    end)
end

