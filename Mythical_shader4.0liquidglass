-- PRE-DECLARE TRACKS FOR TOGGLE ACCESS
local CinDOFTrack = Instance.new("Frame", TabCinema)
local CinConTrack = Instance.new("Frame", TabCinema)
local CinExpTrack = Instance.new("Frame", TabCinema)
local CinShadTrack = Instance.new("Frame", TabCinema)
local CinFOVTrack = Instance.new("Frame", TabCinema)
local originalFOV = workspace.CurrentCamera.FieldOfView

createToggle(TabCinema, "Cinematic Mode", 3, cinematicEnabled, function(val)
    cinematicEnabled = val
    if val then
        horrorFogEnabled = false 
        rainEnabled = false 
        heavenlyEnabled = false
        clearRainParticles()
        ModeText = "Status: Cinematic" 
        BorderColorNow = Color3.fromRGB(120,120,180)
        local p = PROFILES.CINEMATIC
        
        Lighting.Brightness = p.brightness 
        Lighting.ExposureCompensation = p.exposure
        Lighting.ShadowSoftness = p.shadow 
        Lighting.OutdoorAmbient = p.ambient
        Atmosphere.Color = p.atmoColor 
        Atmosphere.Decay = p.atmoDecay
        Atmosphere.Glare = p.atmoGlare 
        Atmosphere.Haze = p.atmoHaze 
        Atmosphere.Density = p.atmoDensity
        
        ColorCorrection.Contrast = p.contrast 
        ColorCorrection.Saturation = p.saturation
        ColorCorrection.TintColor = p.tint
        
        Bloom.Intensity = p.bloom 
        Bloom.Size = p.bloomSize 
        Bloom.Threshold = p.bloomThreshold
        DOF.FarIntensity = p.dofFar 
        SunRays.Intensity = p.sunRays
        
        Lighting.FogStart = 80 
        Lighting.FogEnd = 500
        Lighting.FogColor = Color3.fromRGB(20,22,30)
        
        if CinDOFTrack then CinDOFTrack.BackgroundTransparency = 0.3 end
        if CinConTrack then CinConTrack.BackgroundTransparency = 0.3 end
        if CinExpTrack then CinExpTrack.BackgroundTransparency = 0.3 end
        if CinShadTrack then CinShadTrack.BackgroundTransparency = 0.3 end
        if CinFOVTrack then CinFOVTrack.BackgroundTransparency = 0.3 end
        
        workspace.CurrentCamera.FieldOfView = lerpN(30, 120, 0.44) -- Default ~70
    else
        resetFogLighting()
        ModeText = "Status: Normal"
        if CinDOFTrack then CinDOFTrack.BackgroundTransparency = 0.7 end
        if CinConTrack then CinConTrack.BackgroundTransparency = 0.7 end
        if CinExpTrack then CinExpTrack.BackgroundTransparency = 0.7 end
        if CinShadTrack then CinShadTrack.BackgroundTransparency = 0.7 end
        if CinFOVTrack then CinFOVTrack.BackgroundTransparency = 0.7 end
        
        workspace.CurrentCamera.FieldOfView = originalFOV
    end
end)

