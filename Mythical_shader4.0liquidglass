    ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(200,215,255)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255))
})
ShimGrad.Transparency = NumberSequence.new({
    NumberSequenceKeypoint.new(0, 1),
    NumberSequenceKeypoint.new(0.5, 0.6),
    NumberSequenceKeypoint.new(1, 1)
})
task.spawn(function()
    while task.wait(0.05) do
        if not MainFrame or not MainFrame.Parent then break end
        pcall(function() ShimGrad.Offset = Vector2.new(math.sin(tick() * 0.9) * 0.5, 0) end)
    end
end)

