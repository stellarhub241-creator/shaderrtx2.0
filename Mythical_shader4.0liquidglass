    pb.Text=fps==165 and "165!" or tostring(fps) pb.TextColor3=Color3.fromRGB(255,255,255) pb.Font=Enum.Font.Code pb.TextSize=9
    Instance.new("UICorner",pb).CornerRadius=UDim.new(0,4) applySpringPhysics(pb)
    pb.MouseButton1Click:Connect(function()
        if fps==165 then targetFpsCap=165 FPSValueLabel.Text="Cap: 165 FPS ⚡" pcall(function() if setfpscap then setfpscap(165) end end) pcall(function() TweenService:Create(SliderFill,TweenInfo.new(0.2,Enum.EasingStyle.Back),{Size=UDim2.new(1,0,1,0)}):Play() TweenService:Create(SliderKnob,TweenInfo.new(0.2,Enum.EasingStyle.Back),{Position=UDim2.new(1,-8,0.5,-8)}):Play() end)
        else setFpsCap(fps) end
    end)
end
