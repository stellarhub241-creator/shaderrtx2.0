local function createToggle(parent,text,order,defaultVal,callback)
    local F=Instance.new("Frame",parent); F.Size=UDim2.new(1,-14,0,30); F.Position=UDim2.new(0,UI.PAD_X,0,(order-1)*36+6); F.BackgroundTransparency=1
    local L=Instance.new("TextLabel",F); L.Size=UDim2.new(0.68,0,1,0); L.BackgroundTransparency=1; L.Text=text
    L.TextColor3=UI.COL_TEXT; L.TextSize=UI.SIZE_BODY; L.Font=UI.FONT_BODY; L.TextXAlignment=Enum.TextXAlignment.Left
    Instance.new("UIStroke",L).Transparency=0.65
    local TB=Instance.new("TextButton",F); TB.Size=UDim2.new(0,48,0,22); TB.Position=UDim2.new(1,-48,0.5,-11)
    local theme=COLOR_THEMES[State.currentThemeIndex]
    TB.BackgroundColor3=defaultVal and (theme and theme.primary or Color3.fromRGB(160,0,235)) or Color3.fromRGB(38,38,50)
    TB.BackgroundTransparency=0.28; TB.Text=defaultVal and "ON" or "OFF"; TB.TextColor3=Color3.fromRGB(255,255,255)
    TB.Font=UI.FONT_TITLE; TB.TextSize=UI.SIZE_SMALL
    Instance.new("UICorner",TB).CornerRadius=UI.CORNER_PILL
    Instance.new("UIStroke",TB).Color=Color3.fromRGB(150,150,180)
    spring(TB)
    local cur=defaultVal
    TB.MouseButton1Click:Connect(function()
        cur=not cur
        local th=COLOR_THEMES[State.currentThemeIndex]
        tw(TB,{BackgroundColor3=cur and (th and th.primary or Color3.fromRGB(160,0,235)) or Color3.fromRGB(38,38,50)},SMOOTH_BACK)
        TB.Text=cur and "ON" or "OFF"
        if callback then pcall(function() callback(cur) end) end
    end)
    return TB
end

local function autoCanvas(scroll,n,h,gap,pad) scroll.CanvasSize=UDim2.new(0,0,0,pad+n*(h+gap)) end

