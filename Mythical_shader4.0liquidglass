    sunFolder=nil
end

local function startSunray()
    clearSunray()
    sunFolder=Instance.new("Folder",workspace) sunFolder.Name="StellarSun"
    local cam=workspace.CurrentCamera
    local sunCore=Instance.new("Part",sunFolder)
    sunCore.Size=Vector3.new(12,12,12) sunCore.Material=Enum.Material.Neon
    sunCore.Color=Color3.fromRGB(255,240,160) sunCore.Transparency=0
    sunCore.CastShadow=false sunCore.Anchored=true sunCore.CanCollide=false
    Instance.new("SpecialMesh",sunCore).MeshType=Enum.MeshType.Sphere
    local corona=Instance.new("Part",sunFolder)
    corona.Size=Vector3.new(22,22,22) corona.Material=Enum.Material.Neon
    corona.Color=Color3.fromRGB(255,200,80) corona.Transparency=0.6
    corona.CastShadow=false corona.Anchored=true corona.CanCollide=false
    Instance.new("SpecialMesh",corona).MeshType=Enum.MeshType.Sphere
    local glow=Instance.new("Part",sunFolder)
    glow.Size=Vector3.new(36,36,36) glow.Material=Enum.Material.Neon
    glow.Color=Color3.fromRGB(255,160,40) glow.Transparency=0.82
    glow.CastShadow=false glow.Anchored=true glow.CanCollide=false
    Instance.new("SpecialMesh",glow).MeshType=Enum.MeshType.Sphere
    local pe=Instance.new("ParticleEmitter",sunCore)
    pe.Texture="rbxassetid://6101261905" pe.Rate=20 pe.Lifetime=NumberRange.new(0.8,1.8)
    pe.Speed=NumberRange.new(8,20) pe.SpreadAngle=Vector2.new(180,180)
    pe.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,240,160)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,120,0))})
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.8),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1.0 pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.2),NumberSequenceKeypoint.new(1,1)})
    local t0=tick()
    local conn=RunService.Heartbeat:Connect(function()
        if not sunFolder or not sunFolder.Parent then return end
        local cp=cam.CFrame.Position
        local t=tick()-t0
        local ag=t*0.05
        local sunPos=cp+Vector3.new(math.cos(ag)*200,160,math.sin(ag)*200)
        local pulse=1+math.sin(t*2)*0.04
        pcall(function()
            sunCore.CFrame=CFrame.new(sunPos)
            corona.CFrame=CFrame.new(sunPos) corona.Size=Vector3.new(22*pulse,22*pulse,22*pulse)
            glow.CFrame=CFrame.new(sunPos) glow.Size=Vector3.new(36*pulse,36*pulse,36*pulse)
        end)
    end)
    table.insert(sunConns,conn)
end

