local cinTracks={}

local function makeSlider(parent,yLbl,labelText,yTrack,fillColor,knobColor,defRel)
    local lbl=Instance.new("TextLabel",parent)
    lbl.Size=UDim2.new(1,-16,0,13) lbl.Position=UDim2.new(0,8,0,yLbl)
    lbl.BackgroundTransparency=1 lbl.Text=labelText
    lbl.TextColor3=Color3.fromRGB(162,168,192) lbl.TextSize=10
    lbl.Font=Enum.Font.SourceSans lbl.TextXAlignment=Enum.TextXAlignment.Left
    
    local track=Instance.new("Frame",parent)
    track.Size=UDim2.new(1,-16,0,7) track.Position=UDim2.new(0,8,0,yTrack)
    track.BackgroundColor3=Color3.fromRGB(30,25,45) track.BackgroundTransparency=0.7 track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(0,4)
    
    local fill=Instance.new("Frame",track)
    fill.Size=UDim2.new(defRel,0,1,0) fill.BackgroundColor3=fillColor fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(0,4)
    
    local knob=Instance.new("TextButton",track)
    knob.Size=UDim2.new(0,14,0,14) knob.Position=UDim2.new(defRel,-7,0.5,-7)
    knob.BackgroundColor3=knobColor knob.Text="" knob.BorderSizePixel=0 knob.ZIndex=5
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
    spring(knob)
    
    return track,fill,knob
end

local function bindSlider(track,fill,knob,condFn,changeFn)
    local dragging=false

    -- เริ่มลาก (รองรับทั้งการคลิกเมาส์และการทัชหน้าจอ)
    local function onInputStart(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end

    knob.InputBegan:Connect(onInputStart)
    track.InputBegan:Connect(onInputStart)

    -- สิ้นสุดการลาก (เช็คแบบ Global แก้ปัญหาเมาส์หลุดขอบ)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    -- ระหว่างลาก
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
        if condFn and not condFn() then return end
        
        local rel=math.clamp((input.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        fill.Size=UDim2.new(rel,0,1,0) knob.Position=UDim2.new(rel,-7,0.5,-7)
        pcall(function() changeFn(rel) end)
    end)
end

local CinTitle=Instance.new("TextLabel",TabCinema)
CinTitle.Size=UDim2.new(1,-16,0,16) CinTitle.Position=UDim2.new(0,8,0,4)
CinTitle.BackgroundTransparency=1 CinTitle.Text="🎬 Cinematic Mode"
CinTitle.TextColor3=Color3.fromRGB(200,200,200) CinTitle.TextSize=11
CinTitle.Font=Enum.Font.SourceSansBold CinTitle.TextXAlignment=Enum.TextXAlignment.Left

createToggle(TabCinema,"Cinematic Mode",1,false,function(val)
    cinematicEnabled=val
    if val then
        if horrorFogEnabled or rainEnabled or heavenlyEnabled then cinematicEnabled=false return end
        ModeText="Status: Cinematic" BorderColorNow=Color3.fromRGB(120,120,180)
        clearRainParticles()
        pcall(function()
            applyLighting(PROFILES.CINEMATIC)
            Lighting.GlobalShadows=true Lighting.ShadowSoftness=0.65
            Lighting.FogStart=80 Lighting.FogEnd=500 Lighting.FogColor=Color3.fromRGB(20,22,30)
            workspace.CurrentCamera.FieldOfView=70
        end)
        for _,tr in pairs(cinTracks) do tr.BackgroundTransparency=0.25 end
    else
        resetFogLighting() ModeText="Status: Normal"
        pcall(function() workspace.CurrentCamera.FieldOfView=originalFOV end)
        for _,tr in pairs(cinTracks) do tr.BackgroundTransparency=0.7 end
    end
end)

local BY=50
local sliderDefs={
    {BY+0,  "DOF Intensity",           BY+15,  Color3.fromRGB(100,130,220),Color3.fromRGB(200,215,255),0.55, function(r) DOF.FarIntensity=r end},
    {BY+38, "Contrast",                BY+53,  Color3.fromRGB(180,80,255), Color3.fromRGB(225,185,255),0.6,  function(r) ColorCorrection.Contrast=lerpN(-1,1,r) end},
    {BY+76, "Brightness/Exposure",     BY+91,  Color3.fromRGB(255,195,80), Color3.fromRGB(255,250,190),0.45, function(r) Lighting.ExposureCompensation=lerpN(-2,1,r) end},
    {BY+114,"Shadow Softness",         BY+129, Color3.fromRGB(130,130,130),Color3.fromRGB(210,210,210),0.65, function(r) Lighting.ShadowSoftness=r end},
    {BY+152,"Saturation",              BY+167, Color3.fromRGB(100,220,180),Color3.fromRGB(180,255,235),0.4,  function(r) ColorCorrection.Saturation=lerpN(-1,1,r) end},
    {BY+190,"Bloom Intensity",         BY+205, Color3.fromRGB(255,240,80), Color3.fromRGB(255,255,190),0.08, function(r) Bloom.Intensity=r*2 end},
    {BY+228,"Atmosphere Haze",         BY+243, Color3.fromRGB(140,175,220),Color3.fromRGB(195,218,255),0.3,  function(r) Atmosphere.Haze=r*5 end},
    {BY+266,"Fog Start",               BY+281, Color3.fromRGB(100,160,200),Color3.fromRGB(180,220,255),0.1,  function(r) Lighting.FogStart=lerpN(0,300,r) end},
    {BY+304,"Fog End",                 BY+319, Color3.fromRGB(60,120,180), Color3.fromRGB(140,200,255),0.3,  function(r) Lighting.FogEnd=lerpN(50,2000,r) end},
    {BY+342,"Field of View (30-120°)", BY+357, Color3.fromRGB(80,210,170), Color3.fromRGB(170,255,220),0.44, function(r) pcall(function() workspace.CurrentCamera.FieldOfView=lerpN(30,120,r) end) end},
    {BY+380,"Sun Rays",                BY+395, Color3.fromRGB(255,160,50), Color3.fromRGB(255,210,150),0.05, function(r) SunRays.Intensity=r end},
    {BY+418,"Rain Particles (10-150)", BY+433, Color3.fromRGB(100,180,255),Color3.fromRGB(180,225,255),0.25, function(r) rainParticleCount=math.floor(lerpN(10,150,r)) if rainEnabled then createRainParticles() end end},
}

for _,def in ipairs(sliderDefs) do
    local tr,fi,kn=makeSlider(TabCinema,def[1],def[2],def[3],def[4],def[5],def[6])
    local isFogOrParticle = string.find(def[2],"Fog") or string.find(def[2],"Rain")
    bindSlider(tr,fi,kn, isFogOrParticle and nil or function() return cinematicEnabled end, def[7])
    table.insert(cinTracks,tr)
end
autoCanvas(TabCinema,#sliderDefs+2,38,0,22)

