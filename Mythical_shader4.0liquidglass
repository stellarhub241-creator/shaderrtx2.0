-- ==================== DRAG ====================
local dragToggle, dragStart, startPos
local isDragging       = false
local longPressThread  = nil

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragToggle = true
        dragStart  = input.Position
        startPos   = MainFrame.Position
        if longPressThread then
            pcall(function() task.cancel(longPressThread) end)
            longPressThread = nil
        end
        longPressThread = task.delay(0.4, function()
            if not isDragging then
                pcall(function()
                    local ox = MainFrame.Size.X.Offset
                    local oy = MainFrame.Size.Y.Offset
                    TweenService:Create(MainFrame, TweenInfo.new(0.15,Enum.EasingStyle.Back,Enum.EasingDirection.In), {
                        Size = UDim2.new(0, ox*0.92, 0, oy*0.92)
                    }):Play()
                    task.wait(0.15)
                    TweenService:Create(MainFrame, TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {
                        Size = UDim2.new(0, ox, 0, oy)
                    }):Play()
                end)
            end
            longPressThread = nil
        end)
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragToggle  = false
                isDragging  = false
                if longPressThread then
                    pcall(function() task.cancel(longPressThread) end)
                    longPressThread = nil
                end
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggle then
        local delta = input.Position - dragStart
        if not isDragging and (math.abs(delta.X) > 3 or math.abs(delta.Y) > 3) then
            isDragging = true
            if longPressThread then
                pcall(function() task.cancel(longPressThread) end)
                longPressThread = nil
            end
        end
        if isDragging then
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+delta.X, startPos.Y.Scale, startPos.Y.Offset+delta.Y)
        end
    end
end)

