-- ================================================================
-- SECTION 2: SAS — Stellar Allocation System
-- ================================================================
local SAS = {
    MAX_TOKENS=7, usedTokens=0, _registry={},
    PRIORITY={sun=5,meteor=4,rain=3,sakura=2,wind=1},
    COST={sun=2,meteor=2,rain=1,sakura=1,wind=1},
    register=function(self,id)
        self._registry[id]={active=false,cost=self.COST[id] or 1,priority=self.PRIORITY[id] or 1,quality=1.0}
    end,
    request=function(self,id)
        local r=self._registry[id]; if not r then return false,0 end
        if r.active then return true,r.quality end
        local needed=r.cost; local free=self.MAX_TOKENS-self.usedTokens
        if free>=needed then
            r.active=true; r.quality=1.0
            self.usedTokens=math.min(self.MAX_TOKENS,self.usedTokens+needed)
            self:_log("ALLOC "..id.." used="..self.usedTokens.."/"..self.MAX_TOKENS)
            return true,1.0
        else
            local freed=self:_evict(needed-free,r.priority)
            if freed+free>=needed then
                r.active=true; r.quality=0.65
                self.usedTokens=math.min(self.MAX_TOKENS,self.usedTokens+needed)
                self:_log("ALLOC(reduced) "..id.." Q=65%")
                return true,0.65
            else
                self:_log("DENY "..id.." (token full)")
                return false,0
            end
        end
    end,
    release=function(self,id)
        local r=self._registry[id]
        if not r or not r.active then return end
        r.active=false; r.quality=1.0
        self.usedTokens=math.max(0,self.usedTokens-r.cost)
        self:_restoreQuality()
        self:_log("FREE "..id.." used="..self.usedTokens.."/"..self.MAX_TOKENS)
    end,
    forceQuality=function(self,id,q)
        local r=self._registry[id]; if not r or not r.active then return end
        r.quality=math.clamp(q,0.2,1.0)
    end,
    _evict=function(self,needed,minPriority)
        local freed=0; local sorted={}
        for id,r in pairs(self._registry) do
            if r.active and r.priority<minPriority then table.insert(sorted,{id=id,r=r}) end
        end
        table.sort(sorted,function(a,b) return a.r.priority<b.r.priority end)
        for _,entry in ipairs(sorted) do
            if freed>=needed then break end
            entry.r.quality=0.4
            freed=freed+math.floor(entry.r.cost*0.5)
            self:_log("EVICT-Q "..entry.id.." Q→40%")
        end
        return freed
    end,
    _restoreQuality=function(self)
        local free=self.MAX_TOKENS-self.usedTokens
        for id,r in pairs(self._registry) do
            if r.active and r.quality<1.0 and free>0 then
                r.quality=math.min(1.0,r.quality+0.25)
                self:_log("RESTORE "..id.." Q="..math.floor(r.quality*100).."%")
            end
        end
    end,
    getQuality=function(self,id) local r=self._registry[id]; return r and r.quality or 1.0 end,
    resetAll=function(self)
        self.usedTokens=0
        for id,r in pairs(self._registry) do r.active=false; r.quality=1.0 end
        self:_log("RESET ALL")
    end,
    getStatus=function(self)
        local lines={string.format("Tokens: %d/%d",self.usedTokens,self.MAX_TOKENS)}
        local ordered={"sun","meteor","rain","sakura","wind"}
        for _,id in ipairs(ordered) do
            local r=self._registry[id]
            if r then
                lines[#lines+1]=string.format("  %-8s P%d cost%d %s Q=%.0f%%",id,r.priority,r.cost,r.active and "[ON]" or "[--]",r.quality*100)
            end
        end
        return table.concat(lines,"\n")
    end,
    _log_buf={},
    _log=function(self,msg)
        local e=string.format("[%.1f] SAS: %s",tick()%10000,msg)
        table.insert(self._log_buf,e)
        if #self._log_buf>40 then table.remove(self._log_buf,1) end
    end,
    getLog=function(self) return table.concat(self._log_buf,"\n") end,
}
for id in pairs(SAS.COST) do SAS:register(id) end
SAS:resetAll()

-- ================================================================
-- SECTION 3: StellarA — CPU Math/Trajectory Engine
-- ================================================================
local StellarA = {
    newSpring=function(k,d)
        return {val=0,vel=0,k=k or 200,d=d or 20,
            update=function(s,dt,target)
                local f=-s.k*(s.val-target)-s.d*s.vel
                s.vel=s.vel+f*dt; s.val=s.val+s.vel*dt
                return s.val
            end,
            reset=function(s,v) s.val=v; s.vel=0 end}
    end,
    bezier=function(p0,p1,p2,p3,t)
        local u=1-t
        return u*u*u*p0+3*u*u*t*p1+3*u*t*t*p2+t*t*t*p3
    end,
    smoothNoise=function(x,y,z,oct)
        oct=oct or 3; local v,a,f=0,1,1
        for i=1,oct do v=v+math.noise(x*f,(y or 0)*f,(z or 0)*f)*a; a=a*0.5; f=f*2.1 end
        return v
    end,
    trajectory=function(start,vel,gravity,t)
        return Vector3.new(start.X+vel.X*t,start.Y+vel.Y*t+0.5*gravity*t*t,start.Z+vel.Z*t)
    end,
    fibSphere=function(i,total)
        local phi=math.acos(1-2*i/(total+1))
        local theta=math.pi*(1+math.sqrt(5))*(i-1)
        return Vector3.new(math.sin(phi)*math.cos(theta),math.cos(phi),math.sin(phi)*math.sin(theta))
    end,
    remap=function(v,inMin,inMax,outMin,outMax) return outMin+(v-inMin)/(inMax-inMin)*(outMax-outMin) end,
    newEMA=function(alpha)
        return {val=nil,alpha=alpha or 0.1,
            update=function(s,x)
                if s.val==nil then s.val=x; return x end
                s.val=s.alpha*x+(1-s.alpha)*s.val; return s.val
            end}
    end,
    pulse=function(t,freq,phase) return (math.sin(t*freq*math.pi*2+(phase or 0))+1)*0.5 end,
    lerpN=function(a,b,t) return a+(b-a)*t end,
    lerpC=function(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end,
    lerpHSV=function(a,b,t)
        local ah,as,av=Color3.toHSV(a); local bh,bs,bv=Color3.toHSV(b)
        local dh=bh-ah; if dh>0.5 then dh=dh-1 end; if dh<-0.5 then dh=dh+1 end
        return Color3.fromHSV((ah+dh*t)%1,math.clamp(as+(bs-as)*t,0,1),math.clamp(av+(bv-av)*t,0,1))
    end,
    sampleGradient=function(colors,t)
        if #colors==0 then return Color3.new(1,1,1) end
        if #colors==1 then return colors[1] end
        local seg=(t*(#colors-1)); local idx=math.floor(seg); local frac=seg-idx
        idx=math.clamp(idx,0,#colors-2)
        return StellarA.lerpHSV(colors[idx+1],colors[idx+2],frac)
    end,
    orbit=function(center,radius,angle,height,tilt)
        return center+Vector3.new(math.cos(angle)*radius,height+math.sin(tilt)*20,math.sin(angle)*radius)
    end,
    meteorArc=function(progress,startY,peakY,endY)
        local p=progress
        return startY*(1-p)*(1-p)+peakY*2*p*(1-p)+endY*p*p
    end,
    lerpColorHSV=function(a,b,t)
        local ah,as,av=Color3.toHSV(a); local bh,bs,bv=Color3.toHSV(b)
        local dh=bh-ah; if dh>0.5 then dh=dh-1 end; if dh<-0.5 then dh=dh+1 end
        return Color3.fromHSV((ah+dh*t)%1,math.clamp(as+(bs-as)*t,0,1),math.clamp(av+(bv-av)*t,0,1))
    end,
}

-- ================================================================
-- SECTION 4: StellarEngineB — GPU-like Batch Particle Compute
-- ================================================================
local StellarEngineB = {
    _pool = {},
    registerBatch = function(self, id, items)
        self._pool[id] = items
    end,
    clearBatch = function(self, id)
        self._pool[id] = nil
    end,
    -- คำนวณ sakura batch: drift + fall ทุกตัวในรอบเดียว
    computeSakuraBatch = function(self, items, dt, t)
        for idx=1,#items do
            local s = items[idx]
            local dx = math.sin(t*0.8+s.phase)*0.8 + math.sin(t*1.7+s.phase*1.3)*0.32
            local dz = math.cos(t*0.6+s.phase)*0.8 + math.cos(t*2.1+s.phase*0.7)*0.24
            s.x = s.x + dx*dt
            s.z = s.z + dz*dt
            s.y = s.y - s.vy*dt*60
            s.rot = s.rot + s.rotSpeed*dt
            s.life = s.life + dt
        end
    end,
    -- คำนวณ rain batch: fall เร็ว ตรงลง
    computeRainBatch = function(self, items, t)
        for idx=1,#items do
            local p = items[idx]
            local ph = idx*0.73
            p.fall = (t*16+ph*2.8)%32
        end
    end,
    getStatus = function(self)
        local n=0
        for _ in pairs(self._pool) do n=n+1 end
        return "StellarEngineB OK | active batches: "..n
    end,
}

-- ================================================================
-- SECTION 5: StellarFlu — Fluid Graphics Engine
-- ================================================================
local StellarFlu = {
    sunAuraColor=function(dist,coreColor,t)
        local colors={Color3.fromRGB(255,255,230),Color3.fromRGB(255,240,160),Color3.fromRGB(255,200,80),Color3.fromRGB(255,140,30),Color3.fromRGB(255,60,0),Color3.fromRGB(180,20,0)}
        local base=StellarA.sampleGradient(colors,dist)
        local pulse=0.92+math.sin(t*1.4+dist*math.pi)*0.08
        return Color3.new(math.clamp(base.R*pulse,0,1),math.clamp(base.G*pulse,0,1),math.clamp(base.B*pulse,0,1))
    end,
    sunAuraAlpha=function(dist,t)
        local base=dist*dist*0.95+0.04
        local breath=math.sin(t*1.2+dist*3)*0.025
        return math.clamp(base+breath,0,1)
    end,
    meteorTrailColor=function(dist,baseColor,t)
        local colors={Color3.fromRGB(255,255,255),baseColor,Color3.fromRGB(255,180,60),Color3.fromRGB(180,60,0),Color3.fromRGB(40,10,0)}
        return StellarA.sampleGradient(colors,dist)
    end,
    sakuraPetalColor=function(seed,themeColor)
        local h,s,v=Color3.toHSV(themeColor)
        local hVar=(h+(seed%7)*0.015-0.05)%1
        local sVar=math.clamp(s*0.7+0.15,0,1)
        local vVar=math.clamp(v*0.9+0.08,0,1)
        return Color3.fromHSV(hVar,sVar,vVar)
    end,
    shimmerOffset=function(t,speed) return StellarA.smoothNoise(t*(speed or 0.7),0,0)*0.6 end,
    bloomCurve=function(intensity) return StellarA.bezier(0,0.2,0.8,1.0,math.clamp(intensity,0,1)) end,
    grade=function(col,contrast,saturation,tint)
        local r,g,b=col.R,col.G,col.B
        r=math.clamp((r-0.5)*contrast+0.5,0,1); g=math.clamp((g-0.5)*contrast+0.5,0,1); b=math.clamp((b-0.5)*contrast+0.5,0,1)
        local lum=r*0.299+g*0.587+b*0.114
        r=math.clamp(lum+(r-lum)*saturation,0,1); g=math.clamp(lum+(g-lum)*saturation,0,1); b=math.clamp(lum+(b-lum)*saturation,0,1)
        r=math.clamp(r*tint.R,0,1); g=math.clamp(g*tint.G,0,1); b=math.clamp(b*tint.B,0,1)
        return Color3.new(r,g,b)
    end,
    particleFade=function(lifeRatio,fadeIn,fadeOut)
        fadeIn=fadeIn or 0.15; fadeOut=fadeOut or 0.75
        if lifeRatio<fadeIn then return StellarA.bezier(0,0,0.8,1.0,lifeRatio/fadeIn)
        elseif lifeRatio>fadeOut then return StellarA.bezier(1.0,0.8,0.2,0,(lifeRatio-fadeOut)/(1-fadeOut)) end
        return 1.0
    end,
    getStatus=function() return "StellarFlu OK\nModules: sunAura/meteorTrail/sakuraPetal/shimmer/bloomCurve/grade/fade" end,
}
-- ================================================================
-- SECTION 6: StellarAI — Supreme Commander
-- ================================================================
local StellarAI = {
    enabled=true, fpsHistory={}, fpsIdx=0, fpsSize=60, qualityLevel=1.0,
    errorLog={}, watchedRefs={}, lastCheck=0, checkInterval=2.5, aiTimer=0,
    distTimer=0, distLog={},

    pushFPS=function(self,fps) self.fpsIdx=(self.fpsIdx%self.fpsSize)+1; self.fpsHistory[self.fpsIdx]=fps end,
    avgFPS=function(self)
        local s,n=0,0
        for _,v in pairs(self.fpsHistory) do if v then s=s+v; n=n+1 end end
        return n>0 and s/n or 60
    end,
    adapt=function(self,State,createRainParticles,createSakura)
        if not self.enabled then return end
        local avg=self:avgFPS(); local target=State.targetFpsCap
        local ratio=avg/math.max(target,30)
        local newQ
        if ratio>=0.88 then newQ=1.0 elseif ratio>=0.72 then newQ=0.75
        elseif ratio>=0.55 then newQ=0.5 else newQ=0.3 end
        if math.abs(newQ-self.qualityLevel)>0.15 then
            self.qualityLevel=newQ
            if State.rainEnabled then
                local adj=math.max(10,math.floor(State.rainParticleCount*newQ))
                State.rainParticleCount=adj; pcall(createRainParticles)
            end
            if State.sakuraEnabled then
                local adj=math.max(8,math.floor(State.sakuraCount*newQ))
                State.sakuraCount=adj; pcall(createSakura)
            end
            self:log(string.format("ADAPT Q=%.0f%% avgFPS=%.0f",newQ*100,avg))
        end
    end,
    checkDistanceQuality=function(self,refs)
        local cam=workspace.CurrentCamera; if not cam then return end
        local cp=cam.CFrame.Position
        for id,getPos in pairs(refs) do
            local ok,pos=pcall(getPos)
            if ok and pos then
                local dist=(pos-cp).Magnitude
                local distQ
                if dist<=300 then distQ=1.0
                elseif dist<=700 then distQ=StellarA.remap(dist,300,700,1.0,0.4)
                else distQ=0.25 end
                pcall(function() SAS:forceQuality(id,distQ) end)
                self.distLog[id]=string.format("%s dist=%.0f Q=%.0f%%",id,dist,distQ*100)
            end
        end
    end,
    watch=function(self,id,getter,name) self.watchedRefs[id]={getter=getter,name=name,ok=true,miss=0} end,
    check=function(self,callbacks)
        if not self.enabled then return end
        local now=tick(); if now-self.lastCheck<self.checkInterval then return end
        self.lastCheck=now
        for id,w in pairs(self.watchedRefs) do
            local ok=pcall(function()
                local r=w.getter(); if r==nil then error("nil") end
                if typeof(r)=="Instance" and not r.Parent then error("no parent") end
            end)
            if not ok then
                w.miss=w.miss+1
                if w.ok then self:log("[WARN] "..w.name.." dead"); w.ok=false end
                if callbacks and callbacks[id] then
                    local fixOk=pcall(callbacks[id])
                    if fixOk then self:log("[HEAL] "..w.name.." restored"); w.ok=true; w.miss=0 end
                end
            else w.ok=true; w.miss=0 end
        end
    end,
    log=function(self,msg)
        local e=string.format("[%.1f] AI: %s",tick()%10000,msg)
        table.insert(self.errorLog,e)
        if #self.errorLog>80 then table.remove(self.errorLog,1) end
    end,
    getReport=function(self)
        local lines={"=== StellarAI Report ===",string.format("Quality: %.0f%%  AvgFPS: %.0f",self.qualityLevel*100,self:avgFPS()),"","=== SAS (Token Budget) ===",SAS:getStatus(),"","=== Distance Quality ==="}
        for id,line in pairs(self.distLog) do lines[#lines+1]="  "..line end
        lines[#lines+1]=""; lines[#lines+1]="=== StellarEngineB ==="; lines[#lines+1]=StellarEngineB:getStatus()
        lines[#lines+1]=""; lines[#lines+1]="=== StellarFlu ==="; lines[#lines+1]=StellarFlu.getStatus()
        lines[#lines+1]=""; lines[#lines+1]="=== Watches ==="
        for id,w in pairs(self.watchedRefs) do lines[#lines+1]=string.format("  %s: %s miss=%d",w.name,w.ok and "OK" or "DEAD",w.miss) end
        lines[#lines+1]=""; lines[#lines+1]="=== Recent Log ==="
        local n=#self.errorLog
        for i=math.max(1,n-6),n do if self.errorLog[i] then lines[#lines+1]=self.errorLog[i] end end
        return table.concat(lines,"\n")
    end,
}

