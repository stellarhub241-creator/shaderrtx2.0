-- ================================================================
-- SECTION 21: TABS
-- ================================================================
local function makeTab()
    local s=Instance.new("ScrollingFrame",ContentArea)
    s.Size=UDim2.new(1,0,1,0) s.BackgroundTransparency=1 s.BorderSizePixel=0
    s.ScrollBarThickness=3 s.ScrollBarImageColor3=Color3.fromRGB(160,0,235)
    s.CanvasSize=UDim2.new(0,0,0,600) s.ScrollingDirection=Enum.ScrollingDirection.Y
    s.ElasticBehavior=Enum.ElasticBehavior.Always s.Visible=false s.ClipsDescendants=true
    return s
end

local TabGfx=makeTab() local TabSky=makeTab()
local TabBoost=makeTab() local TabTheme=makeTab()
local TabFPS=makeTab() local TabCinema=makeTab()
local TabParticle=makeTab()
local allTabs={TabGfx,TabSky,TabBoost,TabTheme,TabFPS,TabCinema,TabParticle}

local TAB_DEFS={
    {text="Graphics",  icon="🎨", tab=TabGfx},
    {text="Skybox",    icon="🌌", tab=TabSky},
    {text="Boost",     icon="⚡", tab=TabBoost},
    {text="Theme",     icon="💎", tab=TabTheme},
    {text="FPS Cap",   icon="📊", tab=TabFPS},
    {text="Cinema",    icon="🎬", tab=TabCinema},
    {text="Particle",  icon="✨", tab=TabParticle},
}

-- ================================================================
-- SECTION 22: TAB BUTTONS (White Glass โทน)
-- ================================================================
local tabButtons={} local activeTab=nil
local BTN_H,BTN_GAP=26,30

for i,def in ipairs(TAB_DEFS) do
    local Btn=Instance.new("TextButton",Sidebar)
    Btn.Size=UDim2.new(1,-8,0,BTN_H) Btn.Position=UDim2.new(0,4,0,(i-1)*BTN_GAP+6)
    Btn.BackgroundColor3=Color3.fromRGB(220,218,240) Btn.BackgroundTransparency=0.42
    Btn.Text=def.icon.." "..def.text
    -- [FIX] text สีเข้ม
    Btn.TextColor3=Color3.fromRGB(80,72,110)
    Btn.Font=Enum.Font.SourceSansBold Btn.TextSize=10
    Instance.new("UICorner",Btn).CornerRadius=UDim.new(0,7)
    local bs=Instance.new("UIStroke",Btn) bs.Thickness=1 bs.Color=Color3.fromRGB(185,178,218) bs.Transparency=0.45
    spring(Btn)
    table.insert(tabButtons,{btn=Btn,tab=def.tab})
end
Sidebar.CanvasSize=UDim2.new(0,0,0,#TAB_DEFS*BTN_GAP+20)

local function refreshTabButtons()
    local theme=COLOR_THEMES[currentThemeIndex]
    for _,bd in pairs(tabButtons) do
        local s=bd.btn:FindFirstChildOfClass("UIStroke")
        if bd.tab==activeTab then
            if theme.glass then
                tw(bd.btn,{BackgroundColor3=Color3.fromRGB(200,228,248),BackgroundTransparency=0.18,TextColor3=Color3.fromRGB(40,100,160)},SMOOTH)
                if s then tw(s,{Color=Color3.fromRGB(140,200,240),Transparency=0.1},SMOOTH) end
            else
                tw(bd.btn,{BackgroundColor3=theme.primary,BackgroundTransparency=0.08,TextColor3=Color3.fromRGB(255,255,255)},SMOOTH)
                if s then tw(s,{Color=theme.secondary,Transparency=0.2},SMOOTH) end
            end
        else
            tw(bd.btn,{BackgroundColor3=Color3.fromRGB(220,218,240),BackgroundTransparency=0.42,TextColor3=Color3.fromRGB(80,72,110)},SMOOTH)
            if s then tw(s,{Color=Color3.fromRGB(185,178,218),Transparency=0.45},SMOOTH) end
        end
    end
end

local function switchTab(targetTab)
    if activeTab==targetTab then return end
    if activeTab then
        local old=activeTab
        tw(old,{Position=UDim2.new(-0.07,0,0,0)},TweenInfo.new(0.11,Enum.EasingStyle.Quart,Enum.EasingDirection.In))
        task.delay(0.08,function() if old then old.Visible=false old.Position=UDim2.new(0,0,0,0) end end)
    end
    activeTab=targetTab
    refreshTabButtons()
    targetTab.Position=UDim2.new(0.07,0,0,0) targetTab.Visible=true
    tw(targetTab,{Position=UDim2.new(0,0,0,0)},TweenInfo.new(0.2,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
end

for _,bd in pairs(tabButtons) do bd.btn.MouseButton1Click:Connect(function() switchTab(bd.tab) end) end
switchTab(TabGfx)

-- ================================================================
-- SECTION 23: DRAG
-- ================================================================
local dragToggle,dragStart,startPos,isDragging=false,nil,nil,false
local isDraggingMainFrame=false

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        dragToggle=true dragStart=input.Position startPos=MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then dragToggle=false isDragging=false isDraggingMainFrame=false end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if not dragToggle then return end
    if input.UserInputType~=Enum.UserInputType.MouseMovement and input.UserInputType~=Enum.UserInputType.Touch then return end
    local delta=input.Position-dragStart
    if not isDragging and (math.abs(delta.X)>5 or math.abs(delta.Y)>5) then isDragging=true isDraggingMainFrame=true end
    if isDragging then
        local vp=workspace.CurrentCamera.ViewportSize
        MainFrame.Position=UDim2.new(0,math.clamp(startPos.X.Offset+delta.X,6,vp.X-MainFrame.Size.X.Offset-6),0,math.clamp(startPos.Y.Offset+delta.Y,6,vp.Y-MainFrame.Size.Y.Offset-6))
    end
end)

-- ================================================================
-- SECTION 24: MINIMIZE (ดาว ⭐)
-- ================================================================
local isMinimized=false
MinBtn.MouseButton1Click:Connect(function()
    isMinimized=not isMinimized
    if isMinimized then
        TitleLabel.Visible=false Sidebar.Visible=false ContentArea.Visible=false
        SidebarLine.Visible=false TitleSep.Visible=false
        tw(MainFrame,{Size=UDim2.new(0,40,0,40),BackgroundColor3=Color3.fromRGB(240,238,252),BackgroundTransparency=0.05},
            TweenInfo.new(0.28,Enum.EasingStyle.Back,Enum.EasingDirection.In))
        MinBtn.Size=UDim2.new(1,-4,1,-4) MinBtn.Position=UDim2.new(0,2,0,2)
        MinBtn.TextSize=22
        -- pulse
        task.spawn(function()
            while isMinimized do
                tw(MinBtn,{TextColor3=Color3.fromRGB(220,170,0)},TweenInfo.new(0.7))
                task.wait(0.7)
                tw(MinBtn,{TextColor3=Color3.fromRGB(255,215,50)},TweenInfo.new(0.7))
                task.wait(0.7)
            end
        end)
    else
        tw(MainFrame,{Size=UDim2.new(0,332,0,272),BackgroundColor3=Color3.fromRGB(240,242,248),BackgroundTransparency=0.12},
            TweenInfo.new(0.32,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
        MinBtn.Size=UDim2.new(0,26,0,26) MinBtn.Position=UDim2.new(1,-32,0.5,-13)
        MinBtn.TextSize=14 MinBtn.TextColor3=Color3.fromRGB(200,160,0)
        task.delay(0.18,function()
            Sidebar.Visible=true ContentArea.Visible=true TitleLabel.Visible=true
            SidebarLine.Visible=true TitleSep.Visible=true
        end)
    end
end)

-- ================================================================
-- SECTION 25: TOGGLE HELPER (White Glass สี)
-- ================================================================
local function createToggle(parent,text,order,defaultVal,callback)
    local F=Instance.new("Frame",parent)
    F.Size=UDim2.new(1,-16,0,30) F.Position=UDim2.new(0,8,0,(order-1)*36+6) F.BackgroundTransparency=1
    local L=Instance.new("TextLabel",F)
    L.Size=UDim2.new(0.68,0,1,0) L.BackgroundTransparency=1 L.Text=text
    -- [FIX] text สีเข้มบน UI ขาว
    L.TextColor3=Color3.fromRGB(50,42,70) L.TextSize=11 L.Font=Enum.Font.SourceSans L.TextXAlignment=Enum.TextXAlignment.Left
    local TB=Instance.new("TextButton",F)
    TB.Size=UDim2.new(0,46,0,22) TB.Position=UDim2.new(1,-46,0.5,-11)
    TB.BackgroundColor3=defaultVal and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(200,198,218)
    TB.BackgroundTransparency=0.1 TB.Text=defaultVal and "ON" or "OFF"
    TB.TextColor3=defaultVal and Color3.fromRGB(255,255,255) or Color3.fromRGB(80,72,110)
    TB.Font=Enum.Font.SourceSansBold TB.TextSize=10
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,11)
    local tbs=Instance.new("UIStroke",TB) tbs.Color=Color3.fromRGB(180,175,210) tbs.Thickness=1
    spring(TB)
    local cur=defaultVal
    TB.MouseButton1Click:Connect(function()
        cur=not cur
        tw(TB,{BackgroundColor3=cur and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(200,198,218)},SMOOTH_BACK)
        TB.Text=cur and "ON" or "OFF"
        TB.TextColor3=cur and Color3.fromRGB(255,255,255) or Color3.fromRGB(80,72,110)
        pcall(function() callback(cur) end)
    end)
    return TB
end

local function autoCanvas(scroll,n,h,gap,pad)
    scroll.CanvasSize=UDim2.new(0,0,0,pad+n*(h+gap))
end

-- ================================================================
-- SECTION 26: BALL SLIDER (White Glass, กดไม่ลดความทึบ)
-- ================================================================
local allSliderBalls={}

local function makeBallSlider(parent,yPos,labelText,defRel,changeFn)
    local theme=COLOR_THEMES[currentThemeIndex]

    local container=Instance.new("Frame",parent)
    container.Size=UDim2.new(1,-14,0,46)
    container.Position=UDim2.new(0,7,0,yPos)
    -- [FIX] container ขาวนวล frosted
    container.BackgroundColor3=Color3.fromRGB(245,245,252)
    container.BackgroundTransparency=0.22
    container.BorderSizePixel=0
    Instance.new("UICorner",container).CornerRadius=UDim.new(0,9)
    local cstroke=Instance.new("UIStroke",container)
    cstroke.Thickness=1 cstroke.Color=Color3.fromRGB(195,190,225) cstroke.Transparency=0.3

    local lbl=Instance.new("TextLabel",container)
    lbl.Size=UDim2.new(0.72,0,0,17) lbl.Position=UDim2.new(0,10,0,3)
    lbl.BackgroundTransparency=1 lbl.Text=labelText
    lbl.TextColor3=Color3.fromRGB(50,42,70) lbl.TextSize=10
    lbl.Font=Enum.Font.SourceSansBold lbl.TextXAlignment=Enum.TextXAlignment.Left

    local valLbl=Instance.new("TextLabel",container)
    valLbl.Size=UDim2.new(0.28,-8,0,17) valLbl.Position=UDim2.new(0.72,0,0,3)
    valLbl.BackgroundTransparency=1 valLbl.Text=math.floor(defRel*100).."%"
    valLbl.TextColor3=theme.primary valLbl.TextSize=10
    valLbl.Font=Enum.Font.Code valLbl.TextXAlignment=Enum.TextXAlignment.Right

    local track=Instance.new("Frame",container)
    track.Size=UDim2.new(1,-20,0,8) track.Position=UDim2.new(0,10,0,27)
    track.BackgroundColor3=Color3.fromRGB(210,208,232) track.BackgroundTransparency=0.2 track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(0,4)

    -- tick marks
    for ti=0,8 do
        local tk=Instance.new("Frame",track)
        tk.Size=UDim2.new(0,1,ti%2==0 and 0.62 or 0.4,0)
        tk.Position=UDim2.new(ti/8,0,ti%2==0 and 0.19 or 0.3,0)
        tk.BackgroundColor3=Color3.fromRGB(160,155,195)
        tk.BackgroundTransparency=ti%2==0 and 0.25 or 0.52 tk.BorderSizePixel=0
    end

    local fill=Instance.new("Frame",track)
    fill.Size=UDim2.new(defRel,0,1,0) fill.BackgroundColor3=Color3.fromRGB(255,255,255) fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(0,4)
    local fillGrad=Instance.new("UIGradient",fill)
    fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(230,228,242)),ColorSequenceKeypoint.new(1,theme.primary)})

    local ballShadow=Instance.new("Frame",track)
    ballShadow.Size=UDim2.new(0,15,0,6) ballShadow.Position=UDim2.new(defRel,-7.5,1,-2.5)
    ballShadow.BackgroundColor3=Color3.fromRGB(80,60,120) ballShadow.BackgroundTransparency=0.72
    ballShadow.BorderSizePixel=0 ballShadow.ZIndex=4
    Instance.new("UICorner",ballShadow).CornerRadius=UDim.new(1,0)

    -- [FIX] ลูกบอล: ขาว→สีธีม ซ้ายขวา ไม่ลดความทึบตอนกด
    local ball=Instance.new("TextButton",track)
    ball.Size=UDim2.new(0,20,0,20) ball.Position=UDim2.new(defRel,-10,0.5,-10)
    ball.BackgroundColor3=Color3.fromRGB(248,248,255) ball.Text="" ball.BorderSizePixel=0 ball.ZIndex=6
    Instance.new("UICorner",ball).CornerRadius=UDim.new(1,0)
    local ballGrad=Instance.new("UIGradient",ball)
    ballGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(1,theme.ball)})
    ballGrad.Rotation=0
    local ballStroke=Instance.new("UIStroke",ball)
    ballStroke.Color=lerpC(theme.primary,Color3.fromRGB(120,100,180),0.4) ballStroke.Thickness=2.0

    -- [FIX] spring แบบไม่ลด BackgroundTransparency
    pcall(function()
        local us=ball:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",ball)
        us.Scale=1.0
        ball.MouseEnter:Connect(function() pcall(function() tw(us,{Scale=1.1},SMOOTH_BACK) end) end)
        ball.MouseLeave:Connect(function() pcall(function() tw(us,{Scale=1.0},SMOOTH) end) end)
        ball.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                -- [FIX] แค่ scale ลง ไม่ลด transparency
                pcall(function() tw(us,{Scale=0.9},SMOOTH_FAST) end)
            end
        end)
        ball.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                pcall(function() tw(us,{Scale=1.0},SMOOTH_BACK) end)
            end
        end)
    end)
    addBounceOnHold(ball)

    local sliderRef={fill=fill,fillGrad=fillGrad,ball=ball,ballGrad=ballGrad,ballStroke=ballStroke,valLbl=valLbl,ballShadow=ballShadow}
    table.insert(allSliderBalls,sliderRef)

    local dragging=false local lastRel=defRel

    local function startDrag(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            if isDraggingMainFrame then return end
            dragging=true
        end
    end
    ball.InputBegan:Connect(startDrag)
    track.InputBegan:Connect(startDrag)

    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=false
        end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if isDraggingMainFrame then dragging=false return end
        if i.UserInputType~=Enum.UserInputType.MouseMovement and i.UserInputType~=Enum.UserInputType.Touch then return end
        local rel=math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        if math.abs(rel-lastRel)<0.002 then return end
        -- กลิ้ง
        pcall(function() ball.Rotation=ball.Rotation+(rel-lastRel)*360*2 end)
        lastRel=rel
        fill.Size=UDim2.new(rel,0,1,0)
        ball.Position=UDim2.new(rel,-10,0.5,-10)
        ballShadow.Position=UDim2.new(rel,-7.5,1,-2.5)
        valLbl.Text=math.floor(rel*100).."%"
        local ct=COLOR_THEMES[currentThemeIndex]
        fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(230,228,242)),ColorSequenceKeypoint.new(1,lerpC(Color3.fromRGB(190,185,218),ct.primary,rel))})
        pcall(function() changeFn(rel) end)
    end)

    return container,fill,ball,valLbl
end

local function refreshAllSliders()
    local theme=COLOR_THEMES[currentThemeIndex]
    for _,s in ipairs(allSliderBalls) do
        pcall(function()
            s.fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(230,228,242)),ColorSequenceKeypoint.new(1,theme.primary)})
            s.ballGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(1,theme.ball)})
            s.ballStroke.Color=lerpC(theme.primary,Color3.fromRGB(120,100,180),0.4)
            s.valLbl.TextColor3=theme.primary
        end)
    end
end

-- ================================================================
-- SECTION 27: GRAPHICS TAB
-- (Dawn/Sunset กลับมาเป็น toggle ใน Graphics tab)
-- ================================================================
createToggle(TabGfx,"Depth of Field",1,dofEnabled,function(val)
    dofEnabled=val local d=Lighting:FindFirstChild("StellarDOF") if d then d.Enabled=val end
end)
createToggle(TabGfx,"4K PBR Reflectance",2,pbrEnabled,function(val)
    pbrEnabled=val
    if val then task.spawn(runPBRScan)
    else for _,v in pairs(workspace:GetDescendants()) do pcall(function() if v:IsA("BasePart") or v:IsA("MeshPart") then v.Reflectance=0 end end) end end
end)
createToggle(TabGfx,"Anti-Blue Gloss",3,antiBlueGloss,function(val)
    antiBlueGloss=val if pbrEnabled then task.spawn(runPBRScan) end
end)

-- [NEW] Dawn toggle ใน Graphics
createToggle(TabGfx,"🌄 Dawn Mode",4,false,function(val)
    dawnEnabled=val
    if val then
        sunsetEnabled=false  -- ปิด sunset ถ้าเปิด dawn
        ModeText="Status: Dawn" BorderColorNow=Color3.fromRGB(255,180,200)
        applyLighting(PROFILES.DAWN)
        pcall(function() Lighting.ClockTime=5.5 end)
        applyCinematicBlend()
    else
        if not horrorFogEnabled and not rainEnabled and not heavenlyEnabled and not sunsetEnabled then
            resetFogLighting()
        end
        ModeText="Status: Normal"
    end
end)

-- [NEW] Sunset toggle ใน Graphics
createToggle(TabGfx,"🌅 Sunset Mode",5,false,function(val)
    sunsetEnabled=val
    if val then
        dawnEnabled=false  -- ปิด dawn ถ้าเปิด sunset
        ModeText="Status: Sunset" BorderColorNow=Color3.fromRGB(255,150,60)
        applyLighting(PROFILES.GOLDEN)
        pcall(function() Lighting.ClockTime=19 end)
        applyCinematicBlend()
    else
        if not horrorFogEnabled and not rainEnabled and not heavenlyEnabled and not dawnEnabled then
            resetFogLighting()
        end
        ModeText="Status: Normal"
    end
end)

createToggle(TabGfx,"🌧 Rain Mode",6,false,function(val)
    rainEnabled=val
    if val then
        ModeText="Status: Rainy" BorderColorNow=Color3.fromRGB(100,160,255)
        applyLighting(PROFILES.RAIN)
        pcall(function() Lighting.FogStart=20 Lighting.FogEnd=200 Lighting.FogColor=Color3.fromRGB(110,122,142) end)
        applyCinematicBlend() createRainParticles()
    else
        clearRainParticles()
        if not horrorFogEnabled and not heavenlyEnabled then resetFogLighting() end
        ModeText="Status: Normal"
    end
end)

createToggle(TabGfx,"👼 Heavenly Mode",7,false,function(val)
    heavenlyEnabled=val
    if val then
        ModeText="Status: Heavenly" BorderColorNow=Color3.fromRGB(255,240,120)
        applyLighting(PROFILES.HEAVENLY)
        pcall(function() Lighting.FogStart=500 Lighting.FogEnd=2000 Lighting.FogColor=Color3.fromRGB(225,235,255) Lighting.ClockTime=12 end)
        applyCinematicBlend()
    else
        if not horrorFogEnabled and not rainEnabled then resetFogLighting() end
        ModeText="Status: Normal"
    end
end)

