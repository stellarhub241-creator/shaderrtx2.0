        i.Changed:Connect(function() if i.UserInputState.Name=="End" then pDrag=false end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if pDrag and (i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch")) then
        local d=i.Position-pDragStart; local vp=workspace.CurrentCamera.ViewportSize
        FPSPopup.Position=UDim2.new(0,math.clamp(pStartPos.X.Offset+d.X,6,vp.X-FPSPopup.Size.X.Offset-6),0,math.clamp(pStartPos.Y.Offset+d.Y,6,vp.Y-FPSPopup.Size.Y.Offset-6))
    end
end)
