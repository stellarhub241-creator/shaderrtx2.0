ContentArea.BackgroundTransparency=1; ContentArea.ClipsDescendants=true

-- ================================================================
-- SECTION 24: TABS
-- ================================================================
local function makeTab()
    local s=Instance.new("ScrollingFrame",ContentArea)
    s.Size=UDim2.new(1,0,1,0); s.BackgroundTransparency=1; s.BorderSizePixel=0
    s.ScrollBarThickness=3; s.ScrollBarImageColor3=Color3.fromRGB(160,0,235)
    s.CanvasSize=UDim2.new(0,0,0,600); s.ScrollingDirection=Enum.ScrollingDirection.Y
    s.ElasticBehavior=Enum.ElasticBehavior.Always; s.Visible=false; s.ClipsDescendants=true
    return s
end

local TabGfx=makeTab(); local TabSky=makeTab(); local TabBoost=makeTab()
local TabTheme=makeTab(); local TabFPS=makeTab(); local TabCinema=makeTab()
local TabParticle=makeTab(); local TabAI=makeTab()

local TAB_DEFS={
    {text="Graphics", icon="🎨",tab=TabGfx},
    {text="Skybox",   icon="🌌",tab=TabSky},
    {text="Boost",    icon="⚡",tab=TabBoost},
    {text="Theme",    icon="💎",tab=TabTheme},
    {text="FPS Cap",  icon="📊",tab=TabFPS},
    {text="Cinema",   icon="🎬",tab=TabCinema},
    {text="Particle", icon="✨",tab=TabParticle},
    {text="AI",       icon="🤖",tab=TabAI},
}

-- ================================================================
-- SECTION 25: TAB BUTTONS
-- ================================================================
local tabButtons={}; local activeTab=nil
local BTN_H=UI.BTN_H; local BTN_GAP=34

for i,def in ipairs(TAB_DEFS) do
    local Btn=Instance.new("TextButton",Sidebar)
    Btn.Size=UDim2.new(1,-UI.PAD,0,BTN_H)
    Btn.Position=UDim2.new(0,UI.PAD/2,0,(i-1)*BTN_GAP+UI.PAD)
    Btn.BackgroundColor3=Color3.fromRGB(28,28,42); Btn.BackgroundTransparency=0.38
    Btn.Text=def.icon.." "..def.text; Btn.TextColor3=UI.C_TEXT
    Btn.Font=Enum.Font.SourceSansBold; Btn.TextSize=10
    Instance.new("UICorner",Btn).CornerRadius=UI.RADIUS_SM
    local bs=Instance.new("UIStroke",Btn); bs.Thickness=1; bs.Color=UI.C_STROKE; bs.Transparency=0.45
    spring(Btn); table.insert(tabButtons,{btn=Btn,tab=def.tab})
end
Sidebar.CanvasSize=UDim2.new(0,0,0,#TAB_DEFS*BTN_GAP+UI.PAD*2)

local function refreshTabButtons()
    local theme=COLOR_THEMES[State.currentThemeIndex]
    for _,bd in pairs(tabButtons) do
        local s=bd.btn:FindFirstChildOfClass("UIStroke")
        if bd.tab==activeTab then
            tw(bd.btn,{BackgroundColor3=theme.primary,BackgroundTransparency=0.18,TextColor3=Color3.fromRGB(255,255,255)},SMOOTH)
            if s then tw(s,{Color=theme.secondary,Transparency=0.08},SMOOTH) end
        else
            tw(bd.btn,{BackgroundColor3=Color3.fromRGB(28,28,42),BackgroundTransparency=0.38,TextColor3=UI.C_TEXT},SMOOTH)
            if s then tw(s,{Color=UI.C_STROKE,Transparency=0.45},SMOOTH) end
        end
    end
end

local function switchTab(targetTab)
    if activeTab==targetTab then return end
    if activeTab then
        local old=activeTab
        tw(old,{Position=UDim2.new(-0.08,0,0,0)},TweenInfo.new(0.11,Enum.EasingStyle.Quart,Enum.EasingDirection.In))
        task.delay(0.09,function() if old then old.Visible=false; old.Position=UDim2.new(0,0,0,0) end end)
    end
    activeTab=targetTab; refreshTabButtons()
    targetTab.Position=UDim2.new(0.08,0,0,0); targetTab.Visible=true
    tw(targetTab,{Position=UDim2.new(0,0,0,0)},TweenInfo.new(0.22,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
end
for _,bd in pairs(tabButtons) do bd.btn.MouseButton1Click:Connect(function() switchTab(bd.tab) end) end
switchTab(TabGfx)

-- ================================================================
-- SECTION 26: DRAG (conflict-free)
-- ================================================================
local dragToggle,dragStart,startPos,isDragging=false,nil,nil,false

MainFrame.InputBegan:Connect(function(input)
    if isTouchOrMouse(input.UserInputType) then
        if isAnyResizeActive then return end
        dragToggle=true; dragStart=input.Position; startPos=MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then
                dragToggle=false; isDragging=false; isAnyDragActive=false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not dragToggle or isAnyResizeActive then return end
    if input.UserInputType.Name:match("MouseMovement") or input.UserInputType.Name:match("Touch") then
        local delta=input.Position-dragStart
        if not isDragging and (math.abs(delta.X)>5 or math.abs(delta.Y)>5) then
            isDragging=true; isAnyDragActive=true
            State.activeSliderId=nil  -- cancel any slider
        end
        if isDragging then
            local vp=workspace.CurrentCamera.ViewportSize
            MainFrame.Position=UDim2.new(
                0,math.clamp(startPos.X.Offset+delta.X,6,vp.X-MainFrame.Size.X.Offset-6),
                0,math.clamp(startPos.Y.Offset+delta.Y,6,vp.Y-MainFrame.Size.Y.Offset-6)
            )
            pcall(function()
                Shadow.Position=UDim2.new(0,MainFrame.Position.X.Offset-21,0,MainFrame.Position.Y.Offset-21)
            end)
        end
    end
end)

-- ================================================================
-- SECTION 27: MINIMIZE
-- ================================================================
local isMinimized=false

MinBtn.MouseButton1Click:Connect(function()
    isMinimized=not isMinimized
    local theme=COLOR_THEMES[State.currentThemeIndex]
    if isMinimized then
        for _,v in ipairs({TitleLabel,Sidebar,ContentArea,SidebarLine,TitleSep,SizeBtn}) do
            v.Visible=false
        end
        Shadow.Visible=false
        tw(MainFrame,{Size=UDim2.new(0,42,0,42),BackgroundColor3=theme.primary,BackgroundTransparency=0.04},
            TweenInfo.new(0.28,Enum.EasingStyle.Back,Enum.EasingDirection.In))
        MinBtn.Size=UDim2.new(1,-4,1,-4); MinBtn.Position=UDim2.new(0,2,0,2)
        MinBtn.TextSize=22; minStroke.Color=Color3.fromRGB(255,255,255)
    else
        local isDark=theme.dark or theme.clear
        local bgC=isDark and UI.C_BG2 or (theme.glass and Color3.fromRGB(232,240,252) or Color3.fromRGB(238,240,248))
        local bgT=1-State.uiOpacity
        tw(MainFrame,{Size=UDim2.new(0,336,0,276),BackgroundColor3=bgC,BackgroundTransparency=bgT},
            TweenInfo.new(0.32,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
        MinBtn.Size=UDim2.new(0,26,0,26); MinBtn.Position=UDim2.new(1,-32,0.5,-13)
        MinBtn.TextSize=14; MinBtn.TextColor3=Color3.fromRGB(255,200,50)
        minStroke.Color=theme.primary
        task.delay(0.2,function()
            for _,v in ipairs({TitleLabel,Sidebar,ContentArea,SidebarLine,TitleSep,SizeBtn}) do
                v.Visible=true
            end
            Shadow.Visible=true
        end)
    end
end)

-- ================================================================
-- SECTION 28: TOGGLE HELPER
-- ================================================================
local function createToggle(parent,text,order,defaultVal,callback)
    local yPos=(order-1)*UI.ROW_H+UI.PAD
    local F=Instance.new("Frame",parent)
    F.Size=UDim2.new(1,-UI.PAD*2,0,UI.ROW_H-UI.GAP)
    F.Position=UDim2.new(0,UI.PAD,0,yPos)
    F.BackgroundTransparency=1

    local L=Instance.new("TextLabel",F)
    L.Size=UDim2.new(0.68,0,1,0); L.BackgroundTransparency=1; L.Text=text
    L.TextColor3=UI.C_TEXT; L.TextSize=11; L.Font=Enum.Font.SourceSans
    L.TextXAlignment=Enum.TextXAlignment.Left
    Instance.new("UIStroke",L).Transparency=0.65

    local TB=Instance.new("TextButton",F)
    TB.Size=UDim2.new(0,48,0,22); TB.Position=UDim2.new(1,-48,0.5,-11)
    TB.BackgroundColor3=defaultVal and COLOR_THEMES[State.currentThemeIndex].primary or Color3.fromRGB(38,38,52)
    TB.BackgroundTransparency=0.25; TB.Text=defaultVal and "ON" or "OFF"
    TB.TextColor3=Color3.fromRGB(255,255,255); TB.Font=Enum.Font.SourceSansBold; TB.TextSize=10
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,11)
    local tbs=Instance.new("UIStroke",TB); tbs.Color=Color3.fromRGB(150,150,185); tbs.Thickness=1
    spring(TB)

    local cur=defaultVal
    TB.MouseButton1Click:Connect(function()
        cur=not cur
        tw(TB,{BackgroundColor3=cur and COLOR_THEMES[State.currentThemeIndex].primary or Color3.fromRGB(38,38,52)},SMOOTH_BACK)
        TB.Text=cur and "ON" or "OFF"; pcall(function() callback(cur) end)
    end)
    return TB
end

local function autoCanvas(scroll,n,h,gap,pad)
    scroll.CanvasSize=UDim2.new(0,0,0,pad+n*(h+gap))
end

-- ================================================================
-- SECTION 29: BALL SLIDER (input lock สมบูรณ์)
-- ================================================================
local allSliderBalls={}; local SLIDER_ID_COUNTER=0

local function makeBallSlider(parent,yPos,labelText,defRel,changeFn)
    SLIDER_ID_COUNTER=SLIDER_ID_COUNTER+1; local myId=SLIDER_ID_COUNTER
    local theme=COLOR_THEMES[State.currentThemeIndex]

    local container=Instance.new("Frame",parent)
    container.Size=UDim2.new(1,-UI.PAD*2,0,UI.SLIDE_H)
    container.Position=UDim2.new(0,UI.PAD,0,yPos)
    container.BackgroundColor3=UI.C_BG; container.BackgroundTransparency=0.35; container.BorderSizePixel=0
    Instance.new("UICorner",container).CornerRadius=UI.RADIUS
    local cstroke=Instance.new("UIStroke",container); cstroke.Thickness=1; cstroke.Color=UI.C_STROKE; cstroke.Transparency=0.55

    local lbl=Instance.new("TextLabel",container)
    lbl.Size=UDim2.new(0.72,0,0,18); lbl.Position=UDim2.new(0,UI.PAD,0,4)
    lbl.BackgroundTransparency=1; lbl.Text=labelText; lbl.TextColor3=UI.C_TEXT
    lbl.TextSize=10; lbl.Font=Enum.Font.SourceSansBold; lbl.TextXAlignment=Enum.TextXAlignment.Left
    Instance.new("UIStroke",lbl).Transparency=0.65

    local valLbl=Instance.new("TextLabel",container)
    valLbl.Size=UDim2.new(0.28,-UI.PAD,0,18); valLbl.Position=UDim2.new(0.72,0,0,4)
    valLbl.BackgroundTransparency=1; valLbl.Text=math.floor(defRel*100).."%"
    valLbl.TextColor3=theme.primary; valLbl.TextSize=10; valLbl.Font=Enum.Font.Code
    valLbl.TextXAlignment=Enum.TextXAlignment.Right

    local track=Instance.new("Frame",container)
    track.Size=UDim2.new(1,-UI.PAD*2,0,9); track.Position=UDim2.new(0,UI.PAD,0,30)
    track.BackgroundColor3=Color3.fromRGB(38,38,52); track.BackgroundTransparency=0.18; track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(0,5)

    for ti=0,8 do
        local tk=Instance.new("Frame",track)
        tk.Size=UDim2.new(0,1,ti%2==0 and 0.58 or 0.35,0)
        tk.Position=UDim2.new(ti/8,0,ti%2==0 and 0.21 or 0.32,0)
        tk.BackgroundColor3=Color3.fromRGB(100,100,155); tk.BackgroundTransparency=ti%2==0 and 0.3 or 0.58
        tk.BorderSizePixel=0
    end

    local fill=Instance.new("Frame",track)
    fill.Size=UDim2.new(defRel,0,1,0); fill.BackgroundColor3=Color3.fromRGB(255,255,255); fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(0,5)
    local fillGrad=Instance.new("UIGradient",fill)
    fillGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,85)),
        ColorSequenceKeypoint.new(1,theme.primary),
    })

    local ballShadow=Instance.new("Frame",track)
    ballShadow.Size=UDim2.new(0,16,0,6); ballShadow.Position=UDim2.new(defRel,-8,1,-2)
    ballShadow.BackgroundColor3=Color3.fromRGB(5,5,15); ballShadow.BackgroundTransparency=0.42
    ballShadow.BorderSizePixel=0; ballShadow.ZIndex=4
    Instance.new("UICorner",ballShadow).CornerRadius=UDim.new(1,0)

    local ball=Instance.new("TextButton",track)
    ball.Size=UDim2.new(0,22,0,22); ball.Position=UDim2.new(defRel,-11,0.5,-11)
    ball.BackgroundColor3=Color3.fromRGB(255,255,255); ball.Text=""
    ball.BorderSizePixel=0; ball.ZIndex=6
    Instance.new("UICorner",ball).CornerRadius=UDim.new(1,0)
    local ballGrad=Instance.new("UIGradient",ball)
    ballGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),
        ColorSequenceKeypoint.new(1,theme.ball or theme.primary),
    })
    local ballStroke=Instance.new("UIStroke",ball)
    ballStroke.Color=StellarEngineA:lerpC(theme.primary,Color3.fromRGB(80,80,125),0.4)
    ballStroke.Thickness=2.2

    pcall(function()
        local us=ball:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",ball); us.Scale=1.0
        ball.MouseEnter:Connect(function() pcall(function() tw(us,{Scale=1.12},SMOOTH_BACK) end) end)
        ball.MouseLeave:Connect(function() pcall(function() tw(us,{Scale=1.0},SMOOTH) end) end)
        ball.InputBegan:Connect(function(i) if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=0.88},SMOOTH_FAST) end) end end)
        ball.InputEnded:Connect(function(i) if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=1.0},SMOOTH_BACK) end) end end)
    end)

    local sliderRef={
        fill=fill,fillGrad=fillGrad,ball=ball,ballGrad=ballGrad,
        ballStroke=ballStroke,valLbl=valLbl,ballShadow=ballShadow,
        container=container,lbl=lbl,
    }
    table.insert(allSliderBalls,sliderRef)

    local dragging=false; local lastRel=defRel

    local function tryStart(i)
        if not isTouchOrMouse(i.UserInputType) then return end
        if isInputBlocked() then return end
        if State.activeSliderId~=nil and State.activeSliderId~=myId then return end
        dragging=true; State.activeSliderId=myId
    end
    ball.InputBegan:Connect(tryStart); track.InputBegan:Connect(tryStart)

    UserInputService.InputEnded:Connect(function(i)
        if isTouchOrMouse(i.UserInputType) and dragging then
            dragging=false
            if State.activeSliderId==myId then State.activeSliderId=nil end
        end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if isInputBlocked() then dragging=false; State.activeSliderId=nil; return end
        if State.activeSliderId~=myId then dragging=false; return end
        if i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch") then
            local rel=math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
            if math.abs(rel-lastRel)<0.002 then return end
            pcall(function() ball.Rotation=ball.Rotation+(rel-lastRel)*720 end)
            lastRel=rel
            fill.Size=UDim2.new(rel,0,1,0)
            ball.Position=UDim2.new(rel,-11,0.5,-11)
            ballShadow.Position=UDim2.new(rel,-8,1,-2)
            valLbl.Text=math.floor(rel*100).."%"
            local ct=COLOR_THEMES[State.currentThemeIndex]
            fillGrad.Color=ColorSequence.new({
                ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,85)),
                ColorSequenceKeypoint.new(1,StellarEngineA:lerpCHSV(Color3.fromRGB(150,150,205),ct.primary,rel)),
            })
            pcall(function() changeFn(rel) end)
        end
    end)
    return container,fill,ball,valLbl
end

local function refreshAllSliders()
    local theme=COLOR_THEMES[State.currentThemeIndex]
    for _,s in ipairs(allSliderBalls) do
        pcall(function()
            s.fillGrad.Color=ColorSequence.new({
                ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,85)),
                ColorSequenceKeypoint.new(1,theme.primary),
            })
            s.ballGrad.Color=ColorSequence.new({
                ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),
                ColorSequenceKeypoint.new(1,theme.ball or theme.primary),
            })
            s.ballStroke.Color=StellarEngineA:lerpC(theme.primary,Color3.fromRGB(80,80,125),0.4)
            s.valLbl.TextColor3=theme.primary
            if theme.dark or theme.clear then
                s.container.BackgroundColor3=UI.C_BG; s.lbl.TextColor3=UI.C_TEXT
            elseif theme.glass then
                s.container.BackgroundColor3=Color3.fromRGB(225,238,252); s.lbl.TextColor3=Color3.fromRGB(40,60,95)
            else
                s.container.BackgroundColor3=Color3.fromRGB(242,242,252); s.lbl.TextColor3=Color3.fromRGB(50,42,75)
            end
        end)
    end
end
