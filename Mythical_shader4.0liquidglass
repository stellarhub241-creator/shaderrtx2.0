-- ================================================================
-- SECTION 2: [UPGRADE A] StellarAI — Self-healing & Adaptive
-- ================================================================
-- ตัวแปรพิเศษที่ 1: StellarAI
-- ความสามารถ:
--   · ตรวจจับ performance drop → ลด particle count อัตโนมัติ
--   · ตรวจ nil reference → รัน fallback
--   · ตรวจ effect ค้าง → restart อัตโนมัติ
--   · เก็บ history FPS → คำนวณ baseline
--   · adaptive quality: ปรับ effect intensity ตาม FPS จริง
--   · self-diagnose: รายงาน bug พร้อม fix suggestion
local StellarAI = {
    -- State
    fpsHistory      = {},   -- ring buffer 60 sample
    fpsHistorySize  = 60,
    fpsHistoryIdx   = 0,
    baselineFPS     = 60,
    qualityLevel    = 1.0,  -- 0.2–1.0 adaptive multiplier
    errorLog        = {},
    fixLog          = {},
    watchedRefs     = {},   -- {id→{ref, name, lastOk}}
    autoFixEnabled  = true,
    lastCheckTick   = 0,
    checkInterval   = 2.0,

    -- บันทึก FPS ทุก frame
    pushFPS = function(self, fps)
        self.fpsHistoryIdx = (self.fpsHistoryIdx % self.fpsHistorySize) + 1
        self.fpsHistory[self.fpsHistoryIdx] = fps
    end,

    -- คำนวณ FPS เฉลี่ย 5 วินาที
    getAvgFPS = function(self)
        local sum, n = 0, 0
        for _, v in pairs(self.fpsHistory) do if v then sum=sum+v; n=n+1 end end
        return n>0 and (sum/n) or 60
    end,

    -- adaptive quality: เรียกทุก 2s
    updateQuality = function(self, State, createRainParticles, createSakura)
        local avg = self:getAvgFPS()
        local target = State.targetFpsCap
        local ratio  = avg / math.max(target, 30)

        local newQ
        if     ratio >= 0.88 then newQ = 1.0
        elseif ratio >= 0.72 then newQ = 0.75
        elseif ratio >= 0.55 then newQ = 0.5
        else                      newQ = 0.3
        end

        if math.abs(newQ - self.qualityLevel) > 0.15 then
            self.qualityLevel = newQ
            self:log("AUTO-QUALITY → "..math.floor(newQ*100).."%  (avg "..math.floor(avg).."fps)")

            -- ปรับ particle count อัตโนมัติ
            local base = State.rainParticleCount
            local adjusted = math.max(10, math.floor(base * newQ))
            if State.rainEnabled and adjusted ~= base then
                State.rainParticleCount = adjusted
                pcall(createRainParticles)
                self:log("AUTO rain density → "..adjusted)
            end

            local sBase = State.sakuraCount
            local sAdj  = math.max(8, math.floor(sBase * newQ))
            if State.sakuraEnabled and sAdj ~= sBase then
                State.sakuraCount = sAdj
                pcall(createSakura)
                self:log("AUTO sakura density → "..sAdj)
            end
        end
    end,

    -- ลงทะเบียน ref ที่ต้องตรวจ
    watch = function(self, id, refGetter, name)
        self.watchedRefs[id] = {getter=refGetter, name=name, lastOk=true, missCount=0}
    end,

    -- เรียกโดย master loop ทุก checkInterval
    check = function(self, callbacks)
        if not self.autoFixEnabled then return end
        local now = tick()
        if now - self.lastCheckTick < self.checkInterval then return end
        self.lastCheckTick = now

        for id, w in pairs(self.watchedRefs) do
            local ok = pcall(function()
                local ref = w.getter()
                if ref == nil then error("nil") end
                if typeof(ref) == "Instance" and not ref.Parent then error("no parent") end
            end)
            if not ok then
                w.missCount = w.missCount + 1
                if w.lastOk then
                    self:log("[WARN] "..w.name.." went nil/dead")
                    w.lastOk = false
                end
                -- auto-fix: รัน callback ถ้ามี
                if callbacks and callbacks[id] then
                    local fixOk = pcall(callbacks[id])
                    if fixOk then
                        self:log("[FIX] "..w.name.." auto-restarted")
                        w.lastOk = true; w.missCount = 0
                    end
                end
            else
                if not w.lastOk then
                    self:log("[OK] "..w.name.." recovered")
                end
                w.lastOk = true; w.missCount = 0
            end
        end
    end,

    log = function(self, msg)
        local entry = string.format("[%.1f] %s", tick()%10000, msg)
        table.insert(self.errorLog, entry)
        if #self.errorLog > 80 then table.remove(self.errorLog, 1) end
    end,

    getReport = function(self)
        local lines = {
            string.format("Quality: %.0f%%  AvgFPS: %.0f", self.qualityLevel*100, self:getAvgFPS()),
            string.format("Watches: %d", (function() local n=0; for _ in pairs(self.watchedRefs) do n=n+1 end; return n end)()),
            "--- Recent Log ---",
        }
        local logLen = #self.errorLog
        for i = math.max(1, logLen-8), logLen do
            if self.errorLog[i] then table.insert(lines, self.errorLog[i]) end
        end
        return table.concat(lines, "\n")
    end,
}

-- ================================================================
-- SECTION 3: [UPGRADE B] StellarEngine — Math/Physics/UI Helper
-- ================================================================
-- ตัวแปรพิเศษที่ 2: StellarEngine
-- ความสามารถ:
--   · Spring physics สำหรับ UI animation
--   · Bezier curve (cubic) สำหรับ easing
--   · Perlin noise ที่ smooth กว่า math.noise
--   · Color operations: mix, toHSV, gradient sample
--   · Vector math helpers
--   · UI layout calculator
--   · Reactive binding: ผูก value กับ UI property อัตโนมัติ
local StellarEngine = {
    -- Spring physics: velocity-based spring
    -- usage: local spring = StellarEngine.newSpring(stiffness, damping)
    --        spring:update(dt, target) → current value
    newSpring = function(stiffness, damping)
        return {
            value    = 0,
            velocity = 0,
            k        = stiffness or 200,
            d        = damping   or 20,
            update   = function(self, dt, target)
                local force    = -self.k * (self.value - target) - self.d * self.velocity
                self.velocity  = self.velocity + force * dt
                self.value     = self.value + self.velocity * dt
                return self.value
            end,
            reset    = function(self, val)
                self.value = val; self.velocity = 0
            end,
        }
    end,

    -- Spring สำหรับ Color3
    newColorSpring = function(stiffness, damping)
        local sr = {value=0,velocity=0,k=stiffness or 180,d=damping or 18}
        local sg = {value=0,velocity=0,k=stiffness or 180,d=damping or 18}
        local sb = {value=0,velocity=0,k=stiffness or 180,d=damping or 18}
        local function springStep(s, dt, target)
            local f = -s.k*(s.value-target) - s.d*s.velocity
            s.velocity = s.velocity + f*dt; s.value = s.value + s.velocity*dt
            return s.value
        end
        return {
            value = Color3.new(0,0,0),
            update = function(self, dt, target)
                local r = springStep(sr, dt, target.R)
                local g = springStep(sg, dt, target.G)
                local b = springStep(sb, dt, target.B)
                self.value = Color3.new(math.clamp(r,0,1),math.clamp(g,0,1),math.clamp(b,0,1))
                return self.value
            end,
            reset = function(self, col)
                sr.value=col.R; sg.value=col.G; sb.value=col.B
                sr.velocity=0; sg.velocity=0; sb.velocity=0
                self.value = col
            end,
        }
    end,

    -- Cubic Bezier easing (t ∈ [0,1])
    bezier = function(p0, p1, p2, p3, t)
        local u = 1 - t
        return u*u*u*p0 + 3*u*u*t*p1 + 3*u*t*t*p2 + t*t*t*p3
    end,

    -- Smooth Perlin-like noise (layered octaves)
    smoothNoise = function(x, y, z, octaves)
        octaves = octaves or 3
        local val, amp, freq = 0, 1, 1
        for i = 1, octaves do
            val  = val + math.noise(x*freq, (y or 0)*freq, (z or 0)*freq) * amp
            amp  = amp  * 0.5
            freq = freq * 2.1
        end
        return val
    end,

    -- Color lerp ใน HSV space (ผล smooth กว่า RGB lerp)
    lerpColorHSV = function(a, b, t)
        local ah, as, av = Color3.toHSV(a)
        local bh, bs, bv = Color3.toHSV(b)
        -- shortest path hue
        local dh = bh - ah
        if dh >  0.5 then dh = dh - 1 end
        if dh < -0.5 then dh = dh + 1 end
        return Color3.fromHSV(
            (ah + dh*t) % 1,
            math.clamp(as + (bs-as)*t, 0, 1),
            math.clamp(av + (bv-av)*t, 0, 1)
        )
    end,

    -- Sample gradient ที่ t ∈ [0,1] จาก color table
    sampleGradient = function(colors, t)
        if #colors == 0 then return Color3.new(1,1,1) end
        if #colors == 1 then return colors[1] end
        local seg  = (t * (#colors-1))
        local idx  = math.floor(seg)
        local frac = seg - idx
        idx = math.clamp(idx, 0, #colors-2)
        return StellarEngine.lerpColorHSV(colors[idx+1], colors[idx+2], frac)
    end,

    -- Pulse wave (sin-based, normalized 0→1)
    pulse = function(t, freq, phase)
        return (math.sin(t * freq * math.pi * 2 + (phase or 0)) + 1) * 0.5
    end,

    -- Remap value จาก range A → range B
    remap = function(v, inMin, inMax, outMin, outMax)
        return outMin + (v - inMin) / (inMax - inMin) * (outMax - outMin)
    end,

    -- Exponential smoothing (EMA) สำหรับ smooth ค่า realtime
    newEMA = function(alpha)
        return {
            value = nil,
            alpha = alpha or 0.1,
            update = function(self, newVal)
                if self.value == nil then self.value = newVal; return newVal end
                self.value = self.alpha * newVal + (1-self.alpha) * self.value
                return self.value
            end,
        }
    end,

    -- Layout: แบ่ง row เป็น n columns คืน UDim2 position+size
    gridCell = function(col, row, cols, rows, padX, padY)
        padX = padX or 4; padY = padY or 4
        local w = (1 - padX*(cols+1)/100) / cols
        local h = (1 - padY*(rows+1)/100) / rows
        local x = padX/100 + (col-1)*(w + padX/100)
        local y = padY/100 + (row-1)*(h + padY/100)
        return UDim2.new(w,0,h,0), UDim2.new(x,0,y,0)
    end,

    -- Reactive bind: ผูก getter กับ UI property อัตโนมัติ
    -- usage: local binding = StellarEngine.bind(label, "Text", function() return "FPS: "..fps end)
    --        เรียก binding:update() ใน render loop
    bind = function(obj, prop, getter, transformer)
        return {
            obj = obj, prop = prop, getter = getter,
            lastVal = nil,
            update = function(self)
                local raw = pcall(function()
                    local v = self.getter()
                    if transformer then v = transformer(v) end
                    if v ~= self.lastVal then
                        self.obj[self.prop] = v
                        self.lastVal = v
                    end
                end)
            end,
        }
    end,
}

