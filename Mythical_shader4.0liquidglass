local SizeBtn=Instance.new("TextButton",TitleBar); SizeBtn.Size=UDim2.new(0,48,0,22); SizeBtn.Position=UDim2.new(1,-88,0.5,-11)
SizeBtn.BackgroundColor3=Color3.fromRGB(28,28,38); SizeBtn.BackgroundTransparency=0.25; SizeBtn.TextColor3=Color3.fromRGB(240,240,255)
SizeBtn.Font=Enum.Font.Code; SizeBtn.TextSize=10; SizeBtn.ZIndex=6
Instance.new("UICorner",SizeBtn).CornerRadius=UDim.new(0,6)
