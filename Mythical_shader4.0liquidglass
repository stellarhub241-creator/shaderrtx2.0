createToggle(TabGfx,"☠️ Horror Fog",4,false,function(val)
    horrorFogEnabled=val
    if val then
        ModeText="Status: Horror" BorderColorNow=Color3.fromRGB(80,160,40)
        clearRainParticles()
        applyLighting(PROFILES.HORROR)
        pcall(function()
            Lighting.FogStart=4 Lighting.FogEnd=80
            Lighting.FogColor=Color3.fromRGB(8,14,4)
            Lighting.Ambient=Color3.fromRGB(5,8,2)
            Lighting.GlobalShadows=true
        end)
        applyCinematicBlend()
    else resetFogLighting() ModeText="Status: Normal" end
end)
createToggle(TabGfx,"🌧 Rain Mode",5,false,function(val)
    rainEnabled=val
    if val then
        ModeText="Status: Rainy" BorderColorNow=Color3.fromRGB(100,160,255)
        applyLighting(PROFILES.RAIN)
        pcall(function() Lighting.FogStart=20 Lighting.FogEnd=200 Lighting.FogColor=Color3.fromRGB(110,122,142) end)
        applyCinematicBlend() createRainParticles()
    else
        clearRainParticles()
        if not horrorFogEnabled and not heavenlyEnabled then resetFogLighting() end
        ModeText="Status: Normal"
    end
end)
-- [FIX] Heavenly สวยขึ้น: bloom สูง ทอง particle ลอย
createToggle(TabGfx,"👼 Heavenly Mode",6,false,function(val)
    heavenlyEnabled=val
    if val then
        ModeText="Status: Heavenly" BorderColorNow=Color3.fromRGB(255,240,120)
        applyLighting(PROFILES.HEAVENLY)
        pcall(function()
            Lighting.FogStart=500 Lighting.FogEnd=2000
            Lighting.FogColor=Color3.fromRGB(225,235,255)
            Lighting.ClockTime=12
        end)
        applyCinematicBlend()
    else
        if not horrorFogEnabled and not rainEnabled then resetFogLighting() end
        ModeText="Status: Normal"
    end
end)
createToggle(TabGfx,"💨 Wind Effect",7,false,function(val)
    windEnabled=val
    if val then ModeText="Status: Windy" BorderColorNow=Color3.fromRGB(160,220,180) startWind()
    else clearWind() end
end)
createToggle(TabGfx,"🌟 Neon Edge",8,false,function(val)
