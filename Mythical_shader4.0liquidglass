local US=Instance.new("UIStroke",MF); US.Thickness=1.8; US.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
local UG=Instance.new("UIGradient",US)
local BSTYLES={{id="none",label="◻ None"},{id="solid",label="▣ Solid"},{id="gradient",label="◈ Gradient"},{id="neon",label="✦ Neon"},{id="glow",label="◉ Glow"},{id="shimmer",label="◇ Shimmer"}}
local bConn=nil
local function applyBorder(sid,col)
    St.borderStyle=sid; if col then St.borderCol=col end; local c=St.borderCol
    if bConn then pcall(function() bConn:Disconnect() end); bConn=nil end
    US.Enabled=true
    if sid=="none" then US.Enabled=false
    elseif sid=="solid" then US.Thickness=2.0; UG.Color=ColorSequence.new(c); UG.Transparency=NumberSequence.new(0); UG.Rotation=0
    elseif sid=="gradient" then
        US.Thickness=1.8
        UG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(200,180,240)),ColorSequenceKeypoint.new(0.33,c),ColorSequenceKeypoint.new(0.66,Color3.fromRGB(0,190,230)),ColorSequenceKeypoint.new(1,Color3.fromRGB(200,180,240))})
        UG.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.45),NumberSequenceKeypoint.new(0.5,0.08),NumberSequenceKeypoint.new(1,0.45)})
        bConn=RunService.RenderStepped:Connect(function() pcall(function() UG.Rotation=(tick()*22)%360 end) end)
    elseif sid=="neon" then
        US.Thickness=3.0
        bConn=RunService.RenderStepped:Connect(function()
            local t=tick(); local h=((t*30)%360)/360; local c2=Color3.fromHSV(h,0.92,1); local c3=Color3.fromHSV((h+0.33)%1,0.92,1)
            pcall(function() UG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,c),ColorSequenceKeypoint.new(0.5,c2),ColorSequenceKeypoint.new(1,c3)}); UG.Rotation=(t*50)%360; UG.Transparency=NumberSequence.new(0.1+math.abs(math.sin(t*3))*0.18) end)
        end)
    elseif sid=="glow" then
        US.Thickness=2.8
        UG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(0.5,c),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255))})
        UG.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.55),NumberSequenceKeypoint.new(0.5,0.0),NumberSequenceKeypoint.new(1,0.55)})
        bConn=RunService.RenderStepped:Connect(function() pcall(function() UG.Rotation=(tick()*14)%360 end) end)
    elseif sid=="shimmer" then
        US.Thickness=2.2
        bConn=RunService.RenderStepped:Connect(function()
            local t=tick(); local off=SA.pulse(t,0.6)
            pcall(function() UG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(math.clamp(off,0.01,0.99),c),ColorSequenceKeypoint.new(1,Color3.fromRGB(220,220,255))}); UG.Rotation=(t*18)%360; UG.Transparency=NumberSequence.new(0.05) end)
        end)
    end
end

