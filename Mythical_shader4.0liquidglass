-- canvas size = ครอบทุก tab เสมอ (scroll ลงได้)
Sidebar.CanvasSize = UDim2.new(0,0,0,#TAB_DEFS*BTN_GAP+12)

local function switchTab(targetTab)
    if activeTab==targetTab then return end
    -- slide ออก
    if activeTab then
        local old=activeTab
        pcall(function()
            TweenService:Create(old,TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Position=UDim2.new(-0.15,0,0,0)}):Play()
        end)
        task.delay(0.12,function() if old then old.Visible=false old.Position=UDim2.new(0,0,0,0) end end)
    end
    activeTab = targetTab
    -- reset สี button
    for _,bd in pairs(tabButtons) do
        bd.btn.BackgroundColor3=Color3.fromRGB(20,16,30)
        bd.btn.BackgroundTransparency=0.4
        bd.btn.TextColor3=Color3.fromRGB(180,180,180)
    end
    -- highlight button ที่เลือก
    for _,bd in pairs(tabButtons) do
        if bd.tab==targetTab then
            bd.btn.BackgroundColor3=COLOR_THEMES[currentThemeIndex].primary
            bd.btn.BackgroundTransparency=0.18
            bd.btn.TextColor3=Color3.fromRGB(255,255,255)
        end
    end
    -- slide เข้า
    targetTab.Position=UDim2.new(0.15,0,0,0)
    targetTab.Visible=true
    pcall(function()
        TweenService:Create(targetTab,TweenInfo.new(0.28,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(0,0,0,0)}):Play()
    end)
end

for _,bd in pairs(tabButtons) do
    bd.btn.MouseButton1Click:Connect(function() switchTab(bd.tab) end)
end
switchTab(TabGfx)

-- ================================================================
-- SECTION 18: DRAG (clamp ในจอ, ไม่ bounce)
-- ================================================================
local dragToggle,dragStart,startPos,isDragging,longHold=false,nil,nil,false,nil

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        dragToggle=true dragStart=input.Position startPos=MainFrame.Position
        if longHold then pcall(function() task.cancel(longHold) end) end
        longHold=nil
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then
                dragToggle=false isDragging=false
                if longHold then pcall(function() task.cancel(longHold) end) longHold=nil end
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not dragToggle then return end
    if input.UserInputType~=Enum.UserInputType.MouseMovement and input.UserInputType~=Enum.UserInputType.Touch then return end
    local delta = input.Position - dragStart
    if not isDragging and (math.abs(delta.X)>4 or math.abs(delta.Y)>4) then
        isDragging=true
        if longHold then pcall(function() task.cancel(longHold) end) longHold=nil end
    end
    if isDragging then
        local vp=workspace.CurrentCamera.ViewportSize
        local fw=MainFrame.Size.X.Offset local fh=MainFrame.Size.Y.Offset
        local nx=math.clamp(startPos.X.Offset+delta.X, 6, vp.X-fw-6)
        local ny=math.clamp(startPos.Y.Offset+delta.Y, 6, vp.Y-fh-6)
        MainFrame.Position=UDim2.new(0,nx,0,ny)
    end
end)

