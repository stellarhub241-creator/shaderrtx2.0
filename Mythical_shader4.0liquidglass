local minimized=false
MinB.MouseButton1Click:Connect(function()
    minimized=not minimized; local th=THEMES[St.themeIdx]
    if minimized then
        TLbl.Visible=false; SB.Visible=false; CA.Visible=false; SBLine.Visible=false; TSep.Visible=false; SzB.Visible=false; Shad.Visible=false
        tw(MF,{Size=UDim2.new(0,42,0,42),BackgroundColor3=th.pri,BackgroundTransparency=0.04},TweenInfo.new(0.28,Enum.EasingStyle.Back,Enum.EasingDirection.In))
        MinB.Size=UDim2.new(1,-4,1,-4); MinB.Position=UDim2.new(0,2,0,2); MinB.TextSize=22; mStr.Color=Color3.fromRGB(255,255,255)
    else
        local bg=(th.dark or th.clear) and Color3.fromRGB(12,12,18) or (th.glass and Color3.fromRGB(235,242,252) or Color3.fromRGB(238,240,248))
        tw(MF,{Size=UDim2.new(0,340,0,280),BackgroundColor3=bg,BackgroundTransparency=1-St.uiOp},TweenInfo.new(0.32,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
        MinB.Size=UDim2.new(0,26,0,26); MinB.Position=UDim2.new(1,-32,0.5,-13); MinB.TextSize=14; MinB.TextColor3=Color3.fromRGB(255,200,50); mStr.Color=th.pri
        task.delay(0.2,function() SB.Visible=true; CA.Visible=true; TLbl.Visible=true; SBLine.Visible=true; TSep.Visible=true; SzB.Visible=true; Shad.Visible=true end)
    end
end)

