local rainbowActive=false

-- [v4.9.2] apply Liquid Glass effect บน MainFrame
local function applyLiquidGlassEffect(on)
    if on then
        MainFrame.BackgroundColor3=Color3.fromRGB(18,18,24)
        MainFrame.BackgroundTransparency=0.25
        GlassRefraction.Visible=true
        UIStroke.Thickness=2.2
        -- ขอบหักเหแสง: gradient หมุนตาม tick
        task.spawn(function()
            while mainFrame and MainFrame.Parent and COLOR_THEMES[currentThemeIndex].glass do
                pcall(function() UIGradientStroke.Rotation=(tick()*20)%360 end)
                task.wait(0.05)
            end
        end)
    else
        MainFrame.BackgroundColor3=Color3.fromRGB(12,10,18)
        MainFrame.BackgroundTransparency=0.4
        GlassRefraction.Visible=false
        UIStroke.Thickness=2
        UIGradientStroke.Rotation=0
    end
end

local function applyTheme(index)
    local theme=COLOR_THEMES[index] currentThemeIndex=index
    activeThemeLabel.Text="Active: "..theme.name activeThemeLabel.TextColor3=theme.primary
    UIGradientStroke.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,theme.primary),ColorSequenceKeypoint.new(0.5,theme.secondary),ColorSequenceKeypoint.new(1,theme.primary)})
    for _,t in pairs(allTabs) do local sg=t:FindFirstChildOfClass("UIGradient") if sg then sg.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,theme.primary),ColorSequenceKeypoint.new(1,theme.secondary)}) end end
    for _,b in pairs(tabButtons) do if b.BackgroundTransparency<0.35 then pcall(function() TweenService:Create(b,TweenInfo.new(0.3,Enum.EasingStyle.Back),{BackgroundColor3=theme.primary}):Play() end) end end
    pcall(function() TweenService:Create(MinBtn,TweenInfo.new(0.3),{TextColor3=theme.secondary}):Play() end)
    BorderColorNow=theme.primary
    applyLiquidGlassEffect(theme.glass)
end

for i,theme in ipairs(COLOR_THEMES) do
    local TB=Instance.new("TextButton",TabTheme)
    TB.Size=UDim2.new(1,-16,0,26) TB.Position=UDim2.new(0,8,0,(i-1)*31+40)
    TB.BackgroundColor3=theme.primary TB.BackgroundTransparency=0.3
    TB.Text=theme.name TB.TextColor3=Color3.fromRGB(255,255,255) TB.Font=Enum.Font.SourceSansBold TB.TextSize=11
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,6) applySpringPhysics(TB)
    TB.MouseButton1Click:Connect(function()
        if theme.name=="Rainbow" then rainbowActive=true else rainbowActive=false applyTheme(i) end
    end)
end
