local SG=Instance.new("ScreenGui",CoreGui); SG.Name="STELLARHUB_MYTHICAL"; SG.ResetOnSpawn=false; SG.IgnoreGuiInset=true
local TW0=TweenInfo.new(0.28,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
local TW1=TweenInfo.new(0.32,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
local TW2=TweenInfo.new(0.14,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)
local TW3=TweenInfo.new(0.26,Enum.EasingStyle.Quint,Enum.EasingDirection.Out)
local function tw(o,p,i) pcall(function() TweenService:Create(o,i or TW0,p):Play() end) end
local function spring(btn)
    pcall(function()
        local us=btn:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",btn); us.Scale=1.0
        btn.MouseEnter:Connect(function() pcall(function() tw(us,{Scale=1.09},TW1); tw(btn,{BackgroundTransparency=0.05},TW2) end) end)
        btn.MouseLeave:Connect(function() pcall(function() tw(us,{Scale=1.0},TW0); tw(btn,{BackgroundTransparency=0.3},TW2) end) end)
        btn.InputBegan:Connect(function(i) if isTM(i.UserInputType) then pcall(function() tw(us,{Scale=0.91},TW2) end) end end)
        btn.InputEnded:Connect(function(i) if isTM(i.UserInputType) then pcall(function() tw(us,{Scale=1.0},TW1) end) end end)
    end)
end
local function bounce(f)
    f.InputBegan:Connect(function(inp)
        if not isTM(inp.UserInputType) then return end
        local ht=task.delay(0.28,function()
            if inputBlocked() then return end
            pcall(function()
                local us=f:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",f); us.Scale=1
                tw(us,{Scale=1.14},TweenInfo.new(0.1,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)); task.wait(0.1)
                tw(us,{Scale=1.0},TweenInfo.new(0.32,Enum.EasingStyle.Bounce,Enum.EasingDirection.Out))
            end)
        end)
        inp.Changed:Connect(function() if inp.UserInputState==Enum.UserInputState.End then pcall(function() task.cancel(ht) end) end end)
    end)
end

