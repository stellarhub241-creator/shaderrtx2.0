    {text="FPS Cap",  icon="📊", tab=TabFPS},
    {text="Cinema",   icon="🎬", tab=TabCinema},
}

-- ================================================================
-- SECTION 13: SPRING PHYSICS FOR BUTTONS
-- ================================================================
local function applySpringPhysics(button)
    pcall(function()
        local us=button:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",button)
        us.Scale=1.0
        button.MouseEnter:Connect(function() pcall(function()
            TweenService:Create(us,TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.06}):Play()
            TweenService:Create(button,TweenInfo.new(0.2,Enum.EasingStyle.Quad),{BackgroundTransparency=0.15}):Play()
        end) end)
        button.MouseLeave:Connect(function() pcall(function()
            TweenService:Create(us,TweenInfo.new(0.25,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Scale=1.0}):Play()
            TweenService:Create(button,TweenInfo.new(0.2,Enum.EasingStyle.Quad),{BackgroundTransparency=0.4}):Play()
        end) end)
        button.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                pcall(function() TweenService:Create(us,TweenInfo.new(0.1,Enum.EasingStyle.Quad),{Scale=0.94}):Play() end) end end)
        button.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                pcall(function() TweenService:Create(us,TweenInfo.new(0.2,Enum.EasingStyle.Back),{Scale=1.0}):Play() end) end end)
    end)
end

-- ================================================================
-- SECTION 14: TAB SWITCHING
-- ================================================================
local tabButtons={} local miniTabButtons={} local activeTab=nil

local function switchTab(tabFrame,btn)
    if activeTab==tabFrame then return end
    activeTab=tabFrame
    for _,t in pairs(allTabs) do if t~=tabFrame then t.Visible=false end end
    for _,b in pairs(tabButtons) do b.BackgroundColor3=Color3.fromRGB(20,16,30) b.BackgroundTransparency=0.4 b.TextColor3=Color3.fromRGB(180,180,180) end
    for _,b in pairs(miniTabButtons) do b.BackgroundColor3=Color3.fromRGB(20,16,30) b.BackgroundTransparency=0.5 end
    tabFrame.Position=UDim2.new(0,25,0,0) tabFrame.Visible=true
    pcall(function() TweenService:Create(tabFrame,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(0,0,0,0)}):Play() end)
    if btn then btn.BackgroundColor3=COLOR_THEMES[currentThemeIndex].primary btn.BackgroundTransparency=0.2 btn.TextColor3=Color3.fromRGB(255,255,255) end
end

local BTN_H=22 local BTN_GAP=26

local function rebuildSidebar(availH)
    for _,b in pairs(tabButtons) do pcall(function() b:Destroy() end) end
    tabButtons={}
    local maxFit=math.max(1,math.floor((availH-8)/BTN_GAP))
    local shown=math.min(#TAB_DEFS,maxFit)
    for i=1,shown do
        local def=TAB_DEFS[i]
        local Btn=Instance.new("TextButton",Sidebar)
        Btn.Size=UDim2.new(1,-8,0,BTN_H) Btn.Position=UDim2.new(0,4,0,(i-1)*BTN_GAP+4)
        Btn.BackgroundColor3=Color3.fromRGB(20,16,30) Btn.BackgroundTransparency=0.4
        Btn.Text=def.text Btn.TextColor3=Color3.fromRGB(180,180,180)
        Btn.Font=Enum.Font.SourceSansBold Btn.TextSize=10
        Instance.new("UICorner",Btn).CornerRadius=UDim.new(0,6)
        applySpringPhysics(Btn)
        local capturedTab=def.tab
        Btn.MouseButton1Click:Connect(function() switchTab(capturedTab,Btn) end)
        table.insert(tabButtons,Btn)
    end
    Sidebar.CanvasSize=UDim2.new(0,0,0,shown*BTN_GAP+8)
    if #tabButtons>0 and not activeTab then switchTab(TAB_DEFS[1].tab,tabButtons[1]) end
end

-- [v4.9.2] Mini sidebar (icon only เมื่อ UI แคบ)
local function rebuildMiniSidebar()
    for _,b in pairs(miniTabButtons) do pcall(function() b:Destroy() end) end
    miniTabButtons={}
    for i,def in ipairs(TAB_DEFS) do
        local Btn=Instance.new("TextButton",MiniSidebar)
        Btn.Size=UDim2.new(1,-4,0,24) Btn.Position=UDim2.new(0,2,0,(i-1)*26+4)
        Btn.BackgroundColor3=Color3.fromRGB(20,16,30) Btn.BackgroundTransparency=0.5
        Btn.Text=def.icon Btn.TextColor3=Color3.fromRGB(220,220,220)
        Btn.Font=Enum.Font.SourceSans Btn.TextSize=14
        Instance.new("UICorner",Btn).CornerRadius=UDim.new(0,5)
        applySpringPhysics(Btn)
        local capturedTab=def.tab
        Btn.MouseButton1Click:Connect(function() switchTab(capturedTab,nil) end)
        table.insert(miniTabButtons,Btn)
    end
end
rebuildMiniSidebar()

-- ================================================================
-- SECTION 15: DRAG (ไม่มี bounce ขอบ)
-- ================================================================
local dragToggle,dragStart,startPos,isDragging,longPressThread=false,nil,nil,false,nil

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        dragToggle=true dragStart=input.Position startPos=MainFrame.Position
        if longPressThread then pcall(function() task.cancel(longPressThread) end) longPressThread=nil end
        -- [v4.9.2] กดค้าง → ยุบ (ไม่ bounce ขอบ)
        longPressThread=task.delay(0.38,function()
            if not isDragging then
                pcall(function()
                    local us=MainFrame:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",MainFrame)
                    us.Scale=1
                    TweenService:Create(us,TweenInfo.new(0.15,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Scale=0.95}):Play()
                    task.wait(0.15)
                    TweenService:Create(us,TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.0}):Play()
                end)
            end
            longPressThread=nil
        end)
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then
                dragToggle=false isDragging=false
                if longPressThread then pcall(function() task.cancel(longPressThread) end) longPressThread=nil end
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) and dragToggle then
        local delta=input.Position-dragStart
        if not isDragging and (math.abs(delta.X)>4 or math.abs(delta.Y)>4) then
            isDragging=true
            if longPressThread then pcall(function() task.cancel(longPressThread) end) longPressThread=nil end
        end
        if isDragging then
            -- [v4.9.2] clamp ให้อยู่ในจอ เว้น padding 8px
            local vp=workspace.CurrentCamera.ViewportSize
            local fw=MainFrame.Size.X.Offset local fh=MainFrame.Size.Y.Offset
            local nx=math.clamp(startPos.X.Offset+delta.X,8,vp.X-fw-8)
            local ny=math.clamp(startPos.Y.Offset+delta.Y,8,vp.Y-fh-8)
            MainFrame.Position=UDim2.new(0,nx,0,ny)
        end
    end
end)

-- ================================================================
-- SECTION 16: MINIMIZE
-- ================================================================
local isMinimized=false
MinBtn.MouseButton1Click:Connect(function()
    isMinimized=not isMinimized
    if isMinimized then
        TitleLabel.Visible=false Sidebar.Visible=false ContentArea.Visible=false MiniSidebar.Visible=false MinBtn.Text="+"
        MainFrame:TweenSize(UDim2.new(0,68,0,26),Enum.EasingDirection.Out,Enum.EasingStyle.Back,0.4,true)
        MinBtn.Position=UDim2.new(1,-22,0.5,-10)
    else
        MinBtn.Text="-"
        MainFrame:TweenSize(UDim2.new(0,320,0,260),Enum.EasingDirection.Out,Enum.EasingStyle.Back,0.5,true)
        MinBtn.Position=UDim2.new(1,-30,0.5,-12)
        task.delay(0.25,function()
            local w=MainFrame.Size.X.Offset
            if w>=100 then Sidebar.Visible=true ContentArea.Visible=true MiniSidebar.Visible=false
            elseif w>=40 then MiniSidebar.Visible=true ContentArea.Visible=true Sidebar.Visible=false
            end
            TitleLabel.Visible=w>=80
        end)
    end
end)

-- ================================================================
-- SECTION 17: TOGGLE HELPER
-- ================================================================
local function createToggle(parent,text,order,defaultVal,callback)
    local F=Instance.new("Frame",parent)
    F.Size=UDim2.new(1,-16,0,30) F.Position=UDim2.new(0,8,0,(order-1)*36+6) F.BackgroundTransparency=1
    local L=Instance.new("TextLabel",F)
    L.Size=UDim2.new(0.65,0,1,0) L.BackgroundTransparency=1 L.Text=text
    L.TextColor3=Color3.fromRGB(220,220,220) L.TextSize=11 L.Font=Enum.Font.SourceSans L.TextXAlignment=Enum.TextXAlignment.Left
    local TB=Instance.new("TextButton",F)
    TB.Size=UDim2.new(0,44,0,20) TB.Position=UDim2.new(1,-44,0.5,-10)
    TB.BackgroundColor3=defaultVal and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(40,30,55)
    TB.BackgroundTransparency=0.2 TB.Text=defaultVal and "ON" or "OFF"
    TB.TextColor3=Color3.fromRGB(255,255,255) TB.Font=Enum.Font.SourceSansBold TB.TextSize=10
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,10)
    applySpringPhysics(TB)
    local cur=defaultVal
    TB.MouseButton1Click:Connect(function()
        cur=not cur
        pcall(function() TweenService:Create(TB,TweenInfo.new(0.25,Enum.EasingStyle.Back),{BackgroundColor3=cur and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(40,30,55)}):Play() end)
        TB.Text=cur and "ON" or "OFF" callback(cur)
    end)
    return TB
end

local function autoCanvas(scroll,total,h,gap,pad)
    scroll.CanvasSize=UDim2.new(0,0,0,pad+total*(h+gap))
end

