local PopupShimGrad = Instance.new("UIGradient", PopupShim)
PopupShimGrad.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),
    ColorSequenceKeypoint.new(0.5,Color3.fromRGB(100,200,255)),
    ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255))
})
task.spawn(function()
    while task.wait(0.05) do
        if FPSPopup and FPSPopup.Parent then
            pcall(function() PopupShimGrad.Offset = Vector2.new(math.sin(tick()*2)*0.5,0) end)
        else break end
    end
end)

