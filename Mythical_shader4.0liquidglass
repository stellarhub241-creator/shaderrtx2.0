    while task.wait(0.08) do
        if not MainFrame or not MainFrame.Parent then break end
        pcall(function() ShimGrad.Offset=Vector2.new(math.sin(tick()*1.2)*0.5,0) end)
    end
end)

-- Border stroke
local UIStroke = Instance.new("UIStroke",MainFrame)
UIStroke.Thickness=2 UIStroke.ApplyStrokeMode=Enum.ApplyStrokeMode.Border
local UIGradientStroke = Instance.new("UIGradient",UIStroke)
UIGradientStroke.Color=ColorSequence.new({
    ColorSequenceKeypoint.new(0,Color3.fromRGB(255,182,217)),
    ColorSequenceKeypoint.new(0.33,Color3.fromRGB(180,0,255)),
    ColorSequenceKeypoint.new(0.66,Color3.fromRGB(0,220,255)),
