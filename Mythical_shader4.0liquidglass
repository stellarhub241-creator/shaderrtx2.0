Instance.new("UIStroke",TitleLabel).Transparency=0.62

local MinBtn=Instance.new("TextButton",TitleBar)
MinBtn.Size=UDim2.new(0,26,0,26); MinBtn.Position=UDim2.new(1,-32,0.5,-13)
