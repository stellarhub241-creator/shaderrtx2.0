-- [17] DYNAMIC COLOR ENGINE CONTROLLER
-- =============================================================================
local activeThemeLabel = Instance.new("TextLabel", TabTheme)
activeThemeLabel.Size = UDim2.new(1, -10, 0, 18)
activeThemeLabel.Position = UDim2.new(0, 10, 0, 5)
activeThemeLabel.BackgroundTransparency = 1
activeThemeLabel.Text = "Active: Sakura"
activeThemeLabel.TextColor3 = COLOR_THEMES[1].primary
activeThemeLabel.TextSize = 11
activeThemeLabel.Font = Enum.Font.Code
activeThemeLabel.TextXAlignment = Enum.TextXAlignment.Left
activeThemeLabel.ZIndex = 6

local rainbowActive = false
local function applyTheme(index)
    local theme = COLOR_THEMES[index]
    currentThemeIndex = index
    activeThemeLabel.Text = "Active: " .. theme.name
    activeThemeLabel.TextColor3 = theme.primary
    
    UIGradientStroke.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, theme.primary),
        ColorSequenceKeypoint.new(0.5, theme.secondary),
        ColorSequenceKeypoint.new(1, theme.primary)
    })
    
    for _, b in pairs(tabButtons) do
        if b.BackgroundTransparency < 0.35 then
            pcall(function()
                local t1 = TweenInfo.new(0.35, Enum.EasingStyle.Back)
                TweenService:Create(b, t1, {BackgroundColor3 = theme.primary}):Play()
            end)
        end
    end
    
    pcall(function()
        TweenService:Create(MinBtn, TweenInfo.new(0.3), {TextColor3 = theme.secondary}):Play()
    end)
    BorderColorNow = theme.primary
end

for i, theme in ipairs(COLOR_THEMES) do
    local ThemeBtn = Instance.new("TextButton", TabTheme)
    ThemeBtn.Size = UDim2.new(1, -10, 0, 26)
    ThemeBtn.Position = UDim2.new(0, 5, 0, (i - 1) * 30 + 28)
    ThemeBtn.BackgroundColor3 = theme.primary
    ThemeBtn.BackgroundTransparency = 0.3
    ThemeBtn.Text = theme.name
    ThemeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ThemeBtn.Font = Enum.Font.SourceSansBold
    ThemeBtn.TextSize = 11
    ThemeBtn.ZIndex = 6
    
    local ThemeCorner = Instance.new("UICorner", ThemeBtn)
    ThemeCorner.CornerRadius = UDim.new(0, 6)
    
    applySpringPhysics(ThemeCorner)
    ThemeBtn.MouseButton1Click:Connect(function()
        if theme.name == "Rainbow" then
            rainbowActive = true
        else
            rainbowActive = false
            applyTheme(i)
        end
    end)
end

-- =============================================================================
-- [18] CORE RENDERING LOGIC HEARTBEAT (FPS ENGINE & GLOW EFFECT)
-- =============================================================================
local nextUpdate = 0
local frameCount = 0
local lastBorderColor = nil

RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1 
    nextUpdate = nextUpdate + dt 

    GlowEffect.Position = UDim2.new(
        MainFrame.Position.X.Scale, 
        MainFrame.Position.X.Offset - 20, 
        MainFrame.Position.Y.Scale, 
        MainFrame.Position.Y.Offset - 20
    )
    GlowEffect.Size = UDim2.new(
        0, 
        MainFrame.AbsoluteSize.X + 40, 
        0, 
        MainFrame.AbsoluteSize.Y + 40
    )

    if rainbowActive then
        rainbowHue = (rainbowHue + dt * 80) % 360
        local col = Color3.fromHSV(rainbowHue / 360, 1, 1)
        local col2 = Color3.fromHSV(((rainbowHue + 120) % 360) / 360, 1, 1)
        pcall(function()
            UIGradientStroke.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, col),
                ColorSequenceKeypoint.new(0.5, col2),
                ColorSequenceKeypoint.new(1, col)
            })
        end)
        BorderColorNow = col
        activeThemeLabel.TextColor3 = col
    end

    if nextUpdate >= 0.5 then
        local fps = math.round(frameCount / nextUpdate)
        InfoFPSLabel.Text = "FPS: " .. fps
        LiveTimeLabel.Text = ModeText
        LiveTimeLabel.TextColor3 = BorderColorNow
        
        if not rainbowActive and BorderColorNow ~= lastBorderColor then
            lastBorderColor = BorderColorNow
            pcall(function()
                TweenService:Create(UIStroke, TweenInfo.new(0.4), {Color = BorderColorNow}):Play()
            end)
        end
        
        local fpsColor = Color3.fromRGB(0, 255, 120)
        if fps >= 110 then
            fpsColor = Color3.fromRGB(180, 0, 255)
        elseif fps >= 90 then
            fpsColor = Color3.fromRGB(0, 220, 255)
        elseif fps >= 60 then
            fpsColor = Color3.fromRGB(0, 255, 120)
        elseif fps >= 30 then
            fpsColor = Color3.fromRGB(255, 200, 0)
        else
            fpsColor = Color3.fromRGB(255, 60, 60)
        end
        
        InfoFPSLabel.TextColor3 = fpsColor
        frameCount = 0
        nextUpdate = 0
    end
end)

-- =============================================================================
-- [19] RESPONSTRUCT GRID INTERFACE VISIBILITY MATRIX
-- =============================================================================
local camera = workspace.CurrentCamera
local GRID = 64
local SIZE_PRESETS = {
    { label = "1×1", w = 1, h = 1 },
    { label = "1×2", w = 1, h = 2 },
    { label = "2×2", w = 2, h = 2 },
    { label = "4×4", w = 4, h = 4 },
    { label = "8×8", w = 8, h = 8 },
    { label = "24×24", w = 24, h = 24 }
}
local currentSizeIndex = 5

local SizeBtn = Instance.new("TextButton", TitleBar)
SizeBtn.Size = UDim2.new(0, 42, 0, 22)
SizeBtn.Position = UDim2.new(1, -82, 0.5, -11)
SizeBtn.BackgroundColor3 = Color3.fromRGB(20, 16, 30)
SizeBtn.BackgroundTransparency = 0.3
SizeBtn.Text = SIZE_PRESETS[currentSizeIndex].label
SizeBtn.TextColor3 = COLOR_THEMES[currentThemeIndex].secondary
SizeBtn.Font = Enum.Font.Code
SizeBtn.TextSize = 10
SizeBtn.ZIndex = 5

local SizeCorner = Instance.new("UICorner", SizeBtn)
SizeCorner.CornerRadius = UDim.new(0, 5)

local SizeStroke = Instance.new("UIStroke", SizeBtn)
SizeStroke.Color = Color3.fromRGB(80, 60, 110)

applySpringPhysics(SizeBtn)

local function updateUIVisibility(w, h)
    local isTiny = w < 120 or h < 60
    if w >= 150 and h >= 120 then
        Sidebar.Visible = true
        ContentArea.Visible = true
    else
        Sidebar.Visible = false
        ContentArea.Visible = false
    end
    
    if w >= 120 then
        TitleLabel.Visible = true
        SizeBtn.Visible = true
    else
        TitleLabel.Visible = false
        SizeBtn.Visible = false
    end
    MinBtn.Visible = true

    if isTiny and not isMinimized then
        InfoFPSLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
        InfoFPSLabel.AnchorPoint = Vector2.new(0.5, 0.5)
        InfoFPSLabel.TextXAlignment = Enum.TextXAlignment.Center
    elseif not isMinimized then
        InfoFPSLabel.Position = UDim2.new(0, 12, 1, -25)
        InfoFPSLabel.AnchorPoint = Vector2.new(0, 0)
        InfoFPSLabel.TextXAlignment = Enum.TextXAlignment.Left
    end
end

local function gridPx(slots, axis)
    local size = camera.ViewportSize.Y
    if axis == "x" then
        size = camera.ViewportSize.X
    end
    return math.floor(size / GRID * slots)
end

local function applyGridSize(preset)
    if isMinimized then
        return
    end
    local pw = gridPx(preset.w, "x")
    local ph = gridPx(preset.h, "y")
    updateUIVisibility(pw, ph)
    pcall(function()
        local t1 = TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        TweenService:Create(MainFrame, t1, {
            Size = UDim2.new(0, math.max(pw, 50), 0, math.max(ph, 35))
        }):Play()
    end)
end

SizeBtn.MouseButton1Click:Connect(function()
    currentSizeIndex = (currentSizeIndex % #SIZE_PRESETS) + 1
    local preset = SIZE_PRESETS[currentSizeIndex]
    SizeBtn.Text = preset.label
    applyGridSize(preset)
end)

-- =============================================================================
-- [20] DYNAMIC REAL-TIME DRAG TO RESIZE ENGINE
-- =============================================================================
local ResizeHandle = Instance.new("TextButton", MainFrame)
ResizeHandle.Size = UDim2.new(0, 22, 0, 22)
ResizeHandle.Position = UDim2.new(1, -22, 1, -22)
ResizeHandle.BackgroundTransparency = 1
ResizeHandle.Text = "◢"
ResizeHandle.TextColor3 = Color3.fromRGB(255, 255, 255)
ResizeHandle.TextTransparency = 0.5
ResizeHandle.TextSize = 14
ResizeHandle.Font = Enum.Font.SourceSansBold
ResizeHandle.ZIndex = 10

local isResizing = false
local resizeStartInputPos = nil
local resizeStartSize = nil

ResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isResizing = true
        resizeStartInputPos = input.Position
        resizeStartSize = Vector2.new(MainFrame.Size.X.Offset, MainFrame.Size.Y.Offset)
        
        pcall(function()
            TweenService:Create(ResizeHandle, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 0}):Play()
        end)
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                isResizing = false
                pcall(function()
                    TweenService:Create(ResizeHandle, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextTransparency = 0.5}):Play()
                end)
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isResizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - resizeStartInputPos
        local newW = math.clamp(resizeStartSize.X + delta.X, 60, 800)
        local newH = math.clamp(resizeStartSize.Y + delta.Y, 35, 600)
        SizeBtn.Text = "Custom"
        updateUIVisibility(newW, newH)
        pcall(function()
            TweenService:Create(MainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Quad), {
                Size = UDim2.new(0, newW, 0, newH)
            }):Play()
        end)
    end
end)

-- Initialize Application Framework Core
applyTheme(1)
applyGridSize(SIZE_PRESETS[currentSizeIndex])
print("MYTHICAL SHADER v4.5: Full Source Reconstructed and Loaded Successfully!")
-- END OF CODE

