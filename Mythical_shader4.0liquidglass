createToggle(TabGfx,"💙 Horror: Blue Dark",9,false,function(val) State.horrorBlue=val; reapplyActiveMode() end)  -- [FIX 7]
createToggle(TabGfx,"💨 Wind Effect",10,false,function(val) State.windEnabled=val; if val then startWind() else clearWind() end end)
createToggle(TabGfx,"🌟 Neon Edge",11,false,function(val) State.neonEdgeEnabled=val; if val then startNeonEdge(ScreenGui) else clearNeonEdge() end end)
createToggle(TabGfx,"📼 Nostalgia 2016",12,false,function(val) State.nostalgiaEnabled=val; State.dawnEnabled=false; State.sunsetEnabled=false; reapplyActiveMode() end)

LiveTimeLabel=Instance.new("TextLabel",TabGfx); LiveTimeLabel.Size=UDim2.new(1,-14,0,22); LiveTimeLabel.Position=UDim2.new(0,7,0,12*36+10)
LiveTimeLabel.BackgroundColor3=Color3.fromRGB(10,10,18); LiveTimeLabel.BackgroundTransparency=0.3; LiveTimeLabel.Text="Status: Loaded"
LiveTimeLabel.TextColor3=Color3.fromRGB(140,255,160); LiveTimeLabel.TextSize=11; LiveTimeLabel.Font=Enum.Font.Code; LiveTimeLabel.TextXAlignment=Enum.TextXAlignment.Center
Instance.new("UICorner",LiveTimeLabel).CornerRadius=UDim.new(0,7)
autoCanvas(TabGfx,12,30,6,32)

-- ================================================================
-- SECTION 30: SKYBOX TAB
-- ================================================================
local function applySkyPreset(preset)
    pcall(function() skyGuardConn:Disconnect() end)
    pcall(function() for _,child in ipairs(Lighting:GetChildren()) do if child:IsA("Sky") then child:Destroy() end end end)
    task.wait(0.05)
    local sky=Instance.new("Sky",Lighting); sky.Name="StellarSky"
    pcall(function()
        sky.SkyboxBk=preset.bk; sky.SkyboxDn=preset.dn; sky.SkyboxFt=preset.ft; sky.SkyboxLf=preset.lf; sky.SkyboxRt=preset.rt; sky.SkyboxUp=preset.up
        sky.StarCount=preset.star; sky.CelestialBodiesShown=true
        if preset.moonSize then sky.MoonAngularSize=preset.moonSize end
        if not State.heavenlyEnabled then Lighting.ClockTime=preset.time end
        if preset.brightness then Lighting.Brightness=preset.brightness end
        if preset.ambient then Lighting.OutdoorAmbient=preset.ambient end
    end); connectSkyGuard()
end

