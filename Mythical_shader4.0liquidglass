    b.BackgroundColor3=Color3.fromRGB(38,38,50); b.BackgroundTransparency=0.4; b.Text=text; b.TextColor3=Color3.fromRGB(220,220,255)
    b.Font=Enum.Font.SourceSans; b.TextSize=12; Instance.new("UICorner",b).CornerRadius=UDim.new(0,8)
    Instance.new("UIStroke",b).Color=Color3.fromRGB(100,120,200); spring(b); return b
end

