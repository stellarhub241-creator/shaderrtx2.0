SizeBtn.TextColor3=UI.C_TEXT; SizeBtn.Font=Enum.Font.Code; SizeBtn.TextSize=10; SizeBtn.ZIndex=6
Instance.new("UICorner",SizeBtn).CornerRadius=UI.RADIUS_SM
local szStroke=Instance.new("UIStroke",SizeBtn); szStroke.Color=UI.C_STROKE; szStroke.Thickness=1
