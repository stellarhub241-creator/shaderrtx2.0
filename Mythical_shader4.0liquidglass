applySpringPhysics(BoostButton)

local function triggerFPSBoost(turnOn)
    isFpsBoostOn = turnOn
    if turnOn then
        local count = 0
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") then
                if not originalMaterials[v] then originalMaterials[v] = v.Material originalShadows[v] = v.CastShadow end
                v.Material = Enum.Material.SmoothPlastic v.CastShadow = false v.Reflectance = 0
            elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 1 end
            count = count + 1 
            if count % 250 == 0 then task.wait() end
        end
        Terrain.Decoration = false Lighting.GlobalShadows = false
    else
        local count = 0
        for v, mat in pairs(originalMaterials) do
            if v and v.Parent then v.Material = mat v.CastShadow = originalShadows[v] or false end
            count = count + 1 
            if count % 250 == 0 then task.wait() end
        end
        for _, v in pairs(workspace:GetDescendants()) do if v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 0 end end
        Terrain.Decoration = true Lighting.GlobalShadows = true
        table.clear(originalMaterials) table.clear(originalShadows)
        task.spawn(runPBRScan)
    end
end

BoostButton.MouseButton1Click:Connect(function()
    local state = not isFpsBoostOn
    if state then pcall(function() TweenService:Create(BoostButton,TweenInfo.new(0.25,Enum.EasingStyle.Back),{BackgroundColor3=Color3.fromRGB(0,220,100)}):Play() end) BoostButton.Text = "DISABLE FPS BOOST" task.spawn(function() triggerFPSBoost(true) end)
    else pcall(function() TweenService:Create(BoostButton,TweenInfo.new(0.25,Enum.EasingStyle.Back),{BackgroundColor3=Color3.fromRGB(255,60,100)}):Play() end) BoostButton.Text = "ENABLE FPS BOOST" task.spawn(function() triggerFPSBoost(false) end) end
end)

