local ThemeTitle=Instance.new("TextLabel",TabTheme)
ThemeTitle.Size=UDim2.new(1,-16,0,18) ThemeTitle.Position=UDim2.new(0,8,0,4)
ThemeTitle.BackgroundTransparency=1 ThemeTitle.Text="🎨 UI Color Theme"
ThemeTitle.TextColor3=Color3.fromRGB(200,200,200) ThemeTitle.TextSize=11
ThemeTitle.Font=Enum.Font.SourceSansBold ThemeTitle.TextXAlignment=Enum.TextXAlignment.Left

local activeThemeLabel=Instance.new("TextLabel",TabTheme)
activeThemeLabel.Size=UDim2.new(1,-16,0,13) activeThemeLabel.Position=UDim2.new(0,8,0,22)
activeThemeLabel.BackgroundTransparency=1 activeThemeLabel.Text="Active: Purple"
activeThemeLabel.TextColor3=Color3.fromRGB(180,0,255) activeThemeLabel.TextSize=10
activeThemeLabel.Font=Enum.Font.Code activeThemeLabel.TextXAlignment=Enum.TextXAlignment.Left

local rainbowActive=false
local glassRotThread=nil

local function applyTheme(index)
    local theme=COLOR_THEMES[index] currentThemeIndex=index
    activeThemeLabel.Text="Active: "..theme.name
    activeThemeLabel.TextColor3=theme.primary
    pcall(function()
        UIGradientStroke.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,theme.primary),
            ColorSequenceKeypoint.new(0.5,theme.secondary),
            ColorSequenceKeypoint.new(1,theme.primary),
        })
    end)
    for _,t in pairs(allTabs) do
        local sg=t:FindFirstChildOfClass("UIGradient")
        if sg then pcall(function() sg.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,theme.primary),ColorSequenceKeypoint.new(1,theme.secondary)}) end) end
    end
    for _,bd in pairs(tabButtons) do
        if bd.btn.BackgroundTransparency<0.35 then
            pcall(function() TweenService:Create(bd.btn,TweenInfo.new(0.3,Enum.EasingStyle.Back),{BackgroundColor3=theme.primary}):Play() end)
        end
    end
    pcall(function() TweenService:Create(MinBtn,TweenInfo.new(0.28),{TextColor3=theme.secondary}):Play() end)
    BorderColorNow=theme.primary

    -- Liquid Glass effect
    if theme.glass then
        GlassRefraction.Visible=true
        MainFrame.BackgroundColor3=Color3.fromRGB(16,16,22)
        MainFrame.BackgroundTransparency=0.22
        UIStroke.Thickness=2.4
        -- หักเหแสงหมุน
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end) end
        glassRotThread=task.spawn(function()
            while COLOR_THEMES[currentThemeIndex] and COLOR_THEMES[currentThemeIndex].glass do
                pcall(function() UIGradientStroke.Rotation=(tick()*18)%360 end)
                task.wait(0.06)
            end
        end)
    else
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end) glassRotThread=nil end
        GlassRefraction.Visible=false
        MainFrame.BackgroundColor3=Color3.fromRGB(12,10,18)
        MainFrame.BackgroundTransparency=0.38
        UIStroke.Thickness=2
        UIGradientStroke.Rotation=0
    end
end

for i,theme in ipairs(COLOR_THEMES) do
    local TB=Instance.new("TextButton",TabTheme)
    TB.Size=UDim2.new(1,-16,0,26) TB.Position=UDim2.new(0,8,0,(i-1)*31+40)
    TB.BackgroundColor3=theme.primary TB.BackgroundTransparency=0.3
    TB.Text=theme.name TB.TextColor3=Color3.fromRGB(255,255,255)
    TB.Font=Enum.Font.SourceSansBold TB.TextSize=11
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,6)
    spring(TB)
    TB.MouseButton1Click:Connect(function()
        if theme.name=="Rainbow" then rainbowActive=true
        else rainbowActive=false applyTheme(i) end
    end)
end
autoCanvas(TabTheme,#COLOR_THEMES,26,5,50)

