TitleBar.Size=UDim2.new(1,0,0,38); TitleBar.BackgroundTransparency=1; TitleBar.ZIndex=5

local TitleSep=Instance.new("Frame",TitleBar)
TitleSep.Size=UDim2.new(1,0,0,1); TitleSep.Position=UDim2.new(0,0,1,-1)
TitleSep.BorderSizePixel=0; TitleSep.ZIndex=5
local tsepGrad=Instance.new("UIGradient",TitleSep)
tsepGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(200,200,220)),ColorSequenceKeypoint.new(0.3,Color3.fromRGB(160,0,235)),ColorSequenceKeypoint.new(0.7,Color3.fromRGB(0,190,230)),ColorSequenceKeypoint.new(1,Color3.fromRGB(200,200,220))})
tsepGrad.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(0.3,0.28),NumberSequenceKeypoint.new(0.7,0.28),NumberSequenceKeypoint.new(1,1)})

local TitleLabel=Instance.new("TextLabel",TitleBar)
