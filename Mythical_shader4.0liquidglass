local FPS_MIN, FPS_MAX = 10, 120
local sliderDragging   = false

local function setFpsCap(fps)
    targetFpsCap = math.clamp(math.round(fps), FPS_MIN, FPS_MAX)
    local t = (targetFpsCap - FPS_MIN)/(FPS_MAX - FPS_MIN)
    pcall(function()
        TweenService:Create(SliderFill, TweenInfo.new(0.15,Enum.EasingStyle.Quad), {Size=UDim2.new(t,0,1,0)}):Play()
        TweenService:Create(SliderKnob, TweenInfo.new(0.15,Enum.EasingStyle.Quad), {Position=UDim2.new(t,-8,0.5,-8)}):Play()
    end)
    FPSValueLabel.Text = "Cap: "..targetFpsCap.." FPS"
    pcall(function() if setfpscap then setfpscap(targetFpsCap) end end)
end

SliderKnob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then sliderDragging = false end end)
    end
end)
SliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then sliderDragging = false end end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if sliderDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local rel = math.clamp((input.Position.X - SliderTrack.AbsolutePosition.X)/SliderTrack.AbsoluteSize.X, 0, 1)
        setFpsCap(FPS_MIN + rel*(FPS_MAX-FPS_MIN))
    end
end)

local FPS_PRESETS = {10,30,45,60,90,120,165}
local presetRow = Instance.new("Frame", TabFPS)
presetRow.Size = UDim2.new(1,-16,0,22) 
presetRow.Position = UDim2.new(0,8,0,64)
presetRow.BackgroundTransparency = 1

for i, fps in ipairs(FPS_PRESETS) do
    local pb = Instance.new("TextButton", presetRow)
    pb.Size = UDim2.new(1/#FPS_PRESETS,-2,1,0) 
    pb.Position = UDim2.new((i-1)/#FPS_PRESETS,1,0,0)
    pb.BackgroundColor3 = fps==165 and Color3.fromRGB(255,180,0) or Color3.fromRGB(30,25,45)
    pb.BackgroundTransparency = 0.3
    pb.Text = fps==165 and "165!" or tostring(fps)
    pb.TextColor3 = Color3.fromRGB(255,255,255) 
    pb.Font = Enum.Font.Code 
    pb.TextSize = 9
    Instance.new("UICorner",pb).CornerRadius = UDim.new(0,4)
    applySpringPhysics(pb)
    pb.MouseButton1Click:Connect(function()
        if fps == 165 then
            targetFpsCap = 165 
            FPSValueLabel.Text = "Cap: 165 FPS ⚡"
            pcall(function() if setfpscap then setfpscap(165) end end)
            pcall(function()
                TweenService:Create(SliderFill,TweenInfo.new(0.2,Enum.EasingStyle.Back),{Size=UDim2.new(1,0,1,0)}):Play()
                TweenService:Create(SliderKnob,TweenInfo.new(0.2,Enum.EasingStyle.Back),{Position=UDim2.new(1,-8,0.5,-8)}):Play()
            end)
        else 
            setFpsCap(fps) 
        end
    end)
end

