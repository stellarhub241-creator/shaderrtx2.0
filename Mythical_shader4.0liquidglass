local function startNeonEdge(sg)
    clearNeonEdge()
    neonEdgeFrame=Instance.new("Frame",sg)
    neonEdgeFrame.Size=UDim2.new(1,0,1,0) neonEdgeFrame.BackgroundTransparency=1
    neonEdgeFrame.ZIndex=100 neonEdgeFrame.Name="StellarNeonEdge"
    local EDGE_W=8
    local edges={}
    local edgeDefs={
        {UDim2.new(0,0,0,0),     UDim2.new(1,0,0,EDGE_W)},
        {UDim2.new(0,0,1,-EDGE_W),UDim2.new(1,0,0,EDGE_W)},
        {UDim2.new(0,0,0,0),     UDim2.new(0,EDGE_W,1,0)},
        {UDim2.new(1,-EDGE_W,0,0),UDim2.new(0,EDGE_W,1,0)},
    }
    for _,ed in ipairs(edgeDefs) do
        local e=Instance.new("Frame",neonEdgeFrame)
        e.Position=ed[1] e.Size=ed[2]
        e.BackgroundColor3=Color3.fromRGB(180,0,255) e.BackgroundTransparency=0.3
        e.BorderSizePixel=0 e.ZIndex=101
        local eg=Instance.new("UIGradient",e)
        eg.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(180,0,255)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(0,220,255)),ColorSequenceKeypoint.new(1,Color3.fromRGB(180,0,255))})
        table.insert(edges,{frame=e,grad=eg})
    end
    local conn=RunService.RenderStepped:Connect(function()
        if not neonEdgeFrame or not neonEdgeFrame.Parent then return end
        local t=tick()
        local theme=COLOR_THEMES[currentThemeIndex]
        local pulse=0.25+math.sin(t*3)*0.1
        local h=((t*30)%360)/360
        local col=Color3.fromHSV(h,0.9,1)
        for _,ed in ipairs(edges) do
            pcall(function()
                ed.frame.BackgroundTransparency=pulse
                ed.grad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,theme.primary),ColorSequenceKeypoint.new(0.5,col),ColorSequenceKeypoint.new(1,theme.secondary)})
                ed.grad.Offset=Vector2.new(math.sin(t*0.7)*0.3,0)
            end)
        end
    end)
    table.insert(neonEdgeConns,conn)
end

