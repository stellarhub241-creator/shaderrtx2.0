local PopupHeader=Instance.new("Frame",FPSPopup); PopupHeader.Size=UDim2.new(1,0,0,20); PopupHeader.BackgroundColor3=Color3.fromRGB(55,38,95); PopupHeader.BackgroundTransparency=0.28; PopupHeader.BorderSizePixel=0; PopupHeader.ZIndex=21
local PopupTitle=Instance.new("TextLabel",PopupHeader); PopupTitle.Size=UDim2.new(1,-22,1,0); PopupTitle.Position=UDim2.new(0,7,0,0); PopupTitle.BackgroundTransparency=1; PopupTitle.Text="📊 FPS Monitor"; PopupTitle.TextColor3=Color3.fromRGB(220,200,255); PopupTitle.TextSize=9; PopupTitle.Font=Enum.Font.Code; PopupTitle.TextXAlignment=Enum.TextXAlignment.Left; PopupTitle.ZIndex=22
local PopupCloseBtn=Instance.new("TextButton",PopupHeader); PopupCloseBtn.Size=UDim2.new(0,16,0,16); PopupCloseBtn.Position=UDim2.new(1,-18,0.5,-8); PopupCloseBtn.BackgroundColor3=Color3.fromRGB(210,30,60); PopupCloseBtn.BackgroundTransparency=0.1; PopupCloseBtn.Text="×"; PopupCloseBtn.TextColor3=Color3.fromRGB(255,255,255); PopupCloseBtn.Font=Enum.Font.SourceSansBold; PopupCloseBtn.TextSize=12; PopupCloseBtn.ZIndex=23; Instance.new("UICorner",PopupCloseBtn).CornerRadius=UDim.new(1,0); spring(PopupCloseBtn)

local PopupFPSBig=Instance.new("TextLabel",FPSPopup); PopupFPSBig.Size=UDim2.new(1,0,1,-32); PopupFPSBig.Position=UDim2.new(0,0,0,20); PopupFPSBig.BackgroundTransparency=1; PopupFPSBig.Text="--"; PopupFPSBig.TextColor3=Color3.fromRGB(0,220,130); PopupFPSBig.TextScaled=true; PopupFPSBig.Font=Enum.Font.GothamBold; PopupFPSBig.ZIndex=22
local PopupBottomBar=Instance.new("Frame",FPSPopup); PopupBottomBar.Size=UDim2.new(1,0,0,12); PopupBottomBar.Position=UDim2.new(0,0,1,-12); PopupBottomBar.BackgroundColor3=Color3.fromRGB(28,28,40); PopupBottomBar.BackgroundTransparency=0.22; PopupBottomBar.BorderSizePixel=0; PopupBottomBar.ZIndex=22
local PopupCapLabel=Instance.new("TextLabel",PopupBottomBar); PopupCapLabel.Size=UDim2.new(0.5,0,1,0); PopupCapLabel.Position=UDim2.new(0,4,0,0); PopupCapLabel.BackgroundTransparency=1; PopupCapLabel.Text="cap:60"; PopupCapLabel.TextColor3=Color3.fromRGB(150,150,255); PopupCapLabel.TextSize=8; PopupCapLabel.Font=Enum.Font.Code; PopupCapLabel.TextXAlignment=Enum.TextXAlignment.Left; PopupCapLabel.ZIndex=23
local PopupStatusLabel=Instance.new("TextLabel",PopupBottomBar); PopupStatusLabel.Size=UDim2.new(0.5,0,1,0); PopupStatusLabel.Position=UDim2.new(0.5,0,0,0); PopupStatusLabel.BackgroundTransparency=1; PopupStatusLabel.Text="ok"; PopupStatusLabel.TextColor3=Color3.fromRGB(0,200,100); PopupStatusLabel.TextSize=8; PopupStatusLabel.Font=Enum.Font.Code; PopupStatusLabel.TextXAlignment=Enum.TextXAlignment.Right; PopupStatusLabel.ZIndex=23

local ResizeHandleFPS=Instance.new("TextButton",FPSPopup); ResizeHandleFPS.Size=UDim2.new(0,14,0,14); ResizeHandleFPS.Position=UDim2.new(1,-14,1,-14); ResizeHandleFPS.BackgroundTransparency=1; ResizeHandleFPS.Text="◢"; ResizeHandleFPS.TextColor3=Color3.fromRGB(255,255,255); ResizeHandleFPS.TextSize=10; ResizeHandleFPS.ZIndex=24
local fpResizing,fpResStart,fpResSize=false,nil,nil
ResizeHandleFPS.InputBegan:Connect(function(i)
    if isTouchOrMouse(i.UserInputType) then fpResizing=true; isAnyResizeActive=true; fpResStart=i.Position; fpResSize=Vector2.new(FPSPopup.Size.X.Offset,FPSPopup.Size.Y.Offset)
        i.Changed:Connect(function() if i.UserInputState.Name=="End" then fpResizing=false; isAnyResizeActive=false end end) end
end)
UserInputService.InputChanged:Connect(function(i)
    if fpResizing and (i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch")) then
        local d=i.Position-fpResStart; FPSPopup.Size=UDim2.new(0,math.clamp(fpResSize.X+d.X,80,400),0,math.clamp(fpResSize.Y+d.Y,50,300))
    end
end)

addBounceOnHold(FPSPopup)
local pDrag,pDragStart,pStartPos=false,nil,nil
PopupHeader.InputBegan:Connect(function(i)
    if isTouchOrMouse(i.UserInputType) then pDrag=true; pDragStart=i.Position; pStartPos=FPSPopup.Position
        i.Changed:Connect(function() if i.UserInputState.Name=="End" then pDrag=false end end) end
end)
UserInputService.InputChanged:Connect(function(i)
    if pDrag and (i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch")) then
        local d=i.Position-pDragStart; local vp=workspace.CurrentCamera.ViewportSize
        FPSPopup.Position=UDim2.new(0,math.clamp(pStartPos.X.Offset+d.X,6,vp.X-FPSPopup.Size.X.Offset-6),0,math.clamp(pStartPos.Y.Offset+d.Y,6,vp.Y-FPSPopup.Size.Y.Offset-6))
    end
end)

local function getUS() return FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup) end
PopupCloseBtn.MouseButton1Click:Connect(function()
    pcall(function() local s=getUS(); s.Scale=1; tw(s,{Scale=0},TweenInfo.new(0.13,Enum.EasingStyle.Back,Enum.EasingDirection.In)) end)
    task.delay(0.11,function() FPSPopup.Visible=false end); ShowFPSPopupBtn.Text="📊 Show FPS Monitor"
end)
ShowFPSPopupBtn.MouseButton1Click:Connect(function()
    if FPSPopup.Visible then
        pcall(function() local s=getUS(); s.Scale=1; tw(s,{Scale=0},TweenInfo.new(0.13,Enum.EasingStyle.Back,Enum.EasingDirection.In)) end)
        task.delay(0.11,function() FPSPopup.Visible=false end); ShowFPSPopupBtn.Text="📊 Show FPS Monitor"
    else
        FPSPopup.Visible=true; local s=getUS(); s.Scale=0
        tw(s,{Scale=1},TweenInfo.new(0.26,Enum.EasingStyle.Back,Enum.EasingDirection.Out)); ShowFPSPopupBtn.Text="📊 Hide FPS Monitor"
    end
end)

-- ================================================================
-- SECTION 38: GRID SIZE + RESIZE — [FIX 9]
-- ================================================================
local camera=workspace.CurrentCamera; local GRID=64
local SIZE_PRESETS={{label="1×1",w=1,h=1},{label="1×2",w=1,h=2},{label="2×2",w=2,h=2},{label="4×4",w=4,h=4},{label="8×8",w=8,h=8},{label="24×24",w=24,h=24}}
local currentSizeIndex=5; SizeBtn.Text=SIZE_PRESETS[currentSizeIndex].label

local function gridPx(slots,axis) local vp=camera.ViewportSize; return math.floor((axis=="x" and vp.X or vp.Y)/GRID*slots) end
local function updateUIVisibility(w,h)
    local showFull=w>=110 and h>=72
    Sidebar.Visible=showFull; ContentArea.Visible=showFull; SidebarLine.Visible=showFull
    TitleLabel.Visible=w>=75; SizeBtn.Visible=w>=90
    if showFull then Sidebar.Size=UDim2.new(0,92,1,-38); Sidebar.Position=UDim2.new(0,0,0,38); ContentArea.Size=UDim2.new(1,-93,1,-38); ContentArea.Position=UDim2.new(0,93,0,38) end
end
local function applyGridSize(preset)
    local pw=gridPx(preset.w,"x"); local ph=gridPx(preset.h,"y"); updateUIVisibility(pw,ph)
    tw(MainFrame,{Size=UDim2.new(0,math.max(pw,44),0,math.max(ph,30))},TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
end
SizeBtn.MouseButton1Click:Connect(function() currentSizeIndex=(currentSizeIndex%#SIZE_PRESETS)+1; local p=SIZE_PRESETS[currentSizeIndex]; SizeBtn.Text=p.label; applyGridSize(p) end)

local ResizeHandle=Instance.new("TextButton",MainFrame); ResizeHandle.Size=UDim2.new(0,22,0,22); ResizeHandle.Position=UDim2.new(1,-22,1,-22)
ResizeHandle.BackgroundTransparency=1; ResizeHandle.Text="◢"; ResizeHandle.TextColor3=Color3.fromRGB(200,200,255); ResizeHandle.TextTransparency=0.4; ResizeHandle.TextSize=15; ResizeHandle.Font=Enum.Font.GothamBold; ResizeHandle.ZIndex=10

local isResizing,resizeStart,resizeSize0=false,nil,nil
ResizeHandle.InputBegan:Connect(function(i)
    if isTouchOrMouse(i.UserInputType) then
        isResizing=true; isAnyResizeActive=true  -- [FIX 9]
        resizeStart=i.Position; resizeSize0=Vector2.new(MainFrame.Size.X.Offset,MainFrame.Size.Y.Offset)
        tw(ResizeHandle,{TextTransparency=0},TweenInfo.new(0.1))
        i.Changed:Connect(function() if i.UserInputState.Name=="End" then isResizing=false; isAnyResizeActive=false; tw(ResizeHandle,{TextTransparency=0.4},TweenInfo.new(0.1)) end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if not isResizing then return end
    if i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch") then
        local delta=i.Position-resizeStart; local nW=math.clamp(resizeSize0.X+delta.X,44,800); local nH=math.clamp(resizeSize0.Y+delta.Y,30,600)
        SizeBtn.Text="Custom"; updateUIVisibility(nW,nH); tw(MainFrame,{Size=UDim2.new(0,nW,0,nH)},TweenInfo.new(0.04,Enum.EasingStyle.Linear))
    end
end)

local lastVP=camera.ViewportSize
task.spawn(function()
    while task.wait(1) do local vp=camera.ViewportSize; if vp~=lastVP then lastVP=vp; if SizeBtn.Text~="Custom" then applyGridSize(SIZE_PRESETS[currentSizeIndex]) end end end
end)

-- ================================================================
-- SECTION 39: MASTER RENDER LOOP
-- ================================================================
local nextUpdate,frameCount,lastBorderColor=0,0,nil
local debugTimer=0; local aiTimer=0

-- [StellarEngine] EMA smoother สำหรับ FPS display
local fpsEMA=StellarEngine.newEMA(0.12)

-- StellarAI auto-fix callbacks
local aiCallbacks={
    sakura_folder=function() if State.sakuraEnabled then createSakura() end end,
}

RunService.RenderStepped:Connect(function(dt)
    frameCount=frameCount+1; nextUpdate=nextUpdate+dt; debugTimer=debugTimer+dt; aiTimer=aiTimer+dt
    local tC=tick()

    if rainbowActive then
        rainbowHue=(rainbowHue+dt*68)%360
        local col=Color3.fromHSV(rainbowHue/360,1,1); local col2=Color3.fromHSV(((rainbowHue+120)%360)/360,1,1)
        pcall(function()
            UIGradientStroke.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col),ColorSequenceKeypoint.new(0.5,col2),ColorSequenceKeypoint.new(1,col)})
            UIGradientStroke.Transparency=NumberSequence.new(0)
        end)
        if activeThemeLabel then activeThemeLabel.TextColor3=col end
    end

    if not isMinimized and COLOR_THEMES[State.currentThemeIndex].liquid then
        pcall(function()
            -- [StellarEngine] smoothNoise สำหรับ liquid glass distort
            local nx=StellarEngine.smoothNoise(tC*0.8,0,0)*0.045
            local ny=StellarEngine.smoothNoise(0,tC*0.8,0)*0.045
            vpCam.CFrame=workspace.CurrentCamera.CFrame*CFrame.Angles(nx,ny,0)
            vpCam.FieldOfView=workspace.CurrentCamera.FieldOfView
        end)
    else
        pcall(function() vpCam.CFrame=workspace.CurrentCamera.CFrame; vpCam.FieldOfView=workspace.CurrentCamera.FieldOfView end)
    end

    if nextUpdate>=0.25 then
        local rawFPS=math.round(frameCount/nextUpdate)
        local fps=math.round(fpsEMA:update(rawFPS))  -- [StellarEngine] smooth FPS
        StellarAI:pushFPS(fps)

        if LiveTimeLabel then
            local m="Day"
            if State.nostalgiaEnabled then m="📼 Nostalgia 2016"
            elseif State.horrorBlue then m="💙 Horror Blue"
            elseif State.horrorFogEnabled then m="☠️ Horror Green"
            elseif State.dawnEnabled then m="🌄 Dawn"
            elseif State.sunsetEnabled then m="🌅 Sunset"
            elseif State.rainEnabled then m="🌧 Rainy"
            elseif State.heavenlyEnabled then m="👼 Heavenly"
            elseif Lighting.ClockTime<6 or Lighting.ClockTime>=19 then m="🌙 Night" end
            LiveTimeLabel.Text=m
        end

        if FPSPopup.Visible then
            PopupFPSBig.Text=tostring(fps)
            PopupCapLabel.Text="cap:"..(State.targetFpsCap==165 and "165⚡" or tostring(State.targetFpsCap))
            local ratio=fps/math.max(State.targetFpsCap,1)
            if ratio>=0.9 then PopupStatusLabel.Text="smooth"; PopupFPSBig.TextColor3=Color3.fromRGB(80,255,140)
            elseif ratio>=0.6 then PopupStatusLabel.Text="ok"; PopupFPSBig.TextColor3=Color3.fromRGB(255,200,50)
            else PopupStatusLabel.Text="low!"; PopupFPSBig.TextColor3=Color3.fromRGB(255,80,80) end
        end

        if not rainbowActive then
            local tc=COLOR_THEMES[State.currentThemeIndex].primary
            if State.nostalgiaEnabled then tc=Color3.fromRGB(210,150,230)
            elseif State.horrorBlue then tc=Color3.fromRGB(40,50,200)
            elseif State.horrorFogEnabled then tc=Color3.fromRGB(60,180,40)
            elseif State.dawnEnabled then tc=Color3.fromRGB(255,180,200)
            elseif State.sunsetEnabled then tc=Color3.fromRGB(255,150,60)
            elseif State.rainEnabled then tc=Color3.fromRGB(100,160,255)
            elseif State.heavenlyEnabled then tc=Color3.fromRGB(255,240,120) end
            if lastBorderColor~=tc then
                lastBorderColor=tc; tw(FPSPopupStroke,{Color=tc},TweenInfo.new(0.32))
                if State.borderStyle=="solid" or State.borderStyle=="gradient" or State.borderStyle=="glow" then
                    applyBorderStyle(State.borderStyle,tc)
                end
            end
        end
        frameCount=0; nextUpdate=0
    end

    -- Debug update
    if debugTimer>=0.7 and activeTab==TabDebug then
        debugTimer=0
        pcall(function()
            DbgBox.Text=StellarAI:getReport()
            EngineBox.Text=string.format(
                "StellarEngine\nSpring: stiff=280 damp=22\nBezier: cubic 4-point\nNoise: %d octaves\nEMA alpha=0.12\nColorHSV lerp: ON\nGridCell: available\nBind: available",
                3
            )
        end)
    end

    -- StellarAI adaptive quality + watch check
    if aiTimer>=2.0 then
        aiTimer=0
        StellarAI:check(aiCallbacks)
        StellarAI:updateQuality(State, createRainParticles, createSakura)
    end

    -- Shadow sync
    pcall(function()
        Shadow.Position=UDim2.new(0,MainFrame.Position.X.Offset-21,0,MainFrame.Position.Y.Offset-21)
        Shadow.Visible=not isMinimized
    end)
end)

-- ================================================================
-- SECTION 40: INIT
-- ================================================================
applyGridSize(SIZE_PRESETS[currentSizeIndex])
applyTheme(1)
applyBorderStyle("gradient", COLOR_THEMES[1].primary)
reapplyActiveMode()

print("✅ MYTHICAL SHADER v6.6 [ULTIMATE] — Sakura Part-based / Sun rays 3D / Wind fixed / Border clean / Horror enhanced / Meteor particles / StellarAI / StellarEngine")

