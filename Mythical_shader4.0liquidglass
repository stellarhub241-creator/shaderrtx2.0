-- [v4.9.2] Popup Physics: velocity + bounce + บุบตอนชน
local popupVelX,popupVelY=0,0
local popupPhysicsActive=false
local FRICTION=0.86

local function getPopupUIScale()
    return FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup)
end

local function popupBounceSquish()
    pcall(function()
        local us=getPopupUIScale() us.Scale=1
        TweenService:Create(us,TweenInfo.new(0.08,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Scale=0.88}):Play()
        task.delay(0.08,function() pcall(function() TweenService:Create(us,TweenInfo.new(0.2,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1.0}):Play() end) end)
    end)
end

-- กดค้าง → บุบ + สะสม velocity
local popupDrag,popupDragStart,popupStartPos=false,nil,nil
local popupLastPos,popupLastTime=nil,0
local popupHoldThread=nil

PopupHeader.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        popupDrag=true popupDragStart=input.Position popupStartPos=FPSPopup.Position
        popupLastPos=input.Position popupLastTime=tick() popupPhysicsActive=false popupVelX=0 popupVelY=0
        -- กดค้าง → บุบ
        if popupHoldThread then pcall(function() task.cancel(popupHoldThread) end) end
        popupHoldThread=task.delay(0.35,function()
            if popupDrag then popupBounceSquish() end
            popupHoldThread=nil
        end)
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then
                popupDrag=false
                if popupHoldThread then pcall(function() task.cancel(popupHoldThread) end) popupHoldThread=nil end
                -- ปล่อย → ยิง velocity
                local dt=math.max(tick()-popupLastTime,0.01)
                -- velocity ถูกคำนวณใน InputChanged แล้ว
                if math.abs(popupVelX)>10 or math.abs(popupVelY)>10 then
                    popupPhysicsActive=true
                end
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if popupDrag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local d=i.Position-popupDragStart
        FPSPopup.Position=UDim2.new(popupStartPos.X.Scale,popupStartPos.X.Offset+d.X,popupStartPos.Y.Scale,popupStartPos.Y.Offset+d.Y)
        -- สะสม velocity
        local now=tick() local dt=math.max(now-popupLastTime,0.001)
        if popupLastPos then popupVelX=(i.Position.X-popupLastPos.X)/dt popupVelY=(i.Position.Y-popupLastPos.Y)/dt end
        popupLastPos=i.Position popupLastTime=now
    end
end)

-- Physics loop: bounce ชนขอบ
RunService.RenderStepped:Connect(function(dt)
    if not popupPhysicsActive or popupDrag then return end
    if math.abs(popupVelX)<1 and math.abs(popupVelY)<1 then popupPhysicsActive=false return end

    local vp=workspace.CurrentCamera.ViewportSize
    local pw=FPSPopup.Size.X.Offset local ph=FPSPopup.Size.Y.Offset
    local px=FPSPopup.Position.X.Offset local py=FPSPopup.Position.Y.Offset

    -- clamp dt เพื่อป้องกัน spike
    local cdt=math.min(dt,0.05)
    px=px+popupVelX*cdt py=py+popupVelY*cdt
    popupVelX=popupVelX*FRICTION popupVelY=popupVelY*FRICTION

    -- bounce ซ้าย
    if px<8 then px=8 popupVelX=math.abs(popupVelX)*0.55 popupBounceSquish() end
    -- bounce ขวา
    if px+pw>vp.X-8 then px=vp.X-pw-8 popupVelX=-math.abs(popupVelX)*0.55 popupBounceSquish() end
    -- bounce บน
    if py<8 then py=8 popupVelY=math.abs(popupVelY)*0.55 popupBounceSquish() end
    -- bounce ล่าง
    if py+ph>vp.Y-8 then py=vp.Y-ph-8 popupVelY=-math.abs(popupVelY)*0.55 popupBounceSquish() end

    FPSPopup.Position=UDim2.new(0,px,0,py)
end)

-- Resize popup
local popupResizing,popupResizeStart,popupResizeSize=false,nil,nil
PopupResize.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then popupResizing=true popupResizeStart=i.Position popupResizeSize=Vector2.new(FPSPopup.Size.X.Offset,FPSPopup.Size.Y.Offset) i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then popupResizing=false end end) end end)
UserInputService.InputChanged:Connect(function(i)
    if popupResizing and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local d=i.Position-popupResizeStart
        local nW=math.clamp(popupResizeSize.X+d.X,44,300) local nH=math.clamp(popupResizeSize.Y+d.Y,38,200)
        PopupTitle.Visible=nW>=60 PopupCapLabel.Visible=nH>=55 PopupCloseBtn.Visible=nW>=60
        PopupHeader.BackgroundTransparency=nH>=55 and 0.4 or 1
        pcall(function() TweenService:Create(FPSPopup,TweenInfo.new(0.04,Enum.EasingStyle.Quad),{Size=UDim2.new(0,nW,0,nH)}):Play() end)
    end
end)

PopupCloseBtn.MouseButton1Click:Connect(function()
    pcall(function() local s=getPopupUIScale() s.Scale=1 TweenService:Create(s,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Scale=0}):Play() end)
    task.delay(0.16,function() FPSPopup.Visible=false end) ShowFPSPopupBtn.Text="📊 Show FPS Monitor"
end)
ShowFPSPopupBtn.MouseButton1Click:Connect(function()
    if FPSPopup.Visible then
        pcall(function() local s=getPopupUIScale() s.Scale=1 TweenService:Create(s,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Scale=0}):Play() end)
        task.delay(0.16,function() FPSPopup.Visible=false end) ShowFPSPopupBtn.Text="📊 Show FPS Monitor"
    else
        FPSPopup.Visible=true local s=getPopupUIScale() s.Scale=0
        pcall(function() TweenService:Create(s,TweenInfo.new(0.32,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Scale=1}):Play() end)
        ShowFPSPopupBtn.Text="📊 Hide FPS Monitor"
    end
end)

