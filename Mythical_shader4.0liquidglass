local function mkToggle(par,txt,ord,def,cb)
    local F=Instance.new("Frame",par); F.Size=UDim2.new(1,-14,0,30); F.Position=UDim2.new(0,7,0,(ord-1)*36+6); F.BackgroundTransparency=1
    local L=Instance.new("TextLabel",F); L.Size=UDim2.new(0.68,0,1,0); L.BackgroundTransparency=1; L.Text=txt; L.TextColor3=Color3.fromRGB(242,242,255); L.TextSize=11; L.Font=Enum.Font.SourceSans; L.TextXAlignment=Enum.TextXAlignment.Left; Instance.new("UIStroke",L).Transparency=0.65
    local B=Instance.new("TextButton",F); B.Size=UDim2.new(0,48,0,22); B.Position=UDim2.new(1,-48,0.5,-11)
    B.BackgroundColor3=def and THEMES[St.themeIdx].pri or Color3.fromRGB(38,38,50); B.BackgroundTransparency=0.28; B.Text=def and "ON" or "OFF"; B.TextColor3=Color3.fromRGB(255,255,255); B.Font=Enum.Font.SourceSansBold; B.TextSize=10
    Instance.new("UICorner",B).CornerRadius=UDim.new(0,11); Instance.new("UIStroke",B).Color=Color3.fromRGB(150,150,180); spring(B)
    local cur=def
    B.MouseButton1Click:Connect(function() cur=not cur; tw(B,{BackgroundColor3=cur and THEMES[St.themeIdx].pri or Color3.fromRGB(38,38,50)},TW1); B.Text=cur and "ON" or "OFF"; pcall(function() cb(cur) end) end)
    return B
end
local function autoC(sc,n,h,g,pad) sc.CanvasSize=UDim2.new(0,0,0,pad+n*(h+g)) end

-- ================================================================
-- SECTION 30: SLIDER
-- ================================================================
local sliders={}; local sliderCnt=0
local function mkSlider(par,yPos,lbl,def,fn)
    sliderCnt=sliderCnt+1; local myId=sliderCnt; local th=THEMES[St.themeIdx]
    local con=Instance.new("Frame",par); con.Size=UDim2.new(1,-14,0,48); con.Position=UDim2.new(0,7,0,yPos)
    con.BackgroundColor3=Color3.fromRGB(22,22,32); con.BackgroundTransparency=0.38; con.BorderSizePixel=0
    Instance.new("UICorner",con).CornerRadius=UDim.new(0,10); local cs=Instance.new("UIStroke",con); cs.Thickness=1; cs.Color=Color3.fromRGB(100,120,200); cs.Transparency=0.55
    local lb=Instance.new("TextLabel",con); lb.Size=UDim2.new(0.72,0,0,18); lb.Position=UDim2.new(0,10,0,3); lb.BackgroundTransparency=1; lb.Text=lbl; lb.TextColor3=Color3.fromRGB(240,240,255); lb.TextSize=10; lb.Font=Enum.Font.SourceSansBold; lb.TextXAlignment=Enum.TextXAlignment.Left; Instance.new("UIStroke",lb).Transparency=0.65
    local vl=Instance.new("TextLabel",con); vl.Size=UDim2.new(0.28,-8,0,18); vl.Position=UDim2.new(0.72,0,0,3); vl.BackgroundTransparency=1; vl.Text=math.floor(def*100).."%"; vl.TextColor3=th.pri; vl.TextSize=10; vl.Font=Enum.Font.Code; vl.TextXAlignment=Enum.TextXAlignment.Right
    local trk=Instance.new("Frame",con); trk.Size=UDim2.new(1,-20,0,9); trk.Position=UDim2.new(0,10,0,29); trk.BackgroundColor3=Color3.fromRGB(38,38,50); trk.BackgroundTransparency=0.2; trk.BorderSizePixel=0; Instance.new("UICorner",trk).CornerRadius=UDim.new(0,5)
    local fil=Instance.new("Frame",trk); fil.Size=UDim2.new(def,0,1,0); fil.BackgroundColor3=Color3.fromRGB(255,255,255); fil.BorderSizePixel=0; Instance.new("UICorner",fil).CornerRadius=UDim.new(0,5)
    local fG=Instance.new("UIGradient",fil); fG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,80)),ColorSequenceKeypoint.new(1,th.pri)})
    local bsh=Instance.new("Frame",trk); bsh.Size=UDim2.new(0,16,0,6); bsh.Position=UDim2.new(def,-8,1,-2); bsh.BackgroundColor3=Color3.fromRGB(8,8,16); bsh.BackgroundTransparency=0.45; bsh.BorderSizePixel=0; bsh.ZIndex=4; Instance.new("UICorner",bsh).CornerRadius=UDim.new(1,0)
    local ball=Instance.new("TextButton",trk); ball.Size=UDim2.new(0,22,0,22); ball.Position=UDim2.new(def,-11,0.5,-11); ball.BackgroundColor3=Color3.fromRGB(255,255,255); ball.Text=""; ball.BorderSizePixel=0; ball.ZIndex=6; Instance.new("UICorner",ball).CornerRadius=UDim.new(1,0)
    local bG=Instance.new("UIGradient",ball); bG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(1,th.ball or th.pri)})
    local bS=Instance.new("UIStroke",ball); bS.Color=SA.lerpC(th.pri,Color3.fromRGB(80,80,120),0.4); bS.Thickness=2.2
    pcall(function()
        local us=Instance.new("UIScale",ball); us.Scale=1.0
        ball.MouseEnter:Connect(function() pcall(function() tw(us,{Scale=1.12},TW1) end) end)
        ball.MouseLeave:Connect(function() pcall(function() tw(us,{Scale=1.0},TW0) end) end)
        ball.InputBegan:Connect(function(i) if isTM(i.UserInputType) then pcall(function() tw(us,{Scale=0.9},TW2) end) end end)
        ball.InputEnded:Connect(function(i) if isTM(i.UserInputType) then pcall(function() tw(us,{Scale=1.0},TW1) end) end end)
    end)
    sliders[#sliders+1]={fil=fil,fG=fG,ball=ball,bG=bG,bS=bS,vl=vl,bsh=bsh,con=con,lb=lb}
    local drag=false; local lastR=def
    local function sd(i) if isTM(i.UserInputType) then if inputBlocked() then return end; if St.sliderID~=nil and St.sliderID~=myId then return end; drag=true; St.sliderID=myId end end
    ball.InputBegan:Connect(sd); trk.InputBegan:Connect(sd)
    UserInputService.InputEnded:Connect(function(i) if isTM(i.UserInputType) and drag then drag=false; if St.sliderID==myId then St.sliderID=nil end end end)
    UserInputService.InputChanged:Connect(function(i)
        if not drag then return end; if inputBlocked() then drag=false; St.sliderID=nil; return end; if St.sliderID~=myId then drag=false; return end
        if i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch") then
            local r=math.clamp((i.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
            if math.abs(r-lastR)<0.002 then return end
            pcall(function() ball.Rotation=ball.Rotation+(r-lastR)*720 end); lastR=r
            fil.Size=UDim2.new(r,0,1,0); ball.Position=UDim2.new(r,-11,0.5,-11); bsh.Position=UDim2.new(r,-8,1,-2); vl.Text=math.floor(r*100).."%"
            fG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,80)),ColorSequenceKeypoint.new(1,SA.lerpHSV(Color3.fromRGB(150,150,200),THEMES[St.themeIdx].pri,r))})
            pcall(function() fn(r) end)
        end
    end)
    return con,fil,ball,vl
end
local function refreshSliders()
    local th=THEMES[St.themeIdx]
    for _,s in ipairs(sliders) do
        pcall(function()
            s.fG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,80)),ColorSequenceKeypoint.new(1,th.pri)})
            s.bG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(1,th.ball or th.pri)})
            s.bS.Color=SA.lerpC(th.pri,Color3.fromRGB(80,80,120),0.4); s.vl.TextColor3=th.pri
            if th.dark or th.clear then s.con.BackgroundColor3=Color3.fromRGB(22,22,32); s.lb.TextColor3=Color3.fromRGB(220,220,255)
            elseif th.glass then s.con.BackgroundColor3=Color3.fromRGB(228,240,250); s.lb.TextColor3=Color3.fromRGB(40,60,90)
            else s.con.BackgroundColor3=Color3.fromRGB(244,244,252); s.lb.TextColor3=Color3.fromRGB(50,42,70) end
        end)
    end
end

