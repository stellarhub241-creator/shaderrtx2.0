local function clearNeonEdge()
    for _,c in pairs(neonEdgeConns) do pcall(function() c:Disconnect() end) end
    neonEdgeConns={}
    if neonEdgeFrame and neonEdgeFrame.Parent then neonEdgeFrame:Destroy() end
    neonEdgeFrame=nil
