-- ================================================================
-- SECTION 7: UTILITIES
-- ================================================================
local function lerpN(a,b,t) return a+(b-a)*t end
local function lerpC(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end

local function applyLighting(p)
    pcall(function()
        Lighting.Brightness=p.brightness Lighting.ExposureCompensation=p.exposure
        Lighting.ShadowSoftness=p.shadow Lighting.OutdoorAmbient=p.ambient
        Atmosphere.Color=p.atmoColor Atmosphere.Decay=p.atmoDecay
        Atmosphere.Glare=p.atmoGlare Atmosphere.Haze=p.atmoHaze Atmosphere.Density=p.atmoDensity
        ColorCorrection.Contrast=p.contrast ColorCorrection.Saturation=p.saturation
        ColorCorrection.TintColor=p.tint
        Bloom.Intensity=p.bloom Bloom.Size=p.bloomSize Bloom.Threshold=p.bloomThreshold
        DOF.FarIntensity=p.dofFar SunRays.Intensity=p.sunRays
    end)
end

local cinContrast=0.6 local cinSaturation=-0.1 local cinDofFar=0.55 local cinShadow=0.65

local function applyCinematicBlend()
    if not cinematicEnabled then return end
    pcall(function()
        ColorCorrection.Contrast=math.max(ColorCorrection.Contrast,cinContrast)
        ColorCorrection.Saturation=ColorCorrection.Saturation+cinSaturation
        DOF.FarIntensity=math.max(DOF.FarIntensity,cinDofFar)
        Bloom.Threshold=math.min(Bloom.Threshold+0.08,0.99)
        Lighting.ShadowSoftness=math.max(Lighting.ShadowSoftness,cinShadow)
    end)
end

local function resetFogLighting()
    pcall(function()
        Lighting.FogStart=originalFogStart Lighting.FogEnd=originalFogEnd
        Lighting.FogColor=originalFogColor Lighting.Ambient=originalAmbient
        Lighting.Brightness=originalBrightness Lighting.ExposureCompensation=originalExposure
        Lighting.ShadowSoftness=originalShadow Lighting.OutdoorAmbient=originalOutdoor
    end)
end

local function reapplyActiveMode()
    if horrorFogEnabled then
        applyLighting(PROFILES.HORROR)
        pcall(function()
            Lighting.FogStart=4 Lighting.FogEnd=80
            Lighting.FogColor=Color3.fromRGB(10,18,6)
            Lighting.Ambient=Color3.fromRGB(6,10,3)
        end)
    elseif rainEnabled then
        applyLighting(PROFILES.RAIN)
        pcall(function() Lighting.FogStart=20 Lighting.FogEnd=200 Lighting.FogColor=Color3.fromRGB(110,122,142) end)
    elseif heavenlyEnabled then
        applyLighting(PROFILES.HEAVENLY)
        pcall(function() Lighting.FogStart=500 Lighting.FogEnd=2000 Lighting.FogColor=Color3.fromRGB(225,235,255) Lighting.ClockTime=12 end)
    else resetFogLighting() end
    applyCinematicBlend()
end

-- ================================================================
-- SECTION 8: RAIN SYSTEM
-- ================================================================
local rainFolder=nil local rainConns={} local rainParts={} local rainRipples={}

local function clearRainParticles()
    for _,c in pairs(rainConns) do pcall(function() c:Disconnect() end) end
    rainConns={}
    if rainFolder and rainFolder.Parent then rainFolder:Destroy() end
    rainFolder=nil rainParts={} rainRipples={}
end

local function createRainParticles()
    clearRainParticles()
    rainFolder=Instance.new("Folder",workspace) rainFolder.Name="StellarRain"
    local cam=workspace.CurrentCamera
    local count=math.clamp(rainParticleCount,10,150)
    for i=1,count do
        local p=Instance.new("Part")
        p.Size=Vector3.new(0.045,math.random(18,30)*0.1,0.045)
        p.Material=Enum.Material.Glass p.Reflectance=math.random(70,90)/100
        p.Color=Color3.fromRGB(math.random(200,230),math.random(225,245),255)
        p.Transparency=math.random(55,72)/100
        p.CastShadow=false p.Anchored=true p.CanCollide=false p.Parent=rainFolder
        table.insert(rainParts,p)
    end
    local rippleCount=math.max(6,math.floor(count*0.18))
    for i=1,rippleCount do
        local r=Instance.new("Part")
        r.Size=Vector3.new(0.1,0.05,0.1) r.Material=Enum.Material.Glass r.Reflectance=0.7
        r.Color=Color3.fromRGB(180,215,255) r.Transparency=0.82
        r.CastShadow=false r.Anchored=true r.CanCollide=false
        r.Shape=Enum.PartType.Cylinder r.Parent=rainFolder
        table.insert(rainRipples,r)
    end
    local frame=0
    local conn=RunService.Heartbeat:Connect(function()
        frame=frame+1 if frame%2~=0 then return end
        if not rainFolder or not rainFolder.Parent then return end
        local cp=cam.CFrame.Position local t=tick()
        for i,p in ipairs(rainParts) do
            if p and p.Parent then
                local ph=i*0.73 local fall=(t*16+ph*2.8)%32
                p.Reflectance=0.65+math.sin(t*3+ph)*0.25
                p.CFrame=CFrame.new(cp.X+math.sin(ph)*34,cp.Y+20-fall,cp.Z+math.cos(ph)*34)*CFrame.Angles(0.18,0,0.06)
            end
        end
        for i,r in ipairs(rainRipples) do
            if r and r.Parent then
                local rt=(t*0.7+i*0.65)%1 local sc=0.3+rt*3.5 local ph=i*1.13
                local rx=cp.X+math.sin(ph)*22 local rz=cp.Z+math.cos(ph)*22
                local ray=workspace:Raycast(Vector3.new(rx,cp.Y+8,rz),Vector3.new(0,-50,0))
                local ry=ray and ray.Position.Y+0.05 or cp.Y-8
                r.CFrame=CFrame.new(rx,ry,rz)*CFrame.Angles(0,0,math.pi/2)
                r.Size=Vector3.new(0.05,sc,sc) r.Transparency=0.65+(1-rt)*0.28
                r.Reflectance=0.6+math.sin(t*2+i)*0.3
                r.Color=Color3.fromRGB(math.floor(lerpN(150,210,1-rt)),math.floor(lerpN(190,235,1-rt)),255)
            end
        end
    end)
    table.insert(rainConns,conn)
end

-- ================================================================
-- SECTION 9: SAKURA (ParticleEmitter จริง)
-- ================================================================
local sakuraFolder=nil local sakuraConns={}

local function clearSakura()
    for _,c in pairs(sakuraConns) do pcall(function() c:Disconnect() end) end
    sakuraConns={}
    if sakuraFolder and sakuraFolder.Parent then sakuraFolder:Destroy() end
    sakuraFolder=nil
end

local function createSakura()
    clearSakura()
    sakuraFolder=Instance.new("Folder",workspace) sakuraFolder.Name="StellarSakura"
    local cam=workspace.CurrentCamera
    local emitter=Instance.new("Part",sakuraFolder)
    emitter.Size=Vector3.new(1,1,1) emitter.Anchored=true emitter.CanCollide=false
    emitter.Transparency=1 emitter.CastShadow=false emitter.Name="SakuraEmitter"
    local pe=Instance.new("ParticleEmitter",emitter)
    pe.Texture="rbxassetid://266310694"
    pe.Rate=math.clamp(sakuraCount*0.8,8,65)
    pe.Lifetime=NumberRange.new(3.5,6.5) pe.Speed=NumberRange.new(1,4)
    pe.SpreadAngle=Vector2.new(80,80) pe.RotSpeed=NumberRange.new(-120,120)
    pe.Rotation=NumberRange.new(0,360) pe.LightEmission=0.15 pe.LightInfluence=0.85
    pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.1),NumberSequenceKeypoint.new(0.8,0.2),NumberSequenceKeypoint.new(1,1)})
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(0.15,0.9),NumberSequenceKeypoint.new(0.85,0.7),NumberSequenceKeypoint.new(1,0)})
    pe.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,220,235)),ColorSequenceKeypoint.new(0.4,Color3.fromRGB(255,185,210)),ColorSequenceKeypoint.new(1,Color3.fromRGB(240,150,180))})
    pe.Acceleration=Vector3.new(0,-1.2,0) pe.EmissionDirection=Enum.NormalId.Top
    local conn=RunService.Heartbeat:Connect(function()
        if not sakuraFolder or not sakuraFolder.Parent then return end
        if not emitter or not emitter.Parent then return end
        local cp=cam.CFrame.Position
        emitter.CFrame=CFrame.new(cp.X,cp.Y+12,cp.Z)
    end)
    table.insert(sakuraConns,conn)
end

-- ================================================================
-- SECTION 10: WIND SYSTEM
-- ================================================================
local windConns={} local windParts={}

local function clearWind()
    for _,c in pairs(windConns) do pcall(function() c:Disconnect() end) end
    windConns={}
    for _,d in pairs(windParts) do
        pcall(function() if d.part and d.part.Parent then d.part.CFrame=d.origin end end)
    end
    windParts={}
end

local function startWind()
    clearWind()
    local cam=workspace.CurrentCamera
    for _,v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if (v:IsA("BasePart") or v:IsA("MeshPart")) and v.Anchored then
                local sz=v.Size
                local pn=v.Parent and v.Parent.Name or ""
                if sz.X<4 and sz.Z<4 and sz.Y<12
                    and (v.Position-cam.CFrame.Position).Magnitude<150
                    and pn~="StellarRain" and pn~="StellarSakura"
                    and pn~="StellarMeteor" and pn~="StellarSun" then
                    table.insert(windParts,{part=v,origin=v.CFrame,phase=math.random()*math.pi*2,freq=0.8+math.random()*0.8,amp=0.012+math.random()*0.018})
                end
            end
        end)
    end
    local conn=RunService.Heartbeat:Connect(function()
        if not windEnabled then return end
        local t=tick()
        for _,d in pairs(windParts) do
            pcall(function()
                if d.part and d.part.Parent then
                    local wave=math.sin(t*d.freq+d.phase)*d.amp*windStrength
                    local wave2=math.cos(t*d.freq*0.7+d.phase)*d.amp*windStrength*0.5
                    d.part.CFrame=d.origin*CFrame.Angles(wave,wave2*0.3,wave*0.5)
                end
            end)
        end
    end)
    table.insert(windConns,conn)
end

-- ================================================================
-- SECTION 11: METEOR SHOWER (สวยขึ้นมาก)
-- ================================================================
local meteorFolder=nil local meteorConns={} local meteorRunning=false

local function clearMeteor()
    meteorRunning=false
    for _,c in pairs(meteorConns) do pcall(function() c:Disconnect() end) end
    meteorConns={}
    if meteorFolder and meteorFolder.Parent then meteorFolder:Destroy() end
    meteorFolder=nil
end

local function spawnOneMeteor()
    if not meteorFolder or not meteorFolder.Parent then return end
    local cam=workspace.CurrentCamera
    local cp=cam.CFrame.Position

    -- spawn บนฟ้า สุ่มตำแหน่ง
    local angle=math.random()*math.pi*2
    local dist=math.random(80,160)
    local sx=cp.X+math.cos(angle)*dist
    local sy=cp.Y+math.random(100,160)
    local sz=cp.Z+math.sin(angle)*dist

    -- ทิศทางเฉียงลงหา cam
    local target=Vector3.new(cp.X+(math.random()-0.5)*60,cp.Y-20,cp.Z+(math.random()-0.5)*60)
    local dir=(target-Vector3.new(sx,sy,sz)).Unit
    local speed=math.random(80,140)
    local len=math.random(14,28)

    -- HEAD: core สว่าง
    local head=Instance.new("Part",meteorFolder)
    head.Size=Vector3.new(0.6,0.6,0.6) head.Material=Enum.Material.Neon
    head.Color=meteorColor head.Transparency=0 head.CastShadow=false
    head.Anchored=true head.CanCollide=false
    Instance.new("SpecialMesh",head).MeshType=Enum.MeshType.Sphere

    -- BODY: trail หลัก
    local body=Instance.new("Part",meteorFolder)
    body.Size=Vector3.new(0.25,0.25,len) body.Material=Enum.Material.Neon
    body.Color=lerpC(meteorColor,Color3.fromRGB(255,255,255),0.5)
    body.Transparency=0.25 body.CastShadow=false body.Anchored=true body.CanCollide=false

    -- TAIL: trail จาง
    local tail=Instance.new("Part",meteorFolder)
    tail.Size=Vector3.new(0.1,0.1,len*2.2) tail.Material=Enum.Material.Neon
    tail.Color=lerpC(meteorColor,Color3.fromRGB(255,255,255),0.8)
    tail.Transparency=0.68 tail.CastShadow=false tail.Anchored=true tail.CanCollide=false

    -- GLOW: sphere รอบ head
    local glow=Instance.new("Part",meteorFolder)
    glow.Size=Vector3.new(3,3,3) glow.Material=Enum.Material.Neon
    glow.Color=meteorColor glow.Transparency=0.82 glow.CastShadow=false
    glow.Anchored=true glow.CanCollide=false
    Instance.new("SpecialMesh",glow).MeshType=Enum.MeshType.Sphere

    -- particle ประกาย
    local pe=Instance.new("ParticleEmitter",head)
    pe.Texture="rbxassetid://6101261905"
    pe.Rate=90 pe.Lifetime=NumberRange.new(0.15,0.45)
    pe.Speed=NumberRange.new(4,12) pe.SpreadAngle=Vector2.new(35,35)
    pe.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,meteorColor),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,255,200)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255))})
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.5),NumberSequenceKeypoint.new(0.5,0.25),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1.0 pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.1),NumberSequenceKeypoint.new(1,1)})

    -- คำนวณ CFrame ให้หัวชี้ทิศทาง
    local cf=CFrame.lookAt(Vector3.new(sx,sy,sz),Vector3.new(sx,sy,sz)+dir)*CFrame.Angles(math.pi/2,0,0)

    local life=0 local maxLife=4.5 local traveled=0

    local conn=RunService.Heartbeat:Connect(function(dt)
        life=life+dt
        if life>=maxLife then
            pe.Enabled=false
            pcall(function() head:Destroy() body:Destroy() tail:Destroy() glow:Destroy() end)
            return
        end
        local move=dir*speed*dt
        local fade=math.clamp(1-(life-3)/1.5,0,1)
        pcall(function()
            local np=Vector3.new(sx,sy,sz)+dir*speed*life
            local headCF=CFrame.lookAt(np,np+dir)*CFrame.Angles(math.pi/2,0,0)
            head.CFrame=CFrame.new(np)
            body.CFrame=CFrame.lookAt(np-dir*(len/2),np-dir*(len/2)+dir)*CFrame.Angles(math.pi/2,0,0)
            tail.CFrame=CFrame.lookAt(np-dir*(len*1.5),np-dir*(len*1.5)+dir)*CFrame.Angles(math.pi/2,0,0)
            glow.CFrame=CFrame.new(np)
            -- pulse glow
            local pulse=1+math.sin(life*20)*0.15
            glow.Size=Vector3.new(3*pulse,3*pulse,3*pulse)
            head.Transparency=1-fade body.Transparency=0.25+(1-fade)*0.75
            tail.Transparency=0.68+(1-fade)*0.32 glow.Transparency=0.82+(1-fade)*0.18
        end)
    end)
    table.insert(meteorConns,conn)
end

local function startMeteor()
    clearMeteor()
    meteorRunning=true
    meteorFolder=Instance.new("Folder",workspace) meteorFolder.Name="StellarMeteor"
    task.spawn(function()
        while meteorRunning do
            spawnOneMeteor()
            task.wait(math.random()*meteorInterval+0.8)
        end
    end)
end

