        pcall(function() MainFrame:TweenSize(UDim2.new(0,65,0,26),Enum.EasingDirection.Out,Enum.EasingStyle.Back,0.38,true) end)
        MinBtn.Position=UDim2.new(1,-22,0.5,-10)
    else
