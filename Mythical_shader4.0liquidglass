    {"Bloom Intensity",         Color3.fromRGB(255,220,60),  Color3.fromRGB(255,255,160), 0.08, function(r) Bloom.Intensity=r*2 end},
    {"Atmosphere Haze",         Color3.fromRGB(120,160,210), Color3.fromRGB(180,215,255), 0.3,  function(r) Atmosphere.Haze=r*5 end},
    {"Fog Start",               Color3.fromRGB(90,145,195),  Color3.fromRGB(160,210,255), 0.1,  function(r) Lighting.FogStart=lerpN(0,300,r) end},
    {"Fog End",                 Color3.fromRGB(60,115,175),  Color3.fromRGB(130,195,255), 0.3,  function(r) Lighting.FogEnd=lerpN(50,2000,r) end},
    {"Field of View (30-120°)", Color3.fromRGB(70,200,160),  Color3.fromRGB(150,255,210), 0.44, function(r) pcall(function() workspace.CurrentCamera.FieldOfView=lerpN(30,120,r) end) end},
