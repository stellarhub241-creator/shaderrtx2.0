    {BY+304,"Fog End",                   BY+319, Color3.fromRGB(60,120,180), Color3.fromRGB(140,200,255),0.3,  function(r) Lighting.FogEnd=lerpN(50,2000,r) end},
    {BY+342,"Field of View (30-120°)",   BY+357, Color3.fromRGB(80,210,170), Color3.fromRGB(170,255,220),0.44, function(r) workspace.CurrentCamera.FieldOfView=lerpN(30,120,r) end},
