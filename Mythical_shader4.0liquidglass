-- [6] DYNAMIC REAL-TIME DAY/NIGHT LIGHTING SYSTEM
-- =============================================================================
local ModeText = "Status: Loading..."
local BorderColorNow = COLOR_THEMES[currentThemeIndex].primary
local rainbowHue = 0

task.spawn(function()
    while task.wait(0.2) do
        if not horrorFogEnabled and not rainEnabled then
            local t = Lighting.ClockTime
            
            if t >= 5 and t < 6 then
                local ratio = (t - 5) / 1
                applyProfile(lerpProfile(PROFILES.NIGHT, PROFILES.DAWN, ratio))
                ModeText = "Status: Dawn"
            elseif t >= 6 and t < 15 then
                applyProfile(PROFILES.DAY)
                ModeText = "Status: Day"
            elseif t >= 15 and t < 19 then
                local ratio = (t - 15) / 4
                applyProfile(lerpProfile(PROFILES.DAY, PROFILES.GOLDEN, ratio))
                ModeText = "Status: Golden Hour"
            elseif t >= 19 and t < 21 then
                local ratio = (t - 19) / 2
                applyProfile(lerpProfile(PROFILES.GOLDEN, PROFILES.NIGHT, ratio))
                ModeText = "Status: Sunset"
            else
                applyProfile(PROFILES.NIGHT)
                ModeText = "Status: Night"
            end
        end
    end
end)

-- =============================================================================
-- [7] 4K PBR MATERIAL ENGINE SCANNER
-- =============================================================================
local function applyPBROnPart(v)
    if not pbrEnabled or isFpsBoostOn then
        return
    end
    
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.CastShadow = true
        local m = v.Material
        local r = 0
        
        if m == Enum.Material.Concrete then
            r = 0.15
        elseif m == Enum.Material.SmoothPlastic then
            r = 0.35
        elseif m == Enum.Material.Cobblestone then
            r = 0.08
        elseif m == Enum.Material.Wood or m == Enum.Material.WoodPlanks then
            r = 0.03
        elseif m == Enum.Material.Marble then
            r = 0.55
        elseif m == Enum.Material.Granite then
            r = 0.3
        elseif m == Enum.Material.Metal or m == Enum.Material.DiamondPlate then
            r = 0.65
        elseif m == Enum.Material.Glass then
            r = 0.8
        elseif m == Enum.Material.Neon then
            r = 0.85
        elseif m == Enum.Material.Ice then
            r = 0.7
        elseif m == Enum.Material.Sand then
            r = 0.02
        end
        
        if antiBlueGloss then
            local c = v.Color
            local lum = (c.R * 0.299) + (c.G * 0.587) + (c.B * 0.114)
            if lum < 0.18 then
                v.Reflectance = r * (lum * 3.5)
            else
                v.Reflectance = r
            end
        else
            v.Reflectance = r
        end
    end
end

local function runPBRScan()
    local count = 0
    for _, v in pairs(workspace:GetDescendants()) do
        applyPBROnPart(v)
        count = count + 1 
        if count % 200 == 0 then
            task.wait()
        end
    end
end

task.spawn(runPBRScan)
workspace.DescendantAdded:Connect(function(v)
    task.delay(0.1, function()
        applyPBROnPart(v)
    end)
end)

