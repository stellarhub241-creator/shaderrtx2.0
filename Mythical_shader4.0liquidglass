-- SECTION 28: BALL SLIDER
-- ================================================================
local allSliderBalls={}; local SLIDER_ID_COUNTER=0

local function makeBallSlider(parent,yPos,labelText,defRel,changeFn)
    SLIDER_ID_COUNTER=SLIDER_ID_COUNTER+1; local myId=SLIDER_ID_COUNTER
    local theme=COLOR_THEMES[State.currentThemeIndex]

    local container=Instance.new("Frame",parent); container.Size=UDim2.new(1,-14,0,48); container.Position=UDim2.new(0,UI.PAD_X,0,yPos)
    container.BackgroundColor3=UI.COL_PANEL; container.BackgroundTransparency=0.38; container.BorderSizePixel=0
    Instance.new("UICorner",container).CornerRadius=UI.CORNER_MD
    local cstroke=Instance.new("UIStroke",container); cstroke.Thickness=1; cstroke.Color=UI.COL_STROKE; cstroke.Transparency=0.55

    local lbl=Instance.new("TextLabel",container); lbl.Size=UDim2.new(0.72,0,0,18); lbl.Position=UDim2.new(0,10,0,3)
    lbl.BackgroundTransparency=1; lbl.Text=labelText; lbl.TextColor3=UI.COL_TEXT
    lbl.TextSize=UI.SIZE_SMALL; lbl.Font=UI.FONT_TITLE; lbl.TextXAlignment=Enum.TextXAlignment.Left
    Instance.new("UIStroke",lbl).Transparency=0.65

    local valLbl=Instance.new("TextLabel",container); valLbl.Size=UDim2.new(0.28,-8,0,18); valLbl.Position=UDim2.new(0.72,0,0,3)
    valLbl.BackgroundTransparency=1; valLbl.Text=math.floor(defRel*100).."%"
    valLbl.TextColor3=theme and theme.primary or Color3.fromRGB(160,0,235)
    valLbl.TextSize=UI.SIZE_SMALL; valLbl.Font=UI.FONT_CODE; valLbl.TextXAlignment=Enum.TextXAlignment.Right

    local track=Instance.new("Frame",container); track.Size=UDim2.new(1,-20,0,9); track.Position=UDim2.new(0,10,0,29)
    track.BackgroundColor3=Color3.fromRGB(38,38,50); track.BackgroundTransparency=0.2; track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(0,5)

    for ti=0,8 do
        local tk=Instance.new("Frame",track); tk.Size=UDim2.new(0,1,ti%2==0 and 0.6 or 0.38,0)
        tk.Position=UDim2.new(ti/8,0,ti%2==0 and 0.2 or 0.31,0); tk.BackgroundColor3=Color3.fromRGB(100,100,150)
        tk.BackgroundTransparency=ti%2==0 and 0.28 or 0.55; tk.BorderSizePixel=0
    end

    local fill=Instance.new("Frame",track); fill.Size=UDim2.new(defRel,0,1,0); fill.BackgroundColor3=Color3.fromRGB(255,255,255); fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(0,5)
    local fillGrad=Instance.new("UIGradient",fill)
    fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,80)),ColorSequenceKeypoint.new(1,theme and theme.primary or Color3.fromRGB(160,0,235))})

    local ballShadow=Instance.new("Frame",track); ballShadow.Size=UDim2.new(0,16,0,6); ballShadow.Position=UDim2.new(defRel,-8,1,-2)
    ballShadow.BackgroundColor3=Color3.fromRGB(8,8,16); ballShadow.BackgroundTransparency=0.45; ballShadow.BorderSizePixel=0; ballShadow.ZIndex=4
    Instance.new("UICorner",ballShadow).CornerRadius=UI.CORNER_PILL

    local ball=Instance.new("TextButton",track); ball.Size=UDim2.new(0,22,0,22); ball.Position=UDim2.new(defRel,-11,0.5,-11)
    ball.BackgroundColor3=Color3.fromRGB(255,255,255); ball.Text=""; ball.BorderSizePixel=0; ball.ZIndex=6
    Instance.new("UICorner",ball).CornerRadius=UI.CORNER_PILL
    local ballGrad=Instance.new("UIGradient",ball)
    ballGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(1,theme and (theme.ball or theme.primary) or Color3.fromRGB(160,0,235))})
    local ballStroke=Instance.new("UIStroke",ball); ballStroke.Color=lerpC(theme and theme.primary or Color3.fromRGB(160,0,235),Color3.fromRGB(80,80,120),0.4); ballStroke.Thickness=2.2

    pcall(function()
        local us=ball:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",ball); us.Scale=1.0
        ball.MouseEnter:Connect(function() pcall(function() tw(us,{Scale=1.12},SMOOTH_BACK) end) end)
        ball.MouseLeave:Connect(function() pcall(function() tw(us,{Scale=1.0},SMOOTH) end) end)
        ball.InputBegan:Connect(function(i) if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=0.9},SMOOTH_FAST) end) end end)
        ball.InputEnded:Connect(function(i) if isTouchOrMouse(i.UserInputType) then pcall(function() tw(us,{Scale=1.0},SMOOTH_BACK) end) end end)
    end)

    local sliderRef={fill=fill,fillGrad=fillGrad,ball=ball,ballGrad=ballGrad,ballStroke=ballStroke,valLbl=valLbl,ballShadow=ballShadow,container=container,lbl=lbl}
    table.insert(allSliderBalls,sliderRef)

    local dragging=false; local lastRel=defRel
    local function startDragSlider(i)
        if isTouchOrMouse(i.UserInputType) then
            if isInputBlocked() then return end
            if State.activeSliderId~=nil and State.activeSliderId~=myId then return end
            dragging=true; State.activeSliderId=myId
        end
    end
    ball.InputBegan:Connect(startDragSlider); track.InputBegan:Connect(startDragSlider)
    UserInputService.InputEnded:Connect(function(i)
        if isTouchOrMouse(i.UserInputType) and dragging then
            dragging=false; if State.activeSliderId==myId then State.activeSliderId=nil end
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if isInputBlocked() then dragging=false; State.activeSliderId=nil; return end
        if State.activeSliderId~=myId then dragging=false; return end
        if i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch") then
            local trackAbs=track.AbsolutePosition; local trackSz=track.AbsoluteSize
            if not trackAbs or not trackSz then return end
            local rel=math.clamp((i.Position.X-trackAbs.X)/trackSz.X,0,1)
            if math.abs(rel-lastRel)<0.002 then return end
            pcall(function() ball.Rotation=ball.Rotation+(rel-lastRel)*720 end)
            lastRel=rel
            fill.Size=UDim2.new(rel,0,1,0); ball.Position=UDim2.new(rel,-11,0.5,-11)
            ballShadow.Position=UDim2.new(rel,-8,1,-2); valLbl.Text=math.floor(rel*100).."%"
            local ct=COLOR_THEMES[State.currentThemeIndex]
            if ct then fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,80)),ColorSequenceKeypoint.new(1,StellarEngineA.lerpColorHSV(Color3.fromRGB(150,150,200),ct.primary,rel))}) end
            if changeFn then pcall(function() changeFn(rel) end) end
        end
    end)
    return container,fill,ball,valLbl
end

local function refreshAllSliders()
    local theme=COLOR_THEMES[State.currentThemeIndex]
    if not theme then return end
    for _,s in ipairs(allSliderBalls) do
        pcall(function()
            s.fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,60,80)),ColorSequenceKeypoint.new(1,theme.primary)})
            s.ballGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(1,theme.ball or theme.primary)})
            s.ballStroke.Color=lerpC(theme.primary,Color3.fromRGB(80,80,120),0.4)
            s.valLbl.TextColor3=theme.primary
            if theme.dark or theme.clear then s.container.BackgroundColor3=UI.COL_PANEL; s.lbl.TextColor3=UI.COL_TEXT
            elseif theme.glass then s.container.BackgroundColor3=Color3.fromRGB(228,240,250); s.lbl.TextColor3=Color3.fromRGB(40,60,90)
            else s.container.BackgroundColor3=Color3.fromRGB(244,244,252); s.lbl.TextColor3=Color3.fromRGB(50,42,70) end
        end)
    end
end

