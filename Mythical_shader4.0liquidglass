Sidebar.BorderSizePixel=0; Sidebar.ScrollBarThickness=2
Sidebar.ScrollBarImageColor3=Color3.fromRGB(160,0,235)
Sidebar.ScrollingDirection=Enum.ScrollingDirection.Y; Sidebar.ElasticBehavior=Enum.ElasticBehavior.Always

