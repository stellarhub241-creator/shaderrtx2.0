-- ================================================================
-- SECTION 27: CINEMATIC TAB
-- [FIX] Slider ใหม่ — ปุ่มสีชาว + แถบไล่สีตามค่า + drag ไม่ชนกับ MainFrame
-- ================================================================

-- [FIX] Cinema slider ใหม่ สวยขึ้น มี value label + color gradient
local function makeFancySlider(parent, yPos, labelText, fillColorA, fillColorB, defRel, changeFn)
    -- container
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1,-14,0,42)
    container.Position = UDim2.new(0,7,0,yPos)
    container.BackgroundColor3 = Color3.fromRGB(16,12,26)
    container.BackgroundTransparency = 0.45
    container.BorderSizePixel = 0
    Instance.new("UICorner", container).CornerRadius = UDim.new(0,8)

    -- label
    local lbl = Instance.new("TextLabel", container)
    lbl.Size = UDim2.new(0.7,0,0,16)
    lbl.Position = UDim2.new(0,8,0,3)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = Color3.fromRGB(200,205,225)
    lbl.TextSize = 10
    lbl.Font = Enum.Font.SourceSansBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    -- value label (แสดง % หรือค่า)
    local valLbl = Instance.new("TextLabel", container)
    valLbl.Size = UDim2.new(0.3,0,0,16)
    valLbl.Position = UDim2.new(0.7,0,0,3)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = math.floor(defRel*100).."%"
    valLbl.TextColor3 = fillColorB
    valLbl.TextSize = 10
    valLbl.Font = Enum.Font.Code
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    -- track
    local track = Instance.new("Frame", container)
    track.Size = UDim2.new(1,-16,0,7)
    track.Position = UDim2.new(0,8,0,24)
    track.BackgroundColor3 = Color3.fromRGB(22,18,36)
    track.BackgroundTransparency = 0.3
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(0,4)

    -- fill (gradient ไล่สีตามค่า)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(defRel,0,1,0)
    fill.BackgroundColor3 = fillColorA
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0,4)
    local fillGrad = Instance.new("UIGradient", fill)
    fillGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, fillColorA),
        ColorSequenceKeypoint.new(1, fillColorB),
    })

    -- knob (สีชาวกลม)
    local knob = Instance.new("TextButton", track)
    knob.Size = UDim2.new(0,16,0,16)
    knob.Position = UDim2.new(defRel,-8,0.5,-8)
    knob.BackgroundColor3 = Color3.fromRGB(235,235,245)
    knob.Text = "" knob.BorderSizePixel = 0 knob.ZIndex = 5
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
    local ks = Instance.new("UIStroke", knob)
    ks.Color = fillColorB ks.Thickness = 2
    spring(knob)

    -- bind drag
    -- [FIX] เช็ค isDraggingMainFrame ก่อน ถ้า drag window อยู่ ไม่ให้ slider ทำงาน
    local dragging = false
    local pendingRel = defRel  -- เก็บค่าไว้ apply ตอนปล่อย
    local isDragActive = false

    local function startDrag(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            if isDraggingMainFrame then return end  -- [FIX] ป้องกัน
            dragging=true isDragActive=true
        end
    end
    knob.InputBegan:Connect(startDrag)
    track.InputBegan:Connect(startDrag)

    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            if dragging and isDragActive then
                -- [FIX] apply จริงตอนปล่อยมือ (real-only during drag)
                pcall(function() changeFn(pendingRel) end)
            end
            dragging=false isDragActive=false
        end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if isDraggingMainFrame then dragging=false return end  -- [FIX]
        if i.UserInputType~=Enum.UserInputType.MouseMovement and i.UserInputType~=Enum.UserInputType.Touch then return end
        local rel = math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        pendingRel = rel
        -- อัปเดต UI ทันที แต่ apply ค่าจริงตอนปล่อยมือ
        fill.Size = UDim2.new(rel,0,1,0)
        knob.Position = UDim2.new(rel,-8,0.5,-8)
        valLbl.Text = math.floor(rel*100).."%"
        -- [FIX] อัปเดต gradient สีตาม value ให้ไล่ถึงตำแหน่งนั้น
        fillGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, fillColorA),
            ColorSequenceKeypoint.new(1, lerpC(fillColorA,fillColorB,rel)),
        })
    end)

    return container, fill, knob, valLbl
end

local CinTitle=Instance.new("TextLabel",TabCinema)
CinTitle.Size=UDim2.new(1,-16,0,16) CinTitle.Position=UDim2.new(0,8,0,4)
