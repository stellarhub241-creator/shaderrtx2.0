        MinBtn.Size=UDim2.new(1,-4,1,-4); MinBtn.Position=UDim2.new(0,2,0,2); MinBtn.TextSize=22; minStroke.Color=Color3.fromRGB(255,255,255)
    else
        local bgC=(theme.dark or theme.clear) and UI.COL_BG or (theme.glass and Color3.fromRGB(235,242,252) or Color3.fromRGB(238,240,248))
        tw(MainFrame,{Size=UDim2.new(0,338,0,278),BackgroundColor3=bgC,BackgroundTransparency=1-State.uiOpacity},TweenInfo.new(0.32,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
        MinBtn.Size=UDim2.new(0,26,0,26); MinBtn.Position=UDim2.new(1,-32,0.5,-13); MinBtn.TextSize=14; MinBtn.TextColor3=Color3.fromRGB(255,200,50); minStroke.Color=theme.primary
        task.delay(0.2,function()
            Sidebar.Visible=true; ContentArea.Visible=true; TitleLabel.Visible=true
            SidebarLine.Visible=true; TitleSep.Visible=true; SizeBtn.Visible=true; Shadow.Visible=true
        end)
    end
end)

