local popupDrag, popupDragStart, popupStartPos = false, nil, nil
PopupHeader.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        popupDrag      = true
        popupDragStart = input.Position
        popupStartPos  = FPSPopup.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then popupDrag = false end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if popupDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local d = input.Position - popupDragStart
        FPSPopup.Position = UDim2.new(popupStartPos.X.Scale, popupStartPos.X.Offset+d.X, popupStartPos.Y.Scale, popupStartPos.Y.Offset+d.Y)
    end
end)

local popupResizing, popupResizeStart, popupResizeSize = false, nil, nil
PopupResize.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        popupResizing    = true
        popupResizeStart = input.Position
        popupResizeSize  = Vector2.new(FPSPopup.Size.X.Offset, FPSPopup.Size.Y.Offset)
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then popupResizing = false end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if popupResizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local d    = input.Position - popupResizeStart
        local newW = math.clamp(popupResizeSize.X + d.X, 100, 300)
        local newH = math.clamp(popupResizeSize.Y + d.Y, 70,  200)
        pcall(function()
            TweenService:Create(FPSPopup, TweenInfo.new(0.05,Enum.EasingStyle.Quad), {
                Size = UDim2.new(0,newW,0,newH)
            }):Play()
        end)
    end
end)

PopupCloseBtn.MouseButton1Click:Connect(function()
    pcall(function()
        local s = FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup)
        s.Scale = 1
        TweenService:Create(s, TweenInfo.new(0.2,Enum.EasingStyle.Back,Enum.EasingDirection.In), {Scale=0}):Play()
    end)
    task.delay(0.18, function() FPSPopup.Visible = false end)
    ShowFPSPopupBtn.Text = "📊 Show FPS Monitor"
end)

ShowFPSPopupBtn.MouseButton1Click:Connect(function()
    if FPSPopup.Visible then
        pcall(function()
            local s = FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup)
            s.Scale = 1
            TweenService:Create(s, TweenInfo.new(0.2,Enum.EasingStyle.Back,Enum.EasingDirection.In), {Scale=0}):Play()
        end)
        task.delay(0.18, function() FPSPopup.Visible = false end)
        ShowFPSPopupBtn.Text = "📊 Show FPS Monitor"
    else
        FPSPopup.Visible = true
        local s = FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",FPSPopup)
        s.Scale = 0
        pcall(function()
            TweenService:Create(s, TweenInfo.new(0.35,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Scale=1}):Play()
        end)
        ShowFPSPopupBtn.Text = "📊 Hide FPS Monitor"
    end
end)

-- ==================== RENDER LOOP ====================
local nextUpdate, frameCount = 0, 0
local lastBorderColor        = nil
rainbowHue                   = 0

RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1
    nextUpdate = nextUpdate + dt

    if rainbowActive then
        rainbowHue = (rainbowHue + dt*80) % 360
        local col  = Color3.fromHSV(rainbowHue/360, 1, 1)
        local col2 = Color3.fromHSV(((rainbowHue+120)%360)/360, 1, 1)
        pcall(function()
            UIGradientStroke.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0,   col),
                ColorSequenceKeypoint.new(0.5, col2),
                ColorSequenceKeypoint.new(1,   col)
            })
        end)
        BorderColorNow              = col
        activeThemeLabel.TextColor3 = col
    end

    if nextUpdate >= 0.5 then
        local fps = math.round(frameCount/nextUpdate)
        InfoFPSLabel.Text = "FPS: "..fps

        if isMinimized then
            MinimizedStatusLabel.Visible    = false
            MinimizedStatusLabel.Text       = ModeText
            MinimizedStatusLabel.TextColor3 = BorderColorNow
        end

        LiveTimeLabel.Text       = ModeText
        LiveTimeLabel.TextColor3 = BorderColorNow

        if FPSPopup.Visible then
            PopupFPSBig.Text   = tostring(fps)
            PopupCapLabel.Text = "Cap: "..(targetFpsCap == 165 and "165⚡" or tostring(targetFpsCap))
            local fpsRatio = math.clamp(fps/math.max(targetFpsCap,1), 0, 1)
            PopupFPSBig.TextColor3 = Color3.fromRGB(
                math.floor(lerpN(255,0,fpsRatio)),
                math.floor(lerpN(60,255,fpsRatio)),
                math.floor(lerpN(60,180,fpsRatio))
            )
        end

        if not rainbowActive and BorderColorNow ~= lastBorderColor then
            lastBorderColor = BorderColorNow
            pcall(function()
                TweenService:Create(UIStroke,TweenInfo.new(0.4),{Color=BorderColorNow}):Play()
                TweenService:Create(FPSPopupStroke,TweenInfo.new(0.4),{Color=BorderColorNow}):Play()
            end)
        end

        local fpsColor =
            fps >= 110 and Color3.fromRGB(180,0,255)
            or fps >= 90  and Color3.fromRGB(0,220,255)
            or fps >= 60  and Color3.fromRGB(0,255,120)
            or fps >= 30  and Color3.fromRGB(255,200,0)
            or Color3.fromRGB(255,60,60)
        InfoFPSLabel.TextColor3 = fpsColor

        frameCount = 0
        nextUpdate = 0
    end
end)

-- ==================== GRID SIZE SYSTEM ====================
local camera = workspace.CurrentCamera
local GRID   = 64
local SIZE_PRESETS = {
    { label="1×1",   w=1,  h=1  },
    { label="1×2",   w=1,  h=2  },
    { label="2×2",   w=2,  h=2  },
    { label="4×4",   w=4,  h=4  },
    { label="8×8",   w=8,  h=8  },
    { label="24×24", w=24, h=24 },
}
local currentSizeIndex = 5

local SizeBtn = Instance.new("TextButton", TitleBar)
SizeBtn.Size                  = UDim2.new(0,42,0,22)
SizeBtn.Position              = UDim2.new(1,-82,0.5,-11)
SizeBtn.BackgroundColor3      = Color3.fromRGB(20,16,30)
SizeBtn.BackgroundTransparency = 0.3
SizeBtn.Text                  = SIZE_PRESETS[currentSizeIndex].label
SizeBtn.TextColor3            = Color3.fromRGB(0,220,255)
SizeBtn.Font                  = Enum.Font.Code
SizeBtn.TextSize              = 10
Instance.new("UICorner",SizeBtn).CornerRadius = UDim.new(0,5)
Instance.new("UIStroke",SizeBtn).Color        = Color3.fromRGB(80,60,110)
applySpringPhysics(SizeBtn)

local function updateUIVisibility(w, h)
    Sidebar.Visible              = w >= 150 and h >= 120
    ContentArea.Visible          = w >= 150 and h >= 120
    InfoFPSLabel.Visible         = w >= 120 and h >= 40
    TitleLabel.Visible           = w >= 100
    MinimizedStatusLabel.Visible = false
end

local function gridPx(slots, axis)
    local vp = camera.ViewportSize
    return math.floor((axis=="x" and vp.X or vp.Y)/GRID*slots)
end

local function applyGridSize(preset)
    local pw = gridPx(preset.w,"x")
    local ph = gridPx(preset.h,"y")
    updateUIVisibility(pw, ph)
    pcall(function()
        TweenService:Create(MainFrame, TweenInfo.new(0.45,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {
            Size = UDim2.new(0,math.max(pw,50),0,math.max(ph,35))
        }):Play()
    end)
end

SizeBtn.MouseButton1Click:Connect(function()
    currentSizeIndex = (currentSizeIndex % #SIZE_PRESETS) + 1
    local preset     = SIZE_PRESETS[currentSizeIndex]
    SizeBtn.Text     = preset.label
    applyGridSize(preset)
end)

-- ==================== DRAG-TO-RESIZE (MAIN) ====================
local ResizeHandle = Instance.new("TextButton", MainFrame)
ResizeHandle.Size                  = UDim2.new(0,22,0,22)
ResizeHandle.Position              = UDim2.new(1,-22,1,-22)
ResizeHandle.BackgroundTransparency = 1
ResizeHandle.Text                  = "◢"
ResizeHandle.TextColor3            = Color3.fromRGB(255,255,255)
ResizeHandle.TextTransparency      = 0.5
ResizeHandle.TextSize              = 14
ResizeHandle.Font                  = Enum.Font.SourceSansBold
ResizeHandle.ZIndex                = 10

local isResizing, resizeStartPos2, resizeStartSize2 = false, nil, nil

ResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isResizing       = true
        resizeStartPos2  = input.Position
        resizeStartSize2 = Vector2.new(MainFrame.Size.X.Offset, MainFrame.Size.Y.Offset)
        pcall(function() TweenService:Create(ResizeHandle,TweenInfo.new(0.2,Enum.EasingStyle.Quad),{TextTransparency=0}):Play() end)
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                isResizing = false
                pcall(function() TweenService:Create(ResizeHandle,TweenInfo.new(0.2,Enum.EasingStyle.Quad),{TextTransparency=0.5}):Play() end)
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isResizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - resizeStartPos2
        local newW  = math.clamp(resizeStartSize2.X + delta.X, 60, 800)
        local newH  = math.clamp(resizeStartSize2.Y + delta.Y, 35, 600)
        SizeBtn.Text = "Custom"
        updateUIVisibility(newW, newH)
        pcall(function()
            TweenService:Create(MainFrame,TweenInfo.new(0.05,Enum.EasingStyle.Quad),{
                Size = UDim2.new(0,newW,0,newH)
            }):Play()
        end)
    end
end)

local lastVP = camera.ViewportSize
task.spawn(function()
    while task.wait(1) do
        local vp = camera.ViewportSize
        if vp ~= lastVP then
            lastVP = vp
            if SizeBtn.Text ~= "Custom" then applyGridSize(SIZE_PRESETS[currentSizeIndex]) end
        end
    end
end)

applyGridSize(SIZE_PRESETS[currentSizeIndex])
print("✅ MYTHICAL SHADER v4.6: All fixes + Rain particles + FPS Settings loaded!")
