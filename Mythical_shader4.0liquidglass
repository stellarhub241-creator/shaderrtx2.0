-- ==================== TOGGLE HELPER ====================
local function createToggle(parent, text, order, defaultVal, callback)
    local Frame = Instance.new("Frame", parent)
    Frame.Size                  = UDim2.new(1,-20,0,30)
    Frame.Position              = UDim2.new(0,10,0,(order-1)*35+8)
    Frame.BackgroundTransparency = 1
    local Label = Instance.new("TextLabel", Frame)
    Label.Size                  = UDim2.new(0.65,0,1,0)
    Label.BackgroundTransparency = 1
    Label.Text                  = text
    Label.TextColor3            = Color3.fromRGB(220,220,220)
    Label.TextSize              = 11
    Label.Font                  = Enum.Font.SourceSans
    Label.TextXAlignment        = Enum.TextXAlignment.Left
    local ToggleBtn = Instance.new("TextButton", Frame)
    ToggleBtn.Size                  = UDim2.new(0,45,0,20)
    ToggleBtn.Position              = UDim2.new(1,-45,0.5,-10)
    ToggleBtn.BackgroundColor3      = defaultVal and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(40,30,55)
    ToggleBtn.BackgroundTransparency = 0.2
    ToggleBtn.Text                  = defaultVal and "ON" or "OFF"
    ToggleBtn.TextColor3            = Color3.fromRGB(255,255,255)
    ToggleBtn.Font                  = Enum.Font.SourceSansBold
    ToggleBtn.TextSize              = 10
    Instance.new("UICorner",ToggleBtn).CornerRadius = UDim.new(0,10)
    applySpringPhysics(ToggleBtn)
    local current = defaultVal
    ToggleBtn.MouseButton1Click:Connect(function()
        current = not current
        pcall(function()
            TweenService:Create(ToggleBtn, TweenInfo.new(0.25,Enum.EasingStyle.Back), {
                BackgroundColor3 = current and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(40,30,55)
            }):Play()
        end)
        ToggleBtn.Text = current and "ON" or "OFF"
        callback(current)
    end)
    return ToggleBtn
end

