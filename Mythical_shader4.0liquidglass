-- ================================================================
-- SECTION 6: UTILITY FUNCTIONS
-- ================================================================
local function lerpN(a,b,t) return a+(b-a)*t end
local function lerpC(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end
local function lerpProfile(a,b,t)
    return {brightness=lerpN(a.brightness,b.brightness,t),exposure=lerpN(a.exposure,b.exposure,t),shadow=lerpN(a.shadow,b.shadow,t),ambient=lerpC(a.ambient,b.ambient,t),atmoColor=lerpC(a.atmoColor,b.atmoColor,t),atmoDecay=lerpC(a.atmoDecay,b.atmoDecay,t),atmoGlare=lerpN(a.atmoGlare,b.atmoGlare,t),atmoHaze=lerpN(a.atmoHaze,b.atmoHaze,t),atmoDensity=lerpN(a.atmoDensity,b.atmoDensity,t),contrast=lerpN(a.contrast,b.contrast,t),saturation=lerpN(a.saturation,b.saturation,t),tint=lerpC(a.tint,b.tint,t),bloom=lerpN(a.bloom,b.bloom,t),bloomSize=lerpN(a.bloomSize,b.bloomSize,t),bloomThreshold=lerpN(a.bloomThreshold,b.bloomThreshold,t),dofFar=lerpN(a.dofFar,b.dofFar,t),sunRays=lerpN(a.sunRays,b.sunRays,t)}
end

local function applyProfile(p)
    if isFpsBoostOn or horrorFogEnabled or rainEnabled or heavenlyEnabled or cinematicEnabled then return end
    Lighting.Brightness=p.brightness Lighting.ExposureCompensation=p.exposure Lighting.ShadowSoftness=p.shadow Lighting.OutdoorAmbient=p.ambient
    Atmosphere.Color=p.atmoColor Atmosphere.Decay=p.atmoDecay Atmosphere.Glare=p.atmoGlare Atmosphere.Haze=p.atmoHaze Atmosphere.Density=p.atmoDensity
    ColorCorrection.Contrast=p.contrast ColorCorrection.Saturation=p.saturation ColorCorrection.TintColor=p.tint
    Bloom.Intensity=p.bloom Bloom.Size=p.bloomSize Bloom.Threshold=p.bloomThreshold
    DOF.FarIntensity=p.dofFar SunRays.Intensity=p.sunRays
end

local function resetFogLighting()
    Lighting.FogStart=originalFogStart Lighting.FogEnd=originalFogEnd Lighting.FogColor=originalFogColor
    Lighting.Ambient=originalAmbient Lighting.Brightness=originalBrightness Lighting.ExposureCompensation=originalExposure
end

-- ================================================================
-- SECTION 7: RAIN SYSTEM
-- ================================================================
local rainFolder,rainConnections=nil,{}

local function clearRainParticles()
    for _,c in pairs(rainConnections) do pcall(function() c:Disconnect() end) end
    rainConnections={}
    if rainFolder and rainFolder.Parent then rainFolder:Destroy() end
    rainFolder=nil
end

local function createRainParticles()
    clearRainParticles()
    rainFolder=Instance.new("Folder",workspace) rainFolder.Name="StellarRain"
    local cam=workspace.CurrentCamera local parts,ripples={},{}
    for i=1,rainParticleCount do
        local p=Instance.new("Part")
        p.Size=Vector3.new(0.03,math.random(12,22)*0.1,0.03) p.Material=Enum.Material.Neon
        p.Color=Color3.fromRGB(math.random(170,210),math.random(210,235),255) p.Transparency=math.random(60,82)/100
        p.CastShadow=false p.Anchored=true p.CanCollide=false p.Parent=rainFolder table.insert(parts,p)
    end
    for i=1,math.floor(rainParticleCount*0.18) do
        local r=Instance.new("Part")
        r.Size=Vector3.new(0.1,0.06,0.1) r.Material=Enum.Material.Neon r.Color=Color3.fromRGB(180,215,255)
        r.Transparency=0.88 r.CastShadow=false r.Anchored=true r.CanCollide=false r.Shape=Enum.PartType.Cylinder r.Parent=rainFolder
        table.insert(ripples,r)
    end
    local conn=RunService.RenderStepped:Connect(function()
        if not rainFolder or not rainFolder.Parent then return end
        local cp=cam.CFrame.Position
        for i,p in ipairs(parts) do
            if p.Parent then local ph=i*0.73 local fall=(tick()*16+ph*2.8)%32
                p.CFrame=CFrame.new(cp.X+math.sin(ph)*35,cp.Y+20-fall,cp.Z+math.cos(ph)*35)*CFrame.Angles(0.18,0,0.06) end
        end
        for i,r in ipairs(ripples) do
            if r.Parent then local t=(tick()*0.7+i*0.65)%1 local sc=0.3+t*3.2 local ph=i*1.13
                local rx=cp.X+math.sin(ph)*22 local rz=cp.Z+math.cos(ph)*22
                local ray=workspace:Raycast(Vector3.new(rx,cp.Y+10,rz),Vector3.new(0,-60,0))
                local ry=ray and ray.Position.Y+0.05 or cp.Y-10
                r.CFrame=CFrame.new(rx,ry,rz)*CFrame.Angles(0,0,math.pi/2)
                r.Size=Vector3.new(0.06,sc,sc) r.Transparency=0.72+(1-t)*0.22
                r.Color=Color3.fromRGB(math.floor(lerpN(155,200,1-t)),math.floor(lerpN(195,230,1-t)),255) end
        end
    end)
    table.insert(rainConnections,conn)
end

-- ================================================================
-- SECTION 8: TIME-BASED LIGHTING LOOP
-- ================================================================
local ModeText="Status: Loading..." local BorderColorNow=Color3.fromRGB(180,0,255) local rainbowHue=0

task.spawn(function()
    while task.wait(0.2) do
        if not horrorFogEnabled and not rainEnabled and not heavenlyEnabled and not cinematicEnabled then
            local t=Lighting.ClockTime
            if     t>=5  and t<6  then applyProfile(lerpProfile(PROFILES.NIGHT,PROFILES.DAWN,t-5))       ModeText="Status: Dawn"        BorderColorNow=Color3.fromRGB(255,180,200)
            elseif t>=6  and t<15 then applyProfile(PROFILES.DAY)                                          ModeText="Status: Day"         BorderColorNow=Color3.fromRGB(255,220,100)
            elseif t>=15 and t<19 then applyProfile(lerpProfile(PROFILES.DAY,PROFILES.GOLDEN,(t-15)/4))   ModeText="Status: Golden Hour" BorderColorNow=Color3.fromRGB(255,160,80)
            elseif t>=19 and t<21 then applyProfile(lerpProfile(PROFILES.GOLDEN,PROFILES.NIGHT,(t-19)/2)) ModeText="Status: Sunset"      BorderColorNow=Color3.fromRGB(150,180,255)
            else                       applyProfile(PROFILES.NIGHT)                                         ModeText="Status: Night"       BorderColorNow=Color3.fromRGB(100,180,255) end
        end
    end
end)

-- ================================================================
-- SECTION 9: PBR SYSTEM
-- ================================================================
local function applyPBROnPart(v)
    if not pbrEnabled or isFpsBoostOn then return end
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.CastShadow=true local m=v.Material local r=0
        if m==Enum.Material.Concrete then r=0.15
        elseif m==Enum.Material.SmoothPlastic then r=0.35
        elseif m==Enum.Material.Cobblestone then r=0.08
        elseif m==Enum.Material.Wood or m==Enum.Material.WoodPlanks then r=0.03
        elseif m==Enum.Material.Marble then r=0.55
        elseif m==Enum.Material.Granite then r=0.3
        elseif m==Enum.Material.Metal or m==Enum.Material.DiamondPlate then r=0.65
        elseif m==Enum.Material.Glass then r=0.8
        elseif m==Enum.Material.Neon then r=0.85
        elseif m==Enum.Material.Ice then r=0.7
        elseif m==Enum.Material.Sand then r=0.02
        elseif m==Enum.Material.Grass then r=0.0 end
        if antiBlueGloss then local c=v.Color local lum=(c.R*0.299)+(c.G*0.587)+(c.B*0.114) v.Reflectance=lum<0.18 and r*(lum*3.5) or r
        else v.Reflectance=r end
    end
end

local function runPBRScan()
    local n=0 for _,v in pairs(workspace:GetDescendants()) do applyPBROnPart(v) n=n+1 if n%200==0 then task.wait() end end
end
task.spawn(runPBRScan)
workspace.DescendantAdded:Connect(function(v) task.delay(0.1,function() applyPBROnPart(v) end) end)

-- ================================================================
-- SECTION 10: FPS BOOST
-- ================================================================
local function triggerFPSBoost(on)
    isFpsBoostOn=on
    if on then
        local n=0
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") then
                if not originalMaterials[v] then originalMaterials[v]=v.Material originalShadows[v]=v.CastShadow end
                v.Material=Enum.Material.SmoothPlastic v.CastShadow=false v.Reflectance=0
            elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency=1 end
            n=n+1 if n%250==0 then task.wait() end
        end
        Terrain.Decoration=false Lighting.GlobalShadows=false
    else
        local n=0
        for v,mat in pairs(originalMaterials) do
            if v and v.Parent then v.Material=mat v.CastShadow=originalShadows[v] or false end
            n=n+1 if n%250==0 then task.wait() end
        end
        for _,v in pairs(workspace:GetDescendants()) do if v:IsA("Decal") or v:IsA("Texture") then v.Transparency=0 end end
        Terrain.Decoration=true Lighting.GlobalShadows=true
        table.clear(originalMaterials) table.clear(originalShadows) task.spawn(runPBRScan)
    end
end

