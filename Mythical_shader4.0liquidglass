local function mkTab()
    local s=Instance.new("ScrollingFrame",CA); s.Size=UDim2.new(1,0,1,0); s.BackgroundTransparency=1; s.BorderSizePixel=0
    s.ScrollBarThickness=3; s.ScrollBarImageColor3=Color3.fromRGB(160,0,235); s.CanvasSize=UDim2.new(0,0,0,600)
    s.ScrollingDirection=Enum.ScrollingDirection.Y; s.ElasticBehavior=Enum.ElasticBehavior.Always; s.Visible=false; s.ClipsDescendants=true; return s
end
local tGfx=mkTab(); local tSky=mkTab(); local tBoost=mkTab(); local tTheme=mkTab()
local tFPS=mkTab(); local tCin=mkTab(); local tPart=mkTab(); local tDbg=mkTab()
local TDEFS={{txt="Graphics",ic="🎨",tab=tGfx},{txt="Skybox",ic="🌌",tab=tSky},{txt="Boost",ic="⚡",tab=tBoost},{txt="Theme",ic="💎",tab=tTheme},{txt="FPS Cap",ic="📊",tab=tFPS},{txt="Cinema",ic="🎬",tab=tCin},{txt="Particle",ic="✨",tab=tPart},{txt="Trinity",ic="🤖",tab=tDbg}}
local tBtns={}; local activeTab=nil; local tSwitch=false
for i,d in ipairs(TDEFS) do
    local B=Instance.new("TextButton",SB); B.Size=UDim2.new(1,-8,0,27); B.Position=UDim2.new(0,4,0,(i-1)*31+6)
    B.BackgroundColor3=Color3.fromRGB(28,28,40); B.BackgroundTransparency=0.4; B.Text=d.ic.." "..d.txt; B.TextColor3=Color3.fromRGB(240,240,255); B.Font=Enum.Font.SourceSansBold; B.TextSize=10
    Instance.new("UICorner",B).CornerRadius=UDim.new(0,8); local bs=Instance.new("UIStroke",B); bs.Thickness=1; bs.Color=Color3.fromRGB(100,120,200); bs.Transparency=0.45
    spring(B); tBtns[#tBtns+1]={btn=B,tab=d.tab}
end
SB.CanvasSize=UDim2.new(0,0,0,#TDEFS*31+20)
local function refreshTBtns()
    local th=THEMES[St.themeIdx]
    for _,bd in pairs(tBtns) do
        local s=bd.btn:FindFirstChildOfClass("UIStroke")
        if bd.tab==activeTab then tw(bd.btn,{BackgroundColor3=th.pri,BackgroundTransparency=0.18,TextColor3=Color3.fromRGB(255,255,255)},TW0); if s then tw(s,{Color=th.sec,Transparency=0.08},TW0) end
        else tw(bd.btn,{BackgroundColor3=Color3.fromRGB(28,28,40),BackgroundTransparency=0.4,TextColor3=Color3.fromRGB(200,210,255)},TW0); if s then tw(s,{Color=Color3.fromRGB(100,120,200),Transparency=0.45},TW0) end end
    end
end
local function switchTab(tgt)
    if activeTab==tgt or tSwitch then return end; tSwitch=true
    local old=activeTab; activeTab=tgt; refreshTBtns()
    if old then
        local us=Instance.new("UIScale",old); us.Scale=1
        tw(old,{Position=UDim2.new(-0.1,0,0,0)},TweenInfo.new(0.18,Enum.EasingStyle.Quint,Enum.EasingDirection.In)); tw(us,{Scale=0.96},TweenInfo.new(0.18,Enum.EasingStyle.Quint,Enum.EasingDirection.In))
        task.delay(0.16,function() pcall(function() old.Visible=false; old.Position=UDim2.new(0,0,0,0); us:Destroy() end) end)
    end
    tgt.Position=UDim2.new(0.1,0,0,0); tgt.Visible=true
    local us2=Instance.new("UIScale",tgt); us2.Scale=0.96
    tw(tgt,{Position=UDim2.new(0,0,0,0)},TW3); tw(us2,{Scale=1.0},TW3)
    task.delay(0.28,function() tSwitch=false; pcall(function() us2:Destroy() end) end)
end
for _,bd in pairs(tBtns) do bd.btn.MouseButton1Click:Connect(function() switchTab(bd.tab) end) end
switchTab(tGfx)

-- ================================================================
-- SECTION 27: DRAG
-- ================================================================
local dTog,dStart,dPos0,dragging=false,nil,nil,false
MF.InputBegan:Connect(function(inp)
    if isTM(inp.UserInputType) then
        dTog=true; dStart=inp.Position; dPos0=MF.Position
        inp.Changed:Connect(function() if inp.UserInputState==Enum.UserInputState.End then dTog=false; dragging=false; dragActive=false end end)
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if not dTog then return end; if resizeActive then dTog=false; return end
    if inp.UserInputType.Name:match("MouseMovement") or inp.UserInputType.Name:match("Touch") then
        local d=inp.Position-dStart
        if not dragging and (math.abs(d.X)>5 or math.abs(d.Y)>5) then dragging=true; dragActive=true end
        if dragging then local vp=workspace.CurrentCamera.ViewportSize; MF.Position=UDim2.new(0,math.clamp(dPos0.X.Offset+d.X,6,vp.X-MF.Size.X.Offset-6),0,math.clamp(dPos0.Y.Offset+d.Y,6,vp.Y-MF.Size.Y.Offset-6)) end
    end
end)

