-- ================================================================
-- SECTION 2: STELLAR ENGINE B (CPU + RAM)
-- Command queue + result cache — ทำงานก่อน render
-- ================================================================
local StellarEngineB = {
    _queue    = {},   -- {fn, priority} sorted
    _cache    = {},   -- {key → {value, expireAt}}
    _cacheHits= 0,
    _executed = 0,
    _maxQueuePerFrame = 8,

    -- เพิ่ม command เข้า queue (priority 1=สูง)
    push = function(self, fn, priority)
        table.insert(self._queue, {fn=fn, pri=priority or 5})
        -- sort by priority
        table.sort(self._queue, function(a,b) return a.pri < b.pri end)
    end,

    -- รัน queue ทุก frame (เรียกจาก Heartbeat ก่อน render)
    flush = function(self)
        local ran = 0
        while #self._queue > 0 and ran < self._maxQueuePerFrame do
            local cmd = table.remove(self._queue, 1)
            pcall(cmd.fn)
            ran = ran + 1
            self._executed = self._executed + 1
        end
    end,

    -- cache ผลลัพธ์ที่คำนวณแพง
    setCache = function(self, key, value, ttl)
        self._cache[key] = {value=value, expireAt=tick()+(ttl or 2.0)}
    end,

    getCache = function(self, key)
        local c = self._cache[key]
        if c and tick() < c.expireAt then
            self._cacheHits = self._cacheHits + 1
            return c.value
        end
        self._cache[key] = nil
        return nil
    end,

    -- ล้าง cache ที่หมดอายุ (เรียกทุก 5s)
    cleanCache = function(self)
        local now = tick()
        for k, c in pairs(self._cache) do
            if now >= c.expireAt then self._cache[k] = nil end
        end
    end,

    getStats = function(self)
        local cacheSize = 0
        for _ in pairs(self._cache) do cacheSize = cacheSize + 1 end
        return string.format(
            "Queue: %d | Exec: %d | Cache: %d hits / %d keys",
            #self._queue, self._executed, self._cacheHits, cacheSize
        )
    end,
}

-- ================================================================
-- SECTION 3: STELLAR ENGINE A (GPU)
-- Graphics compute — particle physics, trajectory, render budget
-- ================================================================
local StellarEngineA = {
    _budgets    = {},   -- {id → startTick}
    _budgetLog  = {},   -- {id → ms}
    _frameMs    = 0,
    _particleBudgetMs = 2.5,  -- ms per frame สำหรับ particle

    -- เริ่ม budget timer
    beginPass = function(self, id)
        self._budgets[id] = tick()
    end,

    endPass = function(self, id)
        local t = self._budgets[id]
        if not t then return 0 end
        local ms = (tick()-t)*1000
        self._budgetLog[id] = ms
        self._frameMs = self._frameMs + ms
        return ms
    end,

    resetFrame = function(self)
        self._frameMs = 0
    end,

    -- [GPU] คำนวณ sakura fall position (physics-based)
    -- dt, vy(velocity Y), gravity, sway amplitude, time, phase
    calcSakuraPos = function(self, x, y, z, vy, gravity, swayAmp, swayFreq, t, phase, dt)
        -- velocity verlet integration
        local newVy  = vy + gravity * dt
        local newY   = y  + newVy   * dt
        -- horizontal sway ใช้ sin+cos compound
        local swayX  = math.sin(t*swayFreq + phase)     * swayAmp * dt
        local swayZ  = math.cos(t*swayFreq*0.7 + phase) * swayAmp * dt * 0.6
        return x+swayX, newY, z+swayZ, newVy
    end,

    -- [GPU] คำนวณ sun ray direction จาก fibonacci sphere
    calcRayDir = function(self, index, total, time, rotSpeed)
        local phi   = math.acos(1 - 2*index/(total+1))
        local theta = (math.pi*(1+math.sqrt(5))) * (index-1) + time*rotSpeed
        return Vector3.new(
            math.sin(phi)*math.cos(theta),
            math.cos(phi),
            math.sin(phi)*math.sin(theta)
        ).Unit
    end,

    -- [GPU] Meteor trajectory (curved — ใช้ bezier)
    calcMeteorPos = function(self, p0, p1, p2, t)
        local mt = 1-t
        return mt*mt*p0 + 2*mt*t*p1 + t*t*p2
    end,

    -- [GPU] smooth lerp Color3
    lerpC = function(self, a, b, t)
        return Color3.new(
            a.R+(b.R-a.R)*t,
            a.G+(b.G-a.G)*t,
            a.B+(b.B-a.B)*t
        )
    end,

    -- [GPU] lerp Color3 ใน HSV space
    lerpCHSV = function(self, a, b, t)
        local ah,as,av = Color3.toHSV(a)
        local bh,bs,bv = Color3.toHSV(b)
        local dh = bh-ah
        if dh > 0.5 then dh=dh-1 elseif dh < -0.5 then dh=dh+1 end
        return Color3.fromHSV(
            (ah+dh*t)%1,
            math.clamp(as+(bs-as)*t,0,1),
            math.clamp(av+(bv-av)*t,0,1)
        )
    end,

    -- [GPU] smooth noise (octave layered)
    smoothNoise = function(self, x, y, z, octaves)
        octaves = octaves or 3
        local v,a,f = 0,1,1
        for _ = 1, octaves do
            v = v + math.noise(x*f,(y or 0)*f,(z or 0)*f)*a
            a = a*0.5; f = f*2.1
        end
        return v
    end,

    -- [GPU] spring physics (velocity-based)
    springStep = function(self, cur, vel, target, stiff, damp, dt)
        local force = -stiff*(cur-target) - damp*vel
        vel = vel + force*dt
        cur = cur + vel*dt
        return cur, vel
    end,

    -- [GPU] pulse wave 0→1
    pulse = function(self, t, freq, phase)
        return (math.sin(t*(freq or 1)*math.pi*2+(phase or 0))+1)*0.5
    end,

    getStats = function(self)
        local lines = {string.format("Frame GPU: %.2fms", self._frameMs)}
        for id,ms in pairs(self._budgetLog) do
            table.insert(lines, string.format("  %s: %.2fms", id, ms))
        end
        return table.concat(lines, "\n")
    end,
}

-- Lerpน utility shortcuts
local function lerpN(a,b,t) return a+(b-a)*t end
local function lerpC(a,b,t) return StellarEngineA:lerpC(a,b,t) end

-- ================================================================
-- SECTION 4: STELLAR AI (Core Brain)
-- ================================================================
local StellarAI = {
    enabled         = true,
    fpsThreshold    = 45,    -- ตั้งค่าได้จาก UI
    fpsHistory      = {},
    fpsHistorySize  = 60,
    fpsIdx          = 0,
    qualityLevel    = 1.0,
    errorLog        = {},
    watchedSystems  = {},
    autoFixEnabled  = true,
    lastCheckTick   = 0,
    checkInterval   = 2.0,
    -- Map health
    mapCheckEnabled = true,
    fallenObjects   = {},
    worldFloorY     = -500,

    pushFPS = function(self, fps)
        self.fpsIdx = (self.fpsIdx % self.fpsHistorySize) + 1
        self.fpsHistory[self.fpsIdx] = fps
    end,

    getAvgFPS = function(self)
        local sum,n = 0,0
        for _,v in pairs(self.fpsHistory) do if v then sum=sum+v; n=n+1 end end
        return n>0 and (sum/n) or 60
    end,

    -- ลงทะเบียน system watchdog
    watch = function(self, id, getter, name, healFn)
        self.watchedSystems[id] = {
            getter=getter, name=name, healFn=healFn,
            ok=true, missCount=0, healCount=0
        }
    end,

    -- ตรวจสอบ map — วัตถุตกขอบโลก
    checkMap = function(self)
        if not self.mapCheckEnabled then return end
        local cam = workspace.CurrentCamera
        if not cam then return end
        local cp = cam.CFrame.Position
        local checked = 0
        for _, v in ipairs(workspace:GetDescendants()) do
            if checked > 50 then break end
            pcall(function()
                if (v:IsA("BasePart") or v:IsA("MeshPart"))
                    and not v.Anchored
                    and v.Position.Y < self.worldFloorY then
                    local key = tostring(v)
                    if not self.fallenObjects[key] then
                        self.fallenObjects[key] = true
                        self:log("[MAP] fallen object: "..v.Name.." Y="..math.floor(v.Position.Y))
                    end
                end
            end)
            checked = checked + 1
        end
    end,

    -- adaptive quality based on threshold
    updateQuality = function(self, State, callbacks)
        if not self.enabled then return end
        local avg    = self:getAvgFPS()
        local thresh = self.fpsThreshold
        local ratio  = avg / math.max(thresh, 20)
        local newQ
        if     ratio >= 1.1  then newQ = 1.0
        elseif ratio >= 0.85 then newQ = 0.75
        elseif ratio >= 0.65 then newQ = 0.5
        else                      newQ = 0.3
        end
        if math.abs(newQ - self.qualityLevel) > 0.12 then
            self.qualityLevel = newQ
            self:log(string.format("QUALITY → %.0f%% (avg %.0ffps / thresh %dfps)",
                newQ*100, avg, thresh))
            -- ปรับ effect อัตโนมัติ
            if callbacks then
                for _, cb in ipairs(callbacks) do pcall(cb, newQ) end
            end
        end
    end,

    -- watchdog check + self-heal
    check = function(self)
        if not self.autoFixEnabled then return end
        local now = tick()
        if now - self.lastCheckTick < self.checkInterval then return end
        self.lastCheckTick = now
        for id, w in pairs(self.watchedSystems) do
            local alive = false
            pcall(function()
                local ref = w.getter()
                alive = ref ~= nil and (typeof(ref)~="Instance" or ref.Parent~=nil)
            end)
            if not alive then
                w.missCount = w.missCount + 1
                if w.ok then self:log("[WARN] "..w.name.." dead") end
                w.ok = false
                if w.healFn and w.missCount <= 4 then
                    local ok2 = pcall(w.healFn)
                    if ok2 then
                        self:log("[HEAL] "..w.name.." restarted")
                        w.ok=true; w.missCount=0; w.healCount=w.healCount+1
                    end
                end
            else
                if not w.ok then self:log("[OK] "..w.name.." recovered") end
                w.ok=true; w.missCount=0
            end
        end
        self:checkMap()
    end,

    log = function(self, msg)
        table.insert(self.errorLog, string.format("[%.0f] %s", tick()%10000, msg))
        if #self.errorLog > 80 then table.remove(self.errorLog, 1) end
    end,

    getReport = function(self)
        local avg = self:getAvgFPS()
        local lines = {
            string.format("StellarAI %s | Q:%.0f%% | Avg:%.0ffps | Thresh:%dfps",
                self.enabled and "ON" or "OFF", self.qualityLevel*100, avg, self.fpsThreshold),
            string.format("Watches: %d | Fallen objects: %d",
                (function() local n=0; for _ in pairs(self.watchedSystems) do n=n+1 end; return n end)(),
                (function() local n=0; for _ in pairs(self.fallenObjects) do n=n+1 end; return n end)()
            ),
            "--- Log (last 8) ---",
        }
        local logLen = #self.errorLog
        for i = math.max(1,logLen-7), logLen do
            if self.errorLog[i] then table.insert(lines, self.errorLog[i]) end
        end
        return table.concat(lines, "\n")
    end,
}

