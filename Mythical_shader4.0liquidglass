-- ================================================================
-- SECTION 2: SAS
-- ================================================================
local SAS={
    MAX=7,used=0,_r={},
    PR={sun=5,meteor=4,rain=3,sakura=2,wind=1},
    CO={sun=2,meteor=2,rain=1,sakura=1,wind=1},
    _buf={},
    register=function(s,id) s._r[id]={on=false,cost=s.CO[id] or 1,pri=s.PR[id] or 1,q=1.0} end,
    request=function(s,id)
        local r=s._r[id]; if not r then return false,0 end
        if r.on then return true,r.q end
        local need=r.cost; local free=s.MAX-s.used
        if free>=need then
            r.on=true; r.q=1.0; s.used=math.min(s.MAX,s.used+need)
            s:_log("ALLOC "..id.." used="..s.used.."/"..s.MAX); return true,1.0
        else
            local freed=s:_evict(need-free,r.pri)
            if freed+free>=need then
                r.on=true; r.q=0.65; s.used=math.min(s.MAX,s.used+need)
                s:_log("ALLOC(Q65) "..id); return true,0.65
            else s:_log("DENY "..id); return false,0 end
        end
    end,
    release=function(s,id)
        local r=s._r[id]; if not r or not r.on then return end
        r.on=false; r.q=1.0; s.used=math.max(0,s.used-r.cost)
        s:_rQ(); s:_log("FREE "..id.." used="..s.used.."/"..s.MAX)
    end,
    forceQ=function(s,id,q) local r=s._r[id]; if r and r.on then r.q=math.clamp(q,0.2,1.0) end end,
    _evict=function(s,need,minP)
        local freed=0; local sorted={}
        for id,r in pairs(s._r) do if r.on and r.pri<minP then sorted[#sorted+1]={id=id,r=r} end end
        table.sort(sorted,function(a,b) return a.r.pri<b.r.pri end)
        for _,e in ipairs(sorted) do
            if freed>=need then break end
            e.r.q=0.4; freed=freed+math.floor(e.r.cost*0.5); s:_log("EVICT "..e.id)
        end
        return freed
    end,
    _rQ=function(s)
        local free=s.MAX-s.used
        for _,r in pairs(s._r) do if r.on and r.q<1.0 and free>0 then r.q=math.min(1.0,r.q+0.25) end end
    end,
    getQ=function(s,id) local r=s._r[id]; return r and r.q or 1.0 end,
    reset=function(s) s.used=0; for _,r in pairs(s._r) do r.on=false; r.q=1.0 end; s:_log("RESET") end,
    status=function(s)
        local t={string.format("Tokens:%d/%d",s.used,s.MAX)}
        for _,id in ipairs({"sun","meteor","rain","sakura","wind"}) do
            local r=s._r[id]
            if r then t[#t+1]=string.format(" %-7s %s Q=%.0f%%",id,r.on and "[ON]" or "[--]",r.q*100) end
        end
        return table.concat(t,"\n")
    end,
    _log=function(s,msg)
        local e=string.format("[%.0f]%s",tick()%10000,msg)
        s._buf[#s._buf+1]=e; if #s._buf>30 then table.remove(s._buf,1) end
    end,
    logStr=function(s) return table.concat(s._buf,"\n") end,
}
for id in pairs(SAS.CO) do SAS:register(id) end
SAS:reset()

-- ================================================================
-- SECTION 3: StellarA
-- ================================================================
local SA={}
SA.bez=function(p0,p1,p2,p3,t) local u=1-t; return u*u*u*p0+3*u*u*t*p1+3*u*t*t*p2+t*t*t*p3 end
SA.noise=function(x,y,z,o) o=o or 3; local v,a,f=0,1,1; for i=1,o do v=v+math.noise(x*f,(y or 0)*f,(z or 0)*f)*a; a=a*0.5; f=f*2.1 end; return v end
SA.lerp=function(a,b,t) return a+(b-a)*t end
SA.lerpC=function(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end
SA.lerpHSV=function(a,b,t)
    local ah,as,av=Color3.toHSV(a); local bh,bs,bv=Color3.toHSV(b)
    local dh=bh-ah; if dh>0.5 then dh=dh-1 end; if dh<-0.5 then dh=dh+1 end
    return Color3.fromHSV((ah+dh*t)%1,math.clamp(as+(bs-as)*t,0,1),math.clamp(av+(bv-av)*t,0,1))
end
SA.grad=function(cols,t)
    if #cols==0 then return Color3.new(1,1,1) end
    if #cols==1 then return cols[1] end
    local seg=t*(#cols-1); local idx=math.clamp(math.floor(seg),0,#cols-2)
    return SA.lerpHSV(cols[idx+1],cols[idx+2],seg-idx)
end
SA.remap=function(v,a,b,c,d) return c+(v-a)/(b-a)*(d-c) end
SA.pulse=function(t,f,p) return (math.sin(t*f*math.pi*2+(p or 0))+1)*0.5 end
SA.orbit=function(cen,rad,ang,h,tilt) return cen+Vector3.new(math.cos(ang)*rad,h+math.sin(tilt)*20,math.sin(ang)*rad) end
SA.fib=function(i,n)
    local phi=math.acos(1-2*i/(n+1)); local theta=math.pi*(1+math.sqrt(5))*(i-1)
    return Vector3.new(math.sin(phi)*math.cos(theta),math.cos(phi),math.sin(phi)*math.sin(theta))
end
SA.newEMA=function(alpha)
    local s={v=nil,a=alpha or 0.1}
    s.upd=function(self,x) if self.v==nil then self.v=x; return x end; self.v=self.a*x+(1-self.a)*self.v; return self.v end
    return s
end
SA.spring=function(k,d)
    local s={val=0,vel=0,k=k or 200,d=d or 20}
    s.upd=function(self,dt,tgt) local f=-self.k*(self.val-tgt)-self.d*self.vel; self.vel=self.vel+f*dt; self.val=self.val+self.vel*dt; return self.val end
    return s
end
SA.lerpCHSV=function(a,b,t) return SA.lerpHSV(a,b,t) end
SA.sakDrift=function(t,ph,str) return math.sin(t*0.8+ph)*str+math.sin(t*1.7+ph*1.3)*str*0.4, math.cos(t*0.6+ph)*str+math.cos(t*2.1+ph*0.7)*str*0.3 end
SA.fade=function(r,fi,fo) fi=fi or 0.15; fo=fo or 0.75; if r<fi then return SA.bez(0,0,0.8,1,r/fi) elseif r>fo then return SA.bez(1,0.8,0.2,0,(r-fo)/(1-fo)) end; return 1 end

-- ================================================================
-- SECTION 4: StellarEngineB — batch particle compute
-- ================================================================
local SEB={_pool={}}
SEB.reg=function(s,id,items) s._pool[id]=items end
SEB.clear=function(s,id) s._pool[id]=nil end
SEB.sakura=function(s,items,dt,t)
    for i=1,#items do
        local p=items[i]
        local dx=math.sin(t*0.8+p.phase)*0.8+math.sin(t*1.7+p.phase*1.3)*0.32
        local dz=math.cos(t*0.6+p.phase)*0.8+math.cos(t*2.1+p.phase*0.7)*0.24
        p.x=p.x+dx*dt; p.z=p.z+dz*dt
        p.y=p.y-p.vy*dt*60; p.rot=p.rot+p.rotSpeed*dt; p.life=p.life+dt
    end
end
SEB.rain=function(s,items,t)
    for i=1,#items do local p=items[i]; p.fall=(t*16+(i*0.73)*2.8)%32 end
end
SEB.status=function(s) local n=0; for _ in pairs(s._pool) do n=n+1 end; return "StellarEngineB OK | batches:"..n end

-- ================================================================
-- SECTION 5: StellarFlu
-- ================================================================
local SF={}
SF.sunAuraC=function(dist,t)
    local cols={Color3.fromRGB(255,255,230),Color3.fromRGB(255,240,160),Color3.fromRGB(255,200,80),Color3.fromRGB(255,140,30),Color3.fromRGB(255,60,0),Color3.fromRGB(180,20,0)}
    local b=SA.grad(cols,dist); local p=0.92+math.sin(t*1.4+dist*math.pi)*0.08
    return Color3.new(math.clamp(b.R*p,0,1),math.clamp(b.G*p,0,1),math.clamp(b.B*p,0,1))
end
SF.sunAuraA=function(dist,t) return math.clamp(dist*dist*0.95+0.04+math.sin(t*1.2+dist*3)*0.025,0,1) end
SF.sakCol=function(seed,tc)
    local h,s,v=Color3.toHSV(tc)
    return Color3.fromHSV((h+(seed%7)*0.015-0.05)%1,math.clamp(s*0.7+0.15,0,1),math.clamp(v*0.9+0.08,0,1))
end
SF.shimmer=function(t,sp) return SA.noise(t*(sp or 0.7),0,0)*0.6 end
SF.status=function() return "StellarFlu OK" end

-- ================================================================
-- SECTION 6: StellarAI
-- ================================================================
local SAI={on=true,fps={},fi=0,fs=60,ql=1.0,log={},refs={},lastCk=0,dLog={}}
SAI.push=function(s,f) s.fi=(s.fi%s.fs)+1; s.fps[s.fi]=f end
SAI.avg=function(s) local sum,n=0,0; for _,v in pairs(s.fps) do if v then sum=sum+v; n=n+1 end end; return n>0 and sum/n or 60 end
SAI.adapt=function(s,St,cR,cSk)
    if not s.on then return end
    local avg=s:avg(); local ratio=avg/math.max(St.fpsCap,30)
    local nq=ratio>=0.88 and 1.0 or ratio>=0.72 and 0.75 or ratio>=0.55 and 0.5 or 0.3
    if math.abs(nq-s.ql)>0.15 then
        s.ql=nq
        if St.rainOn then St.rainN=math.max(10,math.floor(St.rainN*nq)); pcall(cR) end
        if St.sakOn then St.sakN=math.max(8,math.floor(St.sakN*nq)); pcall(cSk) end
        s:_log(string.format("ADAPT Q=%.0f%% fps=%.0f",nq*100,avg))
    end
end
SAI.watch=function(s,id,get,name) s.refs[id]={get=get,name=name,ok=true,miss=0} end
SAI.check=function(s,cbs)
    if not s.on then return end
    local now=tick(); if now-s.lastCk<2.5 then return end; s.lastCk=now
    for id,w in pairs(s.refs) do
        local ok=pcall(function() local r=w.get(); if not r then error() end; if typeof(r)=="Instance" and not r.Parent then error() end end)
        if not ok then
            w.miss=w.miss+1; if w.ok then s:_log("[WARN]"..w.name.." dead"); w.ok=false end
            if cbs and cbs[id] then if pcall(cbs[id]) then s:_log("[HEAL]"..w.name); w.ok=true; w.miss=0 end end
        else w.ok=true; w.miss=0 end
    end
end
SAI.checkDist=function(s,cp)
    if sunFolder and sunFolder.Parent then
        for _,v in ipairs(sunFolder:GetChildren()) do
            if v:IsA("Part") and v.Size.X>=98 then
                local d=(v.Position-cp).Magnitude
                local q=d<=300 and 1.0 or d<=700 and SA.remap(d,300,700,1.0,0.4) or 0.25
                SAS:forceQ("sun",q); s.dLog.sun="sun d="..math.floor(d).." Q="..math.floor(q*100).."%"; break
            end
        end
    end
    if meteorFolder and meteorFolder.Parent then
        local ch=meteorFolder:GetChildren()
        if ch[1] and ch[1]:IsA("BasePart") then
            local d=(ch[1].Position-cp).Magnitude
            local q=d<=300 and 1.0 or d<=700 and SA.remap(d,300,700,1.0,0.4) or 0.25
            SAS:forceQ("meteor",q); s.dLog.meteor="meteor d="..math.floor(d).." Q="..math.floor(q*100).."%"
        end
    end
end
SAI.report=function(s)
    local t={"=== StellarAI ===",string.format("Q=%.0f%% FPS=%.0f",s.ql*100,s:avg()),"",SAS:status(),"","=== EngineB ===",SEB:status(),"","=== Dist ==="}
    for _,v in pairs(s.dLog) do t[#t+1]=" "..v end
    t[#t+1]=""; t[#t+1]="=== Watches ==="
    for _,w in pairs(s.refs) do t[#t+1]=string.format(" %s:%s miss=%d",w.name,w.ok and "OK" or "DEAD",w.miss) end
    t[#t+1]=""; t[#t+1]="=== Log ==="
    local n=#s.log; for i=math.max(1,n-5),n do if s.log[i] then t[#t+1]=s.log[i] end end
    return table.concat(t,"\n")
end
SAI._log=function(s,msg) local e=string.format("[%.0f]%s",tick()%10000,msg); s.log[#s.log+1]=e; if #s.log>60 then table.remove(s.log,1) end end

