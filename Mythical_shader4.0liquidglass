local function applySkyPreset(preset)
    local sky=Lighting:FindFirstChildOfClass("Sky") if not sky then sky=Instance.new("Sky",Lighting) end
    sky.SkyboxBk=preset.bk sky.SkyboxDn=preset.dn sky.SkyboxFt=preset.ft
    sky.SkyboxLf=preset.lf sky.SkyboxRt=preset.rt sky.SkyboxUp=preset.up
    sky.StarCount=preset.star Lighting.ClockTime=preset.time
end
local skyIdx=0
for _,preset in pairs(SKY_PRESETS) do
    local SkyBtn=Instance.new("TextButton",TabSky)
    SkyBtn.Size=UDim2.new(1,-16,0,30) SkyBtn.Position=UDim2.new(0,8,0,skyIdx*36+6)
    SkyBtn.BackgroundColor3=Color3.fromRGB(30,24,45) SkyBtn.BackgroundTransparency=0.4
    SkyBtn.Text=preset.name SkyBtn.TextColor3=Color3.fromRGB(240,240,255) SkyBtn.Font=Enum.Font.SourceSans SkyBtn.TextSize=12
    Instance.new("UICorner",SkyBtn).CornerRadius=UDim.new(0,6) Instance.new("UIStroke",SkyBtn).Color=Color3.fromRGB(80,60,110)
    applySpringPhysics(SkyBtn) SkyBtn.MouseButton1Click:Connect(function() applySkyPreset(preset) end)
    skyIdx=skyIdx+1
end
