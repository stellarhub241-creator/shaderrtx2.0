local function createTabFrame()
    local f = Instance.new("Frame", ContentArea)
    f.Size                  = UDim2.new(1,0,1,0)
    f.BackgroundTransparency = 1
    f.Visible               = false
    return f
end

local TabGfx      = createTabFrame()
local TabSky      = createTabFrame()
local TabOptimize = createTabFrame()
local TabTheme    = createTabFrame()
local TabFPS      = createTabFrame()

local function applySpringPhysics(button)
    pcall(function()
        local uiScale = button:FindFirstChildOfClass("UIScale")
        if not uiScale then
            uiScale       = Instance.new("UIScale", button)
            uiScale.Scale = 1.0
        end
        button.MouseEnter:Connect(function()
            pcall(function()
                TweenService:Create(uiScale, TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Scale=1.06}):Play()
                TweenService:Create(button, TweenInfo.new(0.2,Enum.EasingStyle.Quad), {BackgroundTransparency=0.15}):Play()
            end)
        end)
        button.MouseLeave:Connect(function()
            pcall(function()
                TweenService:Create(uiScale, TweenInfo.new(0.25,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {Scale=1.0}):Play()
                TweenService:Create(button, TweenInfo.new(0.2,Enum.EasingStyle.Quad), {BackgroundTransparency=0.4}):Play()
            end)
        end)
        button.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                pcall(function()
                    TweenService:Create(uiScale, TweenInfo.new(0.1,Enum.EasingStyle.Quad), {Scale=0.94}):Play()
                end)
            end
        end)
        button.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                pcall(function()
                    TweenService:Create(uiScale, TweenInfo.new(0.2,Enum.EasingStyle.Back), {Scale=1.0}):Play()
                end)
            end
        end)
    end)
end

local tabButtons = {}
local activeTab  = nil

local function switchTab(tabFrame, btn)
    if activeTab == tabFrame then return end
    activeTab = tabFrame
    for _, t in pairs({TabGfx,TabSky,TabOptimize,TabTheme,TabFPS}) do
        if t ~= tabFrame then t.Visible = false end
    end
    for _, b in pairs(tabButtons) do
        b.BackgroundColor3      = Color3.fromRGB(20,16,30)
        b.BackgroundTransparency = 0.4
        b.TextColor3            = Color3.fromRGB(180,180,180)
    end
    tabFrame.Position = UDim2.new(0,30,0,0)
    tabFrame.Visible  = true
    pcall(function()
        TweenService:Create(tabFrame, TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Position=UDim2.new(0,0,0,0)}):Play()
    end)
    btn.BackgroundColor3      = COLOR_THEMES[currentThemeIndex].primary
    btn.BackgroundTransparency = 0.2
    btn.TextColor3            = Color3.fromRGB(255,255,255)
end

local function addTabButton(text, order, targetTab)
    local Btn = Instance.new("TextButton", Sidebar)
    Btn.Size                  = UDim2.new(1,-10,0,24)
    Btn.Position              = UDim2.new(0,5,0,(order-1)*29+8)
    Btn.BackgroundColor3      = Color3.fromRGB(20,16,30)
    Btn.BackgroundTransparency = 0.4
    Btn.Text                  = text
    Btn.TextColor3            = Color3.fromRGB(180,180,180)
    Btn.Font                  = Enum.Font.SourceSansBold
    Btn.TextSize              = 10
    Instance.new("UICorner",Btn).CornerRadius = UDim.new(0,6)
    applySpringPhysics(Btn)
    Btn.MouseButton1Click:Connect(function() switchTab(targetTab,Btn) end)
    table.insert(tabButtons, Btn)
    return Btn
end

