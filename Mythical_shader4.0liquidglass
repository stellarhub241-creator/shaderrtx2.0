createToggle(TabGfx,"Anti-Blue Gloss",3,State.antiBlueGloss,function(val) State.antiBlueGloss=val; if State.pbrEnabled then task.spawn(runPBRScan) end end)
createToggle(TabGfx,"🌄 Dawn Mode",4,false,function(val) State.dawnEnabled=val; State.sunsetEnabled=false; State.nostalgiaEnabled=false; reapplyActiveMode() end)
createToggle(TabGfx,"🌅 Sunset Mode",5,false,function(val) State.sunsetEnabled=val; State.dawnEnabled=false; State.nostalgiaEnabled=false; reapplyActiveMode() end)
createToggle(TabGfx,"🌧 Rain Mode",6,false,function(val) State.rainEnabled=val; reapplyActiveMode(); if val then createRainParticles() else clearRainParticles() end end)
