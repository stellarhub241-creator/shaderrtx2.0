-- ================================================================
-- SECTION 7: UTILITIES
-- ================================================================
local function lerpN(a,b,t) return a+(b-a)*t end
local function lerpC(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end

local function applyLighting(p)
    pcall(function()
        Lighting.Brightness=p.brightness Lighting.ExposureCompensation=p.exposure
        Lighting.ShadowSoftness=p.shadow Lighting.OutdoorAmbient=p.ambient
        Atmosphere.Color=p.atmoColor Atmosphere.Decay=p.atmoDecay
        Atmosphere.Glare=p.atmoGlare Atmosphere.Haze=p.atmoHaze Atmosphere.Density=p.atmoDensity
        ColorCorrection.Contrast=p.contrast ColorCorrection.Saturation=p.saturation
        ColorCorrection.TintColor=p.tint
        Bloom.Intensity=p.bloom Bloom.Size=p.bloomSize Bloom.Threshold=p.bloomThreshold
        DOF.FarIntensity=p.dofFar SunRays.Intensity=p.sunRays
    end)
end

local cinContrast=0.6 local cinSaturation=-0.1 local cinDofFar=0.55 local cinShadow=0.65

local function applyCinematicBlend()
    if not cinematicEnabled then return end
    pcall(function()
        ColorCorrection.Contrast=math.max(ColorCorrection.Contrast,cinContrast)
        ColorCorrection.Saturation=ColorCorrection.Saturation+cinSaturation
        DOF.FarIntensity=math.max(DOF.FarIntensity,cinDofFar)
        Bloom.Threshold=math.min(Bloom.Threshold+0.08,0.99)
        Lighting.ShadowSoftness=math.max(Lighting.ShadowSoftness,cinShadow)
    end)
end

local function resetFogLighting()
    pcall(function()
        Lighting.FogStart=originalFogStart Lighting.FogEnd=originalFogEnd
        Lighting.FogColor=originalFogColor Lighting.Ambient=originalAmbient
        Lighting.Brightness=originalBrightness Lighting.ExposureCompensation=originalExposure
        Lighting.ShadowSoftness=originalShadow Lighting.OutdoorAmbient=originalOutdoor
    end)
end

local function reapplyActiveMode()
    if horrorFogEnabled then
        local p=horrorBlue and PROFILES.HORROR_BLUE or PROFILES.HORROR_GREEN
        applyLighting(p)
        local fc=horrorBlue and Color3.fromRGB(4,5,14) or Color3.fromRGB(8,14,4)
        pcall(function() Lighting.FogStart=4 Lighting.FogEnd=80 Lighting.FogColor=fc Lighting.Ambient=fc end)
    elseif dawnEnabled then
        applyLighting(PROFILES.DAWN)
        pcall(function() Lighting.ClockTime=5.5 end)
    elseif sunsetEnabled then
        applyLighting(PROFILES.GOLDEN)
        pcall(function() Lighting.ClockTime=19 end)
    elseif rainEnabled then
        applyLighting(PROFILES.RAIN)
        pcall(function() Lighting.FogStart=20 Lighting.FogEnd=200 Lighting.FogColor=Color3.fromRGB(110,122,142) end)
    elseif heavenlyEnabled then
        applyLighting(PROFILES.HEAVENLY)
        pcall(function() Lighting.FogStart=500 Lighting.FogEnd=2000 Lighting.FogColor=Color3.fromRGB(225,235,255) Lighting.ClockTime=12 end)
    else resetFogLighting() end
    applyCinematicBlend()
end

-- ================================================================
-- SECTION 8: RAIN SYSTEM
-- ================================================================
local rainFolder=nil local rainConns={} local rainParts={} local rainRipples={}

local function clearRainParticles()
    for _,c in pairs(rainConns) do pcall(function() c:Disconnect() end) end
    rainConns={}
    if rainFolder and rainFolder.Parent then rainFolder:Destroy() end
    rainFolder=nil rainParts={} rainRipples={}
end

local function createRainParticles()
    clearRainParticles()
    rainFolder=Instance.new("Folder",workspace) rainFolder.Name="StellarRain"
    local cam=workspace.CurrentCamera
    local count=math.clamp(rainParticleCount,10,150)
    for i=1,count do
        local p=Instance.new("Part")
        p.Size=Vector3.new(0.045,math.random(18,30)*0.1,0.045)
        p.Material=Enum.Material.Glass p.Reflectance=math.random(70,90)/100
        p.Color=Color3.fromRGB(math.random(200,230),math.random(225,245),255)
        p.Transparency=math.random(55,72)/100
        p.CastShadow=false p.Anchored=true p.CanCollide=false p.Parent=rainFolder
        table.insert(rainParts,p)
    end
    local rippleCount=math.max(6,math.floor(count*0.18))
    for i=1,rippleCount do
        local r=Instance.new("Part")
        r.Size=Vector3.new(0.1,0.05,0.1) r.Material=Enum.Material.Glass r.Reflectance=0.7
        r.Color=Color3.fromRGB(180,215,255) r.Transparency=0.82
        r.CastShadow=false r.Anchored=true r.CanCollide=false
        r.Shape=Enum.PartType.Cylinder r.Parent=rainFolder
        table.insert(rainRipples,r)
    end
    local frame=0
    local conn=RunService.Heartbeat:Connect(function()
        frame=frame+1 if frame%2~=0 then return end
        if not rainFolder or not rainFolder.Parent then return end
        local cp=cam.CFrame.Position local t=tick()
        for i,p in ipairs(rainParts) do
            if p and p.Parent then
                local ph=i*0.73 local fall=(t*16+ph*2.8)%32
                p.Reflectance=0.65+math.sin(t*3+ph)*0.25
                p.CFrame=CFrame.new(cp.X+math.sin(ph)*34,cp.Y+20-fall,cp.Z+math.cos(ph)*34)*CFrame.Angles(0.18,0,0.06)
            end
        end
        for i,r in ipairs(rainRipples) do
            if r and r.Parent then
                local rt=(t*0.7+i*0.65)%1 local sc=0.3+rt*3.5 local ph=i*1.13
                local rx=cp.X+math.sin(ph)*22 local rz=cp.Z+math.cos(ph)*22
                local ray=workspace:Raycast(Vector3.new(rx,cp.Y+8,rz),Vector3.new(0,-50,0))
                local ry=ray and ray.Position.Y+0.05 or cp.Y-8
                r.CFrame=CFrame.new(rx,ry,rz)*CFrame.Angles(0,0,math.pi/2)
                r.Size=Vector3.new(0.05,sc,sc) r.Transparency=0.65+(1-rt)*0.28
                r.Reflectance=0.6+math.sin(t*2+i)*0.3
                r.Color=Color3.fromRGB(math.floor(lerpN(150,210,1-rt)),math.floor(lerpN(190,235,1-rt)),255)
            end
        end
    end)
    table.insert(rainConns,conn)
end

-- ================================================================
-- SECTION 9: SAKURA (ParticleEmitter สวยขึ้น)
-- ================================================================
local sakuraFolder=nil local sakuraConns={}

local function clearSakura()
    for _,c in pairs(sakuraConns) do pcall(function() c:Disconnect() end) end
    sakuraConns={}
    if sakuraFolder and sakuraFolder.Parent then sakuraFolder:Destroy() end
    sakuraFolder=nil
end

local function createSakura()
    clearSakura()
    sakuraFolder=Instance.new("Folder",workspace) sakuraFolder.Name="StellarSakura"
    local cam=workspace.CurrentCamera

    local emitter=Instance.new("Part",sakuraFolder)
    emitter.Size=Vector3.new(60,1,60)
    emitter.Anchored=true emitter.CanCollide=false
    emitter.Transparency=1 emitter.CastShadow=false emitter.Name="SakuraEmitter"

    -- [FIX] ParticleEmitter สวยขึ้น ใช้ texture ที่ดีกว่า
    local pe=Instance.new("ParticleEmitter",emitter)
    pe.Texture="rbxassetid://266310694"
    pe.Rate=math.clamp(sakuraCount*1.2,12,90)
    pe.Lifetime=NumberRange.new(4,8)
    pe.Speed=NumberRange.new(0.5,3)
    pe.SpreadAngle=Vector2.new(60,60)
    pe.RotSpeed=NumberRange.new(-80,80)
    pe.Rotation=NumberRange.new(0,360)
    pe.LightEmission=0.2
    pe.LightInfluence=0.8
    pe.Transparency=NumberSequence.new({
        NumberSequenceKeypoint.new(0,0.05),
        NumberSequenceKeypoint.new(0.7,0.15),
        NumberSequenceKeypoint.new(1,1),
    })
    pe.Size=NumberSequence.new({
        NumberSequenceKeypoint.new(0,0),
        NumberSequenceKeypoint.new(0.1,1.1),
        NumberSequenceKeypoint.new(0.9,0.9),
        NumberSequenceKeypoint.new(1,0),
    })
    pe.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(255,230,242)),
        ColorSequenceKeypoint.new(0.35,Color3.fromRGB(255,192,218)),
        ColorSequenceKeypoint.new(0.7,Color3.fromRGB(248,160,195)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(235,140,180)),
    })
    -- drift ลอยตามลม
    pe.Acceleration=Vector3.new(0.4,-0.8,0.2)
    pe.EmissionDirection=Enum.NormalId.Top
    pe.VelocityInheritance=0

    -- emitter ลอยตาม cam บนหัว
    local conn=RunService.Heartbeat:Connect(function()
        if not sakuraFolder or not sakuraFolder.Parent then return end
        if not emitter or not emitter.Parent then return end
        local cp=cam.CFrame.Position
        emitter.CFrame=CFrame.new(cp.X,cp.Y+10,cp.Z)
    end)
    table.insert(sakuraConns,conn)
end

-- ================================================================
-- SECTION 10: WIND SYSTEM
-- ================================================================
local windConns={} local windParts={}

local function clearWind()
    for _,c in pairs(windConns) do pcall(function() c:Disconnect() end) end
    windConns={}
    for _,d in pairs(windParts) do
        pcall(function() if d.part and d.part.Parent then d.part.CFrame=d.origin end end)
    end
    windParts={}
end

local function startWind()
    clearWind()
    local cam=workspace.CurrentCamera
    for _,v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if (v:IsA("BasePart") or v:IsA("MeshPart")) and v.Anchored then
                local sz=v.Size
                local pn=v.Parent and v.Parent.Name or ""
                if sz.X<4 and sz.Z<4 and sz.Y<12
                    and (v.Position-cam.CFrame.Position).Magnitude<150
                    and pn~="StellarRain" and pn~="StellarSakura"
                    and pn~="StellarMeteor" and pn~="StellarSun" then
                    table.insert(windParts,{part=v,origin=v.CFrame,phase=math.random()*math.pi*2,freq=0.8+math.random()*0.8,amp=0.012+math.random()*0.018})
                end
            end
        end)
    end
    local conn=RunService.Heartbeat:Connect(function()
        if not windEnabled then return end
        local t=tick()
        for _,d in pairs(windParts) do
            pcall(function()
                if d.part and d.part.Parent then
                    local wave=math.sin(t*d.freq+d.phase)*d.amp*windStrength
                    local wave2=math.cos(t*d.freq*0.7+d.phase)*d.amp*windStrength*0.5
                    d.part.CFrame=d.origin*CFrame.Angles(wave,wave2*0.3,wave*0.5)
                end
            end)
        end
    end)
    table.insert(windConns,conn)
end

-- ================================================================
-- SECTION 11: METEOR (สวยขึ้น ใกล้ cam มากขึ้น)
-- ================================================================
local meteorFolder=nil local meteorConns={} local meteorRunning=false

local function clearMeteor()
    meteorRunning=false
    for _,c in pairs(meteorConns) do pcall(function() c:Disconnect() end) end
    meteorConns={}
    if meteorFolder and meteorFolder.Parent then meteorFolder:Destroy() end
    meteorFolder=nil
end

local function spawnOneMeteor()
    if not meteorFolder or not meteorFolder.Parent then return end
    local cam=workspace.CurrentCamera
    local cp=cam.CFrame.Position

    -- [FIX] spawn ใกล้ cam มากขึ้น มองเห็นได้ทุกแมพ
    local angle=math.random()*math.pi*2
    local sx=cp.X+math.cos(angle)*60
    local sy=cp.Y+math.random(40,70)  -- ต่ำลงมาก ใกล้จอ
    local sz=cp.Z+math.sin(angle)*60

    -- ทิศทางเฉียงลง
    local target=Vector3.new(cp.X+(math.random()-0.5)*30,cp.Y-15,cp.Z+(math.random()-0.5)*30)
    local dir=(target-Vector3.new(sx,sy,sz)).Unit
    local speed=math.random(55,95)
    local len=math.random(18,35)

    -- HEAD
    local head=Instance.new("Part",meteorFolder)
    head.Size=Vector3.new(0.7,0.7,0.7)
    head.Material=Enum.Material.Neon head.Color=meteorColor
    head.Transparency=0 head.CastShadow=false head.Anchored=true head.CanCollide=false
    Instance.new("SpecialMesh",head).MeshType=Enum.MeshType.Sphere

    -- BODY
    local body=Instance.new("Part",meteorFolder)
    body.Size=Vector3.new(0.3,0.3,len)
    body.Material=Enum.Material.Neon
    body.Color=lerpC(meteorColor,Color3.fromRGB(255,255,255),0.45)
    body.Transparency=0.18 body.CastShadow=false body.Anchored=true body.CanCollide=false

    -- TAIL
    local tail=Instance.new("Part",meteorFolder)
    tail.Size=Vector3.new(0.12,0.12,len*2.4)
    tail.Material=Enum.Material.Neon
    tail.Color=lerpC(meteorColor,Color3.fromRGB(255,255,255),0.75)
    tail.Transparency=0.6 tail.CastShadow=false tail.Anchored=true tail.CanCollide=false

    -- TAIL2 (จางมาก ยาวมาก)
    local tail2=Instance.new("Part",meteorFolder)
    tail2.Size=Vector3.new(0.06,0.06,len*4)
    tail2.Material=Enum.Material.Neon
    tail2.Color=Color3.fromRGB(255,255,255)
    tail2.Transparency=0.82 tail2.CastShadow=false tail2.Anchored=true tail2.CanCollide=false

    -- GLOW sphere
    local glow=Instance.new("Part",meteorFolder)
    glow.Size=Vector3.new(4,4,4)
    glow.Material=Enum.Material.Neon glow.Color=meteorColor
    glow.Transparency=0.78 glow.CastShadow=false glow.Anchored=true glow.CanCollide=false
    Instance.new("SpecialMesh",glow).MeshType=Enum.MeshType.Sphere

    -- Particle ประกาย
    local pe=Instance.new("ParticleEmitter",head)
    pe.Texture="rbxassetid://6101261905"
    pe.Rate=120 pe.Lifetime=NumberRange.new(0.1,0.4)
    pe.Speed=NumberRange.new(3,10) pe.SpreadAngle=Vector2.new(28,28)
    pe.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,meteorColor),
        ColorSequenceKeypoint.new(0.4,Color3.fromRGB(255,245,180)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255)),
    })
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.55),NumberSequenceKeypoint.new(0.5,0.28),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1.0
    pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.05),NumberSequenceKeypoint.new(1,1)})

    local life=0 local maxLife=3.5

    local conn=RunService.Heartbeat:Connect(function(dt)
        life=life+dt
        if life>=maxLife then
            pe.Enabled=false
            pcall(function() head:Destroy() body:Destroy() tail:Destroy() tail2:Destroy() glow:Destroy() end)
            return
        end
        local fade=math.clamp(1-(life-2.2)/1.3,0,1)
        local np=Vector3.new(sx,sy,sz)+dir*speed*life
        pcall(function()
            head.CFrame=CFrame.new(np)
            body.CFrame=CFrame.lookAt(np-dir*(len*0.5),np-dir*(len*0.5)+dir)*CFrame.Angles(math.pi/2,0,0)
            tail.CFrame=CFrame.lookAt(np-dir*(len*1.4),np-dir*(len*1.4)+dir)*CFrame.Angles(math.pi/2,0,0)
            tail2.CFrame=CFrame.lookAt(np-dir*(len*3),np-dir*(len*3)+dir)*CFrame.Angles(math.pi/2,0,0)
            local pulse=1+math.sin(life*18)*0.12
            glow.CFrame=CFrame.new(np) glow.Size=Vector3.new(4*pulse,4*pulse,4*pulse)
            head.Transparency=1-fade
            body.Transparency=0.18+(1-fade)*0.82
            tail.Transparency=0.6+(1-fade)*0.4
            tail2.Transparency=0.82+(1-fade)*0.18
            glow.Transparency=0.78+(1-fade)*0.22
        end)
    end)
    table.insert(meteorConns,conn)
end

local function startMeteor()
    clearMeteor()
    meteorRunning=true
    meteorFolder=Instance.new("Folder",workspace) meteorFolder.Name="StellarMeteor"
    task.spawn(function()
        while meteorRunning do
            spawnOneMeteor()
            task.wait(math.random()*meteorInterval+0.5)
        end
    end)
end

-- ================================================================
-- SECTION 12: SUN OBJECT (สวยขึ้น ray หลายเส้น)
-- ================================================================
local sunFolder=nil local sunConns={}

local function clearSunray()
    for _,c in pairs(sunConns) do pcall(function() c:Disconnect() end) end
    sunConns={}
    if sunFolder and sunFolder.Parent then sunFolder:Destroy() end
    sunFolder=nil
end

local function startSunray()
    clearSunray()
    sunFolder=Instance.new("Folder",workspace) sunFolder.Name="StellarSun"
    local cam=workspace.CurrentCamera

    -- Core
    local core=Instance.new("Part",sunFolder)
    core.Size=Vector3.new(14,14,14) core.Material=Enum.Material.Neon
    core.Color=Color3.fromRGB(255,248,180) core.Transparency=0
    core.CastShadow=false core.Anchored=true core.CanCollide=false
    Instance.new("SpecialMesh",core).MeshType=Enum.MeshType.Sphere

    -- Corona layers
    local layers={
        {sz=22,col=Color3.fromRGB(255,220,100),tr=0.55},
        {sz=32,col=Color3.fromRGB(255,190,60), tr=0.72},
        {sz=46,col=Color3.fromRGB(255,150,30), tr=0.85},
        {sz=68,col=Color3.fromRGB(255,100,10), tr=0.93},
    }
    local coronaParts={}
    for _,l in ipairs(layers) do
        local c=Instance.new("Part",sunFolder)
        c.Size=Vector3.new(l.sz,l.sz,l.sz) c.Material=Enum.Material.Neon
        c.Color=l.col c.Transparency=l.tr
        c.CastShadow=false c.Anchored=true c.CanCollide=false
        Instance.new("SpecialMesh",c).MeshType=Enum.MeshType.Sphere
        table.insert(coronaParts,{part=c,baseSz=l.sz,baseTr=l.tr})
    end

    -- [NEW] Sun rays หลายเส้น
    local rays={}
    for i=1,8 do
        local ray=Instance.new("Part",sunFolder)
        ray.Size=Vector3.new(0.8,0.8,math.random(30,55))
        ray.Material=Enum.Material.Neon
        ray.Color=Color3.fromRGB(255,235,140) ray.Transparency=0.6
        ray.CastShadow=false ray.Anchored=true ray.CanCollide=false
        table.insert(rays,{part=ray,angle=(i/8)*math.pi*2,tilt=math.random()*0.5})
    end

    -- Particle
    local pe=Instance.new("ParticleEmitter",core)
    pe.Texture="rbxassetid://6101261905" pe.Rate=30 pe.Lifetime=NumberRange.new(1,2.5)
    pe.Speed=NumberRange.new(12,28) pe.SpreadAngle=Vector2.new(180,180)
    pe.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,248,180)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,180,50)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,100,0))})
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,1.0),NumberSequenceKeypoint.new(0.5,0.5),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1.0
    pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.15),NumberSequenceKeypoint.new(1,1)})

    local t0=tick()
    local conn=RunService.Heartbeat:Connect(function()
        if not sunFolder or not sunFolder.Parent then return end
        local cp=cam.CFrame.Position
        local t=tick()-t0
        local ag=t*0.04
        -- วนรอบ cam
        local sunPos=cp+Vector3.new(math.cos(ag)*180,140+math.sin(t*0.3)*8,math.sin(ag)*180)
        local pulse=1+math.sin(t*2.2)*0.05
        pcall(function()
            core.CFrame=CFrame.new(sunPos)
            for _,lc in ipairs(coronaParts) do
                lc.part.CFrame=CFrame.new(sunPos)
                lc.part.Size=Vector3.new(lc.baseSz*pulse,lc.baseSz*pulse,lc.baseSz*pulse)
                lc.part.Transparency=lc.baseTr+(math.sin(t*1.8)*0.04)
            end
            -- หมุน rays รอบดวงอาทิตย์
            for _,r in ipairs(rays) do
                local ra=r.angle+t*0.6
                local rx=sunPos+Vector3.new(math.cos(ra)*28,math.sin(r.tilt)*12,math.sin(ra)*28)
                r.part.CFrame=CFrame.lookAt(rx,sunPos)*CFrame.Angles(math.pi/2,0,0)
                r.part.Transparency=0.55+math.sin(t*3+r.angle)*0.2
            end
        end)
    end)
    table.insert(sunConns,conn)
end

-- ================================================================
-- SECTION 13: NEON EDGE (ตรวจจับขอบจอจริง AbsoluteSize)
-- ================================================================
local neonEdgeConns={} local neonEdges={}

local function clearNeonEdge()
    for _,c in pairs(neonEdgeConns) do pcall(function() c:Disconnect() end) end
    neonEdgeConns={}
    for _,e in ipairs(neonEdges) do pcall(function() e:Destroy() end) end
    neonEdges={}
end

local function startNeonEdge(sg)
    clearNeonEdge()
    local EDGE_W=8
    -- สร้างขอบ 4 ด้านแยกกัน ไม่ใช้ container
    local edgeDefs={
        -- top
        {pos=UDim2.new(0,0,0,0),         size=UDim2.new(1,0,0,EDGE_W)},
        -- bottom
        {pos=UDim2.new(0,0,1,-EDGE_W),   size=UDim2.new(1,0,0,EDGE_W)},
        -- left
        {pos=UDim2.new(0,0,0,0),         size=UDim2.new(0,EDGE_W,1,0)},
        -- right
        {pos=UDim2.new(1,-EDGE_W,0,0),   size=UDim2.new(0,EDGE_W,1,0)},
    }
    local grads={}
    for _,ed in ipairs(edgeDefs) do
        local f=Instance.new("Frame",sg)
        f.Position=ed.pos f.Size=ed.size
        f.BackgroundColor3=Color3.fromRGB(180,0,255) f.BackgroundTransparency=0.3
        f.BorderSizePixel=0 f.ZIndex=200
        f.IgnoreGuiInset=true
        -- ไม่ต้องใช้ UICorner
        local g=Instance.new("UIGradient",f)
        g.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(180,0,255)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(0,220,255)),ColorSequenceKeypoint.new(1,Color3.fromRGB(180,0,255))})
        table.insert(neonEdges,f)
        table.insert(grads,g)
    end

    local conn=RunService.RenderStepped:Connect(function()
        local t=tick()
        local theme=COLOR_THEMES[currentThemeIndex]
        local pulse=0.22+math.abs(math.sin(t*2.5))*0.18
        local h=((t*28)%360)/360
        local col=Color3.fromHSV(h,0.85,1)
        for i,e in ipairs(neonEdges) do
            pcall(function()
                e.BackgroundTransparency=pulse
                grads[i].Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,theme.primary),
                    ColorSequenceKeypoint.new(0.5,col),
                    ColorSequenceKeypoint.new(1,theme.secondary),
                })
                grads[i].Offset=Vector2.new(math.sin(t*0.6+i)*0.28,0)
            end)
        end
    end)
    table.insert(neonEdgeConns,conn)
end

-- ================================================================
-- SECTION 14: TIME LOOP (Day/Night + Dawn/Sunset จาก Graphics)
-- ================================================================
local ModeText="Status: Loading..." local BorderColorNow=Color3.fromRGB(180,0,255) local rainbowHue=0

task.spawn(function()
    while task.wait(0.25) do
        -- time loop ทำงานเฉพาะเมื่อไม่มี mode พิเศษ
        if not horrorFogEnabled and not rainEnabled and not heavenlyEnabled
            and not dawnEnabled and not sunsetEnabled then
            local t=Lighting.ClockTime
            if t>=6 and t<19 then
                applyLighting(PROFILES.DAY) ModeText="Status: Day" BorderColorNow=Color3.fromRGB(255,220,100)
            else
                applyLighting(PROFILES.NIGHT) ModeText="Status: Night" BorderColorNow=Color3.fromRGB(100,180,255)
            end
            applyCinematicBlend()
        end
    end
end)

-- ================================================================
-- SECTION 15: PBR
-- ================================================================
local function applyPBROnPart(v)
    if not pbrEnabled or isFpsBoostOn then return end
    if not v or not v.Parent then return end
    if not (v:IsA("BasePart") or v:IsA("MeshPart")) then return end
    local pn=v.Parent and v.Parent.Name or ""
    if pn=="StellarRain" or pn=="StellarSakura" or pn=="StellarMeteor" or pn=="StellarSun" then return end
    v.CastShadow=true
    local m=v.Material local r=0
    if m==Enum.Material.Concrete        then r=0.15
    elseif m==Enum.Material.SmoothPlastic then r=0.35
    elseif m==Enum.Material.Cobblestone   then r=0.08
    elseif m==Enum.Material.Wood or m==Enum.Material.WoodPlanks then r=0.03
    elseif m==Enum.Material.Marble        then r=0.55
    elseif m==Enum.Material.Granite       then r=0.3
    elseif m==Enum.Material.Metal or m==Enum.Material.DiamondPlate then r=0.65
    elseif m==Enum.Material.Glass         then r=0.8
    elseif m==Enum.Material.Neon          then r=0.85
    elseif m==Enum.Material.Ice           then r=0.7
    elseif m==Enum.Material.Sand          then r=0.02 end
    if antiBlueGloss then
        local c=v.Color local lum=(c.R*0.299)+(c.G*0.587)+(c.B*0.114)
        v.Reflectance=lum<0.18 and r*(lum*3.5) or r
    else v.Reflectance=r end
end

local function runPBRScan()
    local n=0 local cam=workspace.CurrentCamera
    for _,v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") or v:IsA("MeshPart") then
                if (v.Position-cam.CFrame.Position).Magnitude<200 then applyPBROnPart(v) end
            end
        end)
        n=n+1 if n%200==0 then task.wait() end
    end
end
task.spawn(runPBRScan)
workspace.DescendantAdded:Connect(function(v)
    task.delay(0.2,function() pcall(function() applyPBROnPart(v) end) end)
end)

-- ================================================================
-- SECTION 16: FPS BOOST
-- ================================================================
local function triggerFPSBoost(on)
    isFpsBoostOn=on
    if on then
        local n=0
        for _,v in pairs(workspace:GetDescendants()) do
            pcall(function()
                local pn=v.Parent and v.Parent.Name or ""
                if (v:IsA("BasePart") or v:IsA("MeshPart"))
                    and pn~="StellarRain" and pn~="StellarSakura"
                    and pn~="StellarMeteor" and pn~="StellarSun" then
                    if not originalMaterials[v] then originalMaterials[v]=v.Material originalShadows[v]=v.CastShadow end
                    v.Material=Enum.Material.SmoothPlastic v.CastShadow=false v.Reflectance=0
                elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency=1 end
            end)
            n=n+1 if n%300==0 then task.wait() end
        end
        pcall(function() Terrain.Decoration=false Lighting.GlobalShadows=false end)
    else
        local n=0
        for v,mat in pairs(originalMaterials) do
            pcall(function() if v and v.Parent then v.Material=mat v.CastShadow=originalShadows[v] or false end end)
            n=n+1 if n%300==0 then task.wait() end
        end
        for _,v in pairs(workspace:GetDescendants()) do
            pcall(function() if v:IsA("Decal") or v:IsA("Texture") then v.Transparency=0 end end)
        end
        pcall(function() Terrain.Decoration=true Lighting.GlobalShadows=true end)
        table.clear(originalMaterials) table.clear(originalShadows)
        task.spawn(runPBRScan)
    end
end

-- ================================================================
-- SECTION 17: UI FRAMEWORK (White Glass / Clear โทน)
-- ================================================================
local ScreenGui=Instance.new("ScreenGui",CoreGui)
ScreenGui.Name="STELLARHUB_MYTHICAL" ScreenGui.ResetOnSpawn=false ScreenGui.IgnoreGuiInset=true

local SMOOTH       = TweenInfo.new(0.22,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
local SMOOTH_BACK  = TweenInfo.new(0.28,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
local SMOOTH_FAST  = TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)

local function tw(obj,props,info) pcall(function() TweenService:Create(obj,info or SMOOTH,props):Play() end) end

local function spring(btn)
    pcall(function()
        local us=btn:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",btn)
        us.Scale=1.0
        btn.MouseEnter:Connect(function() pcall(function()
            tw(us,{Scale=1.08},SMOOTH_BACK)
            tw(btn,{BackgroundTransparency=0.05},SMOOTH_FAST)
        end) end)
        btn.MouseLeave:Connect(function() pcall(function()
            tw(us,{Scale=1.0},SMOOTH)
            tw(btn,{BackgroundTransparency=0.32},SMOOTH_FAST)
        end) end)
        btn.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                -- [FIX] ไม่ลดความทึบตอนกด แค่ scale
                pcall(function() tw(us,{Scale=0.94},SMOOTH_FAST) end)
            end
        end)
        btn.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                pcall(function() tw(us,{Scale=1.0},SMOOTH_BACK) end)
            end
        end)
    end)
end

local function addBounceOnHold(frame)
    local holdThread=nil
    frame.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
            if holdThread then pcall(function() task.cancel(holdThread) end) end
            holdThread=task.delay(0.28,function()
                pcall(function()
                    local us=frame:FindFirstChildOfClass("UIScale") or Instance.new("UIScale",frame)
                    us.Scale=1
                    tw(us,{Scale=1.14},TweenInfo.new(0.1,Enum.EasingStyle.Quad,Enum.EasingDirection.Out))
                    task.wait(0.1)
                    tw(us,{Scale=1.0},TweenInfo.new(0.28,Enum.EasingStyle.Bounce,Enum.EasingDirection.Out))
                end)
                holdThread=nil
            end)
            input.Changed:Connect(function()
                if input.UserInputState==Enum.UserInputState.End then
                    if holdThread then pcall(function() task.cancel(holdThread) end) holdThread=nil end
                end
            end)
        end
    end)
end

