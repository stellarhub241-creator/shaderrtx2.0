local function applyLighting(p)
    pcall(function()
        Lighting.Brightness=p.brightness; Lighting.ExposureCompensation=p.exposure
        Lighting.ShadowSoftness=p.shadow; Lighting.OutdoorAmbient=p.ambient
        Atmosphere.Color=p.atmoColor; Atmosphere.Decay=p.atmoDecay
        Atmosphere.Glare=p.atmoGlare; Atmosphere.Haze=p.atmoHaze; Atmosphere.Density=p.atmoDensity
        ColorCorrection.Contrast=p.contrast; ColorCorrection.Saturation=p.saturation; ColorCorrection.TintColor=p.tint
        Bloom.Intensity=p.bloom; Bloom.Size=p.bloomSize; Bloom.Threshold=p.bloomThreshold
        DOF.FarIntensity=p.dofFar; SunRays.Intensity=p.sunRays
    end)
end

local function applyCinematicBlend()
    if not State.cinematicEnabled then return end
    pcall(function()
        ColorCorrection.Contrast=math.max(ColorCorrection.Contrast,0.6)
        ColorCorrection.Saturation=ColorCorrection.Saturation-0.1
        DOF.FarIntensity=math.max(DOF.FarIntensity,0.55)
        Bloom.Threshold=math.min(Bloom.Threshold+0.08,0.99)
        Lighting.ShadowSoftness=math.max(Lighting.ShadowSoftness,0.65)
    end)
end

local function resetFogLighting()
    pcall(function()
        if not State.nostalgiaEnabled then
            Lighting.FogStart=State.originalFogStart; Lighting.FogEnd=State.originalFogEnd
            Lighting.FogColor=State.originalFogColor; Lighting.Ambient=State.originalAmbient
            Lighting.Brightness=State.originalBrightness; Lighting.ExposureCompensation=State.originalExposure
            Lighting.ShadowSoftness=State.originalShadow; Lighting.OutdoorAmbient=State.originalOutdoor
        end
    end)
end

local function reapplyActiveMode()
    if State.nostalgiaEnabled then
        applyLighting(PROFILES.NOSTALGIA)
        pcall(function() Lighting.ClockTime=17.2; Lighting.FogStart=180; Lighting.FogEnd=2200; Lighting.FogColor=Color3.fromRGB(210,160,225); Lighting.Ambient=Color3.fromRGB(120,80,145) end)
    elseif State.horrorBlue then
        applyLighting(PROFILES.HORROR_B)
        pcall(function() Lighting.FogStart=1; Lighting.FogEnd=38; Lighting.FogColor=Color3.fromRGB(1,2,25); Lighting.Ambient=Color3.fromRGB(1,2,25) end)
    elseif State.horrorFogEnabled then
        applyLighting(PROFILES.HORROR_G)
        pcall(function() Lighting.FogStart=2; Lighting.FogEnd=50; Lighting.FogColor=Color3.fromRGB(4,18,2); Lighting.Ambient=Color3.fromRGB(4,18,2) end)
    elseif State.dawnEnabled then applyLighting(PROFILES.DAWN); pcall(function() Lighting.ClockTime=5.5 end)
    elseif State.sunsetEnabled then applyLighting(PROFILES.GOLDEN); pcall(function() Lighting.ClockTime=19 end)
    elseif State.rainEnabled then
        applyLighting(PROFILES.RAIN)
        pcall(function() Lighting.FogStart=20; Lighting.FogEnd=200; Lighting.FogColor=Color3.fromRGB(110,122,142) end)
    elseif State.heavenlyEnabled then
        applyLighting(PROFILES.HEAVENLY)
        pcall(function() Lighting.FogStart=500; Lighting.FogEnd=2000; Lighting.FogColor=Color3.fromRGB(225,235,255); Lighting.ClockTime=12 end)
    else resetFogLighting() end
    applyCinematicBlend()
end

-- ================================================================
-- SECTION 12: RAIN SYSTEM (ใช้ StellarEngineB compute batch)
-- ================================================================
local rainFolder=nil; local rainConns={}; local rainParts={}; local rainRipples={}

local function clearRainParticles()
    for _,c in pairs(rainConns) do pcall(function() c:Disconnect() end) end
    rainConns={}
    if rainFolder and rainFolder.Parent then pcall(function() rainFolder:Destroy() end) end
    rainFolder=nil; rainParts={}; rainRipples={}; SAS:release("rain"); StellarEngineB:clearBatch("rain")
end

local function createRainParticles()
    clearRainParticles()
    local ok,q=SAS:request("rain"); if not ok then return end
    rainFolder=Instance.new("Folder",workspace); rainFolder.Name="StellarRain"
    local cam=workspace.CurrentCamera
    local count=math.clamp(math.floor(State.rainParticleCount*q),10,150)
    for i=1,count do
        local p=Instance.new("Part"); p.Size=Vector3.new(0.045,math.random(18,30)*0.1,0.045)
        p.Material=Enum.Material.Glass; p.Reflectance=math.random(70,90)/100
        p.Color=Color3.fromRGB(math.random(200,230),math.random(225,245),255)
        p.Transparency=math.random(55,72)/100; p.CastShadow=false; p.Anchored=true; p.CanCollide=false; p.Parent=rainFolder
        table.insert(rainParts,p)
    end
    local rippleCount=math.max(5,math.floor(count*0.18))
    for i=1,rippleCount do
        local r=Instance.new("Part"); r.Size=Vector3.new(0.1,0.05,0.1); r.Material=Enum.Material.Glass
        r.Reflectance=0.7; r.Color=Color3.fromRGB(180,215,255); r.Transparency=0.82
        r.CastShadow=false; r.Anchored=true; r.CanCollide=false; r.Shape=Enum.PartType.Cylinder; r.Parent=rainFolder
        table.insert(rainRipples,r)
    end
    -- [B] register batch สำหรับคำนวณ fall เฟส
    local batchItems={}
    for i=1,count do batchItems[i]={fall=0} end
    StellarEngineB:registerBatch("rain", batchItems)

    local frame=0
    table.insert(rainConns, RunService.Heartbeat:Connect(function()
        frame=frame+1; if frame%2~=0 then return end
        if not rainFolder or not rainFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()
        StellarEngineB:computeRainBatch(batchItems,t)
        for i,p in ipairs(rainParts) do
            if p and p.Parent then
                local ph=i*0.73; local fall=batchItems[i] and batchItems[i].fall or 0
                pcall(function()
                    p.Reflectance=0.65+math.sin(t*3+ph)*0.25
                    p.CFrame=CFrame.new(cp.X+math.sin(ph)*34,cp.Y+20-fall,cp.Z+math.cos(ph)*34)*CFrame.Angles(0.18,0,0.06)
                end)
            end
        end
        for i,r in ipairs(rainRipples) do
            if r and r.Parent then
                pcall(function()
                    local rt=(t*0.7+i*0.65)%1; local sc=0.3+rt*3.5; local ph=i*1.13
                    local rx=cp.X+math.sin(ph)*22; local rz=cp.Z+math.cos(ph)*22
                    local ray=workspace:Raycast(Vector3.new(rx,cp.Y+8,rz),Vector3.new(0,-50,0))
                    local ry=ray and ray.Position.Y+0.05 or cp.Y-8
                    r.CFrame=CFrame.new(rx,ry,rz)*CFrame.Angles(0,0,math.pi/2)
                    r.Size=Vector3.new(0.05,sc,sc)
                    r.Transparency=0.65+(1-rt)*0.28; r.Reflectance=0.6+math.sin(t*2+i)*0.3
                    r.Color=Color3.fromRGB(math.floor(lerpN(150,210,1-rt)),math.floor(lerpN(190,235,1-rt)),255)
                end)
            end
        end
    end))
end

-- ================================================================
-- SECTION 13: SAKURA — Part+Neon+Mesh ตกจริง (ใช้ StellarEngineB)
-- ================================================================
local sakuraFolder=nil; local sakuraConns={}; local sakuraParts={}

local function clearSakura()
    for _,c in pairs(sakuraConns) do pcall(function() c:Disconnect() end) end
    sakuraConns={}
    if sakuraFolder and sakuraFolder.Parent then pcall(function() sakuraFolder:Destroy() end) end
    sakuraFolder=nil; sakuraParts={}; SAS:release("sakura"); StellarEngineB:clearBatch("sakura")
end

local function createSakura()
    clearSakura()
    local ok,q=SAS:request("sakura"); if not ok then return end
    sakuraFolder=Instance.new("Folder",workspace); sakuraFolder.Name="StellarSakura"
    local cam=workspace.CurrentCamera
    local count=math.clamp(math.floor(State.sakuraCount*q),8,80)
    local theme=COLOR_THEMES[State.currentThemeIndex]

    for i=1,count do
        local p=Instance.new("Part",sakuraFolder)
        p.Size=Vector3.new(1.2,0.12,1.2)
        p.Material=Enum.Material.Neon
        p.CastShadow=false; p.Anchored=true; p.CanCollide=false
        p.Color=StellarFlu.sakuraPetalColor(i, theme.primary)
        p.Transparency=0.15
        local mesh=Instance.new("SpecialMesh",p)
        mesh.MeshType=Enum.MeshType.Sphere
        mesh.Scale=Vector3.new(1,0.18,1)

        local cp=cam.CFrame.Position
        local sx=cp.X+math.random(-40,40)
        local sy=cp.Y+math.random(10,35)
        local sz=cp.Z+math.random(-40,40)

        table.insert(sakuraParts,{
            part=p, mesh=mesh, x=sx, y=sy, z=sz,
            vy=math.random(18,45)*0.01, rot=math.random(0,360),
            rotX=math.random(-30,30)*0.01, rotZ=math.random(-30,30)*0.01,
            rotSpeed=math.random(-90,90), phase=math.random()*math.pi*2,
            life=math.random()*10, maxLife=math.random(8,18), seed=i,
        })
    end

    -- [B] register batch — StellarEngineB จะคำนวณ drift+fall ให้ทุกตัวพร้อมกัน
    StellarEngineB:registerBatch("sakura", sakuraParts)

    local conn=RunService.Heartbeat:Connect(function(dt)
        if not sakuraFolder or not sakuraFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()

        -- [B] GPU-like batch compute ทำงานครั้งเดียวสำหรับทั้งชุด
        StellarEngineB:computeSakuraBatch(sakuraParts, dt, t)

        for _,s in ipairs(sakuraParts) do
            if s.part and s.part.Parent then
                if s.life>s.maxLife or s.y<cp.Y-40 then
                    s.x=cp.X+math.random(-42,42); s.y=cp.Y+math.random(20,40); s.z=cp.Z+math.random(-42,42)
                    s.vy=math.random(18,45)*0.01; s.life=0; s.maxLife=math.random(8,18)
                    s.rotSpeed=math.random(-90,90)
                    local theme2=COLOR_THEMES[State.currentThemeIndex]
                    pcall(function() s.part.Color=StellarFlu.sakuraPetalColor(s.seed+math.random(10), theme2.primary) end)
                end
                local alpha=StellarFlu.particleFade(s.life/s.maxLife)
                pcall(function()
                    s.part.CFrame=CFrame.new(s.x,s.y,s.z)*CFrame.Angles(s.rotX*s.rot, math.rad(s.rot), s.rotZ*s.rot)
                    s.part.Transparency=math.clamp(1-alpha*0.88, 0.08, 0.92)
                end)
            end
        end
    end)
    table.insert(sakuraConns,conn)
    StellarAI:watch("sakura_folder",function() return sakuraFolder end,"SakuraFolder")
end

-- ================================================================
-- SECTION 14: WIND SYSTEM
-- ================================================================
local windConns={}; local windParts={}

local function clearWind()
    for _,c in pairs(windConns) do pcall(function() c:Disconnect() end) end
    windConns={}
    for _,d in pairs(windParts) do
        pcall(function() if d.part and d.part.Parent then d.part.CFrame=d.origin end end)
    end
    windParts={}; SAS:release("wind")
end

local function startWind()
    clearWind()
    local ok=SAS:request("wind"); if not ok then return end
    local cam=workspace.CurrentCamera; local collected=0
    for _,v in ipairs(workspace:GetDescendants()) do
        if collected>=200 then break end
        pcall(function()
            if not (v:IsA("BasePart") or v:IsA("MeshPart")) or not v.Anchored then return end
            local pn=v.Parent and v.Parent.Name or ""
            if pn=="StellarRain" or pn=="StellarSakura" or pn=="StellarMeteor" or pn=="StellarSun" then return end
            if v.Size.X>6 or v.Size.Z>6 or v.Size.Y>18 then return end
            if (v.Position-cam.CFrame.Position).Magnitude>120 then return end
            table.insert(windParts,{part=v,origin=v.CFrame,phase=math.random()*math.pi*2,freq=0.8+math.random()*1.2,amp=0.008+math.random()*0.022})
            collected=collected+1
        end)
    end
    if #windParts==0 then StellarAI:log("[Wind] no eligible parts"); SAS:release("wind"); return end
    table.insert(windConns, RunService.Heartbeat:Connect(function(dt)
        if not State.windEnabled then return end
        local t=tick()
        for _,d in pairs(windParts) do
            pcall(function()
                if d.part and d.part.Parent then
                    local wave=math.sin(t*d.freq+d.phase)*d.amp*State.windStrength
                    local wave2=StellarA.smoothNoise(t*d.freq*0.5,d.phase,0)*d.amp*State.windStrength*0.4
                    d.part.CFrame=d.origin*CFrame.Angles(wave,wave2*0.3,wave*0.6)
                end
            end)
        end
    end))
end

-- ================================================================
-- SECTION 15: METEOR — v6.6 base, fix color, อัปเกรดอลังการ
-- ================================================================
local meteorFolder=nil; local meteorConns={}; local meteorRunning=false

local function clearMeteor()
    meteorRunning=false
    for _,c in pairs(meteorConns) do pcall(function() c:Disconnect() end) end
    meteorConns={}
    if meteorFolder and meteorFolder.Parent then pcall(function() meteorFolder:Destroy() end) end
    meteorFolder=nil; SAS:release("meteor")
end

local function spawnOneMeteor()
    if not meteorFolder or not meteorFolder.Parent then return end
    local q = SAS:getQuality("meteor")
    local cam=workspace.CurrentCamera; local cp=cam.CFrame.Position
    local angle=math.random()*math.pi*2; local dist=math.random(500,800)
    local sx=cp.X+math.cos(angle)*dist; local sy=cp.Y+math.random(300,500); local sz=cp.Z+math.sin(angle)*dist
    local target=Vector3.new(cp.X+math.cos(angle+math.pi)*dist,cp.Y-math.random(50,100),cp.Z+math.sin(angle+math.pi)*dist)
    local dir=(target-Vector3.new(sx,sy,sz)).Unit; local speed=math.random(250,450); local len=math.random(50,120)
    local meteorC = State.meteorColor

    local head=Instance.new("Part",meteorFolder); head.Size=Vector3.new(6,6,6); head.Material=Enum.Material.Neon
    head.Color=meteorC; head.Transparency=0; head.CastShadow=false; head.Anchored=true; head.CanCollide=false
    Instance.new("SpecialMesh",head).MeshType=Enum.MeshType.Sphere

    local pLight=Instance.new("PointLight",head)
    pLight.Color=meteorC; pLight.Range=350; pLight.Brightness=5; pLight.Shadows=true

    local innerCore=Instance.new("Part",meteorFolder)
    innerCore.Size=Vector3.new(3,3,3); innerCore.Material=Enum.Material.Neon
    innerCore.Color=Color3.fromRGB(255,255,255); innerCore.Transparency=0.1
    innerCore.CastShadow=false; innerCore.Anchored=true; innerCore.CanCollide=false
    Instance.new("SpecialMesh",innerCore).MeshType=Enum.MeshType.Sphere

    local headAura=Instance.new("Part",meteorFolder)
    headAura.Size=Vector3.new(16,16,16); headAura.Material=Enum.Material.Neon
    headAura.Color=meteorC; headAura.Transparency=0.7
    headAura.CastShadow=false; headAura.Anchored=true; headAura.CanCollide=false
    Instance.new("SpecialMesh",headAura).MeshType=Enum.MeshType.Sphere

    local body=Instance.new("Part",meteorFolder); body.Size=Vector3.new(2.8,2.8,len); body.Material=Enum.Material.Neon
    body.Color=StellarA.lerpColorHSV(meteorC,Color3.fromRGB(255,255,255),0.4)
    body.Transparency=0.15; body.CastShadow=false; body.Anchored=true; body.CanCollide=false

    local tail=Instance.new("Part",meteorFolder); tail.Size=Vector3.new(1.7,1.7,len*2.8); tail.Material=Enum.Material.Neon
    tail.Color=StellarA.lerpColorHSV(meteorC,Color3.fromRGB(255,255,255),0.68)
    tail.Transparency=0.42; tail.CastShadow=false; tail.Anchored=true; tail.CanCollide=false

    local tail2=Instance.new("Part",meteorFolder); tail2.Size=Vector3.new(0.7,0.7,len*5.5); tail2.Material=Enum.Material.Neon
    tail2.Color=Color3.fromRGB(255,255,255); tail2.Transparency=0.75; tail2.CastShadow=false; tail2.Anchored=true; tail2.CanCollide=false

    local tail3=Instance.new("Part",meteorFolder); tail3.Size=Vector3.new(0.3,0.3,len*8); tail3.Material=Enum.Material.Neon
    tail3.Color=StellarA.lerpColorHSV(meteorC,Color3.fromRGB(255,255,255),0.85)
    tail3.Transparency=0.85; tail3.CastShadow=false; tail3.Anchored=true; tail3.CanCollide=false

    local glow=Instance.new("Part",meteorFolder); glow.Size=Vector3.new(24,24,24); glow.Material=Enum.Material.Neon
    glow.Color=meteorC; glow.Transparency=0.76; glow.CastShadow=false; glow.Anchored=true; glow.CanCollide=false
    Instance.new("SpecialMesh",glow).MeshType=Enum.MeshType.Sphere

    local pe=Instance.new("ParticleEmitter",head)
    pe.Texture="rbxassetid://2273224484"
    pe.Rate=math.floor(450*q); pe.Lifetime=NumberRange.new(0.15,0.6); pe.Speed=NumberRange.new(8,38)
    pe.SpreadAngle=Vector2.new(62,62)
    pe.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(0.3,meteorC),ColorSequenceKeypoint.new(0.7,Color3.fromRGB(255,200,80)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,100,0))})
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,4.5),NumberSequenceKeypoint.new(0.4,2.2),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1; pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)})
    pe.EmissionDirection=Enum.NormalId.Back; pe.RotSpeed=NumberRange.new(-200,200); pe.Rotation=NumberRange.new(0,360)

    local pe2=Instance.new("ParticleEmitter",body)
    pe2.Texture="rbxassetid://6060542021"
    pe2.Rate=math.floor(180*q); pe2.Lifetime=NumberRange.new(0.1,0.45); pe2.Speed=NumberRange.new(2,14)
    pe2.SpreadAngle=Vector2.new(28,28)
    pe2.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,225,110)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,120,20)),ColorSequenceKeypoint.new(1,Color3.fromRGB(180,50,0))})
    pe2.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,2.3),NumberSequenceKeypoint.new(1,0)})
    pe2.LightEmission=0.85; pe2.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.1),NumberSequenceKeypoint.new(1,1)})
    pe2.EmissionDirection=Enum.NormalId.Back

    local pe3=Instance.new("ParticleEmitter",headAura)
    pe3.Texture="rbxassetid://2273224484"
    pe3.Rate=math.floor(70*q); pe3.Lifetime=NumberRange.new(0.35,1.1); pe3.Speed=NumberRange.new(0,6)
    pe3.SpreadAngle=Vector2.new(180,180)
    pe3.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,meteorC),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255))})
    pe3.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,6.5),NumberSequenceKeypoint.new(1,0)})
    pe3.LightEmission=0.65
    pe3.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.45),NumberSequenceKeypoint.new(1,1)})

    local life=0; local maxLife=5.5; local isFading=false
    local meteorConn
    meteorConn=RunService.Heartbeat:Connect(function(dt)
        life=life+dt
        if life>=maxLife-0.5 and not isFading then
            isFading=true; pe.Enabled=false; pe2.Enabled=false; pe3.Enabled=false
            pcall(function()
                TweenService:Create(glow,TweenInfo.new(0.22,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=Vector3.new(90,90,90),Transparency=0}):Play()
                TweenService:Create(pLight,TweenInfo.new(0.22),{Range=600,Brightness=9}):Play()
                TweenService:Create(head, TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(innerCore,TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(headAura,TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(body, TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(tail, TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(tail2,TweenInfo.new(0.5),{Transparency=1}):Play()
                TweenService:Create(tail3,TweenInfo.new(0.5),{Transparency=1}):Play()
            end)
        end
        if life>=maxLife then
            pcall(function()
                head:Destroy(); innerCore:Destroy(); headAura:Destroy()
                body:Destroy(); tail:Destroy(); tail2:Destroy(); tail3:Destroy(); glow:Destroy()
            end)
            pcall(function() meteorConn:Disconnect() end)
            return
        end
        local np=Vector3.new(sx,sy,sz)+dir*speed*life
        pcall(function()
            if not isFading then
                head.CFrame=CFrame.new(np)
                innerCore.CFrame=CFrame.new(np)
                headAura.CFrame=CFrame.new(np)
                body.CFrame=CFrame.lookAt(np-dir*(len*0.5),np-dir*(len*0.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail.CFrame=CFrame.lookAt(np-dir*(len*1.5),np-dir*(len*1.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail2.CFrame=CFrame.lookAt(np-dir*(len*3.2),np-dir*(len*3.2)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail3.CFrame=CFrame.lookAt(np-dir*(len*6.5),np-dir*(len*6.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                local pulse=1+math.sin(life*28)*0.18
                glow.CFrame=CFrame.new(np); glow.Size=Vector3.new(24*pulse,24*pulse,24*pulse)
                local auraPulse=1+math.sin(life*16)*0.22
                headAura.Size=Vector3.new(16*auraPulse,16*auraPulse,16*auraPulse)
            else
                head.CFrame=head.CFrame+dir*speed*0.08*dt
                innerCore.CFrame=head.CFrame; headAura.CFrame=head.CFrame; glow.CFrame=head.CFrame
                TweenService:Create(glow,TweenInfo.new(0.3),{Transparency=1,Size=Vector3.new(0,0,0)}):Play()
            end
        end)
    end)
    table.insert(meteorConns,meteorConn)
end

local function startMeteor()
    clearMeteor()
    local ok=SAS:request("meteor"); if not ok then StellarAI:log("Meteor denied by SAS"); return end
    meteorRunning=true
    meteorFolder=Instance.new("Folder",workspace); meteorFolder.Name="StellarMeteor"
    task.spawn(function()
        while meteorRunning do
            spawnOneMeteor()
            task.wait(math.random()*State.meteorInterval+0.5)
        end
    end)
end

-- ================================================================
-- SECTION 16: SUN OBJECT — v6.6 base (60 rays fibonacci), fixed
-- ================================================================
local sunFolder=nil; local sunConns={}

local function clearSunray()
    for _,c in pairs(sunConns) do pcall(function() c:Disconnect() end) end
    sunConns={}
    if sunFolder and sunFolder.Parent then pcall(function() sunFolder:Destroy() end) end
    sunFolder=nil; SAS:release("sun")
end

local function startSunray()
    clearSunray()
    local ok,q=SAS:request("sun"); if not ok then StellarAI:log("Sun denied by SAS"); return end
    sunFolder=Instance.new("Folder",workspace); sunFolder.Name="StellarSun"
    local cam=workspace.CurrentCamera

    local core=Instance.new("Part",sunFolder); core.Size=Vector3.new(100,100,100); core.Material=Enum.Material.Neon
    core.Color=Color3.fromRGB(255,248,180); core.Transparency=0; core.CastShadow=false; core.Anchored=true; core.CanCollide=false
    Instance.new("SpecialMesh",core).MeshType=Enum.MeshType.Sphere

    local sunLight=Instance.new("PointLight",core)
    sunLight.Color=Color3.fromRGB(255,220,150); sunLight.Brightness=2.5; sunLight.Range=750; sunLight.Shadows=false

    local coronaData={
        {sz=145,col=Color3.fromRGB(255,228,100),tr=0.55},
        {sz=200,col=Color3.fromRGB(255,195,55),tr=0.70},
        {sz=280,col=Color3.fromRGB(255,155,28),tr=0.84},
        {sz=400,col=Color3.fromRGB(255,108,8),tr=0.93},
        {sz=560,col=Color3.fromRGB(255,60,0),tr=0.96},
    }
    local coronaParts={}
    for _,l in ipairs(coronaData) do
        local c=Instance.new("Part",sunFolder); c.Size=Vector3.new(l.sz,l.sz,l.sz); c.Material=Enum.Material.Neon
        c.Color=l.col; c.Transparency=l.tr; c.CastShadow=false; c.Anchored=true; c.CanCollide=false
        Instance.new("SpecialMesh",c).MeshType=Enum.MeshType.Sphere
        table.insert(coronaParts,{part=c,baseSz=l.sz,baseTr=l.tr})
    end

    local RAY_COUNT = math.floor(60*q)
    local rays={}
    for i=1,RAY_COUNT do
        local phi   = math.acos(1 - 2*i/(RAY_COUNT+1))
        local theta = (math.pi*(1+math.sqrt(5)))*(i-1)
        local r = Instance.new("Part",sunFolder)
        local isMain = i <= math.floor(RAY_COUNT*0.66)
        local rLen = math.random(450, 950)
        r.Size = Vector3.new(isMain and 5 or 3, isMain and 5 or 3, rLen)
        r.Material = Enum.Material.Neon
        r.Color = Color3.fromRGB(255,230,130)
        r.Transparency = 0.65
        r.CastShadow = false; r.Anchored = true; r.CanCollide = false
        table.insert(rays,{part=r,phi=phi,theta=theta,rLen=rLen,kind=isMain and "main" or "sub"})
    end

    local ambientGlow=Instance.new("Part",sunFolder); ambientGlow.Size=Vector3.new(750,750,750); ambientGlow.Material=Enum.Material.Neon
    ambientGlow.Color=Color3.fromRGB(255,140,30); ambientGlow.Transparency=0.975; ambientGlow.CastShadow=false; ambientGlow.Anchored=true; ambientGlow.CanCollide=false
    Instance.new("SpecialMesh",ambientGlow).MeshType=Enum.MeshType.Sphere

    local t0=tick()
    local conn=RunService.Heartbeat:Connect(function()
        if not sunFolder or not sunFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()-t0; local ag=t*0.018
        local sunPos=cp+Vector3.new(math.cos(ag)*1350,480+math.sin(t*0.1)*40,math.sin(ag)*1350)
        local pulse=1+math.sin(t*1.4)*0.035

        pcall(function()
            core.CFrame=CFrame.new(sunPos); core.Size=Vector3.new(100*pulse,100*pulse,100*pulse)
            ambientGlow.CFrame=CFrame.new(sunPos); ambientGlow.Transparency=0.970+math.sin(t*0.7)*0.015

            for _,lc in ipairs(coronaParts) do
                lc.part.CFrame=CFrame.new(sunPos)
                local sz=lc.baseSz*pulse; lc.part.Size=Vector3.new(sz,sz,sz)
                lc.part.Transparency=lc.baseTr+math.sin(t*1.2+lc.baseSz*0.01)*0.025
            end

            for _,r in ipairs(rays) do
                local theta = r.theta + t*0.35
                local dx = math.sin(r.phi)*math.cos(theta)
                local dy = math.cos(r.phi)
                local dz = math.sin(r.phi)*math.sin(theta)
                local rayDir = Vector3.new(dx,dy,dz).Unit
                local midPt  = sunPos + rayDir*(r.rLen*0.5)
                r.part.CFrame = CFrame.lookAt(midPt, midPt+rayDir)
                r.part.Transparency = (r.kind=="main" and 0.60 or 0.70) + math.abs(math.sin(t*2+r.phi))*0.22
                local hShift = ((t*6 + r.phi*20)%360)/360
                r.part.Color = Color3.fromHSV(0.08 + hShift*0.05, 0.85, 1)
            end
        end)
    end)
    table.insert(sunConns,conn)
end
