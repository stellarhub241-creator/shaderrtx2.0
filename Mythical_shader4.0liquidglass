local function setSky(ps)
    pcall(function() skyConn:Disconnect() end)
    pcall(function() for _,c in ipairs(Lighting:GetChildren()) do if c:IsA("Sky") then c:Destroy() end end end); task.wait(0.05)
    local s=Instance.new("Sky",Lighting); s.Name="StellarSky"
    pcall(function() s.SkyboxBk=ps.bk; s.SkyboxDn=ps.dn; s.SkyboxFt=ps.ft; s.SkyboxLf=ps.lf; s.SkyboxRt=ps.rt; s.SkyboxUp=ps.up; s.StarCount=ps.star; s.CelestialBodiesShown=true; if ps.moon then s.MoonAngularSize=ps.moon end; if not St.heavenOn then Lighting.ClockTime=ps.time end; if ps.br then Lighting.Brightness=ps.br end; if ps.amb then Lighting.OutdoorAmbient=ps.amb end end)
    guardSky()
end
