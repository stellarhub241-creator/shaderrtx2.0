local PopupShimGrad=Instance.new("UIGradient",PopupShim)
PopupShimGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(200,215,255)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255))})
PopupShimGrad.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(0.5,0.55),NumberSequenceKeypoint.new(1,1)})
task.spawn(function()
    while task.wait(0.06) do
        if not FPSPopup or not FPSPopup.Parent then break end
        pcall(function() PopupShimGrad.Offset=Vector2.new(math.sin(tick()*1.6)*0.5,0) end)
    end
end)

