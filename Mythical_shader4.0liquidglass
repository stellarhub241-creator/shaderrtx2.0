        MinBtn.Position=UDim2.new(1,-32,0.5,-13)
        task.delay(0.2,function()
            Sidebar.Visible=true ContentArea.Visible=true TitleLabel.Visible=true SidebarLine.Visible=true
        end)
    end
end)

-- ================================================================
-- SECTION 21: TOGGLE HELPER
-- ================================================================
local function createToggle(parent,text,order,defaultVal,callback)
    local F=Instance.new("Frame",parent)
    F.Size=UDim2.new(1,-16,0,30) F.Position=UDim2.new(0,8,0,(order-1)*36+6)
    F.BackgroundTransparency=1
    local L=Instance.new("TextLabel",F)
    L.Size=UDim2.new(0.68,0,1,0) L.BackgroundTransparency=1 L.Text=text
    L.TextColor3=Color3.fromRGB(215,215,225) L.TextSize=11 L.Font=Enum.Font.SourceSans
    L.TextXAlignment=Enum.TextXAlignment.Left
    local TB=Instance.new("TextButton",F)
    TB.Size=UDim2.new(0,46,0,22) TB.Position=UDim2.new(1,-46,0.5,-11)
    TB.BackgroundColor3=defaultVal and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(38,28,52)
    TB.BackgroundTransparency=0.18 TB.Text=defaultVal and "ON" or "OFF"
    TB.TextColor3=Color3.fromRGB(255,255,255) TB.Font=Enum.Font.SourceSansBold TB.TextSize=10
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,11)
    Instance.new("UIStroke",TB).Color=Color3.fromRGB(100,80,140)
    spring(TB)
    local cur=defaultVal
    TB.MouseButton1Click:Connect(function()
        cur=not cur
        pcall(function()
            TweenService:Create(TB,TweenInfo.new(0.22,Enum.EasingStyle.Back),{
                BackgroundColor3=cur and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(38,28,52)
            }):Play()
        end)
        TB.Text=cur and "ON" or "OFF"
        pcall(function() callback(cur) end)
    end)
    return TB
end

local function autoCanvas(scroll,n,h,gap,pad)
    scroll.CanvasSize=UDim2.new(0,0,0,pad+n*(h+gap))
end

