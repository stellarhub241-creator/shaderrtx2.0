    if FPop.Visible then pcall(function() local s=getUS2(); s.Scale=1; tw(s,{Scale=0},TweenInfo.new(0.13,Enum.EasingStyle.Back,Enum.EasingDirection.In)) end); task.delay(0.11,function() FPop.Visible=false end); ShowFPS.Text="📊 Show FPS Monitor"
    else FPop.Visible=true; local s=getUS2(); s.Scale=0; tw(s,{Scale=1},TweenInfo.new(0.26,Enum.EasingStyle.Back,Enum.EasingDirection.Out)); ShowFPS.Text="📊 Hide FPS Monitor" end
end)
bounce(FPop)

-- ================================================================
-- SECTION 40: GRID + RESIZE
-- ================================================================
local cam=workspace.CurrentCamera; local GRID=64
local SIZES={{label="1×1",w=1,h=1},{label="1×2",w=1,h=2},{label="2×2",w=2,h=2},{label="4×4",w=4,h=4},{label="8×8",w=8,h=8},{label="24×24",w=24,h=24}}
local sIdx=5; SzB.Text=SIZES[sIdx].label
local function gPx(sl,ax) local vp=cam.ViewportSize; return math.floor((ax=="x" and vp.X or vp.Y)/GRID*sl) end
local function updVis(w,h)
    local full=w>=110 and h>=72; SB.Visible=full; CA.Visible=full; SBLine.Visible=full; TLbl.Visible=w>=75; SzB.Visible=w>=90
    if full then SB.Size=UDim2.new(0,92,1,-38); SB.Position=UDim2.new(0,0,0,38); CA.Size=UDim2.new(1,-93,1,-38); CA.Position=UDim2.new(0,93,0,38) end
end
local function applySize(pr) local pw=gPx(pr.w,"x"); local ph=gPx(pr.h,"y"); updVis(pw,ph); tw(MF,{Size=UDim2.new(0,math.max(pw,44),0,math.max(ph,30))},TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out)) end
SzB.MouseButton1Click:Connect(function() sIdx=(sIdx%#SIZES)+1; local p=SIZES[sIdx]; SzB.Text=p.label; applySize(p) end)
local RH=Instance.new("TextButton",MF); RH.Size=UDim2.new(0,22,0,22); RH.Position=UDim2.new(1,-22,1,-22); RH.BackgroundTransparency=1; RH.Text="◢"; RH.TextColor3=Color3.fromRGB(200,200,255); RH.TextTransparency=0.4; RH.TextSize=15; RH.Font=Enum.Font.GothamBold; RH.ZIndex=10
local rsz,rSt,rSz0=false,nil,nil
RH.InputBegan:Connect(function(i) if isTM(i.UserInputType) then rsz=true; resizeActive=true; rSt=i.Position; rSz0=Vector2.new(MF.Size.X.Offset,MF.Size.Y.Offset); tw(RH,{TextTransparency=0},TweenInfo.new(0.1)); i.Changed:Connect(function() if i.UserInputState.Name=="End" then rsz=false; resizeActive=false; tw(RH,{TextTransparency=0.4},TweenInfo.new(0.1)) end end) end end)
UserInputService.InputChanged:Connect(function(i) if not rsz then return end; if i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch") then local d=i.Position-rSt; local nW=math.clamp(rSz0.X+d.X,44,800); local nH=math.clamp(rSz0.Y+d.Y,30,600); SzB.Text="Custom"; updVis(nW,nH); tw(MF,{Size=UDim2.new(0,nW,0,nH)},TweenInfo.new(0.04,Enum.EasingStyle.Linear)) end end)
local lastVP=cam.ViewportSize
task.spawn(function() while task.wait(1) do local vp=cam.ViewportSize; if vp~=lastVP then lastVP=vp; if SzB.Text~="Custom" then applySize(SIZES[sIdx]) end end end end)

-- ================================================================
-- SECTION 41: MASTER RENDER LOOP
-- ================================================================
local nxtUpd,fCnt,lastBC=0,0,nil
local dbgT,aiT,distT=0,0,0
local fpsEMA=SA.newEMA(0.12)
local aiCbs={sak=function() if St.sakOn then makeSak() end end}

RunService.RenderStepped:Connect(function(dt)
    fCnt=fCnt+1; nxtUpd=nxtUpd+dt; dbgT=dbgT+dt; aiT=aiT+dt; distT=distT+dt
    local tc=tick()

    if rbActive then
        rbHue=(rbHue+dt*68)%360; local col=Color3.fromHSV(rbHue/360,1,1); local col2=Color3.fromHSV(((rbHue+120)%360)/360,1,1)
        pcall(function() UG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col),ColorSequenceKeypoint.new(0.5,col2),ColorSequenceKeypoint.new(1,col)}); UG.Transparency=NumberSequence.new(0) end)
        if ThAct then ThAct.TextColor3=col end
    end

    if not minimized and THEMES[St.themeIdx].liquid then
        pcall(function() local nx=SA.noise(tc*0.8,0,0)*0.045; local ny=SA.noise(0,tc*0.8,0)*0.045; vpCam.CFrame=workspace.CurrentCamera.CFrame*CFrame.Angles(nx,ny,0); vpCam.FieldOfView=workspace.CurrentCamera.FieldOfView end)
    else
        pcall(function() vpCam.CFrame=workspace.CurrentCamera.CFrame; vpCam.FieldOfView=workspace.CurrentCamera.FieldOfView end)
    end

    pcall(function() Shad.Position=UDim2.new(0,MF.Position.X.Offset-22,0,MF.Position.Y.Offset-22); Shad.Visible=not minimized end)

    if nxtUpd>=0.25 then
        local rawFPS=math.round(fCnt/nxtUpd); local fps=math.round(fpsEMA:upd(rawFPS))
        SAI:push(fps)
        if LiveLbl then
            local m="Day"
            if St.nostOn then m="📼 Nostalgia" elseif St.horrorB then m="💙 Horror Blue" elseif St.horrorG then m="☠️ Horror Green"
            elseif St.dawnOn then m="🌄 Dawn" elseif St.sunsetOn then m="🌅 Sunset" elseif St.rainOn then m="🌧 Rainy"
            elseif St.heavenOn then m="👼 Heavenly" elseif Lighting.ClockTime<6 or Lighting.ClockTime>=19 then m="🌙 Night" end
            LiveLbl.Text=m
        end
        if FPop.Visible then
            FPB.Text=tostring(fps); FPCap.Text="cap:"..(St.fpsCap==165 and "165⚡" or tostring(St.fpsCap))
            local ratio=fps/math.max(St.fpsCap,1)
            if ratio>=0.9 then FPSt.Text="smooth"; FPB.TextColor3=Color3.fromRGB(80,255,140)
            elseif ratio>=0.6 then FPSt.Text="ok"; FPB.TextColor3=Color3.fromRGB(255,200,50)
            else FPSt.Text="low!"; FPB.TextColor3=Color3.fromRGB(255,80,80) end
        end
        if not rbActive then
            local tc2=THEMES[St.themeIdx].pri
            if St.nostOn then tc2=Color3.fromRGB(210,150,230) elseif St.horrorB then tc2=Color3.fromRGB(40,50,200)
            elseif St.horrorG then tc2=Color3.fromRGB(60,180,40) elseif St.dawnOn then tc2=Color3.fromRGB(255,180,200)
            elseif St.sunsetOn then tc2=Color3.fromRGB(255,150,60) elseif St.rainOn then tc2=Color3.fromRGB(100,160,255)
            elseif St.heavenOn then tc2=Color3.fromRGB(255,240,120) end
            if lastBC~=tc2 then lastBC=tc2; tw(FPS_S,{Color=tc2},TweenInfo.new(0.32)); if St.borderStyle=="solid" or St.borderStyle=="gradient" or St.borderStyle=="glow" then applyBorder(St.borderStyle,tc2) end end
        end
        fCnt=0; nxtUpd=0
    end

    if dbgT>=0.8 and activeTab==tDbg then
        dbgT=0
        pcall(function()
            DbgM.Text=SAI:report()
            local ls={}; local n=#SAS._buf; for i=math.max(1,n-10),n do if SAS._buf[i] then ls[#ls+1]=SAS._buf[i] end end
            DbgL.Text="=== SAS Log ===\n"..table.concat(ls,"\n")
        end)
    end

    if aiT>=2.5 then aiT=0; SAI:check(aiCbs); SAI:adapt(St,makeRain,makeSak) end

    if distT>=1.0 then
        distT=0
        pcall(function()
            local cp=workspace.CurrentCamera.CFrame.Position
            SAI:checkDist(cp)
        end)
    end
end)

-- ================================================================
-- SECTION 42: INIT
-- ================================================================
applySize(SIZES[sIdx])
applyTheme(1)
applyBorder("gradient",THEMES[1].pri)
reapply()

-- ================================================================
-- SECTION 43: CLEANUP ON RELOAD
-- ================================================================
local function cleanup()
    pcall(clearRain); pcall(clearSak); pcall(clearWind); pcall(clearMet); pcall(clearSun); pcall(clearNeon)
    if bConn then pcall(function() bConn:Disconnect() end) end
    SAS:reset(); SEB._pool={}
end
game:GetService("Players").LocalPlayer.CharacterRemoving:Connect(function() pcall(cleanup) end)

