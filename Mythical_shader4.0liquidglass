local TitleLabel=Instance.new("TextLabel",TitleBar)
TitleLabel.Size=UDim2.new(0.62,0,1,0); TitleLabel.Position=UDim2.new(0,UI.PAD+4,0,0)
TitleLabel.BackgroundTransparency=1; TitleLabel.Text="✦ MYTHICAL SHADER v6.7"
TitleLabel.TextColor3=UI.C_TEXT; TitleLabel.TextSize=11; TitleLabel.Font=Enum.Font.Code
TitleLabel.TextXAlignment=Enum.TextXAlignment.Left; TitleLabel.ZIndex=6
local tlStroke=Instance.new("UIStroke",TitleLabel); tlStroke.Transparency=0.6; tlStroke.Thickness=1

local MinBtn=Instance.new("TextButton",TitleBar)
MinBtn.Size=UDim2.new(0,26,0,26); MinBtn.Position=UDim2.new(1,-32,0.5,-13)
MinBtn.BackgroundColor3=Color3.fromRGB(28,28,38); MinBtn.BackgroundTransparency=0.25
MinBtn.Text="⭐"; MinBtn.TextColor3=Color3.fromRGB(255,200,50)
MinBtn.Font=Enum.Font.Code; MinBtn.TextSize=14; MinBtn.ZIndex=6
Instance.new("UICorner",MinBtn).CornerRadius=UI.RADIUS_SM
