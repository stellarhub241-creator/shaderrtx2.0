local activeThemeLabel = Instance.new("TextLabel", TabTheme)
activeThemeLabel.Size = UDim2.new(1,-16,0,14) 
activeThemeLabel.Position = UDim2.new(0,8,0,22)
activeThemeLabel.BackgroundTransparency = 1 
activeThemeLabel.Text = "Active: Purple"
activeThemeLabel.TextColor3 = Color3.fromRGB(180,0,255) 
activeThemeLabel.TextSize = 10
activeThemeLabel.Font = Enum.Font.Code 
activeThemeLabel.TextXAlignment = Enum.TextXAlignment.Left

local rainbowActive = false
local function applyTheme(index)
    local theme = COLOR_THEMES[index]
    currentThemeIndex = index
    activeThemeLabel.Text = "Active: "..theme.name
    activeThemeLabel.TextColor3 = theme.primary
    
    UIGradientStroke.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, theme.primary),
        ColorSequenceKeypoint.new(0.5, theme.secondary),
        ColorSequenceKeypoint.new(1, theme.primary)
    })
    
    for _, t in pairs(allTabs) do
        local sg = t:FindFirstChildOfClass("UIGradient")
        if sg then
            sg.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, theme.primary),
                ColorSequenceKeypoint.new(1, theme.secondary)
            })
        end
    end
    
    for _, b in pairs(tabButtons) do
        if b.BackgroundTransparency < 0.35 then
            pcall(function() TweenService:Create(b,TweenInfo.new(0.35,Enum.EasingStyle.Back),{BackgroundColor3=theme.primary}):Play() end)
        end
    end
    
    pcall(function() TweenService:Create(MinBtn,TweenInfo.new(0.3),{TextColor3=theme.secondary}):Play() end)
    BorderColorNow = theme.primary
end

for i, theme in ipairs(COLOR_THEMES) do
    local ThemeBtn = Instance.new("TextButton", TabTheme)
    ThemeBtn.Size = UDim2.new(1,-16,0,26) 
    ThemeBtn.Position = UDim2.new(0,8,0,(i-1)*31+40)
    ThemeBtn.BackgroundColor3 = theme.primary 
    ThemeBtn.BackgroundTransparency = 0.3
    ThemeBtn.Text = theme.name 
    ThemeBtn.TextColor3 = Color3.fromRGB(255,255,255)
    ThemeBtn.Font = Enum.Font.SourceSansBold 
    ThemeBtn.TextSize = 11
    Instance.new("UICorner",ThemeBtn).CornerRadius = UDim.new(0,6)
    applySpringPhysics(ThemeBtn)
    ThemeBtn.MouseButton1Click:Connect(function()
        if theme.name == "Rainbow" then 
            rainbowActive = true
        else 
            rainbowActive = false 
            applyTheme(i) 
        end
    end)
end
autoCanvas(TabTheme, #COLOR_THEMES, 26, 5, 50)

