local function makeTab()
    local s=Instance.new("ScrollingFrame",ContentArea)
    s.Size=UDim2.new(1,0,1,0) s.BackgroundTransparency=1 s.BorderSizePixel=0
    s.ScrollBarThickness=3 s.ScrollBarImageColor3=Color3.fromRGB(180,0,255)
    s.CanvasSize=UDim2.new(0,0,0,600) s.ScrollingDirection=Enum.ScrollingDirection.Y
    s.ElasticBehavior=Enum.ElasticBehavior.Always s.Visible=false s.ClipsDescendants=true
    return s
end

local TabGfx=makeTab() local TabSky=makeTab()
local TabBoost=makeTab() local TabTheme=makeTab()
local TabFPS=makeTab() local TabCinema=makeTab()
local TabParticle=makeTab()
local allTabs={TabGfx,TabSky,TabBoost,TabTheme,TabFPS,TabCinema,TabParticle}

local TAB_DEFS={
    {text="Graphics",  icon="🎨", tab=TabGfx},
    {text="Skybox",    icon="🌌", tab=TabSky},
    {text="Boost",     icon="⚡", tab=TabBoost},
    {text="Theme",     icon="💎", tab=TabTheme},
    {text="FPS Cap",   icon="📊", tab=TabFPS},
    {text="Cinema",    icon="🎬", tab=TabCinema},
    {text="Particle",  icon="✨", tab=TabParticle},
}

-- ================================================================
-- SECTION 22: TAB BUTTONS
-- ================================================================
local tabButtons={} local activeTab=nil
local BTN_H,BTN_GAP=26,30

for i,def in ipairs(TAB_DEFS) do
    local Btn=Instance.new("TextButton",Sidebar)
    Btn.Size=UDim2.new(1,-8,0,BTN_H) Btn.Position=UDim2.new(0,4,0,(i-1)*BTN_GAP+6)
    Btn.BackgroundColor3=Color3.fromRGB(18,14,28) Btn.BackgroundTransparency=0.45
    Btn.Text=def.icon.." "..def.text Btn.TextColor3=Color3.fromRGB(150,150,168)
    Btn.Font=Enum.Font.SourceSansBold Btn.TextSize=10
    Instance.new("UICorner",Btn).CornerRadius=UDim.new(0,7)
    local bs=Instance.new("UIStroke",Btn) bs.Thickness=1 bs.Color=Color3.fromRGB(48,35,72) bs.Transparency=0.5
    spring(Btn)
    table.insert(tabButtons,{btn=Btn,tab=def.tab})
end
Sidebar.CanvasSize=UDim2.new(0,0,0,#TAB_DEFS*BTN_GAP+20)

local function refreshTabButtons()
    local theme=COLOR_THEMES[currentThemeIndex]
    for _,bd in pairs(tabButtons) do
        local s=bd.btn:FindFirstChildOfClass("UIStroke")
        if bd.tab==activeTab then
            if theme.glass then
                tween(bd.btn,{BackgroundColor3=Color3.fromRGB(155,205,238),BackgroundTransparency=0.55,TextColor3=Color3.fromRGB(195,238,255)},SMOOTH)
                if s then tween(s,{Color=Color3.fromRGB(175,222,255),Transparency=0.1},SMOOTH) end
            else
                tween(bd.btn,{BackgroundColor3=theme.primary,BackgroundTransparency=0.08,TextColor3=Color3.fromRGB(255,255,255)},SMOOTH)
                if s then tween(s,{Color=theme.secondary,Transparency=0.2},SMOOTH) end
            end
        else
            tween(bd.btn,{BackgroundColor3=Color3.fromRGB(18,14,28),BackgroundTransparency=0.45,TextColor3=Color3.fromRGB(150,150,168)},SMOOTH)
            if s then tween(s,{Color=Color3.fromRGB(48,35,72),Transparency=0.5},SMOOTH) end
        end
    end
end

local function switchTab(targetTab)
    if activeTab==targetTab then return end
    if activeTab then
        local old=activeTab
        tween(old,{Position=UDim2.new(-0.08,0,0,0)},TweenInfo.new(0.12,Enum.EasingStyle.Quart,Enum.EasingDirection.In))
        task.delay(0.08,function() if old then old.Visible=false old.Position=UDim2.new(0,0,0,0) end end)
    end
    activeTab=targetTab
    refreshTabButtons()
    targetTab.Position=UDim2.new(0.08,0,0,0) targetTab.Visible=true
    tween(targetTab,{Position=UDim2.new(0,0,0,0)},TweenInfo.new(0.22,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
end

for _,bd in pairs(tabButtons) do bd.btn.MouseButton1Click:Connect(function() switchTab(bd.tab) end) end
switchTab(TabGfx)

-- ================================================================
-- SECTION 23: DRAG
-- ================================================================
local dragToggle,dragStart,startPos,isDragging=false,nil,nil,false
local isDraggingMainFrame=false

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
        dragToggle=true dragStart=input.Position startPos=MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState==Enum.UserInputState.End then dragToggle=false isDragging=false isDraggingMainFrame=false end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if not dragToggle then return end
    if input.UserInputType~=Enum.UserInputType.MouseMovement and input.UserInputType~=Enum.UserInputType.Touch then return end
    local delta=input.Position-dragStart
    if not isDragging and (math.abs(delta.X)>5 or math.abs(delta.Y)>5) then isDragging=true isDraggingMainFrame=true end
    if isDragging then
        local vp=workspace.CurrentCamera.ViewportSize
        MainFrame.Position=UDim2.new(0,math.clamp(startPos.X.Offset+delta.X,6,vp.X-MainFrame.Size.X.Offset-6),0,math.clamp(startPos.Y.Offset+delta.Y,6,vp.Y-MainFrame.Size.Y.Offset-6))
    end
end)

-- ================================================================
-- SECTION 24: MINIMIZE (ย่อสุด = ⭐ โลโก้ดาว)
-- ================================================================
local isMinimized=false
local starBtn=nil  -- minimize to star

MinBtn.MouseButton1Click:Connect(function()
    isMinimized=not isMinimized
    if isMinimized then
        -- ซ่อน UI ทั้งหมด
        TitleLabel.Visible=false Sidebar.Visible=false ContentArea.Visible=false
        SidebarLine.Visible=false TitleSep.Visible=false
        -- ย่อเหลือแค่ปุ่มดาว
        tween(MainFrame,{Size=UDim2.new(0,38,0,38),BackgroundTransparency=0.05,BackgroundColor3=Color3.fromRGB(20,16,32)},
            TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.In))
        MinBtn.Size=UDim2.new(1,-4,1,-4) MinBtn.Position=UDim2.new(0,2,0,2)
        MinBtn.Text="⭐" MinBtn.TextSize=22
        -- pulse animation
        task.spawn(function()
            while isMinimized do
                tween(MinBtn,{TextColor3=Color3.fromRGB(255,220,80)},TweenInfo.new(0.6))
                task.wait(0.6)
                tween(MinBtn,{TextColor3=Color3.fromRGB(200,160,40)},TweenInfo.new(0.6))
                task.wait(0.6)
            end
        end)
    else
        -- restore
        tween(MainFrame,{Size=UDim2.new(0,332,0,272),BackgroundTransparency=0.22,BackgroundColor3=Color3.fromRGB(9,7,15)},
            TweenInfo.new(0.35,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
        MinBtn.Size=UDim2.new(0,26,0,26) MinBtn.Position=UDim2.new(1,-32,0.5,-13)
        MinBtn.Text="⭐" MinBtn.TextSize=14 MinBtn.TextColor3=Color3.fromRGB(255,220,80)
        task.delay(0.2,function()
            Sidebar.Visible=true ContentArea.Visible=true TitleLabel.Visible=true
            SidebarLine.Visible=true TitleSep.Visible=true
        end)
    end
end)

-- ================================================================
-- SECTION 25: TOGGLE HELPER
-- ================================================================
local function createToggle(parent,text,order,defaultVal,callback)
    local F=Instance.new("Frame",parent)
    F.Size=UDim2.new(1,-16,0,30) F.Position=UDim2.new(0,8,0,(order-1)*36+6) F.BackgroundTransparency=1
    local L=Instance.new("TextLabel",F)
    L.Size=UDim2.new(0.68,0,1,0) L.BackgroundTransparency=1 L.Text=text
    L.TextColor3=Color3.fromRGB(215,215,228) L.TextSize=11 L.Font=Enum.Font.SourceSans L.TextXAlignment=Enum.TextXAlignment.Left
    local TB=Instance.new("TextButton",F)
    TB.Size=UDim2.new(0,46,0,22) TB.Position=UDim2.new(1,-46,0.5,-11)
    TB.BackgroundColor3=defaultVal and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(36,26,50)
    TB.BackgroundTransparency=0.1 TB.Text=defaultVal and "ON" or "OFF"
    TB.TextColor3=Color3.fromRGB(255,255,255) TB.Font=Enum.Font.SourceSansBold TB.TextSize=10
    Instance.new("UICorner",TB).CornerRadius=UDim.new(0,11)
    Instance.new("UIStroke",TB).Color=Color3.fromRGB(100,80,140)
    spring(TB)
    local cur=defaultVal
    TB.MouseButton1Click:Connect(function()
        cur=not cur
        tween(TB,{BackgroundColor3=cur and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(36,26,50)},SMOOTH_BACK)
        TB.Text=cur and "ON" or "OFF"
        pcall(function() callback(cur) end)
    end)
    return TB
end

local function autoCanvas(scroll,n,h,gap,pad)
    scroll.CanvasSize=UDim2.new(0,0,0,pad+n*(h+gap))
end

-- ================================================================
-- SECTION 26: BALL SLIDER (โปร)
-- ================================================================
local allSliderBalls={}

local function makeBallSlider(parent,yPos,labelText,defRel,changeFn)
    local theme=COLOR_THEMES[currentThemeIndex]

    local container=Instance.new("Frame",parent)
    container.Size=UDim2.new(1,-14,0,46)
    container.Position=UDim2.new(0,7,0,yPos)
    container.BackgroundColor3=Color3.fromRGB(13,10,21)
    container.BackgroundTransparency=0.32
    container.BorderSizePixel=0
    Instance.new("UICorner",container).CornerRadius=UDim.new(0,9)
    local cstroke=Instance.new("UIStroke",container)
    cstroke.Thickness=1 cstroke.Color=Color3.fromRGB(62,48,90) cstroke.Transparency=0.42

    local lbl=Instance.new("TextLabel",container)
    lbl.Size=UDim2.new(0.72,0,0,17) lbl.Position=UDim2.new(0,10,0,3)
    lbl.BackgroundTransparency=1 lbl.Text=labelText
    lbl.TextColor3=Color3.fromRGB(212,214,232) lbl.TextSize=10
    lbl.Font=Enum.Font.SourceSansBold lbl.TextXAlignment=Enum.TextXAlignment.Left

    local valLbl=Instance.new("TextLabel",container)
    valLbl.Size=UDim2.new(0.28,-8,0,17) valLbl.Position=UDim2.new(0.72,0,0,3)
    valLbl.BackgroundTransparency=1 valLbl.Text=math.floor(defRel*100).."%"
    valLbl.TextColor3=theme.secondary valLbl.TextSize=10
    valLbl.Font=Enum.Font.Code valLbl.TextXAlignment=Enum.TextXAlignment.Right

    local track=Instance.new("Frame",container)
    track.Size=UDim2.new(1,-20,0,8) track.Position=UDim2.new(0,10,0,27)
    track.BackgroundColor3=Color3.fromRGB(16,12,28) track.BackgroundTransparency=0.15 track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(0,4)

    for ti=0,8 do
        local tk=Instance.new("Frame",track)
        tk.Size=UDim2.new(0,1,ti%2==0 and 0.65 or 0.42,0)
        tk.Position=UDim2.new(ti/8,0,ti%2==0 and 0.17 or 0.29,0)
        tk.BackgroundColor3=Color3.fromRGB(192,192,205) tk.BackgroundTransparency=ti%2==0 and 0.3 or 0.56 tk.BorderSizePixel=0
    end

    local fill=Instance.new("Frame",track)
    fill.Size=UDim2.new(defRel,0,1,0) fill.BackgroundColor3=Color3.fromRGB(255,255,255) fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(0,4)
    local fillGrad=Instance.new("UIGradient",fill)
    fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(228,228,236)),ColorSequenceKeypoint.new(1,theme.primary)})

    -- shadow ใต้ลูก
    local ballShadow=Instance.new("Frame",track)
    ballShadow.Size=UDim2.new(0,16,0,7) ballShadow.Position=UDim2.new(defRel,-8,1,-3)
    ballShadow.BackgroundColor3=Color3.fromRGB(0,0,0) ballShadow.BackgroundTransparency=0.6
    ballShadow.BorderSizePixel=0 ballShadow.ZIndex=4
    Instance.new("UICorner",ballShadow).CornerRadius=UDim.new(1,0)

    -- ลูกบอล gradient ซ้าย(ขาว)→ขวา(ธีม)
    local ball=Instance.new("TextButton",track)
    ball.Size=UDim2.new(0,20,0,20) ball.Position=UDim2.new(defRel,-10,0.5,-10)
    ball.BackgroundColor3=Color3.fromRGB(245,245,252) ball.Text="" ball.BorderSizePixel=0 ball.ZIndex=6
    Instance.new("UICorner",ball).CornerRadius=UDim.new(1,0)
    local ballGrad=Instance.new("UIGradient",ball)
    ballGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(248,248,255)),ColorSequenceKeypoint.new(1,theme.ball)})
    ballGrad.Rotation=0
    local ballStroke=Instance.new("UIStroke",ball)
    ballStroke.Color=lerpC(theme.primary,Color3.fromRGB(58,42,98),0.45) ballStroke.Thickness=2.0
    spring(ball) addBounceOnHold(ball)

    local sliderRef={fill=fill,fillGrad=fillGrad,ball=ball,ballGrad=ballGrad,ballStroke=ballStroke,valLbl=valLbl,ballShadow=ballShadow}
    table.insert(allSliderBalls,sliderRef)

    local dragging=false local lastRel=defRel

    local function startDrag(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            if isDraggingMainFrame then return end
            dragging=true
        end
    end
    ball.InputBegan:Connect(startDrag)
    track.InputBegan:Connect(startDrag)

    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=false
        end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if isDraggingMainFrame then dragging=false return end
        if i.UserInputType~=Enum.UserInputType.MouseMovement and i.UserInputType~=Enum.UserInputType.Touch then return end
        local rel=math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        if math.abs(rel-lastRel)<0.002 then return end
        pcall(function() ball.Rotation=ball.Rotation+(rel-lastRel)*360*2 end)
        lastRel=rel
        fill.Size=UDim2.new(rel,0,1,0)
        ball.Position=UDim2.new(rel,-10,0.5,-10)
        ballShadow.Position=UDim2.new(rel,-8,1,-3)
        valLbl.Text=math.floor(rel*100).."%"
        local ct=COLOR_THEMES[currentThemeIndex]
        fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(228,228,236)),ColorSequenceKeypoint.new(1,lerpC(Color3.fromRGB(170,170,185),ct.primary,rel))})
        pcall(function() changeFn(rel) end)
    end)

    return container,fill,ball,valLbl
end

local function refreshAllSliders()
    local theme=COLOR_THEMES[currentThemeIndex]
    for _,s in ipairs(allSliderBalls) do
        pcall(function()
            s.fillGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(228,228,236)),ColorSequenceKeypoint.new(1,theme.primary)})
            s.ballGrad.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(248,248,255)),ColorSequenceKeypoint.new(1,theme.ball)})
            s.ballStroke.Color=lerpC(theme.primary,Color3.fromRGB(58,42,98),0.45)
            s.valLbl.TextColor3=theme.secondary
        end)
    end
end

