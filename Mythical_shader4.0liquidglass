    pcall(function() local s=getUS(); s.Scale=1; tw(s,{Scale=0},TweenInfo.new(0.13,Enum.EasingStyle.Back,Enum.EasingDirection.In)) end)
    task.delay(0.11,function() FPSPopup.Visible=false end); ShowFPSPopupBtn.Text="📊 Show FPS Monitor"
end)
ShowFPSPopupBtn.MouseButton1Click:Connect(function()
    if FPSPopup.Visible then
        pcall(function() local s=getUS(); s.Scale=1; tw(s,{Scale=0},TweenInfo.new(0.13,Enum.EasingStyle.Back,Enum.EasingDirection.In)) end)
        task.delay(0.11,function() FPSPopup.Visible=false end); ShowFPSPopupBtn.Text="📊 Show FPS Monitor"
    else
        FPSPopup.Visible=true; local s=getUS(); s.Scale=0
        tw(s,{Scale=1},TweenInfo.new(0.26,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
        ShowFPSPopupBtn.Text="📊 Hide FPS Monitor"
    end
end)
addBounceOnHold(FPSPopup)

-- ================================================================
-- SECTION 40: GRID SIZE + RESIZE
-- ================================================================
local camera=workspace.CurrentCamera; local GRID=64
local SIZE_PRESETS={
    {label="1×1",w=1,h=1},{label="1×2",w=1,h=2},{label="2×2",w=2,h=2},
    {label="4×4",w=4,h=4},{label="8×8",w=8,h=8},{label="24×24",w=24,h=24}
}
local currentSizeIndex=5; SizeBtn.Text=SIZE_PRESETS[currentSizeIndex].label
local function gridPx(slots,axis) local vp=camera.ViewportSize; return math.floor((axis=="x" and vp.X or vp.Y)/GRID*slots) end
local function updateUIVisibility(w,h)
    local showFull=w>=110 and h>=72
    Sidebar.Visible=showFull; ContentArea.Visible=showFull; SidebarLine.Visible=showFull
    TitleLabel.Visible=w>=75; SizeBtn.Visible=w>=90
    if showFull then
        Sidebar.Size=UDim2.new(0,92,1,-38); Sidebar.Position=UDim2.new(0,0,0,38)
        ContentArea.Size=UDim2.new(1,-93,1,-38); ContentArea.Position=UDim2.new(0,93,0,38)
    end
end
local function applyGridSize(preset)
    local pw=gridPx(preset.w,"x"); local ph=gridPx(preset.h,"y")
    updateUIVisibility(pw,ph)
    tw(MainFrame,{Size=UDim2.new(0,math.max(pw,44),0,math.max(ph,30))},TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out))
end
SizeBtn.MouseButton1Click:Connect(function()
    currentSizeIndex=(currentSizeIndex%#SIZE_PRESETS)+1
    local p=SIZE_PRESETS[currentSizeIndex]; SizeBtn.Text=p.label; applyGridSize(p)
end)
local ResizeHandle=Instance.new("TextButton",MainFrame)
ResizeHandle.Size=UDim2.new(0,22,0,22); ResizeHandle.Position=UDim2.new(1,-22,1,-22)
ResizeHandle.BackgroundTransparency=1; ResizeHandle.Text="◢"; ResizeHandle.TextColor3=Color3.fromRGB(200,200,255)
ResizeHandle.TextTransparency=0.4; ResizeHandle.TextSize=15; ResizeHandle.Font=Enum.Font.GothamBold; ResizeHandle.ZIndex=10
local isResizing,resizeStart,resizeSize0=false,nil,nil
ResizeHandle.InputBegan:Connect(function(i)
    if isTouchOrMouse(i.UserInputType) then
        isResizing=true; isAnyResizeActive=true; resizeStart=i.Position
        resizeSize0=Vector2.new(MainFrame.Size.X.Offset,MainFrame.Size.Y.Offset)
        tw(ResizeHandle,{TextTransparency=0},TweenInfo.new(0.1))
        i.Changed:Connect(function()
            if i.UserInputState.Name=="End" then
                isResizing=false; isAnyResizeActive=false
                tw(ResizeHandle,{TextTransparency=0.4},TweenInfo.new(0.1))
            end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if not isResizing then return end
    if i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch") then
        local delta=i.Position-resizeStart
        local nW=math.clamp(resizeSize0.X+delta.X,44,800); local nH=math.clamp(resizeSize0.Y+delta.Y,30,600)
        SizeBtn.Text="Custom"; updateUIVisibility(nW,nH)
        tw(MainFrame,{Size=UDim2.new(0,nW,0,nH)},TweenInfo.new(0.04,Enum.EasingStyle.Linear))
    end
end)
local lastVP=camera.ViewportSize
task.spawn(function()
    while task.wait(1) do
        local vp=camera.ViewportSize
        if vp~=lastVP then lastVP=vp; if SizeBtn.Text~="Custom" then applyGridSize(SIZE_PRESETS[currentSizeIndex]) end end
    end
end)

-- ================================================================
-- SECTION 41: MASTER RENDER LOOP (StellarAI distance check ทุก 1s)
-- ================================================================
local nextUpdate,frameCount,lastBorderColor=0,0,nil
local debugTimer=0; local aiTimer=0; local distTimer=0
local fpsEMA=StellarA.newEMA(0.12)
local aiCallbacks={sakura_folder=function() if State.sakuraEnabled then createSakura() end end}

-- [NEW] distance refs สำหรับ StellarAI ตรวจระยะ
local distanceRefs={
    sun=function()
        if sunFolder and sunFolder.Parent then
            local c=sunFolder:FindFirstChild("Part")
            for _,v in ipairs(sunFolder:GetChildren()) do
                if v:IsA("Part") and v.Size.X>=99 and v.Size.X<=101 then return v.Position end
            end
        end
        error("no sun")
    end,
    meteor=function()
        if meteorFolder and meteorFolder.Parent and #meteorFolder:GetChildren()>0 then
            local first=meteorFolder:GetChildren()[1]
            if first and first:IsA("BasePart") then return first.Position end
        end
        error("no meteor")
    end,
    sakura=function()
        if sakuraFolder and sakuraFolder.Parent then return workspace.CurrentCamera.CFrame.Position end
        error("no sakura")
    end,
}

RunService.RenderStepped:Connect(function(dt)
    frameCount=frameCount+1; nextUpdate=nextUpdate+dt; debugTimer=debugTimer+dt; aiTimer=aiTimer+dt; distTimer=distTimer+dt
    local tC=tick()

    if rainbowActive then
        rainbowHue=(rainbowHue+dt*68)%360
        local col=Color3.fromHSV(rainbowHue/360,1,1); local col2=Color3.fromHSV(((rainbowHue+120)%360)/360,1,1)
        pcall(function()
            UIGradientStroke.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,col),ColorSequenceKeypoint.new(0.5,col2),ColorSequenceKeypoint.new(1,col)})
            UIGradientStroke.Transparency=NumberSequence.new(0)
        end)
        if activeThemeLabel then activeThemeLabel.TextColor3=col end
    end

    if not isMinimized and COLOR_THEMES[State.currentThemeIndex].liquid then
        pcall(function()
            local nx=StellarA.smoothNoise(tC*0.8,0,0)*0.045; local ny=StellarA.smoothNoise(0,tC*0.8,0)*0.045
            vpCam.CFrame=workspace.CurrentCamera.CFrame*CFrame.Angles(nx,ny,0)
            vpCam.FieldOfView=workspace.CurrentCamera.FieldOfView
        end)
    else
        pcall(function() vpCam.CFrame=workspace.CurrentCamera.CFrame; vpCam.FieldOfView=workspace.CurrentCamera.FieldOfView end)
    end

    pcall(function() Shadow.Position=UDim2.new(0,MainFrame.Position.X.Offset-22,0,MainFrame.Position.Y.Offset-22); Shadow.Visible=not isMinimized end)

    if nextUpdate>=0.25 then
        local rawFPS=math.round(frameCount/nextUpdate); local fps=math.round(fpsEMA:update(rawFPS))
        StellarAI:pushFPS(fps)

        if LiveTimeLabel then
            local m="Day"
            if State.nostalgiaEnabled then m="📼 Nostalgia 2016"
            elseif State.horrorBlue then m="💙 Horror Blue"
            elseif State.horrorFogEnabled then m="☠️ Horror Green"
            elseif State.dawnEnabled then m="🌄 Dawn"
            elseif State.sunsetEnabled then m="🌅 Sunset"
            elseif State.rainEnabled then m="🌧 Rainy"
            elseif State.heavenlyEnabled then m="👼 Heavenly"
            elseif Lighting.ClockTime<6 or Lighting.ClockTime>=19 then m="🌙 Night" end
            LiveTimeLabel.Text=m
        end

        if FPSPopup.Visible then
            PopupFPSBig.Text=tostring(fps)
            PopupCapLabel.Text="cap:"..(State.targetFpsCap==165 and "165⚡" or tostring(State.targetFpsCap))
            local ratio=fps/math.max(State.targetFpsCap,1)
            if ratio>=0.9 then PopupStatusLabel.Text="smooth"; PopupFPSBig.TextColor3=Color3.fromRGB(80,255,140)
            elseif ratio>=0.6 then PopupStatusLabel.Text="ok"; PopupFPSBig.TextColor3=Color3.fromRGB(255,200,50)
            else PopupStatusLabel.Text="low!"; PopupFPSBig.TextColor3=Color3.fromRGB(255,80,80) end
        end

        if not rainbowActive then
            local tc=COLOR_THEMES[State.currentThemeIndex].primary
            if State.nostalgiaEnabled then tc=Color3.fromRGB(210,150,230)
            elseif State.horrorBlue then tc=Color3.fromRGB(40,50,200)
            elseif State.horrorFogEnabled then tc=Color3.fromRGB(60,180,40)
            elseif State.dawnEnabled then tc=Color3.fromRGB(255,180,200)
            elseif State.sunsetEnabled then tc=Color3.fromRGB(255,150,60)
            elseif State.rainEnabled then tc=Color3.fromRGB(100,160,255)
            elseif State.heavenlyEnabled then tc=Color3.fromRGB(255,240,120) end
            if lastBorderColor~=tc then
                lastBorderColor=tc
                tw(FPSPopupStroke,{Color=tc},TweenInfo.new(0.32))
                if State.borderStyle=="solid" or State.borderStyle=="gradient" or State.borderStyle=="glow" then
                    applyBorderStyle(State.borderStyle,tc)
                end
            end
        end
        frameCount=0; nextUpdate=0
    end

    if debugTimer>=0.8 and activeTab==TabDebug then
        debugTimer=0
        pcall(function()
            DbgMain.Text=StellarAI:getReport()
            local logLines={}; local n=#SAS._log_buf
            for i=math.max(1,n-10),n do if SAS._log_buf[i] then table.insert(logLines,SAS._log_buf[i]) end end
            DbgLog.Text="=== SAS Log ===\n"..table.concat(logLines,"\n")
        end)
    end

    if aiTimer>=2.5 then
        aiTimer=0
        StellarAI:check(aiCallbacks)
        StellarAI:adapt(State,createRainParticles,createSakura)
    end

    -- [NEW] Distance-based quality check ทุก 1 วินาที
    if distTimer>=1.0 then
        distTimer=0
        StellarAI:checkDistanceQuality(distanceRefs)
    end
end)

-- ================================================================
-- SECTION 42: INIT
-- ================================================================
applyGridSize(SIZE_PRESETS[currentSizeIndex])
applyTheme(1)
applyBorderStyle("gradient",COLOR_THEMES[1].primary)
reapplyActiveMode()

print("✅ MYTHICAL SHADER v6.7 PRO EDITION [TRINITY+B ENGINE]")
print("   SAS: token budget, fixed double-count bug")
print("   StellarA: CPU math/trajectory engine")
print("   StellarEngineB: GPU-like batch particle compute (sakura/rain)")
print("   StellarFlu: fluid graphics/color engine")
print("   StellarAI: FPS adapt + distance-based quality + self-heal")
print("   Meteor: v6.6 base, fix color, upgraded (3-layer tail+aura+explosion glow)")
print("   Sun: v6.6 base 60-ray fibonacci sphere, fixed distance+brightness")
print("   Sakura: ตกจริง Part+Neon+Mesh")
print("   UI: smooth tab transition, fixed border, fixed slider input lock")
