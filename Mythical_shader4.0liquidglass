    if fpResizing and (i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch")) then
        local d=i.Position-fpResStart
        FPSPopup.Size=UDim2.new(0,math.clamp(fpResSize.X+d.X,80,400),0,math.clamp(fpResSize.Y+d.Y,50,300))
    end
end)
