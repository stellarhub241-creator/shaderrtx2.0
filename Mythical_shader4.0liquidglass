local function applySpringPhysics(button)
    pcall(function()
        local uiScale = button:FindFirstChildOfClass("UIScale")
        if not uiScale then
            uiScale       = Instance.new("UIScale", button)
            uiScale.Scale = 1.0
        end
        button.MouseEnter:Connect(function()
            pcall(function()
                TweenService:Create(uiScale, TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Scale=1.06}):Play()
                TweenService:Create(button, TweenInfo.new(0.2,Enum.EasingStyle.Quad), {BackgroundTransparency=0.15}):Play()
            end)
        end)
        button.MouseLeave:Connect(function()
            pcall(function()
                TweenService:Create(uiScale, TweenInfo.new(0.25,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {Scale=1.0}):Play()
                TweenService:Create(button, TweenInfo.new(0.2,Enum.EasingStyle.Quad), {BackgroundTransparency=0.4}):Play()
            end)
        end)
        button.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                pcall(function() TweenService:Create(uiScale, TweenInfo.new(0.1,Enum.EasingStyle.Quad), {Scale=0.94}):Play() end)
            end
        end)
        button.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                pcall(function() TweenService:Create(uiScale, TweenInfo.new(0.2,Enum.EasingStyle.Back), {Scale=1.0}):Play() end)
            end
        end)
    end)
end

local tabButtons = {}
local activeTab  = nil

local function switchTab(tabFrame, btn)
    if activeTab == tabFrame then return end
    activeTab = tabFrame
    for _, t in pairs(allTabs) do
        if t ~= tabFrame then t.Visible = false end
    end
    for _, b in pairs(tabButtons) do
        b.BackgroundColor3       = Color3.fromRGB(20,16,30)
        b.BackgroundTransparency = 0.4
        b.TextColor3             = Color3.fromRGB(180,180,180)
    end
    tabFrame.Position = UDim2.new(0,25,0,0)
    tabFrame.Visible  = true
    pcall(function()
        TweenService:Create(tabFrame, TweenInfo.new(0.35,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Position=UDim2.new(0,0,0,0)}):Play()
    end)
    btn.BackgroundColor3       = COLOR_THEMES[currentThemeIndex].primary
    btn.BackgroundTransparency = 0.2
    btn.TextColor3             = Color3.fromRGB(255,255,255)
end

local function addTabButton(text, order, targetTab)
    local Btn = Instance.new("TextButton", Sidebar)
    Btn.Size                   = UDim2.new(1,-8,0,22)
    Btn.Position               = UDim2.new(0,4,0,(order-1)*27+6)
    Btn.BackgroundColor3       = Color3.fromRGB(20,16,30)
    Btn.BackgroundTransparency = 0.4
    Btn.Text                   = text
    Btn.TextColor3             = Color3.fromRGB(180,180,180)
    Btn.Font                   = Enum.Font.SourceSansBold
    Btn.TextSize               = 10
    Instance.new("UICorner",Btn).CornerRadius = UDim.new(0,6)
    applySpringPhysics(Btn)
    Btn.MouseButton1Click:Connect(function() switchTab(targetTab,Btn) end)
    table.insert(tabButtons, Btn)
    return Btn
end

local b1 = addTabButton("Graphics", 1, TabGfx)
local b2 = addTabButton("Skybox",   2, TabSky)
local b3 = addTabButton("Boost",    3, TabOptimize)
local b4 = addTabButton("Theme",    4, TabTheme)
local b5 = addTabButton("FPS Cap",  5, TabFPS)
local b6 = addTabButton("Cinema",   6, TabCinema)
switchTab(TabGfx, b1)

-- ==================== DRAG ====================
local dragToggle, dragStart, startPos
local isDragging      = false
local longPressThread = nil

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragToggle = true
        dragStart  = input.Position
        startPos   = MainFrame.Position
        if longPressThread then
            pcall(function() task.cancel(longPressThread) end)
            longPressThread = nil
        end
        longPressThread = task.delay(0.4, function()
            if not isDragging then
                pcall(function()
                    local ox = MainFrame.Size.X.Offset
                    local oy = MainFrame.Size.Y.Offset
                    TweenService:Create(MainFrame, TweenInfo.new(0.15,Enum.EasingStyle.Back,Enum.EasingDirection.In), {Size=UDim2.new(0,ox*0.92,0,oy*0.92)}):Play()
                    task.wait(0.15)
                    TweenService:Create(MainFrame, TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out), {Size=UDim2.new(0,ox,0,oy)}):Play()
                end)
            end
            longPressThread = nil
        end)
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragToggle = false
                isDragging = false
                if longPressThread then
                    pcall(function() task.cancel(longPressThread) end)
                    longPressThread = nil
                end
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggle then
        local delta = input.Position - dragStart
        if not isDragging and (math.abs(delta.X) > 3 or math.abs(delta.Y) > 3) then
            isDragging = true
            if longPressThread then
                pcall(function() task.cancel(longPressThread) end)
                longPressThread = nil
            end
        end
        if isDragging then
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+delta.X, startPos.Y.Scale, startPos.Y.Offset+delta.Y)
        end
    end
end)

-- ==================== MINIMIZE ====================
local isMinimized = false
MinBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    if isMinimized then
        TitleLabel.Visible  = false
        Sidebar.Visible     = false
        ContentArea.Visible = false
        MinBtn.Text         = "+"
        MainFrame:TweenSize(UDim2.new(0,80,0,28), Enum.EasingDirection.Out, Enum.EasingStyle.Back, 0.4, true)
        MinBtn.Position = UDim2.new(1,-26,0.5,-10)
    else
        MinBtn.Text = "-"
        MainFrame:TweenSize(UDim2.new(0,320,0,260), Enum.EasingDirection.Out, Enum.EasingStyle.Back, 0.5, true)
        MinBtn.Position = UDim2.new(1,-32,0.5,-12)
        task.delay(0.25, function()
            Sidebar.Visible     = true
            ContentArea.Visible = true
            TitleLabel.Visible  = true
        end)
    end
end)

local function createToggle(parent, text, order, defaultVal, callback)
    local Frame = Instance.new("Frame", parent)
    Frame.Size                   = UDim2.new(1,-16,0,30)
    Frame.Position               = UDim2.new(0,8,0,(order-1)*36+6)
    Frame.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", Frame)
    Label.Size                   = UDim2.new(0.65,0,1,0)
    Label.BackgroundTransparency = 1
    Label.Text                   = text
    Label.TextColor3             = Color3.fromRGB(220,220,220)
    Label.TextSize               = 11
    Label.Font                   = Enum.Font.SourceSans
    Label.TextXAlignment         = Enum.TextXAlignment.Left
    
    local ToggleBtn = Instance.new("TextButton", Frame)
    ToggleBtn.Size                   = UDim2.new(0,44,0,20)
    ToggleBtn.Position               = UDim2.new(1,-44,0.5,-10)
    ToggleBtn.BackgroundColor3       = defaultVal and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(40,30,55)
    ToggleBtn.BackgroundTransparency = 0.2
    ToggleBtn.Text                   = defaultVal and "ON" or "OFF"
    ToggleBtn.TextColor3             = Color3.fromRGB(255,255,255)
    ToggleBtn.Font                   = Enum.Font.SourceSansBold
    ToggleBtn.TextSize               = 10
    Instance.new("UICorner",ToggleBtn).CornerRadius = UDim.new(0,10)
    applySpringPhysics(ToggleBtn)
    
    local current = defaultVal
    ToggleBtn.MouseButton1Click:Connect(function()
        current = not current
        pcall(function()
            TweenService:Create(ToggleBtn, TweenInfo.new(0.25,Enum.EasingStyle.Back), {
                BackgroundColor3 = current and COLOR_THEMES[currentThemeIndex].primary or Color3.fromRGB(40,30,55)
            }):Play()
        end)
        ToggleBtn.Text = current and "ON" or "OFF"
        callback(current)
    end)
    return ToggleBtn
end

local function autoCanvas(scroll, itemCount, itemH, spacing, padding)
    scroll.CanvasSize = UDim2.new(0,0,0, padding + itemCount*(itemH+spacing))
end

