tsepGrad.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(0.3,0.35),NumberSequenceKeypoint.new(0.7,0.35),NumberSequenceKeypoint.new(1,1)})

