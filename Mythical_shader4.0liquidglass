-- =============================================================================
-- [5] SHADER MATHEMATICS & INTERPOLATION FUNCTIONS
-- =============================================================================
local function lerpN(a, b, t)
    return a + (b - a) * t
end

local function lerpC(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local function lerpProfile(a, b, t)
    local mixed = {
        brightness = lerpN(a.brightness, b.brightness, t),
        exposure = lerpN(a.exposure, b.exposure, t),
        shadow = lerpN(a.shadow, b.shadow, t),
        ambient = lerpC(a.ambient, b.ambient, t),
        atmoColor = lerpC(a.atmoColor, b.atmoColor, t),
        atmoDecay = lerpC(a.atmoDecay, b.atmoDecay, t),
        atmoGlare = lerpN(a.atmoGlare, b.atmoGlare, t),
        atmoHaze = lerpN(a.atmoHaze, b.atmoHaze, t),
        atmoDensity = lerpN(a.atmoDensity, b.atmoDensity, t),
        contrast = lerpN(a.contrast, b.contrast, t),
        saturation = lerpN(a.saturation, b.saturation, t),
        tint = lerpC(a.tint, b.tint, t),
        bloom = lerpN(a.bloom, b.bloom, t),
        bloomSize = lerpN(a.bloomSize, b.bloomSize, t),
        bloomThreshold = lerpN(a.bloomThreshold, b.bloomThreshold, t),
        dofFar = lerpN(a.dofFar, b.dofFar, t),
        sunRays = lerpN(a.sunRays, b.sunRays, t)
    }
    return mixed
end

-- Apply Preset Changes directly to global Environment Lighting
local function applyProfile(p)
    if isFpsBoostOn or horrorFogEnabled or rainEnabled then
        return 
    end
    
    Lighting.Brightness = p.brightness
    Lighting.ExposureCompensation = p.exposure
    Lighting.ShadowSoftness = p.shadow
    Lighting.OutdoorAmbient = p.ambient
    
    Atmosphere.Color = p.atmoColor
    Atmosphere.Decay = p.atmoDecay
    Atmosphere.Glare = p.atmoGlare
    Atmosphere.Haze = p.atmoHaze
    Atmosphere.Density = p.atmoDensity
    
    ColorCorrection.Contrast = p.contrast
    ColorCorrection.Saturation = p.saturation
    ColorCorrection.TintColor = p.tint
    
    Bloom.Intensity = p.bloom
    Bloom.Size = p.bloomSize
    Bloom.Threshold = p.bloomThreshold
    
    DOF.FarIntensity = p.dofFar
    SunRays.Intensity = p.sunRays
end

