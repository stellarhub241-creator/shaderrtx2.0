createToggle(TabGfx,"Depth of Field",1,dofEnabled,function(val)
    dofEnabled=val
    local d=Lighting:FindFirstChild("StellarDOF") if d then d.Enabled=val end
end)
createToggle(TabGfx,"4K PBR Reflectance",2,pbrEnabled,function(val)
    pbrEnabled=val
    if val then task.spawn(runPBRScan)
    else for _,v in pairs(workspace:GetDescendants()) do pcall(function() if v:IsA("BasePart") or v:IsA("MeshPart") then v.Reflectance=0 end end) end end
end)
createToggle(TabGfx,"Anti-Blue Gloss",3,antiBlueGloss,function(val)
    antiBlueGloss=val if pbrEnabled then task.spawn(runPBRScan) end
end)
createToggle(TabGfx,"Horror Fog",4,false,function(val)
    horrorFogEnabled=val
    if val then
        if rainEnabled or heavenlyEnabled or cinematicEnabled then return end
        ModeText="Status: Horror" BorderColorNow=Color3.fromRGB(180,0,40)
        clearRainParticles()
        pcall(function()
            Lighting.Brightness=0.4 Lighting.ExposureCompensation=-0.3 Lighting.ShadowSoftness=0.8
            Lighting.OutdoorAmbient=Color3.fromRGB(12,18,8)
            Atmosphere.Color=Color3.fromRGB(30,45,20) Atmosphere.Decay=Color3.fromRGB(8,14,5)
            Atmosphere.Glare=0 Atmosphere.Haze=2.2 Atmosphere.Density=0.38
            ColorCorrection.Contrast=0.5 ColorCorrection.Saturation=-0.5
            ColorCorrection.TintColor=Color3.fromRGB(140,180,120)
            Bloom.Intensity=0.1 Bloom.Size=8 Bloom.Threshold=0.95
            DOF.FarIntensity=0.6 SunRays.Intensity=0
            Lighting.FogStart=8 Lighting.FogEnd=120
            Lighting.FogColor=Color3.fromRGB(18,28,12) Lighting.Ambient=Color3.fromRGB(10,16,6)
        end)
    else resetFogLighting() end
end)
createToggle(TabGfx,"Rain Mode",5,false,function(val)
    rainEnabled=val
    if val then
        if horrorFogEnabled or heavenlyEnabled or cinematicEnabled then rainEnabled=false return end
        ModeText="Status: Rainy" BorderColorNow=Color3.fromRGB(100,160,255)
        pcall(function()
            local p=PROFILES.RAIN
            applyLighting(p)
            Lighting.FogStart=20 Lighting.FogEnd=200 Lighting.FogColor=Color3.fromRGB(110,122,142)
        end)
        createRainParticles()
    else clearRainParticles() resetFogLighting() end
end)
createToggle(TabGfx,"Heavenly Mode",6,false,function(val)
    heavenlyEnabled=val
    if val then
        if horrorFogEnabled or rainEnabled or cinematicEnabled then heavenlyEnabled=false return end
        ModeText="Status: Heavenly" BorderColorNow=Color3.fromRGB(255,230,150)
        clearRainParticles()
        pcall(function()
            applyLighting(PROFILES.HEAVENLY)
            Lighting.FogStart=300 Lighting.FogEnd=1200
            Lighting.FogColor=Color3.fromRGB(220,230,255) Lighting.ClockTime=12
        end)
    else resetFogLighting() end
end)

