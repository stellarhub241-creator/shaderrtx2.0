    HEAV ={br=2.5,exp=0.22,sh=0.1, amb=Color3.fromRGB(180,190,240),aC=Color3.fromRGB(210,228,255),aD=Color3.fromRGB(170,195,248),aG=2.2,aH=0.6,aDn=0.08,ct=0.1,sat=0.5,  tnt=Color3.fromRGB(255,248,228),bl=1.2,bs=28,bt=0.45,df=0.05,sR=0.6},
    HORG ={br=0.25,exp=-0.5,sh=0.98,amb=Color3.fromRGB(4,16,2),    aC=Color3.fromRGB(8,35,5),    aD=Color3.fromRGB(2,10,1),  aG=0.0,aH=6.5,aDn=0.78,ct=0.80,sat=-0.35,tnt=Color3.fromRGB(60,140,45), bl=0.65,bs=32,bt=0.48,df=0.88,sR=0.0},
    HORB ={br=0.18,exp=-0.65,sh=0.99,amb=Color3.fromRGB(1,2,28),   aC=Color3.fromRGB(3,4,40),    aD=Color3.fromRGB(1,1,22),  aG=0.0,aH=7.0,aDn=0.85,ct=0.88,sat=-0.92,tnt=Color3.fromRGB(30,40,200), bl=0.40,bs=45,bt=0.75,df=0.95,sR=0.0},
    NOST ={br=1.45,exp=0.18,sh=0.38,amb=Color3.fromRGB(120,80,145),aC=Color3.fromRGB(230,175,215),aD=Color3.fromRGB(175,115,195),aG=1.2,aH=2.8,aDn=0.38,ct=0.18,sat=0.22,tnt=Color3.fromRGB(255,220,235),bl=0.65,bs=20,bt=0.68,df=0.22,sR=0.28},
}
local function applyP(p)
    pcall(function()
        Lighting.Brightness=p.br; Lighting.ExposureCompensation=p.exp; Lighting.ShadowSoftness=p.sh; Lighting.OutdoorAmbient=p.amb
        Atmo.Color=p.aC; Atmo.Decay=p.aD; Atmo.Glare=p.aG; Atmo.Haze=p.aH; Atmo.Density=p.aDn
        CC.Contrast=p.ct; CC.Saturation=p.sat; CC.TintColor=p.tnt
        Bloom.Intensity=p.bl; Bloom.Size=p.bs; Bloom.Threshold=p.bt
        DOF.FarIntensity=p.df; SR.Intensity=p.sR
    end)
end
local function cinBlend()
    if not St.cinOn then return end
    pcall(function() CC.Contrast=math.max(CC.Contrast,0.6); CC.Saturation=CC.Saturation-0.1; DOF.FarIntensity=math.max(DOF.FarIntensity,0.55); Bloom.Threshold=math.min(Bloom.Threshold+0.08,0.99); Lighting.ShadowSoftness=math.max(Lighting.ShadowSoftness,0.65) end)
end
local function resetFog()
    pcall(function()
        if not St.nostOn then
            Lighting.FogStart=St.origFogS; Lighting.FogEnd=St.origFogE; Lighting.FogColor=St.origFogC
            Lighting.Ambient=St.origAmb; Lighting.Brightness=St.origBr; Lighting.ExposureCompensation=St.origExp
            Lighting.ShadowSoftness=St.origShad; Lighting.OutdoorAmbient=St.origOut
        end
    end)
end
local function reapply()
    if St.nostOn then applyP(P.NOST); pcall(function() Lighting.ClockTime=17.2; Lighting.FogStart=180; Lighting.FogEnd=2200; Lighting.FogColor=Color3.fromRGB(210,160,225); Lighting.Ambient=Color3.fromRGB(120,80,145) end)
    elseif St.horrorB then applyP(P.HORB); pcall(function() Lighting.FogStart=1; Lighting.FogEnd=38; Lighting.FogColor=Color3.fromRGB(1,2,25); Lighting.Ambient=Color3.fromRGB(1,2,25) end)
    elseif St.horrorG then applyP(P.HORG); pcall(function() Lighting.FogStart=2; Lighting.FogEnd=50; Lighting.FogColor=Color3.fromRGB(4,18,2); Lighting.Ambient=Color3.fromRGB(4,18,2) end)
    elseif St.dawnOn then applyP(P.DAWN); pcall(function() Lighting.ClockTime=5.5 end)
    elseif St.sunsetOn then applyP(P.GOLD); pcall(function() Lighting.ClockTime=19 end)
    elseif St.rainOn then applyP(P.RAIN); pcall(function() Lighting.FogStart=20; Lighting.FogEnd=200; Lighting.FogColor=Color3.fromRGB(110,122,142) end)
    elseif St.heavenOn then applyP(P.HEAV); pcall(function() Lighting.FogStart=500; Lighting.FogEnd=2000; Lighting.FogColor=Color3.fromRGB(225,235,255); Lighting.ClockTime=12 end)
    else resetFog() end
    cinBlend()
end

-- ================================================================
-- SECTION 12: RAIN
-- ================================================================
local rainFolder,rainConns,rainParts,rainRipples=nil,{},{},{}
local function clearRain()
    for _,c in pairs(rainConns) do pcall(function() c:Disconnect() end) end
    rainConns={}
    if rainFolder and rainFolder.Parent then pcall(function() rainFolder:Destroy() end) end
    rainFolder=nil; rainParts={}; rainRipples={}; SAS:release("rain"); SEB:clear("rain")
end
local function makeRain()
    clearRain()
    local ok,q=SAS:request("rain"); if not ok then return end
    rainFolder=Instance.new("Folder",workspace); rainFolder.Name="StellarRain"
    local cam=workspace.CurrentCamera
    local cnt=math.clamp(math.floor(St.rainN*q),10,150)
    local batch={}
    for i=1,cnt do
        local p=Instance.new("Part"); p.Size=Vector3.new(0.045,math.random(18,30)*0.1,0.045)
        p.Material=Enum.Material.Glass; p.Reflectance=math.random(70,90)/100
        p.Color=Color3.fromRGB(math.random(200,230),math.random(225,245),255)
        p.Transparency=math.random(55,72)/100; p.CastShadow=false; p.Anchored=true; p.CanCollide=false; p.Parent=rainFolder
        rainParts[i]=p; batch[i]={fall=0}
    end
    SEB:reg("rain",batch)
    local rCnt=math.max(5,math.floor(cnt*0.18))
    for i=1,rCnt do
        local r=Instance.new("Part"); r.Size=Vector3.new(0.1,0.05,0.1); r.Material=Enum.Material.Glass
        r.Reflectance=0.7; r.Color=Color3.fromRGB(180,215,255); r.Transparency=0.82
        r.CastShadow=false; r.Anchored=true; r.CanCollide=false; r.Shape=Enum.PartType.Cylinder; r.Parent=rainFolder
        rainRipples[i]=r
    end
    local frame=0
    rainConns[1]=RunService.Heartbeat:Connect(function()
        frame=frame+1; if frame%2~=0 then return end
        if not rainFolder or not rainFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()
        SEB:rain(batch,t)
        for i,p in ipairs(rainParts) do
            if p and p.Parent then
                local ph=i*0.73; local fall=batch[i] and batch[i].fall or 0
                pcall(function() p.Reflectance=0.65+math.sin(t*3+ph)*0.25; p.CFrame=CFrame.new(cp.X+math.sin(ph)*34,cp.Y+20-fall,cp.Z+math.cos(ph)*34)*CFrame.Angles(0.18,0,0.06) end)
            end
        end
        for i,r in ipairs(rainRipples) do
            if r and r.Parent then
                pcall(function()
                    local rt=(t*0.7+i*0.65)%1; local sc=0.3+rt*3.5; local ph=i*1.13
                    local rx=cp.X+math.sin(ph)*22; local rz=cp.Z+math.cos(ph)*22
                    local ray=workspace:Raycast(Vector3.new(rx,cp.Y+8,rz),Vector3.new(0,-50,0))
                    local ry=ray and ray.Position.Y+0.05 or cp.Y-8
                    r.CFrame=CFrame.new(rx,ry,rz)*CFrame.Angles(0,0,math.pi/2); r.Size=Vector3.new(0.05,sc,sc)
                    r.Transparency=0.65+(1-rt)*0.28; r.Color=Color3.fromRGB(math.floor(SA.lerp(150,210,1-rt)),math.floor(SA.lerp(190,235,1-rt)),255)
                end)
            end
        end
    end)
end

-- ================================================================
-- SECTION 13: SAKURA
-- ================================================================
local sakFolder,sakConns,sakParts=nil,{},{}
local function clearSak()
    for _,c in pairs(sakConns) do pcall(function() c:Disconnect() end) end
    sakConns={}
    if sakFolder and sakFolder.Parent then pcall(function() sakFolder:Destroy() end) end
    sakFolder=nil; sakParts={}; SAS:release("sakura"); SEB:clear("sakura")
end
local function makeSak()
    clearSak()
    local ok,q=SAS:request("sakura"); if not ok then return end
    sakFolder=Instance.new("Folder",workspace); sakFolder.Name="StellarSakura"
    local cam=workspace.CurrentCamera
    local cnt=math.clamp(math.floor(St.sakN*q),8,80)
    local theme=THEMES[St.themeIdx]
    for i=1,cnt do
        local p=Instance.new("Part",sakFolder); p.Size=Vector3.new(1.2,0.12,1.2); p.Material=Enum.Material.Neon
        p.CastShadow=false; p.Anchored=true; p.CanCollide=false; p.Color=SF.sakCol(i,theme.pri); p.Transparency=0.15
        local m=Instance.new("SpecialMesh",p); m.MeshType=Enum.MeshType.Sphere; m.Scale=Vector3.new(1,0.18,1)
        local cp=cam.CFrame.Position
        sakParts[i]={part=p,x=cp.X+math.random(-40,40),y=cp.Y+math.random(10,35),z=cp.Z+math.random(-40,40),
            vy=math.random(18,45)*0.01,rot=math.random(0,360),rotX=math.random(-30,30)*0.01,
            rotZ=math.random(-30,30)*0.01,rotSpeed=math.random(-90,90),phase=math.random()*math.pi*2,
            life=math.random()*10,maxLife=math.random(8,18),seed=i}
    end
    SEB:reg("sakura",sakParts)
    sakConns[1]=RunService.Heartbeat:Connect(function(dt)
        if not sakFolder or not sakFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()
        SEB:sakura(sakParts,dt,t)
        local th=THEMES[St.themeIdx]
        for _,s in ipairs(sakParts) do
            if s.part and s.part.Parent then
                if s.life>s.maxLife or s.y<cp.Y-40 then
                    s.x=cp.X+math.random(-42,42); s.y=cp.Y+math.random(20,40); s.z=cp.Z+math.random(-42,42)
                    s.vy=math.random(18,45)*0.01; s.life=0; s.maxLife=math.random(8,18); s.rotSpeed=math.random(-90,90)
                    pcall(function() s.part.Color=SF.sakCol(s.seed+math.random(10),th.pri) end)
                end
                local alpha=SA.fade(s.life/s.maxLife)
                pcall(function()
                    s.part.CFrame=CFrame.new(s.x,s.y,s.z)*CFrame.Angles(s.rotX*s.rot,math.rad(s.rot),s.rotZ*s.rot)
                    s.part.Transparency=math.clamp(1-alpha*0.88,0.08,0.92)
                end)
            end
        end
    end)
    SAI:watch("sak",function() return sakFolder end,"SakuraFolder")
end

-- ================================================================
-- SECTION 14: WIND
-- ================================================================
local windConns,windParts={},{}
local function clearWind()
    for _,c in pairs(windConns) do pcall(function() c:Disconnect() end) end
    windConns={}
    for _,d in pairs(windParts) do pcall(function() if d.part and d.part.Parent then d.part.CFrame=d.origin end end) end
    windParts={}; SAS:release("wind")
end
local function makeWind()
    clearWind()
    local ok=SAS:request("wind"); if not ok then return end
    local cam=workspace.CurrentCamera; local col=0
    for _,v in ipairs(workspace:GetDescendants()) do
        if col>=200 then break end
        pcall(function()
            if not (v:IsA("BasePart") or v:IsA("MeshPart")) or not v.Anchored then return end
            local pn=v.Parent and v.Parent.Name or ""
            if pn=="StellarRain" or pn=="StellarSakura" or pn=="StellarMeteor" or pn=="StellarSun" then return end
            if v.Size.X>6 or v.Size.Z>6 or v.Size.Y>18 then return end
            if (v.Position-cam.CFrame.Position).Magnitude>120 then return end
            windParts[#windParts+1]={part=v,origin=v.CFrame,phase=math.random()*math.pi*2,freq=0.8+math.random()*1.2,amp=0.008+math.random()*0.022}
            col=col+1
        end)
    end
    if #windParts==0 then SAI:_log("[Wind]no parts"); SAS:release("wind"); return end
    windConns[1]=RunService.Heartbeat:Connect(function(dt)
        if not St.windOn then return end
        local t=tick()
        for _,d in pairs(windParts) do
            pcall(function()
                if d.part and d.part.Parent then
                    local w=math.sin(t*d.freq+d.phase)*d.amp*St.windStr
                    local w2=SA.noise(t*d.freq*0.5,d.phase,0)*d.amp*St.windStr*0.4
                    d.part.CFrame=d.origin*CFrame.Angles(w,w2*0.3,w*0.6)
                end
            end)
        end
    end)
end

-- ================================================================
-- SECTION 15: METEOR — v6.6 base fix color + อัปเกรด
-- ================================================================
local meteorFolder,meteorConns,meteorRunning=nil,{},false
local function clearMet()
    meteorRunning=false
    for _,c in pairs(meteorConns) do pcall(function() c:Disconnect() end) end
    meteorConns={}
    if meteorFolder and meteorFolder.Parent then pcall(function() meteorFolder:Destroy() end) end
    meteorFolder=nil; SAS:release("meteor")
end
local function spawnMet()
    if not meteorFolder or not meteorFolder.Parent then return end
    local q=SAS:getQ("meteor")
    local cam=workspace.CurrentCamera; local cp=cam.CFrame.Position
    local ang=math.random()*math.pi*2; local dist=math.random(500,800)
    local sx=cp.X+math.cos(ang)*dist; local sy=cp.Y+math.random(300,500); local sz=cp.Z+math.sin(ang)*dist
    local tgt=Vector3.new(cp.X+math.cos(ang+math.pi)*dist,cp.Y-math.random(50,100),cp.Z+math.sin(ang+math.pi)*dist)
    local dir=(tgt-Vector3.new(sx,sy,sz)).Unit; local spd=math.random(250,450); local len=math.random(50,120)
    local mc=St.metCol
    local head=Instance.new("Part",meteorFolder); head.Size=Vector3.new(6,6,6); head.Material=Enum.Material.Neon
    head.Color=mc; head.Transparency=0; head.CastShadow=false; head.Anchored=true; head.CanCollide=false
    Instance.new("SpecialMesh",head).MeshType=Enum.MeshType.Sphere
    local pL=Instance.new("PointLight",head); pL.Color=mc; pL.Range=350; pL.Brightness=5; pL.Shadows=true
    local inner=Instance.new("Part",meteorFolder); inner.Size=Vector3.new(3,3,3); inner.Material=Enum.Material.Neon
    inner.Color=Color3.fromRGB(255,255,255); inner.Transparency=0.1; inner.CastShadow=false; inner.Anchored=true; inner.CanCollide=false
    Instance.new("SpecialMesh",inner).MeshType=Enum.MeshType.Sphere
    local aura=Instance.new("Part",meteorFolder); aura.Size=Vector3.new(16,16,16); aura.Material=Enum.Material.Neon
    aura.Color=mc; aura.Transparency=0.7; aura.CastShadow=false; aura.Anchored=true; aura.CanCollide=false
    Instance.new("SpecialMesh",aura).MeshType=Enum.MeshType.Sphere
    local body=Instance.new("Part",meteorFolder); body.Size=Vector3.new(2.8,2.8,len); body.Material=Enum.Material.Neon
    body.Color=SA.lerpCHSV(mc,Color3.fromRGB(255,255,255),0.4); body.Transparency=0.15; body.CastShadow=false; body.Anchored=true; body.CanCollide=false
    local tail=Instance.new("Part",meteorFolder); tail.Size=Vector3.new(1.7,1.7,len*2.8); tail.Material=Enum.Material.Neon
    tail.Color=SA.lerpCHSV(mc,Color3.fromRGB(255,255,255),0.68); tail.Transparency=0.42; tail.CastShadow=false; tail.Anchored=true; tail.CanCollide=false
    local tail2=Instance.new("Part",meteorFolder); tail2.Size=Vector3.new(0.7,0.7,len*5.5); tail2.Material=Enum.Material.Neon
    tail2.Color=Color3.fromRGB(255,255,255); tail2.Transparency=0.75; tail2.CastShadow=false; tail2.Anchored=true; tail2.CanCollide=false
    local tail3=Instance.new("Part",meteorFolder); tail3.Size=Vector3.new(0.3,0.3,len*8); tail3.Material=Enum.Material.Neon
    tail3.Color=SA.lerpCHSV(mc,Color3.fromRGB(255,255,255),0.85); tail3.Transparency=0.85; tail3.CastShadow=false; tail3.Anchored=true; tail3.CanCollide=false
    local glow=Instance.new("Part",meteorFolder); glow.Size=Vector3.new(24,24,24); glow.Material=Enum.Material.Neon
    glow.Color=mc; glow.Transparency=0.76; glow.CastShadow=false; glow.Anchored=true; glow.CanCollide=false
    Instance.new("SpecialMesh",glow).MeshType=Enum.MeshType.Sphere
    local pe=Instance.new("ParticleEmitter",head); pe.Texture="rbxassetid://2273224484"
    pe.Rate=math.floor(450*q); pe.Lifetime=NumberRange.new(0.15,0.6); pe.Speed=NumberRange.new(8,38); pe.SpreadAngle=Vector2.new(62,62)
    pe.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),ColorSequenceKeypoint.new(0.3,mc),ColorSequenceKeypoint.new(0.7,Color3.fromRGB(255,200,80)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,100,0))})
    pe.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,4.5),NumberSequenceKeypoint.new(0.4,2.2),NumberSequenceKeypoint.new(1,0)})
    pe.LightEmission=1; pe.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)}); pe.EmissionDirection=Enum.NormalId.Back; pe.RotSpeed=NumberRange.new(-200,200); pe.Rotation=NumberRange.new(0,360)
    local pe2=Instance.new("ParticleEmitter",body); pe2.Texture="rbxassetid://6060542021"
    pe2.Rate=math.floor(180*q); pe2.Lifetime=NumberRange.new(0.1,0.45); pe2.Speed=NumberRange.new(2,14); pe2.SpreadAngle=Vector2.new(28,28)
    pe2.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(255,225,110)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(255,120,20)),ColorSequenceKeypoint.new(1,Color3.fromRGB(180,50,0))})
    pe2.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,2.3),NumberSequenceKeypoint.new(1,0)}); pe2.LightEmission=0.85
    pe2.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.1),NumberSequenceKeypoint.new(1,1)}); pe2.EmissionDirection=Enum.NormalId.Back
    local pe3=Instance.new("ParticleEmitter",aura); pe3.Texture="rbxassetid://2273224484"
    pe3.Rate=math.floor(70*q); pe3.Lifetime=NumberRange.new(0.35,1.1); pe3.Speed=NumberRange.new(0,6); pe3.SpreadAngle=Vector2.new(180,180)
    pe3.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,mc),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255))})
    pe3.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,6.5),NumberSequenceKeypoint.new(1,0)}); pe3.LightEmission=0.65
    pe3.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.45),NumberSequenceKeypoint.new(1,1)})
    local life=0; local maxLife=5.5; local fading=false
    local conn
    conn=RunService.Heartbeat:Connect(function(dt)
        life=life+dt
        if life>=maxLife-0.5 and not fading then
            fading=true; pe.Enabled=false; pe2.Enabled=false; pe3.Enabled=false
            pcall(function()
                TweenService:Create(glow,TweenInfo.new(0.22,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=Vector3.new(90,90,90),Transparency=0}):Play()
                TweenService:Create(pL,TweenInfo.new(0.22),{Range=600,Brightness=9}):Play()
                for _,p in ipairs({head,inner,aura,body,tail,tail2,tail3}) do TweenService:Create(p,TweenInfo.new(0.5),{Transparency=1}):Play() end
            end)
        end
        if life>=maxLife then
            pcall(function() head:Destroy(); inner:Destroy(); aura:Destroy(); body:Destroy(); tail:Destroy(); tail2:Destroy(); tail3:Destroy(); glow:Destroy() end)
            pcall(function() conn:Disconnect() end); return
        end
        local np=Vector3.new(sx,sy,sz)+dir*spd*life
        pcall(function()
            if not fading then
                head.CFrame=CFrame.new(np); inner.CFrame=CFrame.new(np); aura.CFrame=CFrame.new(np)
                body.CFrame=CFrame.lookAt(np-dir*(len*0.5),np-dir*(len*0.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail.CFrame=CFrame.lookAt(np-dir*(len*1.5),np-dir*(len*1.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail2.CFrame=CFrame.lookAt(np-dir*(len*3.2),np-dir*(len*3.2)+dir)*CFrame.Angles(math.pi/2,0,0)
                tail3.CFrame=CFrame.lookAt(np-dir*(len*6.5),np-dir*(len*6.5)+dir)*CFrame.Angles(math.pi/2,0,0)
                local pulse=1+math.sin(life*28)*0.18; glow.CFrame=CFrame.new(np); glow.Size=Vector3.new(24*pulse,24*pulse,24*pulse)
                local ap=1+math.sin(life*16)*0.22; aura.Size=Vector3.new(16*ap,16*ap,16*ap)
            else head.CFrame=head.CFrame+dir*spd*0.08*dt; inner.CFrame=head.CFrame; aura.CFrame=head.CFrame; glow.CFrame=head.CFrame
                TweenService:Create(glow,TweenInfo.new(0.3),{Transparency=1,Size=Vector3.new(0,0,0)}):Play()
            end
        end)
    end)
    meteorConns[#meteorConns+1]=conn
end
local function startMet()
    clearMet(); local ok=SAS:request("meteor"); if not ok then SAI:_log("Meteor denied"); return end
    meteorRunning=true; meteorFolder=Instance.new("Folder",workspace); meteorFolder.Name="StellarMeteor"
    task.spawn(function() while meteorRunning do spawnMet(); task.wait(math.random()*St.metInt+0.5) end end)
end

-- ================================================================
-- SECTION 16: SUN — v6.6 base 60 rays fibonacci, fixed
-- ================================================================
local sunFolder,sunConns=nil,{}
local function clearSun()
    for _,c in pairs(sunConns) do pcall(function() c:Disconnect() end) end
    sunConns={}
    if sunFolder and sunFolder.Parent then pcall(function() sunFolder:Destroy() end) end
    sunFolder=nil; SAS:release("sun")
end
local function startSun()
    clearSun(); local ok,q=SAS:request("sun"); if not ok then SAI:_log("Sun denied"); return end
    sunFolder=Instance.new("Folder",workspace); sunFolder.Name="StellarSun"
    local cam=workspace.CurrentCamera
    local core=Instance.new("Part",sunFolder); core.Size=Vector3.new(100,100,100); core.Material=Enum.Material.Neon
    core.Color=Color3.fromRGB(255,248,180); core.Transparency=0; core.CastShadow=false; core.Anchored=true; core.CanCollide=false
    Instance.new("SpecialMesh",core).MeshType=Enum.MeshType.Sphere
    local sL=Instance.new("PointLight",core); sL.Color=Color3.fromRGB(255,220,150); sL.Brightness=2.5; sL.Range=750; sL.Shadows=false
    local cData={{sz=145,col=Color3.fromRGB(255,228,100),tr=0.55},{sz=200,col=Color3.fromRGB(255,195,55),tr=0.70},{sz=280,col=Color3.fromRGB(255,155,28),tr=0.84},{sz=400,col=Color3.fromRGB(255,108,8),tr=0.93},{sz=560,col=Color3.fromRGB(255,60,0),tr=0.96}}
    local crowns={}
    for _,l in ipairs(cData) do
        local c=Instance.new("Part",sunFolder); c.Size=Vector3.new(l.sz,l.sz,l.sz); c.Material=Enum.Material.Neon
        c.Color=l.col; c.Transparency=l.tr; c.CastShadow=false; c.Anchored=true; c.CanCollide=false
        Instance.new("SpecialMesh",c).MeshType=Enum.MeshType.Sphere
        crowns[#crowns+1]={p=c,sz=l.sz,tr=l.tr}
    end
    local RC=math.floor(60*q); local rays={}
    for i=1,RC do
        local phi=math.acos(1-2*i/(RC+1)); local theta=(math.pi*(1+math.sqrt(5)))*(i-1)
        local r=Instance.new("Part",sunFolder); local main=i<=math.floor(RC*0.66); local rLen=math.random(450,950)
        r.Size=Vector3.new(main and 5 or 3,main and 5 or 3,rLen); r.Material=Enum.Material.Neon
        r.Color=Color3.fromRGB(255,230,130); r.Transparency=0.65; r.CastShadow=false; r.Anchored=true; r.CanCollide=false
        rays[#rays+1]={p=r,phi=phi,theta=theta,len=rLen,main=main}
    end
    local ag=Instance.new("Part",sunFolder); ag.Size=Vector3.new(750,750,750); ag.Material=Enum.Material.Neon
    ag.Color=Color3.fromRGB(255,140,30); ag.Transparency=0.975; ag.CastShadow=false; ag.Anchored=true; ag.CanCollide=false
    Instance.new("SpecialMesh",ag).MeshType=Enum.MeshType.Sphere
    local t0=tick()
    sunConns[1]=RunService.Heartbeat:Connect(function()
        if not sunFolder or not sunFolder.Parent then return end
        local cp=cam.CFrame.Position; local t=tick()-t0; local a=t*0.018
        local sPos=cp+Vector3.new(math.cos(a)*1350,480+math.sin(t*0.1)*40,math.sin(a)*1350)
        local pulse=1+math.sin(t*1.4)*0.035
        pcall(function()
            core.CFrame=CFrame.new(sPos); core.Size=Vector3.new(100*pulse,100*pulse,100*pulse)
            ag.CFrame=CFrame.new(sPos); ag.Transparency=0.970+math.sin(t*0.7)*0.015
            for _,c in ipairs(crowns) do c.p.CFrame=CFrame.new(sPos); local sz=c.sz*pulse; c.p.Size=Vector3.new(sz,sz,sz); c.p.Transparency=c.tr+math.sin(t*1.2+c.sz*0.01)*0.025 end
            for _,r in ipairs(rays) do
                local th=r.theta+t*0.35; local dx=math.sin(r.phi)*math.cos(th); local dy=math.cos(r.phi); local dz=math.sin(r.phi)*math.sin(th)
                local rd=Vector3.new(dx,dy,dz).Unit; local mid=sPos+rd*(r.len*0.5)
                r.p.CFrame=CFrame.lookAt(mid,mid+rd)
                r.p.Transparency=(r.main and 0.60 or 0.70)+math.abs(math.sin(t*2+r.phi))*0.22
                r.p.Color=Color3.fromHSV(0.08+((t*6+r.phi*20)%360)/360*0.05,0.85,1)
            end
        end)
    end)
end
