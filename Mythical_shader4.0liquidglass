-- SECTION 32: THEME TAB + BORDER STYLE + OPACITY
-- ================================================================
local ThemeTitle=Instance.new("TextLabel",TabTheme)
ThemeTitle.Size=UDim2.new(1,-16,0,18); ThemeTitle.Position=UDim2.new(0,8,0,4)
ThemeTitle.BackgroundTransparency=1; ThemeTitle.Text="💎 UI Color Theme"
ThemeTitle.TextColor3=Color3.fromRGB(200,200,255); ThemeTitle.TextSize=11
ThemeTitle.Font=Enum.Font.SourceSansBold; ThemeTitle.TextXAlignment=Enum.TextXAlignment.Left

local activeThemeLabel=Instance.new("TextLabel",TabTheme)
activeThemeLabel.Size=UDim2.new(1,-16,0,14); activeThemeLabel.Position=UDim2.new(0,8,0,22)
activeThemeLabel.BackgroundTransparency=1; activeThemeLabel.Text="Active: Dark Glass"
activeThemeLabel.TextColor3=Color3.fromRGB(100,120,255); activeThemeLabel.TextSize=10
activeThemeLabel.Font=Enum.Font.Code; activeThemeLabel.TextXAlignment=Enum.TextXAlignment.Left

local rainbowActive=false; local glassRotThread=nil

local function applyTheme(index)
    local theme=COLOR_THEMES[index]; State.currentThemeIndex=index
    tw(activeThemeLabel,{TextColor3=theme.primary},SMOOTH)
    activeThemeLabel.Text="Active: "..theme.name
    refreshTabButtons(); refreshAllSliders()

    if theme.glass or theme.clear then
        GlassHighlight.Visible  = true
        GlassViewport.Visible   = theme.liquid==true

        local bgC = (theme.dark or theme.clear) and Color3.fromRGB(15,15,20) or Color3.fromRGB(235,242,252)
        local bgT = 1 - State.uiOpacity
        tw(MainFrame,{BackgroundColor3=bgC, BackgroundTransparency=bgT},SMOOTH)
        UIStroke.Thickness = 1.8
        SidebarLine.BackgroundColor3 = (theme.dark or theme.clear) and Color3.fromRGB(100,100,150) or Color3.fromRGB(165,205,240)
        Sidebar.BackgroundColor3     = (theme.dark or theme.clear) and Color3.fromRGB(10,10,15)  or Color3.fromRGB(228,238,252)
        szStroke.Color   = theme.primary; minStroke.Color = theme.primary

        if glassRotThread then pcall(function() task.cancel(glassRotThread) end) end
        glassRotThread=task.spawn(function()
            while State.currentThemeIndex==index and (COLOR_THEMES[State.currentThemeIndex].glass or COLOR_THEMES[State.currentThemeIndex].clear) do
                pcall(function()
                    UIGradientStroke.Rotation=(tick()*16)%360
                    local h=((tick()*18)%360)/360; local c=Color3.fromHSV(h,0.35,1)
                    UIGradientStroke.Color=ColorSequence.new({
                        ColorSequenceKeypoint.new(0,Color3.fromRGB(190,215,248)),
                        ColorSequenceKeypoint.new(0.5,c),
                        ColorSequenceKeypoint.new(1,Color3.fromRGB(170,205,245)),
                    })
                end); task.wait(0.05)
            end
        end)
    else
        if glassRotThread then pcall(function() task.cancel(glassRotThread) end); glassRotThread=nil end
        GlassHighlight.Visible=false; GlassViewport.Visible=false
        tw(MainFrame,{BackgroundColor3=Color3.fromRGB(240,242,248), BackgroundTransparency=0.12},SMOOTH)
        UIStroke.Thickness=1.2; UIGradientStroke.Rotation=0
        SidebarLine.BackgroundColor3=Color3.fromRGB(200,195,225); Sidebar.BackgroundColor3=Color3.fromRGB(235,235,248)
        szStroke.Color=Color3.fromRGB(180,170,215); minStroke.Color=Color3.fromRGB(180,170,210)
        UIGradientStroke.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0,Color3.fromRGB(200,180,240)),
            ColorSequenceKeypoint.new(0.5,theme.secondary),
            ColorSequenceKeypoint.new(1,Color3.fromRGB(200,180,240)),
        })
        UIGradientStroke.Transparency=NumberSequence.new({
            NumberSequenceKeypoint.new(0,0.4); NumberSequenceKeypoint.new(0.5,0.1); NumberSequenceKeypoint.new(1,0.4)
        })
    end
    -- re-apply current border style with new theme color
    applyBorderStyle(State.borderStyle, theme.primary)
end

-- Theme buttons
for i,theme in ipairs(COLOR_THEMES) do
    local TB=Instance.new("TextButton",TabTheme)
    TB.Size=UDim2.new(1,-16,0,27); TB.Position=UDim2.new(0,8,0,(i-1)*32+42)
