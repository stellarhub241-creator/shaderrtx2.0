-- ================================================================
-- SECTION 1: StellarEngine A
-- ================================================================
-- safe HSV (nil-safe)
local function safeToHSV(col)
    if not col then return 0,0,1 end
    local ok,h,s,v = pcall(function() return Color3.toHSV(col) end)
    if ok then return h,s,v else return 0,0,1 end
end
local function safeFromHSV(h,s,v)
    local ok,col = pcall(function() return Color3.fromHSV(
        math.clamp(h%1,0,1),
        math.clamp(s,0,1),
        math.clamp(v,0,1)
    ) end)
    if ok and col then return col else return Color3.new(1,1,1) end
end

-- sine-based noise fallback (ไม่ใช้ math.noise เลย)
local function sineNoise(x, y, z)
    x = x or 0; y = y or 0; z = z or 0
    return math.sin(x*1.3+y*0.7)*math.cos(y*1.1+z*0.9)*math.sin(z*1.7+x*0.5)
end

local StellarEngineA = {
    applyGravity = function(vy, dt, gravity, drag)
        gravity = gravity or 9.8; drag = drag or 0.08
        local dragForce = drag * vy * vy * (vy > 0 and 1 or -1)
        return vy + (gravity - dragForce) * dt
    end,

    turbulence = function(x, y, z, t, scale, strength)
        scale = scale or 1.0; strength = strength or 0.5
        x=x or 0; y=y or 0; z=z or 0; t=t or 0
        local tx = sineNoise(x*scale, y*scale*0.5, t*0.7)
        local ty = sineNoise(y*scale, z*scale*0.5, t*0.5)
        local tz = sineNoise(z*scale, x*scale*0.5, t*0.6)
        return tx*strength, ty*strength*0.4, tz*strength
    end,

    newSpring = function(stiffness, damping)
        local s = {value=0, velocity=0, k=stiffness or 200, d=damping or 20}
        function s:update(dt, target)
            local err   = self.value - target
            local force = -self.k * err - self.d * self.velocity
            self.velocity = self.velocity + force * dt
            self.value    = self.value    + self.velocity * dt
            return self.value
        end
        function s:reset(val) self.value = val or 0; self.velocity = 0 end
        return s
    end,

    newColorSpring = function(stiffness, damping)
        local k = stiffness or 180; local d = damping or 18
        local function ch() return {value=0,velocity=0} end
        local sr,sg,sb = ch(),ch(),ch()
        local function step(sp, dt, target)
            local f = -k*(sp.value-target) - d*sp.velocity
            sp.velocity = sp.velocity + f*dt
            sp.value    = sp.value    + sp.velocity*dt
            return math.clamp(sp.value,0,1)
        end
        return {
            value = Color3.new(0,0,0),
            update = function(self, dt, target)
                if not target then return self.value end
                self.value = Color3.new(step(sr,dt,target.R),step(sg,dt,target.G),step(sb,dt,target.B))
                return self.value
            end,
            reset = function(self, col)
                if not col then return end
                sr.value=col.R; sg.value=col.G; sb.value=col.B
                sr.velocity=0; sg.velocity=0; sb.velocity=0
                self.value = col
            end,
        }
    end,

    bezier = function(p0, p1, p2, p3, t)
        local u = 1-t
        return u*u*u*p0 + 3*u*u*t*p1 + 3*u*t*t*p2 + t*t*t*p3
    end,

    smoothstep5 = function(t)
        t = math.clamp(t,0,1)
        return t*t*t*(t*(t*6-15)+10)
    end,

    smoothNoise = function(x, y, z, octaves)
        octaves = octaves or 3
        x=x or 0; y=y or 0; z=z or 0
        local val,amp,freq = 0,1,1
        for _ = 1, octaves do
            val  = val + sineNoise(x*freq, y*freq, z*freq)*amp
            amp  = amp  * 0.5
            freq = freq * 2.1
        end
        return val
    end,

    lerpColorHSV = function(a, b, t)
        if not a or not b then return a or b or Color3.new(1,1,1) end
        local ah,as,av = safeToHSV(a)
        local bh,bs,bv = safeToHSV(b)
        local dh = bh-ah
        if dh > 0.5 then dh=dh-1 elseif dh<-0.5 then dh=dh+1 end
        return safeFromHSV(ah+dh*t, as+(bs-as)*t, av+(bv-av)*t)
    end,

    sampleGradient = function(colors, t)
        if not colors or #colors==0 then return Color3.new(1,1,1) end
        if #colors==1 then return colors[1] end
        local seg  = t*(#colors-1)
        local idx  = math.floor(seg)
        local frac = seg-idx
        idx = math.clamp(idx,0,#colors-2)
        return StellarEngineA.lerpColorHSV(colors[idx+1],colors[idx+2],frac)
    end,

    pulse = function(t, freq, phase)
        return (math.sin((t or 0)*(freq or 1)*math.pi*2+(phase or 0))+1)*0.5
    end,

    remap = function(v, inMin, inMax, outMin, outMax)
        return outMin+(v-inMin)/(inMax-inMin)*(outMax-outMin)
    end,

    newEMA = function(alpha)
        return {
            value=nil, alpha=alpha or 0.1,
            update = function(self, v)
                if v==nil then return self.value or 0 end
                if self.value==nil then self.value=v; return v end
                self.value = self.alpha*v+(1-self.alpha)*self.value
                return self.value
            end,
        }
    end,

    fibSphere = function(i, n)
        local phi   = math.acos(1 - 2*i/(n+1))
        local theta = math.pi*(1+math.sqrt(5))*(i-1)
        return math.sin(phi)*math.cos(theta), math.cos(phi), math.sin(phi)*math.sin(theta)
    end,

    coronaPulse = function(t, layer)
        t=t or 0; layer=layer or 0
        local f1 = math.sin(t*1.4 + layer*0.8)
        local f2 = math.sin(t*2.8 + layer*1.6) * 0.4
        local f3 = math.sin(t*0.7 + layer*0.3) * 0.2
        return 1 + (f1+f2+f3)*0.04
    end,

    particleFade = function(lifeRatio, fadeIn, fadeOut)
        lifeRatio = lifeRatio or 0
        fadeIn  = fadeIn  or 0.12
        fadeOut = fadeOut or 0.20
        if lifeRatio < fadeIn then
            return StellarEngineA.smoothstep5(lifeRatio/fadeIn)
        elseif lifeRatio > (1-fadeOut) then
            return StellarEngineA.smoothstep5((1-lifeRatio)/fadeOut)
        end
        return 1
    end,

    gridCell = function(col, row, cols, rows, padX, padY)
        padX=padX or 4; padY=padY or 4
        local w=(1-padX*(cols+1)/100)/cols
        local h=(1-padY*(rows+1)/100)/rows
        local x=padX/100+(col-1)*(w+padX/100)
        local y=padY/100+(row-1)*(h+padY/100)
        return UDim2.new(w,0,h,0), UDim2.new(x,0,y,0)
    end,

    bind = function(obj, prop, getter, transformer)
        return {
            obj=obj, prop=prop, getter=getter, lastVal=nil,
            update = function(self)
                if not self.obj or not self.getter then return end
                pcall(function()
                    local v = self.getter()
                    if transformer then v=transformer(v) end
                    if v~=self.lastVal then self.obj[self.prop]=v; self.lastVal=v end
                end)
            end,
        }
    end,
}

-- ================================================================
-- SECTION 2: StellarEngine B
-- ================================================================
local StellarEngineB = {
    _queue = {},
    _cache = {},

    push = function(self, priority, id, fn, ...)
        if not fn then return end
        local args = {...}
        for i,t in ipairs(self._queue) do
            if t.id==id then
                self._queue[i]={priority=priority,id=id,fn=fn,args=args}
                self:_sort(); return
            end
        end
        table.insert(self._queue,{priority=priority,id=id,fn=fn,args=args})
        self:_sort()
    end,

    _sort = function(self)
        table.sort(self._queue, function(a,b) return a.priority < b.priority end)
    end,

    flush = function(self, maxTasks)
        maxTasks = maxTasks or 4
        local ran = 0
        while #self._queue>0 and ran<maxTasks do
            local t = table.remove(self._queue,1)
            if t and t.fn then
                pcall(function()
                    local args = t.args or {}
                    t.fn(unpack(args))
                end)
            end
            ran = ran+1
        end
        return ran
    end,

    cacheSet = function(self, key, value, ttl)
        if not key then return end
        self._cache[key] = {value=value, expireAt=tick()+(ttl or 2.0)}
    end,

    cacheGet = function(self, key)
        if not key then return nil end
        local entry = self._cache[key]
        if not entry then return nil end
        if tick() > entry.expireAt then self._cache[key]=nil; return nil end
        return entry.value
    end,

    cacheClear = function(self, prefix)
        if prefix then
            for k in pairs(self._cache) do
                if string.sub(k,1,#prefix)==prefix then self._cache[k]=nil end
            end
        else
            self._cache={}
        end
    end,

    batchParticleStep = function(self, particles, dt, gravScale, dragCoeff)
        if not particles then return end
        gravScale = gravScale or 1.0
        dragCoeff = dragCoeff or 0.06
        local cacheKey = "batch_"..#particles
        local basePhys = self:cacheGet(cacheKey)
        if not basePhys then
            basePhys = {gravity=9.8*gravScale, drag=dragCoeff}
            self:cacheSet(cacheKey, basePhys, 0.5)
        end
        for _,p in ipairs(particles) do
            if p and p.active then
                local speed  = math.sqrt(p.vx*p.vx + p.vy*p.vy + p.vz*p.vz)
                local dragF  = basePhys.drag * speed
                p.vx = p.vx - p.vx*dragF*dt
                p.vy = p.vy + (basePhys.gravity - p.vy*dragF)*dt
                p.vz = p.vz - p.vz*dragF*dt
                p.x  = p.x + p.vx*dt
                p.y  = p.y - p.vy*dt
                p.z  = p.z + p.vz*dt
                p.life = p.life + dt
            end
        end
    end,

    getStats = function(self)
        local cacheCount=0
        for _ in pairs(self._cache) do cacheCount=cacheCount+1 end
        return {queueLen=#self._queue, cacheKeys=cacheCount}
    end,
}

-- ================================================================
-- SECTION 3: PARTICLE BUDGET
-- ================================================================
local ParticleBudget = {
    TOTAL = 3.0,
    used  = 0.0,
    EFFECTS = {
        sun    = {priority=1, cost=1.0, active=false, qualityMult=1.0},
        meteor = {priority=2, cost=1.0, active=false, qualityMult=1.0},
        rain   = {priority=3, cost=1.0, active=false, qualityMult=1.0},
        sakura = {priority=4, cost=1.0, active=false, qualityMult=1.0},
        wind   = {priority=5, cost=0.5, active=false, qualityMult=1.0},
    },

    setActive = function(self, name, active)
        if not self.EFFECTS[name] then return end
        self.EFFECTS[name].active = active
        self:recalculate()
    end,

    recalculate = function(self)
        local active = {}
        for name,e in pairs(self.EFFECTS) do
            if e.active then table.insert(active,{name=name,priority=e.priority,cost=e.cost,e=e}) end
        end
        table.sort(active, function(a,b) return a.priority < b.priority end)
        local remaining = self.TOTAL
        self.used = 0
        for _,item in ipairs(active) do
            if remaining >= item.cost then
                item.e.qualityMult = 1.0
                remaining = remaining - item.cost
                self.used = self.used + item.cost
            elseif remaining > 0 then
                item.e.qualityMult = remaining / item.cost
                self.used = self.used + remaining
                remaining = 0
            else
                item.e.qualityMult = 0.15
            end
        end
        for _,e in pairs(self.EFFECTS) do
            if not e.active then e.qualityMult=1.0 end
        end
    end,

    getQuality = function(self, name)
        if not self.EFFECTS[name] then return 1.0 end
        return self.EFFECTS[name].qualityMult or 1.0
    end,

    getReport = function(self)
        local lines = {string.format("Budget: %.1f/%.1f", self.used, self.TOTAL)}
        local sorted = {}
        for name,e in pairs(self.EFFECTS) do table.insert(sorted,{name=name,e=e}) end
        table.sort(sorted,function(a,b) return a.e.priority<b.e.priority end)
        for _,item in ipairs(sorted) do
            if item.e.active then
                table.insert(lines, string.format("  [P%d] %s %.0f%%", item.e.priority, item.name, item.e.qualityMult*100))
            end
        end
        return table.concat(lines,"\n")
    end,
}

-- ================================================================
-- SECTION 4: StellarAI
-- ================================================================
local StellarAI = {
    fpsHistory     = {},
    fpsHistorySize = 60,
    fpsHistoryIdx  = 0,
    qualityLevel   = 1.0,
    errorLog       = {},
    watchedRefs    = {},
    autoFixEnabled = true,
    lastCheckTick  = 0,
    checkInterval  = 2.0,
    targetFPS      = 60,
    _degradeStep   = 0,
    _lastDegradeT  = 0,
    engineA        = nil,
    engineB        = nil,
    budget         = nil,

    schedulePhysics = function(self, priority, id, fn, ...)
        if self.engineB and fn then
            self.engineB:push(priority, id, fn, ...)
        end
    end,

    pushFPS = function(self, fps)
        if not fps then return end
        self.fpsHistoryIdx = (self.fpsHistoryIdx % self.fpsHistorySize)+1
        self.fpsHistory[self.fpsHistoryIdx] = fps
    end,

    getAvgFPS = function(self)
        local sum,n=0,0
        for _,v in pairs(self.fpsHistory) do if v then sum=sum+v; n=n+1 end end
        return n>0 and (sum/n) or 60
    end,

    updateQuality = function(self, State, createRainFn, createSakuraFn)
        if not State then return end
        local avg    = self:getAvgFPS()
        local target = self.targetFPS or 60
        local ratio  = avg / math.max(target, 20)
        local now    = tick()
        if now - self._lastDegradeT < 3.0 then return end

        if ratio < 0.75 and self._degradeStep < 2 then
            self._degradeStep  = self._degradeStep+1
            self._lastDegradeT = now
            local mult = self._degradeStep==1 and 0.65 or 0.35
            self:log(string.format("DEGRADE step%d %.0f%% (avg %.0f/target %d)",
                self._degradeStep, mult*100, avg, target))

            if State.rainEnabled and createRainFn then
                local newRain = math.max(10, math.floor((State.rainParticleCount or 60)*mult))
                if newRain ~= State.rainParticleCount then
                    State.rainParticleCount = newRain
                    self:schedulePhysics(3,"rain_rebuild",createRainFn)
                end
            end
            if State.sakuraEnabled and createSakuraFn then
                local newSak = math.max(8, math.floor((State.sakuraCount or 45)*mult))
                if newSak ~= State.sakuraCount then
                    State.sakuraCount = newSak
                    self:schedulePhysics(4,"sakura_rebuild",createSakuraFn)
                end
            end

        elseif ratio >= 0.92 and self._degradeStep > 0 then
            self._degradeStep  = math.max(0, self._degradeStep-1)
            self._lastDegradeT = now
            self:log(string.format("RECOVER step%d (avg %.0f)", self._degradeStep, avg))
        end
    end,

    watch = function(self, id, refGetter, name, fixCallback, priority)
        if not id or not refGetter then return end
        self.watchedRefs[id] = {
            getter=refGetter, name=name or id,
            fixCb=fixCallback, lastOk=true, missCount=0, priority=priority or 5,
        }
    end,

    check = function(self)
        if not self.autoFixEnabled then return end
        local now = tick()
        if now-self.lastCheckTick < self.checkInterval then return end
        self.lastCheckTick = now

        for id,w in pairs(self.watchedRefs) do
            if w and w.getter then
                local alive = pcall(function()
                    local ref = w.getter()
                    if ref == nil then error("nil") end
                    if typeof(ref)=="Instance" then
                        if not ref.Parent then error("no parent") end
                    end
                end)
                if not alive then
                    w.missCount = (w.missCount or 0)+1
                    if w.lastOk then self:log("[WARN] "..(w.name or id).." dead"); w.lastOk=false end
                    if w.fixCb then
                        self:schedulePhysics(w.priority or 5, "fix_"..id, function()
                            local ok = pcall(w.fixCb)
                            if ok then
                                self:log("[FIX] "..(w.name or id).." restarted")
                                w.lastOk=true; w.missCount=0
                            end
                        end)
                    end
                else
                    if not w.lastOk then self:log("[OK] "..(w.name or id).." recovered") end
                    w.lastOk=true; w.missCount=0
                end
            end
        end

        if self.engineB then
            local s = self.engineB:getStats()
            if s.queueLen > 20 then self:log("[WARN] EngineB backlog: "..s.queueLen) end
        end
    end,

    log = function(self, msg)
        if not msg then return end
        local e = string.format("[%.1f] %s", tick()%10000, tostring(msg))
        table.insert(self.errorLog, e)
        if #self.errorLog>80 then table.remove(self.errorLog,1) end
    end,

    getReport = function(self)
        local avg = self:getAvgFPS()
        local bStats = {queueLen=0,cacheKeys=0}
        if self.engineB then pcall(function() bStats=self.engineB:getStats() end) end
        local lines = {
            string.format("AvgFPS: %.0f / target: %d  step:%d", avg, self.targetFPS or 60, self._degradeStep),
            string.format("EngineB Q:%d C:%d", bStats.queueLen, bStats.cacheKeys),
            self.budget and self.budget:getReport() or "Budget: N/A",
            "--- Log ---",
        }
        local logLen = #self.errorLog
        for i=math.max(1,logLen-9),logLen do
            if self.errorLog[i] then table.insert(lines, self.errorLog[i]) end
        end
        return table.concat(lines,"\n")
    end,
}

StellarAI.engineA = StellarEngineA
StellarAI.engineB = StellarEngineB
StellarAI.budget  = ParticleBudget

