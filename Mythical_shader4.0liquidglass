ResetSkyBtn.MouseButton1Click:Connect(function()
    pcall(function() skyGuardConn:Disconnect() end)
    pcall(function()
        for _,child in ipairs(Lighting:GetChildren()) do if child:IsA("Sky") then child:Destroy() end end
        task.wait(0.05)
        local sky=Instance.new("Sky",Lighting); sky.Name="StellarSky"
        sky.SunTextureId="rbxassetid://1079349813"; sky.SunAngularSize=21
        sky.MoonTextureId="rbxassetid://6444320592"; sky.MoonAngularSize=11
        sky.StarCount=8000; sky.CelestialBodiesShown=true
    end); connectSkyGuard()
end)
