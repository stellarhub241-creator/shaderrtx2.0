-- =============================================================================
-- [10] ELASTIC SPRING PHYSICS MODULE
-- =============================================================================
local function applySpringPhysics(button)
    pcall(function()
        local uiScale = button:FindFirstChildOfClass("UIScale")
        if not uiScale then
            uiScale = Instance.new("UIScale", button)
            uiScale.Scale = 1.0
        end
        
        button.MouseEnter:Connect(function()
            pcall(function()
                local t1 = TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                local t2 = TweenInfo.new(0.2, Enum.EasingStyle.Quad)
                TweenService:Create(uiScale, t1, {Scale = 1.06}):Play()
                TweenService:Create(button, t2, {BackgroundTransparency = 0.15}):Play()
            end)
        end)
        
        button.MouseLeave:Connect(function()
            pcall(function()
                local t1 = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                local t2 = TweenInfo.new(0.2, Enum.EasingStyle.Quad)
                TweenService:Create(uiScale, t1, {Scale = 1.0}):Play()
                TweenService:Create(button, t2, {BackgroundTransparency = 0.4}):Play()
            end)
        end)
        
        button.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                pcall(function()
                    local t1 = TweenInfo.new(0.1, Enum.EasingStyle.Quad)
                    TweenService:Create(uiScale, t1, {Scale = 0.94}):Play()
                end)
            end
        end)
        
        button.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                pcall(function()
                    local t1 = TweenInfo.new(0.2, Enum.EasingStyle.Back)
                    TweenService:Create(uiScale, t1, {Scale = 1.0}):Play()
                end)
            end
        end)
    end)
end

-- =============================================================================
-- [11] TAB NAVIGATION MANAGEMENT
-- =============================================================================
local tabButtons = {}
local activeTab = nil

local function switchTab(tabFrame, btn)
    if activeTab == tabFrame then
        return
    end
    activeTab = tabFrame
    
    TabGfx.Visible = false
    TabSky.Visible = false
    TabOptimize.Visible = false
    TabTheme.Visible = false
    
    for _, b in pairs(tabButtons) do
        b.BackgroundColor3 = Color3.fromRGB(20, 16, 30)
        b.BackgroundTransparency = 0.4
        b.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
    
    tabFrame.Position = UDim2.new(0, 25, 0, 0)
    tabFrame.Visible = true
    
    pcall(function()
        local t1 = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        TweenService:Create(tabFrame, t1, {Position = UDim2.new(0, 0, 0, 0)}):Play()
    end)
    
    btn.BackgroundColor3 = COLOR_THEMES[currentThemeIndex].primary
    btn.BackgroundTransparency = 0.2
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
end

local function addTabButton(text, order, targetTab)
    local Btn = Instance.new("TextButton", Sidebar)
    Btn.Size = UDim2.new(1, -10, 0, 28)
    Btn.Position = UDim2.new(0, 5, 0, (order - 1) * 33 + 8)
    Btn.BackgroundColor3 = Color3.fromRGB(20, 16, 30)
    Btn.BackgroundTransparency = 0.4
    Btn.Text = text
    Btn.TextColor3 = Color3.fromRGB(180, 180, 180)
    Btn.Font = Enum.Font.SourceSansBold
    Btn.TextSize = 11
    Btn.ZIndex = 5
    
    local BtnCorner = Instance.new("UICorner", Btn)
    BtnCorner.CornerRadius = UDim.new(0, 6)
    
    applySpringPhysics(Btn)
    
    Btn.MouseButton1Click:Connect(function()
        switchTab(targetTab, Btn)
    end)
    
    table.insert(tabButtons, Btn)
    return Btn
end

local b1 = addTabButton("Graphics", 1, TabGfx)
local b2 = addTabButton("Skybox", 2, TabSky)
local b3 = addTabButton("FPS Boost", 3, TabOptimize)
local b4 = addTabButton("Theme", 4, TabTheme)
switchTab(TabGfx, b1)

-- =============================================================================
-- [12] COMPLEX DRAG ENGINE & FORCE TOUCH CONTROLLER (UNMODIFIED SECTIONS)
-- =============================================================================
local dragToggle, dragStart, startPos
local isMinimized = false

local function toggleMinimize()
    isMinimized = not isMinimized
    if isMinimized then
        MainFrame:TweenSize(UDim2.new(0, 180, 0, 65), Enum.EasingDirection.Out, Enum.EasingStyle.Back, 0.45, true)
        Sidebar.Visible = false
        ContentArea.Visible = false
        MinBtn.Text = "+"
        TitleLabel:TweenSizeAndPosition(UDim2.new(0, 130, 0, 25), UDim2.new(0, 12, 0, 5), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3)
        MinBtn:TweenPosition(UDim2.new(1, -33, 0, 6), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3)
        
        InfoFPSLabel.AnchorPoint = Vector2.new(0, 0)
        InfoFPSLabel:TweenSizeAndPosition(UDim2.new(0, 100, 0, 20), UDim2.new(0, 12, 0, 38), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3)
        InfoFPSLabel.TextXAlignment = Enum.TextXAlignment.Left
    else
        MainFrame:TweenSize(UDim2.new(0, 320, 0, 260), Enum.EasingDirection.Out, Enum.EasingStyle.Back, 0.45, true)
        task.delay(0.15, function()
            if not isMinimized then
                Sidebar.Visible = true
                ContentArea.Visible = true
            end
        end)
        MinBtn.Text = "-"
        TitleLabel:TweenSizeAndPosition(UDim2.new(0.6, 0, 1, 0), UDim2.new(0, 15, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3)
        MinBtn:TweenPosition(UDim2.new(1, -35, 0.5, -12), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3)
        
        InfoFPSLabel:TweenSizeAndPosition(UDim2.new(0, 100, 0, 20), UDim2.new(0, 12, 1, -25), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3)
    end
end

MinBtn.MouseButton1Click:Connect(toggleMinimize)

local touchStartPos = Vector2.new()
local isTouching = false
local forceTouchTime = 0.5

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isTouching = true
        touchStartPos = input.Position
        dragToggle = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        GlowEffect.ImageColor3 = BorderColorNow
        pcall(function()
            TweenService:Create(GlowEffect, TweenInfo.new(0.3), {ImageTransparency = 0.25}):Play()
            TweenService:Create(UIStroke, TweenInfo.new(0.3), {Thickness = 2.5}):Play()
        end)

        -- Force Touch Configuration Loop
        task.spawn(function()
            task.wait(forceTouchTime)
            if isTouching then
                local dist = (input.Position - touchStartPos).Magnitude
                if dist < 15 then
                    dragToggle = false
                    pcall(function()
                        local s = MainFrame:FindFirstChildOfClass("UIScale")
                        if not s then
                            s = Instance.new("UIScale", MainFrame)
                        end
                        TweenService:Create(s, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {Scale = 0.95}):Play()
                        task.wait(0.1)
                        toggleMinimize()
                        TweenService:Create(s, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Scale = 1.0}):Play()
                    end)
                end
            end
        end)

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragToggle = false
                isTouching = false
                pcall(function()
                    TweenService:Create(GlowEffect, TweenInfo.new(0.4), {ImageTransparency = 1}):Play()
                    TweenService:Create(UIStroke, TweenInfo.new(0.4), {Thickness = 1.8}):Play()
                end)
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggle then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- =============================================================================
-- [13] TOGGLE HUD BUTTON COMPONENT INITIALIZER
-- =============================================================================
local function createToggle(parent, text, order, defaultVal, callback)
    local Frame = Instance.new("Frame", parent)
    Frame.Size = UDim2.new(1, -20, 0, 30)
    Frame.Position = UDim2.new(0, 10, 0, (order - 1) * 35 + 8)
    Frame.BackgroundTransparency = 1
    Frame.ZIndex = 5
    
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(0.65, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(220, 220, 220)
    Label.TextSize = 11
    Label.Font = Enum.Font.SourceSans
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.ZIndex = 6
    
    local ToggleBtn = Instance.new("TextButton", Frame)
    ToggleBtn.Size = UDim2.new(0, 45, 0, 20)
    ToggleBtn.Position = UDim2.new(1, -45, 0.5, -10)
    if defaultVal then
        ToggleBtn.BackgroundColor3 = COLOR_THEMES[currentThemeIndex].primary
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(40, 30, 55)
    end
    ToggleBtn.BackgroundTransparency = 0.2
    if defaultVal then
        ToggleBtn.Text = "ON"
    else
        ToggleBtn.Text = "OFF"
    end
    ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleBtn.Font = Enum.Font.SourceSansBold
    ToggleBtn.TextSize = 10
    ToggleBtn.ZIndex = 6
    
    local ToggleCorner = Instance.new("UICorner", ToggleBtn)
    ToggleCorner.CornerRadius = UDim.new(0, 10)
    
    applySpringPhysics(ToggleBtn)
    
    local current = defaultVal
    ToggleBtn.MouseButton1Click:Connect(function()
        current = not current
        local targetColor = Color3.fromRGB(40, 30, 55)
        if current then
            targetColor = COLOR_THEMES[currentThemeIndex].primary
        end
        
        pcall(function()
            local t1 = TweenInfo.new(0.25, Enum.EasingStyle.Back)
            TweenService:Create(ToggleBtn, t1, {BackgroundColor3 = targetColor}):Play()
        end)
        
        if current then
            ToggleBtn.Text = "ON"
        else
            ToggleBtn.Text = "OFF"
        end
        callback(current)
    end)
    return ToggleBtn
end

