local fpResizing, fpResStart, fpResSize = false, nil, nil
ResizeHandleFPS.InputBegan:Connect(function(i)
    if isTouchOrMouse(i.UserInputType) then
        fpResizing = true
        fpResStart = i.Position
        fpResSize = Vector2.new(FPSPopup.Size.X.Offset, FPSPopup.Size.Y.Offset)
        i.Changed:Connect(function()
            if i.UserInputState.Name == "End" then fpResizing = false end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if fpResizing and (i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch")) then
        local delta = i.Position - fpResStart
        local nW = math.clamp(fpResSize.X + delta.X, 80, 400)
        local nH = math.clamp(fpResSize.Y + delta.Y, 50, 300)
        FPSPopup.Size = UDim2.new(0, nW, 0, nH)
    end
end)

addBounceOnHold(FPSPopup)

local pDrag, pDragStart, pStartPos = false, nil, nil 
PopupHeader.InputBegan:Connect(function(i) 
    if isTouchOrMouse(i.UserInputType) then 
        pDrag = true 
        pDragStart = i.Position 
        pStartPos = FPSPopup.Position 
        i.Changed:Connect(function() if i.UserInputState.Name == "End" then pDrag = false end end) 
    end 
end)

UserInputService.InputChanged:Connect(function(i) 
    if pDrag and (i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch")) then 
        local d = i.Position - pDragStart 
        local vp = workspace.CurrentCamera.ViewportSize 
        FPSPopup.Position = UDim2.new(
            0, math.clamp(pStartPos.X.Offset + d.X, 6, vp.X - FPSPopup.Size.X.Offset - 6), 
            0, math.clamp(pStartPos.Y.Offset + d.Y, 6, vp.Y - FPSPopup.Size.Y.Offset - 6)
        ) 
    end 
end)

local function getUS() return FPSPopup:FindFirstChildOfClass("UIScale") or Instance.new("UIScale", FPSPopup) end

PopupCloseBtn.MouseButton1Click:Connect(function() 
    pcall(function() local s = getUS() s.Scale = 1 tw(s, {Scale = 0}, TweenInfo.new(0.13, Enum.EasingStyle.Back, Enum.EasingDirection.In)) end) 
    task.delay(0.11, function() FPSPopup.Visible = false end) 
    ShowFPSPopupBtn.Text = "📊 Show FPS Monitor" 
end)

ShowFPSPopupBtn.MouseButton1Click:Connect(function() 
    if FPSPopup.Visible then 
        pcall(function() local s = getUS() s.Scale = 1 tw(s, {Scale = 0}, TweenInfo.new(0.13, Enum.EasingStyle.Back, Enum.EasingDirection.In)) end) 
        task.delay(0.11, function() FPSPopup.Visible = false end) 
        ShowFPSPopupBtn.Text = "📊 Show FPS Monitor" 
    else 
        FPSPopup.Visible = true 
        local s = getUS() s.Scale = 0 
        tw(s, {Scale = 1}, TweenInfo.new(0.24, Enum.EasingStyle.Back, Enum.EasingDirection.Out)) 
        ShowFPSPopupBtn.Text = "📊 Hide FPS Monitor" 
    end 
end)

-- ================================================================
-- SECTION 35: GRID SIZE + RESIZE (MANUAL RESIZE PRESERVED)
-- ================================================================
local camera = workspace.CurrentCamera 
local GRID = 64
local SIZE_PRESETS = {
    {label="1×1", w=1, h=1},
    {label="1×2", w=1, h=2},
    {label="2×2", w=2, h=2},
    {label="4×4", w=4, h=4},
    {label="8×8", w=8, h=8},
    {label="24×24",w=24,h=24}
}
local currentSizeIndex = 5 
SizeBtn.Text = SIZE_PRESETS[currentSizeIndex].label

local function gridPx(slots, axis) 
    local vp = camera.ViewportSize 
    return math.floor((axis == "x" and vp.X or vp.Y) / GRID * slots) 
end

local function updateUIVisibility(w, h) 
    local showFull = w >= 110 and h >= 72 
    Sidebar.Visible = showFull 
    ContentArea.Visible = showFull 
    SidebarLine.Visible = showFull 
    TitleLabel.Visible = w >= 75 
    SizeBtn.Visible = w >= 88 
    
    if showFull then 
        Sidebar.Size = UDim2.new(0, 90, 1, -36) 
        Sidebar.Position = UDim2.new(0, 0, 0, 36) 
        ContentArea.Size = UDim2.new(1, -91, 1, -36) 
        ContentArea.Position = UDim2.new(0, 91, 0, 36) 
    end 
end

local function applyGridSize(preset) 
    local pw = gridPx(preset.w, "x") 
    local ph = gridPx(preset.h, "y") 
    updateUIVisibility(pw, ph) 
    tw(MainFrame, {Size = UDim2.new(0, math.max(pw, 44), 0, math.max(ph, 30))}, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)) 
end

SizeBtn.MouseButton1Click:Connect(function() 
    currentSizeIndex = (currentSizeIndex % #SIZE_PRESETS) + 1 
    local preset = SIZE_PRESETS[currentSizeIndex] 
    SizeBtn.Text = preset.label 
    applyGridSize(preset) 
end)

local ResizeHandle = Instance.new("TextButton", MainFrame) 
ResizeHandle.Size = UDim2.new(0, 20, 0, 20) 
ResizeHandle.Position = UDim2.new(1, -20, 1, -20) 
ResizeHandle.BackgroundTransparency = 1 
ResizeHandle.Text = "◢" 
ResizeHandle.TextColor3 = Color3.fromRGB(200, 200, 255) 
ResizeHandle.TextTransparency = 0.4 
ResizeHandle.TextSize = 14 
ResizeHandle.Font = Enum.Font.GothamBold 
ResizeHandle.ZIndex = 10

local isResizing, resizeStart, resizeSize0 = false, nil, nil

ResizeHandle.InputBegan:Connect(function(i) 
    if isTouchOrMouse(i.UserInputType) then 
        isResizing = true 
        resizeStart = i.Position 
        resizeSize0 = Vector2.new(MainFrame.Size.X.Offset, MainFrame.Size.Y.Offset) 
        tw(ResizeHandle, {TextTransparency = 0}, TweenInfo.new(0.1)) 
        
        i.Changed:Connect(function() 
            if i.UserInputState.Name == "End" then 
                isResizing = false 
                tw(ResizeHandle, {TextTransparency = 0.4}, TweenInfo.new(0.1)) 
            end 
        end) 
    end 
end)

UserInputService.InputChanged:Connect(function(i) 
    if not isResizing then return end 
    if i.UserInputType.Name:match("MouseMovement") or i.UserInputType.Name:match("Touch") then 
        local delta = i.Position - resizeStart 
        local nW = math.clamp(resizeSize0.X + delta.X, 44, 800) 
        local nH = math.clamp(resizeSize0.Y + delta.Y, 30, 600) 
        SizeBtn.Text = "Custom" 
        updateUIVisibility(nW, nH) 
        tw(MainFrame, {Size = UDim2.new(0, nW, 0, nH)}, TweenInfo.new(0.04, Enum.EasingStyle.Linear)) 
    end 
end)

local lastVP = camera.ViewportSize 
task.spawn(function() 
    while task.wait(1) do 
        local vp = camera.ViewportSize 
        if vp ~= lastVP then 
            lastVP = vp 
            if SizeBtn.Text ~= "Custom" then 
                applyGridSize(SIZE_PRESETS[currentSizeIndex]) 
            end 
        end 
    end 
end)

-- ================================================================
-- SECTION 36: MASTER RENDER LOOP
-- ================================================================
local nextUpdate, frameCount, lastBorderColor = 0, 0, nil

RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1 
    nextUpdate = nextUpdate + dt
    local tC = tick()

    if rainbowActive then
        rainbowHue = (rainbowHue + dt * 68) % 360
        local col = Color3.fromHSV(rainbowHue / 360, 1, 1) 
        local col2 = Color3.fromHSV(((rainbowHue + 120) % 360) / 360, 1, 1)
        pcall(function() 
            UIGradientStroke.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, col),
                ColorSequenceKeypoint.new(0.5, col2),
                ColorSequenceKeypoint.new(1, col)
            }) 
            UIGradientStroke.Transparency = NumberSequence.new(0) 
        end)
        
        local activeColor = COLOR_THEMES[State.currentThemeIndex].primary
        if activeThemeLabel then activeThemeLabel.TextColor3 = col end
    end

    if not isMinimized and COLOR_THEMES[State.currentThemeIndex].liquid then
        pcall(function()
            local nx = math.noise(tC * 0.8, 0, 0) * 0.05
            local ny = math.noise(0, tC * 0.8, 0) * 0.05
            vpCam.CFrame = workspace.CurrentCamera.CFrame * CFrame.Angles(nx, ny, 0)
            vpCam.FieldOfView = workspace.CurrentCamera.FieldOfView
        end)
    else
        pcall(function() 
            vpCam.CFrame = workspace.CurrentCamera.CFrame 
            vpCam.FieldOfView = workspace.CurrentCamera.FieldOfView 
        end)
    end

    if nextUpdate >= 0.25 then
        local fps = math.round(frameCount / nextUpdate)
        
        if LiveTimeLabel then
            local modeTextStr = "Status: Day"
            if State.nostalgiaEnabled then modeTextStr = "Status: Nostalgia 2016" 
            elseif State.horrorFogEnabled then modeTextStr = State.horrorBlue and "Status: Horror (Dark)" or "Status: Horror (Green)" 
            elseif State.dawnEnabled then modeTextStr = "Status: Dawn" 
            elseif State.sunsetEnabled then modeTextStr = "Status: Sunset" 
            elseif State.rainEnabled then modeTextStr = "Status: Rainy" 
            elseif State.heavenlyEnabled then modeTextStr = "Status: Heavenly" 
            elseif Lighting.ClockTime < 6 or Lighting.ClockTime >= 19 then modeTextStr = "Status: Night" end
            LiveTimeLabel.Text = modeTextStr
        end

        if FPSPopup.Visible then
            PopupFPSBig.Text = tostring(fps) 
            PopupCapLabel.Text = "cap:" .. (State.targetFpsCap == 165 and "165⚡" or tostring(State.targetFpsCap))
            
            local ratio = fps / math.max(State.targetFpsCap, 1)
            if ratio >= 0.9 then 
                PopupStatusLabel.Text = "smooth" 
                PopupFPSBig.TextColor3 = Color3.fromRGB(100, 255, 150)
            elseif ratio >= 0.6 then 
                PopupStatusLabel.Text = "ok" 
                PopupFPSBig.TextColor3 = Color3.fromRGB(255, 200, 50)
            else 
                PopupStatusLabel.Text = "low!" 
                PopupFPSBig.TextColor3 = Color3.fromRGB(255, 100, 100) 
            end
        end

        if not rainbowActive then
            local targetColor = COLOR_THEMES[State.currentThemeIndex].primary
            if State.nostalgiaEnabled then targetColor = Color3.fromRGB(255, 120, 220) 
            elseif State.dawnEnabled then targetColor = Color3.fromRGB(255, 180, 200) 
            elseif State.sunsetEnabled then targetColor = Color3.fromRGB(255, 150, 60) 
            elseif State.rainEnabled then targetColor = Color3.fromRGB(100, 160, 255) 
            elseif State.heavenlyEnabled then targetColor = Color3.fromRGB(255, 240, 120) 
            elseif State.horrorFogEnabled then targetColor = State.horrorBlue and Color3.fromRGB(40, 50, 180) or Color3.fromRGB(80, 160, 40) end
            
            if lastBorderColor ~= targetColor then
                lastBorderColor = targetColor 
                tw(UIStroke, {Color = targetColor}, TweenInfo.new(0.32)) 
                tw(FPSPopupStroke, {Color = targetColor}, TweenInfo.new(0.32))
            end
        end

        frameCount = 0 
        nextUpdate = 0
    end
end)

