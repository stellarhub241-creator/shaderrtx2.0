local function applySkyPreset(preset)
    pcall(function()
        local sky=Lighting:FindFirstChildOfClass("Sky") or Instance.new("Sky",Lighting)
        sky.SkyboxBk=preset.bk sky.SkyboxDn=preset.dn sky.SkyboxFt=preset.ft
        sky.SkyboxLf=preset.lf sky.SkyboxRt=preset.rt sky.SkyboxUp=preset.up
        sky.StarCount=preset.star
        if not heavenlyEnabled then Lighting.ClockTime=preset.time end
    end)
end

