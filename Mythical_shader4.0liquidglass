    HORROR_G = {brightness=0.25,exposure=-0.5, shadow=0.98, ambient=Color3.fromRGB(4,16,2),      atmoColor=Color3.fromRGB(8,35,5),     atmoDecay=Color3.fromRGB(2,10,1),     atmoGlare=0.0,atmoHaze=6.5,atmoDensity=0.78,contrast=0.80,saturation=-0.35,tint=Color3.fromRGB(60,140,45),  bloom=0.65,bloomSize=32,bloomThreshold=0.48,dofFar=0.88,sunRays=0.0},
    HORROR_B = {brightness=0.18,exposure=-0.65,shadow=0.99, ambient=Color3.fromRGB(1,2,28),      atmoColor=Color3.fromRGB(3,4,40),     atmoDecay=Color3.fromRGB(1,1,22),     atmoGlare=0.0,atmoHaze=7.0,atmoDensity=0.85,contrast=0.88,saturation=-0.92,tint=Color3.fromRGB(30,40,200),  bloom=0.40,bloomSize=45,bloomThreshold=0.75,dofFar=0.95,sunRays=0.0},
