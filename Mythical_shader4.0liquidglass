local function isTouchOrMouse(inputType)
    return inputType == Enum.UserInputType.MouseButton1 or inputType == Enum.UserInputType.Touch
end

-- ================================================================
-- SECTION 2: PRIORITY MANAGER
-- ================================================================
-- จัดลำดับความสำคัญ effect/particle ไม่ให้ชนกัน
-- และช่วยคำนวน loop ได้แม่นยำขึ้น
local PriorityManager = {
    _registry = {},   -- {id, priority, active, lastTick, budget}
    _budgetMs = 1.8,  -- ms per frame ที่ยอมให้ effect ใช้รวมกัน
    _log      = {},   -- debug log

    register = function(self, id, priority)
        -- priority: 1=สูงสุด (rain/sakura), 2=กลาง (wind/meteor), 3=ต่ำ (sun corona)
        self._registry[id] = {priority=priority, active=false, lastTick=0, budget=0}
        self:_log_push("REGISTER "..id.." P"..priority)
    end,

    setActive = function(self, id, val)
        if self._registry[id] then
            self._registry[id].active = val
            self:_log_push((val and "ON " or "OFF ")..id)
        end
    end,

    -- เรียกตอนเริ่ม effect loop ทุกครั้ง → คืน true ถ้าควรรัน
    canRun = function(self, id)
        local r = self._registry[id]
        if not r or not r.active then return false end
        -- ถ้า budget เกิน ให้ priority ต่ำรอ
        local totalBusy = 0
        for _, v in pairs(self._registry) do
            if v.active and v.priority < r.priority then totalBusy = totalBusy + 1 end
        end
        return totalBusy < 3
    end,

    -- บันทึกเวลาคำนวน (ms) เพื่อ debug
    recordBudget = function(self, id, ms)
        if self._registry[id] then
            self._registry[id].budget = ms
            self._registry[id].lastTick = tick()
        end
    end,

    _log_push = function(self, msg)
        table.insert(self._log, string.format("[%.2f] %s", tick() % 1000, msg))
        if #self._log > 60 then table.remove(self._log, 1) end
    end,

    getDebugText = function(self)
        local lines = {}
        for id, r in pairs(self._registry) do
            table.insert(lines, string.format("%s | P%d | %s | %.2fms",
                id, r.priority, r.active and "ON" or "OFF", r.budget))
        end
        table.sort(lines)
        return table.concat(lines, "\n")
    end
}

-- ================================================================
-- SECTION 3: COMPUTE WATCHER
-- ================================================================
-- ตรวจสอบว่า loop คำนวนทำงานถูกต้อง ไม่หยุดค้าง
-- และ debug ได้ใน real-time
local ComputeWatcher = {
    _watches  = {},  -- {id → {lastPing, interval, ok, missCount}}
    _maxMiss  = 3,   -- miss กี่ครั้งถือว่า hang
    _log      = {},

    register = function(self, id, expectedIntervalSec)
        self._watches[id] = {
            lastPing  = tick(),
            interval  = expectedIntervalSec,
            ok        = true,
            missCount = 0,
        }
    end,

    ping = function(self, id)
        local w = self._watches[id]
        if not w then return end
        w.lastPing  = tick()
        w.ok        = true
        w.missCount = 0
    end,

    -- เรียกจาก master render loop ทุก 0.5s
    check = function(self)
        local now = tick()
        for id, w in pairs(self._watches) do
            local elapsed = now - w.lastPing
            if elapsed > w.interval * (self._maxMiss + 1) then
                if w.ok then
                    w.ok = false
                    table.insert(self._log, string.format("[HANG] %s (%.1fs)", id, elapsed))
                end
                w.missCount = w.missCount + 1
            else
                w.ok = true
            end
        end
    end,

    getDebugText = function(self)
        local lines = {}
        for id, w in pairs(self._watches) do
            table.insert(lines, string.format("%s | %s | miss:%d",
                id, w.ok and "OK" or "HANG", w.missCount))
        end
        table.sort(lines)
        return table.concat(lines, "\n")
    end,

    getLog = function(self)
        return table.concat(self._log, "\n")
    end
}

