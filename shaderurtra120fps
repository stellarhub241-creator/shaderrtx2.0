local nextUpdate, frameCount = 0, 0
RunService.RenderStepped:Connect(function(dt)
    frameCount += 1
    nextUpdate += dt
    if nextUpdate >= 0.5 then
        local fps = math.round(frameCount / nextUpdate)
        FPSLabel.Text = "FPS: " .. fps
        FPSLabel.TextColor3 = fps >= 60 and Color3.fromRGB(0, 255, 150) or fps >= 30 and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(255, 60, 60)
        frameCount, nextUpdate = 0, 0
    end
end)

-- [ PHASE 3: PROFILE & APPLY FUNCTION ] --
local DAY = {
    clock = 10, brightness = 2.5, exposure = 0.25,
    ambient = Color3.fromRGB(100, 100, 110), atmoColor = Color3.fromRGB(185, 215, 255),
    atmoDecay = Color3.fromRGB(110, 120, 140), atmoGlare = 1.5, atmoHaze = 1.5,
    atmoDensity = 0.25, contrast = 0.2, saturation = 0.4,
    tint = Color3.fromRGB(255, 255, 255), bloom = 0.4, bloomSize = 18, bloomThreshold = 0.8,
}

local NIGHT = {
    clock = 21, brightness = 1.9, exposure = 0.2,
    ambient = Color3.fromRGB(30, 38, 65), atmoColor = Color3.fromRGB(30, 50, 100),
    atmoDecay = Color3.fromRGB(20, 25, 55), atmoGlare = 0.3, atmoHaze = 0.6,
    atmoDensity = 0.25, contrast = 0.2, saturation = 0.3,
    tint = Color3.fromRGB(215, 228, 255), bloom = 0.8, bloomSize = 18, bloomThreshold = 0.5,
}

for _, v in pairs(Lighting:GetChildren()) do
    if v:IsA("PostProcessEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then v:Destroy() end
end

local Atmosphere = Instance.new("Atmosphere", Lighting)
local ColorCorrection = Instance.new("ColorCorrectionEffect", Lighting)
local Bloom = Instance.new("BloomEffect", Lighting)
local SunRays = Instance.new("SunRaysEffect", Lighting)
local DOF = Instance.new("DepthOfFieldEffect", Lighting)
DOF.FarIntensity, DOF.FocusDistance, DOF.InFocusRadius = 0.35, 35, 20

local function applyProfile(p)
    Lighting.ClockTime = p.clock
    Lighting.Brightness = p.brightness
    Lighting.ExposureCompensation = p.exposure
    Lighting.OutdoorAmbient = p.ambient
    Atmosphere.Color, Atmosphere.Decay = p.atmoColor, p.atmoDecay
    Atmosphere.Glare, Atmosphere.Haze, Atmosphere.Density = p.atmoGlare, p.atmoHaze, p.atmoDensity
    ColorCorrection.Contrast, ColorCorrection.Saturation, ColorCorrection.TintColor = p.contrast, p.saturation, p.tint
    Bloom.Intensity, Bloom.Size, Bloom.Threshold = p.bloom, p.bloomSize, p.bloomThreshold
end

-- [ PHASE 4: DYNAMIC SWITCHER & SMART LOOP ] --
local isDay = true
applyProfile(DAY)

-- สลับโหมดทุก 300 วินาที
task.spawn(function()
    while task.wait(300) do 
        isDay = not isDay
        applyProfile(isDay and DAY or NIGHT)
        StatusLabel.Text = isDay and "◉ MODE: DAY" or "◉ MODE: NIGHT"
    end
end)

-- ✅ Smart Loop Check (แก้ตามที่ท่านสั่ง)
task.spawn(function()
    while task.wait(0.1) do
        local t = Lighting.ClockTime + 0.005
        if isDay then
            if t >= 17.5 then t = 6 end  -- กลางวัน วน 6 โมงเช้า -> 5 โมงเย็น
        else
            if t >= 24 then t = 18 end   -- กลางคืน วน 6 โมงเย็น -> เที่ยงคืน
        end
        Lighting.ClockTime = t
    end
end)

