local function registerAndApplyPart(v)
    if not (v:IsA("BasePart") or v:IsA("MeshPart")) then return end
    if not MaterialCache[v] then
        MaterialCache[v] = { Material = v.Material, CastShadow = v.CastShadow, Reflectance = v.Reflectance, Color = v.Color }
        ActiveParts[v] = true
    end
    if isFpsBoostOn then
        v.Material = Enum.Material.SmoothPlastic; v.CastShadow = false; v.Reflectance = 0
    else
        local data = MaterialCache[v] v.Material = data.Material; v.CastShadow = data.CastShadow
        if pbrEnabled then
            local m = data.Material local r = 0
            if m == Enum.Material.Concrete then r = 0.15 elseif m == Enum.Material.SmoothPlastic then r = 0.35 elseif m == Enum.Material.Marble then r = 0.55 elseif m == Enum.Material.Metal or m == Enum.Material.DiamondPlate then r = 0.65 elseif m == Enum.Material.Glass then r = 0.8 elseif m == Enum.Material.Neon then r = 0.85 end
            if antiBlueGloss then
                local c = data.Color local lum = (c.R * 0.299) + (c.G * 0.587) + (c.B * 0.114)
                v.Reflectance = lum < 0.18 and r * (lum * 3.5) or r
            else v.Reflectance = r end
        else v.Reflectance = data.Reflectance end
    end
end

