-- ==================== 📈 LOOP BUFFER SYSTEM (🔒 FEATURE 1) ====================
local nextUpdate = 0 local fpsBuffer = {}
safeConnect(RunService.RenderStepped, function(dt)
    nextUpdate = nextUpdate + dt
    
    -- ใส่ค่าเข้า Buffer แถวเรียงลำดับลึกซึ้ง (Moving Average Calculation)
    table.insert(fpsBuffer, 1 / dt)
    if #fpsBuffer > 45 then table.remove(fpsBuffer, 1) end -- บัฟเฟอร์สมดุลที่ 45 เฟรม
    
    if not isMinimized then
        local shimmerTime = os.clock()
        GlassGradient.Offset = Vector2.new(math.sin(shimmerTime * 1.5) * 0.3, math.cos(shimmerTime * 1.5) * 0.3)
    end
    if rainbowActive then
        rainbowHue = (rainbowHue + dt * 80) % 360 local col = Color3.fromHSV(rainbowHue/360, 1, 1) local col2 = Color3.fromHSV(((rainbowHue+120)%360)/360, 1, 1)
        UIGradientStroke.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, col), ColorSequenceKeypoint.new(0.5, col2), ColorSequenceKeypoint.new(1, col)})
        BorderColorNow = col activeThemeLabel.TextColor3 = col if activeTabButton then activeTabButton.BackgroundColor3 = col end
    end
    if nextUpdate >= 0.25 then
        -- คำนวณหาค่าเฉลี่ยตัวเลขความนิ่งตัวนับเฟรมเรตที่แม่นยำ
        local sum = 0 for _, v in ipairs(fpsBuffer) do sum = sum + v end
        local stableFps = math.floor(sum / #fpsBuffer)
        if stableFps > 999 or stableFps < 1 then stableFps = 60 end
        
        InfoFPSLabel.Text = "FPS: " .. stableFps
        if isMinimized then MinimizedStatusLabel.Text = ModeText MinimizedStatusLabel.TextColor3 = BorderColorNow end
        if not rainbowActive then TweenService:Create(UIStroke, TweenInfo.new(0.25), {Color = BorderColorNow}):Play() end
        nextUpdate = 0
    end
end)

