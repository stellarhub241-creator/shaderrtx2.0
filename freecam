RunService.RenderStepped:Connect(function()
    if SpectateMode == "FOLLOW" and SpectateTarget and SpectateTarget.Character then
        local root = SpectateTarget.Character:FindFirstChild("HumanoidRootPart")
        local hum = SpectateTarget.Character:FindFirstChildOfClass("Humanoid")
        if root then
            local rX, rY = math.rad(orbitAngleX), math.rad(orbitAngleY)
            local offset = Vector3.new(
                math.sin(rX) * math.cos(rY) * orbitDistance,
                math.sin(rY) * orbitDistance,
                math.cos(rX) * math.cos(rY) * orbitDistance
            )
            Camera.CFrame = CFrame.new(root.Position + offset, root.Position)
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local dist = myRoot and math.floor((myRoot.Position - root.Position).Magnitude) or 0
            local currentHP = hum and math.floor(hum.Health) or 0
            local maxHP = hum and math.floor(hum.MaxHealth) or 100
            InfoHUD.Visible = true
            HUDName.Text = "Watch: " .. SpectateTarget.Name
            HUDHealth.Text = "HP: " .. currentHP .. "/" .. maxHP
            HUDDetails.Text = "Dist: " .. dist .. " | Age: " .. SpectateTarget.AccountAge .. "d"
            SpecHighlight.Parent = SpectateTarget.Character
            SpecHighlight.Enabled = true
        end
        DPad.Visible = false

    elseif SpectateMode == "LOCKON" and SpectateTarget and SpectateTarget.Character then
        local root = SpectateTarget.Character:FindFirstChild("HumanoidRootPart")
        local hum = SpectateTarget.Character:FindFirstChildOfClass("Humanoid")
        if root then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, root.Position)
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local dist = myRoot and math.floor((myRoot.Position - root.Position).Magnitude) or 0
            local currentHP = hum and math.floor(hum.Health) or 0
            local maxHP = hum and math.floor(hum.MaxHealth) or 100
            InfoHUD.Visible = true
            HUDName.Text = "Lock: " .. SpectateTarget.Name
            HUDHealth.Text = "HP: " .. currentHP .. "/" .. maxHP
            HUDDetails.Text = "Dist: " .. dist .. " | Age: " .. SpectateTarget.AccountAge .. "d"
            SpecHighlight.Parent = SpectateTarget.Character
            SpecHighlight.Enabled = true
        end
        DPad.Visible = false

    elseif SpectateMode == "FREECAM" then
        InfoHUD.Visible = false
        DPad.Visible = true
        SpecHighlight.Enabled = false
        SpecHighlight.Parent = nil
        local move = Vector3.new(0, 0, 0)
        if camButtons.Forward then move += Camera.CFrame.LookVector end
        if camButtons.Back then move -= Camera.CFrame.LookVector end
        if camButtons.Left then move -= Camera.CFrame.RightVector end
        if camButtons.Right then move += Camera.CFrame.RightVector end
        if camButtons.Up then move += Vector3.new(0, 1, 0) end
        if camButtons.Down then move -= Vector3.new(0, 1, 0) end
        FreeCamCFrame = FreeCamCFrame + move * FreeCamSpeed
        Camera.CFrame = FreeCamCFrame
    else
        InfoHUD.Visible = false
        DPad.Visible = false
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer or not p.Character then continue end
        local root = p.Character:FindFirstChild("HumanoidRootPart")
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if root and hum then
            if hum.WalkSpeed > SPEED_LIMIT then
                if not suspiciousLog[p.Name.."_spd"] then
                    suspiciousLog[p.Name.."_spd"] = true
                    AddLog("SPD " .. p.Name .. " " .. math.floor(hum.WalkSpeed), Color3.fromRGB(255, 160, 0))
                end
            else suspiciousLog[p.Name.."_spd"] = nil end

            if lastPositions[p.Name] then
                local dist = (root.Position - lastPositions[p.Name]).Magnitude
                if dist > TELE_LIMIT then
                    if not suspiciousLog[p.Name.."_tele"] then
                        suspiciousLog[p.Name.."_tele"] = true
                        AddLog("TELE " .. p.Name .. " " .. math.floor(dist), Color3.fromRGB(255, 80, 80))
                    end
                else suspiciousLog[p.Name.."_tele"] = nil end
            end

            if lastHeights[p.Name] then
                local heightDiff = root.Position.Y - lastHeights[p.Name]
                local onGround = hum.FloorMaterial ~= Enum.Material.Air
                if not onGround and heightDiff > 5 and hum.Health > 0 then
                    if not suspiciousLog[p.Name.."_fly"] then
                        suspiciousLog[p.Name.."_fly"] = true
                        AddLog("FLY " .. p.Name, Color3.fromRGB(180, 100, 255))
                    end
                else suspiciousLog[p.Name.."_fly"] = nil end
            end

            if lastPositions[p.Name] then
                local rayOrigin = lastPositions[p.Name]
                local rayDir = root.Position - rayOrigin
                local ray = workspace:Raycast(rayOrigin, rayDir)
                if ray and ray.Instance and not ray.Instance:IsDescendantOf(p.Character) and ray.Instance.CanCollide then
                    if not suspiciousLog[p.Name.."_noclip"] then
                        suspiciousLog[p.Name.."_noclip"] = true
                        AddLog("NOCLIP " .. p.Name, Color3.fromRGB(200, 100, 255))
                    end
                else suspiciousLog[p.Name.."_noclip"] = nil end
            end

            lastPositions[p.Name] = root.Position
            lastHeights[p.Name] = root.Position.Y
        end
    end
end)

