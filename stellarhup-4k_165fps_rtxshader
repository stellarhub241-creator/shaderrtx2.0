-- [ PHASE 6: REAL-TIME INTERPOLATION ENGINE ] --

local function lerpN(a,b,t) 
    return a+(b-a)*t 
end

[span_12](start_span)local function lerpC(a,b,t)[span_12](end_span)
    return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t) 
end

local function lerpProfile(a,b,t)
    return {
        brightness=lerpN(a.brightness,b.brightness,t),
        exposure=lerpN(a.exposure,b.exposure,t),
        shadow=lerpN(a.shadow,b.shadow,t),
        ambient=lerpC(a.ambient,b.ambient,t),
        atmoColor=lerpC(a.atmoColor,b.atmoColor,t),
        atmoDecay=lerpC(a.atmoDecay,b.atmoDecay,t),
        atmoGlare=lerpN(a.atmoGlare,b.atmoGlare,t),
        atmoHaze=lerpN(a.atmoHaze,b.atmoHaze,t),
        atmoDensity=lerpN(a.atmoDensity,b.atmoDensity,t),
        contrast=lerpN(a.contrast,b.contrast,t),
        saturation=lerpN(a.saturation,b.saturation,t),
        tint=lerpC(a.tint,b.tint,t),
        bloom=lerpN(a.bloom,b.bloom,t),
        bloomSize=lerpN(a.bloomSize,b.bloomSize,t),
        bloomThreshold=lerpN(a.bloomThreshold,b.bloomThreshold,t),
        dofFar=lerpN(a.dofFar,b.dofFar,t),
        sunRays=lerpN(a.sunRays,b.sunRays,t),
    }
end

