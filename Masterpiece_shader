-- [ PHASE 6: ADVANCED ULTRA-PBR PASS (ANTI-BLUE ENGINE) ] --
local function applyPBROnPart(v)
    if not pbrEnabled or isFpsBoostOn then return end
    if v:IsA("BasePart") or v:IsA("MeshPart") then
        v.CastShadow = true
        local m = v.Material
        local baseReflectance = 0
        
        if m == Enum.Material.Concrete then baseReflectance = 0.15
        elseif m == Enum.Material.SmoothPlastic then baseReflectance = 0.35
        elseif m == Enum.Material.Cobblestone then baseReflectance = 0.08
        elseif m == Enum.Material.Wood or m == Enum.Material.WoodPlanks then baseReflectance = 0.03
        elseif m == Enum.Material.Marble then baseReflectance = 0.55
        elseif m == Enum.Material.Granite then baseReflectance = 0.3
        elseif m == Enum.Material.Metal or m == Enum.Material.DiamondPlate then baseReflectance = 0.65
        elseif m == Enum.Material.Glass then baseReflectance = 0.8
        elseif m == Enum.Material.Neon then baseReflectance = 0.85
        elseif m == Enum.Material.Ice then baseReflectance = 0.7
        elseif m == Enum.Material.Sand then baseReflectance = 0.02
        elseif m == Enum.Material.Grass then baseReflectance = 0.0
        end

        -- ล้างค่าแสงสะท้อนของท้องฟ้าสีครามอออกจากวัตถุที่มีสีมืดสนิท
        if antiBlueGloss then
            local color = v.Color
            local luminance = (color.R * 0.299) + (color.G * 0.587) + (color.B * 0.114)
            if luminance < 0.18 then
                v.Reflectance = baseReflectance * (luminance * 3.5)
            else
                v.Reflectance = baseReflectance
            end
        else
            v.Reflectance = baseReflectance
        end
    end
end

local function runPBRScan()
    local count = 0
    for _, v in pairs(workspace:GetDescendants()) do
        applyPBROnPart(v)
        count = count + 1
        if count % 200 == 0 then task.wait() end
    end
end
