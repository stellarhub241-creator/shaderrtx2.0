local function triggerFPSBoost(turnOn)
    isFpsBoostOn = turnOn
    if turnOn then
        local count = 0
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") then
                -- สำรองประเภทวัสดุไว้เพื่อใช้ย้อนคืน
                if not originalMaterials[v] then
                    originalMaterials[v] = v.Material
                    originalShadows[v] = v.CastShadow
                end
                
                -- สั่งให้เป็นวัสดุที่ประมวลผลง่ายสุด และปิดเงาตกสะท้อนทั้งหมด
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
                v.Reflectance = 0
            elseif v:IsA("Decal") or v:IsA("Texture") then
                v.Transparency = 1
            end
            
            count = count + 1
            if count % 250 == 0 then task.wait() end
        end
        
        Terrain.Decoration = false
        Lighting.GlobalShadows = false
        
    else
        -- ย้อนวัสดุดั้งเดิมทั้งหมดกลับมา
        local count = 0
        for v, mat in pairs(originalMaterials) do
            if v and v.Parent then
                v.Material = mat
                v.CastShadow = originalShadows[v] or false
            end
            count = count + 1
            if count % 250 == 0 then task.wait() end
        end
        
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Decal") or v:IsA("Texture") then
                v.Transparency = 0
            end
        end
        
        Terrain.Decoration = true
        Lighting.GlobalShadows = true
        
        -- ล้างตารางสำรองความจำ
        table.clear(originalMaterials)
        table.clear(originalShadows)
        
        task.spawn(runPBRScan) -- คืนค่าความเงาสวยงาม
    end
end

