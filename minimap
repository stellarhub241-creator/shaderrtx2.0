UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local function isOutside(frame, clickPos)
            if not frame.Visible then return true end
            local pos = frame.AbsolutePosition
            local size = frame.AbsoluteSize
            return clickPos.X < pos.X or clickPos.X > pos.X + size.X or clickPos.Y < pos.Y or clickPos.Y > pos.Y + size.Y
        end
        local clickPos = input.Position
        if isOutside(PlayerMenu, clickPos) then PlayerMenu.Visible = false end
        if isOutside(WpListMenu, clickPos) then WpListMenu.Visible = false end
    end
end)

