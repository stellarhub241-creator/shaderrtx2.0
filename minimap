    local lookVector = Camera.CFrame.LookVector
    local angle = math.atan2(lookVector.X, lookVector.Z) + math.pi
    Compass.Rotation = math.deg(angle)

    local mapWidth = MapContent.AbsoluteSize.X
    local mapHeight = MapContent.AbsoluteSize.Y
    local centerX = mapWidth / 2
    local centerY = mapHeight / 2
    local radius = (mapWidth / 2) - 10

    -- อัปเดตจุดปักหมุด (Pin UI)
    if activePinPos then
        local diffX = activePinPos.X - localPos.X
        local diffZ = activePinPos.Z - localPos.Z

        local uiX = centerX + (diffX * (currentZoom / 10))
        local uiY = centerY + (diffZ * (currentZoom / 10))

        local dx = uiX - centerX
        local dy = uiY - centerY
        local dist = math.sqrt(dx*dx + dy*dy)

        if dist > radius then
            local angleToDot = math.atan2(dy, dx)
            uiX = centerX + math.cos(angleToDot) * radius
            uiY = centerY + math.sin(angleToDot) * radius
        end

        PinElement.Position = UDim2.new(0, uiX, 0, uiY)
        local realDistance = math.round((Vector3.new(activePinPos.X, 0, activePinPos.Z) - Vector3.new(localPos.X, 0, localPos.Z)).Magnitude)
        PinInfoLabel.Text = string.format("📍 ระยะห่าง: %d ม.", realDistance)
    end

    -- อัปเดตตำแหน่งผู้เล่นทุกคนในโลกเกม
    for player, dot in pairs(playerDots) do
