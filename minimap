-- PIN SYSTEM (ปักหมุด)
MapContent.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        -- ไม่ปักหมุดหากคลิกโดนปุ่มซูมหรือทิศเหนือ
        local mousePos = input.Position
        local zoomMin = ZoomContainer.AbsolutePosition
        local zoomMax = ZoomContainer.AbsolutePosition + ZoomContainer.AbsoluteSize
        if mousePos.X >= zoomMin.X and mousePos.X <= zoomMax.X and mousePos.Y >= zoomMin.Y and mousePos.Y <= zoomMax.Y then return end
        
        local compassMin = Compass.AbsolutePosition
        local compassMax = Compass.AbsolutePosition + Compass.AbsoluteSize
        if mousePos.X >= compassMin.X and mousePos.X <= compassMax.X and mousePos.Y >= compassMin.Y and mousePos.Y <= compassMax.Y then return end

        local localCharacter = LocalPlayer.Character
        local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")
        if not localRoot then return end

        local contentPos = MapContent.AbsolutePosition
        local contentSize = MapContent.AbsoluteSize
        local relativeX = mousePos.X - contentPos.X
        local relativeY = mousePos.Y - contentPos.Y
        
        if relativeX >= 0 and relativeX <= contentSize.X and relativeY >= 0 and relativeY <= contentSize.Y then
            local centerX = contentSize.X / 2
            local centerY = contentSize.Y / 2
            
            local diffX = (relativeX - centerX) / (currentZoom / 10)
            local diffZ = (relativeY - centerY) / (currentZoom / 10)
            
            local localPos = localRoot.Position
            local targetWorldX = localPos.X + diffX
            local targetWorldZ = localPos.Z + diffZ
            
            -- ปรับระดับความสูง Y ด้วย Raycast ป้องกันการวาปติดใต้พื้นดิน
            local raycastParams = RaycastParams.new()
            raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            raycastParams.FilterDescendantsInstances = {localCharacter}
            local raycastResult = workspace:Raycast(Vector3.new(targetWorldX, 1000, targetWorldZ), Vector3.new(0, -2000, 0), raycastParams)
            local targetWorldY = raycastResult and raycastResult.Position.Y or localPos.Y
            
            activePinPos = Vector3.new(targetWorldX, targetWorldY, targetWorldZ)
            PinElement.Visible = true
        end
    end
end)

