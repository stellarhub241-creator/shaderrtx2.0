            local diffZ = root.Position.Z - localPos.Z

            local uiX = centerX + (diffX * (currentZoom / 10))
            local uiY = centerY + (diffZ * (currentZoom / 10))

            local dx = uiX - centerX
            local dy = uiY - centerY
            local dist = math.sqrt(dx*dx + dy*dy)

            if dist > radius then
                local angleToDot = math.atan2(dy, dx)
                uiX = centerX + math.cos(angleToDot) * radius
                uiY = centerY + math.sin(angleToDot) * radius
            end

            dot.Position = UDim2.new(0, uiX, 0, uiY)
            
            -- หากเป็นตัวเราเอง ให้ลูกศรชี้หมุนตามองศาการหันจริงของตัวละคร
            if player == LocalPlayer then
                local charLook = localRoot.CFrame.LookVector
                local charAngle = math.atan2(charLook.X, charLook.Z) + math.pi
                dot.Rotation = math.deg(charAngle) - 180 -- ชดเชยทิศทางให้หัวลูกศรหันตรงพอดี
            end
        else
            dot.Visible = false
        end
    end
end)

