-- 🎯 ระบบสแกนหาเป้าหมายและคัดกรองแบบอัตโนมัติ
-- ==========================================
local function getClosestTarget()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") then
            local targetChar = player.Character
            local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
            
            if targetHRP and targetChar.Humanoid.Health > 0 then
                local isSameTeam = (Config.TeamCheck and player.Team == LocalPlayer.Team)
                
                if not isSameTeam then
                    local distance = (myChar.HumanoidRootPart.Position - targetHRP.Position).Magnitude
                    -- ใช้ขอบเขต SearchRange ในการค้นหาเพื่อเดินเข้าหา
                    if distance < shortestDistance and distance <= Config.SearchRange then
                        shortestDistance = distance
                        closestPlayer = player
                    end
                end
            end
        end
    end
    return closestPlayer
end

-- ฟังก์ชันปิดกล่องชนของร่างกายผู้เล่นชั่วคราว (No-Clip) เพื่อให้ทะลุกำแพงได้ไม่ติดขัด
local function enableNoClip()
    local myChar = LocalPlayer.Character
    if myChar then
        for _, part in pairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end
end

-- ===================================================
-- 🔄 ลูปรันระบบโจมตี ล็อกเป้า และเดินออโต้ทะลุกำแพง
-- ===================================================
RunService.Stepped:Connect(function()
    if Config.BotEnabled then
        local target = getClosestTarget()
        CurrentTarget = target
        
        local myChar = LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        
        if target and target.Character and target.Character:FindFirstChild(Config.TargetPart) and myHRP then
            local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
            local aimPart = target.Character[Config.TargetPart]
            
            -- [1] หมุนหน้ากล้องล็อกเป้าทันที
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, aimPart.Position)
            
            -- คำนวณระยะทางจริงในขณะนั้น
            local currentDistance = (myHRP.Position - targetHRP.Position).Magnitude
            
            -- [2] ระบบ Auto Walk (สไลด์ตัวเข้าหาเป้าหมายทะลุกำแพง)
            if Config.AutoWalk then
                enableNoClip() -- ปิดกล่องชนตัวเราเพื่อไม่ให้ติดกำแพง
                
                -- เคลื่อนที่เข้าหาเป้าหมายแบบสมูท (เว้นระยะห่างไว้ 4 Studs เพื่อความเนียนในการโจมตีระยะประชิด)
                local direction = (targetHRP.Position - myHRP.Position).Unit
                local destination = targetHRP.Position - (direction * 4)
                
                -- ใช้การขยับ CFrame โดยตรงเพื่อทะลุสิ่งกีดขวางทั้งหมด
                myHRP.CFrame = CFrame.new(myHRP.Position, targetHRP.Position):Lerp(CFrame.new(destination, targetHRP.Position), 0.12)
                
                -- รีเซ็ตค่าความเร็วป้องกันตัวละครโดนระบบฟิสิกส์ดีดออกนอกแมพ
                myHRP.Velocity = Vector3.new(0, 0, 0)
            end
            
            -- [3] ระบบยิงอัตโนมัติ (จะยิงเมื่ออยู่ในระยะโจมตี)
            if currentDistance <= Config.AttackRange then
                if Config.ESPEnabled then
                    TargetHighlight.Parent = target.Character
                    TargetHighlight.Enabled = true
                else
                    TargetHighlight.Enabled = false
                end
                
                -- จำลองการยิง/คลิก
                VirtualUser:Button1Down(Vector2.new(0,0), Camera.CFrame)
                task.wait(0.01)
                VirtualUser:Button1Up(Vector2.new(0,0), Camera.CFrame)
            else
                TargetHighlight.Enabled = false
                TargetHighlight.Parent = nil
            end
        else
            TargetHighlight.Enabled = false
            TargetHighlight.Parent = nil
        end
    else
        TargetHighlight.Enabled = false
        TargetHighlight.Parent = nil
    end
end)

