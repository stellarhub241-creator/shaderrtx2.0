pcall(function() if setfpscap then setfpscap(120) end end)

-- ตั้งค่าระบบตั้งต้น (Config)
local Config = {
    BotEnabled = true,
    AutoWalk = true,           -- ระบบเดินตามเป้าหมายออโต้ (ทะลุกำแพง)
    AttackRange = 35,          -- ระยะล็อกยิงออโต้
    SearchRange = 150,         -- ระยะในการสแกนและเดินเข้าหาศัตรู (กว้างขึ้นเพื่อให้ระบบเดินออโต้ทำงานได้จากระยะไกล)
    TargetPart = "HumanoidRootPart", 
    TeamCheck = false,         
    ESPEnabled = true          
}

-- ตัวแปรเก็บเป้าหมายปัจจุบัน
local CurrentTarget = nil

