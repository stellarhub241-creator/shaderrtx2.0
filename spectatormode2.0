ZoomLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
ZoomLabel.TextSize = 10
ZoomLabel.Font = Enum.Font.Code
ZoomLabel.Text = "Zoom:"
ZoomLabel.TextXAlignment = Enum.TextXAlignment.Left

local ZoomOut = Instance.new("TextButton", Content)
