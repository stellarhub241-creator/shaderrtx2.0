-- [ ⚠️ หน้าต่างประวัติระบบตรวจสอบ (Detector Logs Window) ] --
local LogFrame = Instance.new("Frame", ScreenGui)
LogFrame.Size = UDim2.new(0, 220, 0, 160)
LogFrame.Position = UDim2.new(0.05, 170, 0.3, 0)
LogFrame.BackgroundColor3 = Color3.fromRGB(15, 10, 10)
LogFrame.BackgroundTransparency = 0.15
LogFrame.Active = true
makeDraggable(LogFrame)

local LogCorner = Instance.new("UICorner", LogFrame)
LogCorner.CornerRadius = UDim.new(0, 10)
Instance.new("UIStroke", LogFrame).Color = Color3.fromRGB(220, 50, 50)

local LogTitle = Instance.new("TextLabel", LogFrame)
LogTitle.Size = UDim2.new(1, 0, 0, 28)
LogTitle.BackgroundColor3 = Color3.fromRGB(45, 10, 10)
LogTitle.TextColor3 = Color3.fromRGB(255, 100, 100)
LogTitle.Text = "  ⚠️ DETECTOR LOGS"
LogTitle.TextSize = 11
LogTitle.Font = Enum.Font.Code
LogTitle.TextXAlignment = Enum.TextXAlignment.Left

local LogTitleCorner = Instance.new("UICorner", LogTitle)
LogTitleCorner.CornerRadius = UDim.new(0, 10)

local ScrollLog = Instance.new("ScrollingFrame", LogFrame)
ScrollLog.Size = UDim2.new(1, -10, 1, -34)
ScrollLog.Position = UDim2.new(0, 5, 0, 31)
ScrollLog.BackgroundTransparency = 1
ScrollLog.ScrollBarThickness = 3
ScrollLog.ScrollBarImageColor3 = Color3.fromRGB(220, 50, 50)

local UIList = Instance.new("UIListLayout", ScrollLog)
UIList.Padding = UDim.new(0, 3)

-- ฟังก์ชันดึงค่าเวลาจำลองในเครื่องผู้ใช้เพื่อแปะหัว Logs
local function getTimestamp()
    local date = os.date("*t")
    return string.format("[%02d:%02d:%02d]", date.hour, date.min, date.sec)
end

local function AddLog(text, color)
    local lbl = Instance.new("TextLabel", ScrollLog)
    lbl.Size = UDim2.new(1, 0, 0, 16)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = color or Color3.fromRGB(255, 230, 100)
    lbl.TextSize = 9
    lbl.Font = Enum.Font.Code
    lbl.Text = getTimestamp() .. " " .. text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    -- บริหารจัดการจำกัดประวัติให้เหมาะสม
    local children = ScrollLog:GetChildren()
    local labels = {}
    for _, c in pairs(children) do
        if c:IsA("TextLabel") then table.insert(labels, c) end
    end
    if #labels > 20 then labels[1]:Destroy() end
    
    ScrollLog.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
end

-- [ 🕹️ แผงควบคุมสัญญาน D-PAD สำหรับ Free Cam ] --
local DPad = Instance.new("Frame", ScreenGui)
DPad.Size = UDim2.new(0, 140, 0, 140)
DPad.Position = UDim2.new(0.5, -70, 0.65, 0)
DPad.BackgroundTransparency = 1
DPad.Visible = false
DPad.Active = true
makeDraggable(DPad)

local function CreateDBtn(name, pos, txt)
    local b = Instance.new("TextButton", DPad)
    b.Size = UDim2.new(0, 42, 0, 42)
    b.Position = pos
    b.Text = txt
    b.BackgroundColor3 = Color3.fromRGB(15, 20, 30)
    b.BackgroundTransparency = 0.2
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Font = Enum.Font.Code
    b.TextSize = 13
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
    
    local stroke = Instance.new("UIStroke", b)
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(0, 180, 255)
    
    b.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            camButtons[name] = true
        end
    end)
    b.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            camButtons[name] = false
        end
    end)
end

CreateDBtn("Forward", UDim2.new(0.35, 0, 0, 0), "▲")
CreateDBtn("Back", UDim2.new(0.35, 0, 0.6, 0), "▼")
CreateDBtn("Left", UDim2.new(0, 0, 0.3, 0), "◀")
CreateDBtn("Right", UDim2.new(0.7, 0, 0.3, 0), "▶")
CreateDBtn("Up", UDim2.new(0.7, 0, 0, 0), "↑")
CreateDBtn("Down", UDim2.new(0, 0, 0.6, 0), "↓")

-- [ 🔄 ระบบวนลูปการทำงานประมวลผลหลัก (Main Render Loop) ] --
RunService.RenderStepped:Connect(function()
    
    -- ส่วนของการควบคุมและจัดการมุมมองกล้อง
    if SpectateMode == "FOLLOW" and SpectateTarget and SpectateTarget.Character then
        local root = SpectateTarget.Character:FindFirstChild("HumanoidRootPart")
        local hum = SpectateTarget.Character:FindFirstChildOfClass("Humanoid")
        
        if root then
            local rX, rY = math.rad(orbitAngleX), math.rad(orbitAngleY)
            local offset = Vector3.new(
                math.sin(rX) * math.cos(rY) * orbitDistance,
                math.sin(rY) * orbitDistance,
                math.cos(rX) * math.cos(rY) * orbitDistance
            )
            Camera.CFrame = CFrame.new(root.Position + offset, root.Position)

            -- แสดงรายละเอียดโปรไฟล์ผู้เล่นด้านบนจอ
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local dist = myRoot and math.floor((myRoot.Position - root.Position).Magnitude) or 0
            local currentHP = hum and math.floor(hum.Health) or 0
            local maxHP = hum and math.floor(hum.MaxHealth) or 100
            
            InfoHUD.Visible = true
            HUDName.Text = "👁 Watch: " .. SpectateTarget.Name
            HUDHealth.Text = "Health: " .. currentHP .. "/" .. maxHP .. " HP"
            HUDDetails.Text = "Distance: " .. dist .. " studs | Age: " .. SpectateTarget.AccountAge .. " days"
            
            -- ควบคุมเอฟเฟกต์เรืองแสงติดตาม
            SpecHighlight.Parent = SpectateTarget.Character
            SpecHighlight.Enabled = true
        end
        DPad.Visible = false

    elseif SpectateMode == "LOCKON" and SpectateTarget and SpectateTarget.Character then
        local root = SpectateTarget.Character:FindFirstChild("HumanoidRootPart")
        local hum = SpectateTarget.Character:FindFirstChildOfClass("Humanoid")
        
        if root then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, root.Position)
            
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local dist = myRoot and math.floor((myRoot.Position - root.Position).Magnitude) or 0
            local currentHP = hum and math.floor(hum.Health) or 0
            local maxHP = hum and math.floor(hum.MaxHealth) or 100
            
            InfoHUD.Visible = true
            HUDName.Text = "🎯 Lock: " .. SpectateTarget.Name
            HUDHealth.Text = "Health: " .. currentHP .. "/" .. maxHP .. " HP"
            HUDDetails.Text = "Distance: " .. dist .. " studs | Age: " .. SpectateTarget.AccountAge .. " days"
            
            SpecHighlight.Parent = SpectateTarget.Character
            SpecHighlight.Enabled = true
        end
        DPad.Visible = false

    elseif SpectateMode == "FREECAM" then
        InfoHUD.Visible = false
        DPad.Visible = true
        SpecHighlight.Enabled = false
        SpecHighlight.Parent = nil
        
        local move = Vector3.new(0, 0, 0)
        if camButtons.Forward then move = move + Camera.CFrame.LookVector end
        if camButtons.Back then move = move - Camera.CFrame.LookVector end
        if camButtons.Left then move = move - Camera.CFrame.RightVector end
        if camButtons.Right then move = move + Camera.CFrame.RightVector end
        if camButtons.Up then move = move + Vector3.new(0, 1, 0) end
        if camButtons.Down then move = move - Vector3.new(0, 1, 0) end
        
        FreeCamCFrame = FreeCamCFrame + move * FreeCamSpeed
        Camera.CFrame = FreeCamCFrame
    else
        InfoHUD.Visible = false
        DPad.Visible = false
    end

    -- [ 🤖 ระบบตรวจจับผู้เล่นที่พฤทีพรรรมผิดปกติ (Anti-Exploit Detector Log) ] --
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer or not p.Character then continue end
        
        local root = p.Character:FindFirstChild("HumanoidRootPart")
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        
        if root and hum then
            -- 1. ตรวจจับการเดินเร็วผิดปกติ (Speed Check)
            if hum.WalkSpeed > SPEED_LIMIT then
                if not suspiciousLog[p.Name .. "_spd"] then
                    suspiciousLog[p.Name .. "_spd"] = true
                    AddLog("⚡ " .. p.Name .. " spd:" .. math.floor(hum.WalkSpeed), Color3.fromRGB(255, 160, 0))
                end
            else 
                suspiciousLog[p.Name .. "_spd"] = nil 
            end

            -- 2. ตรวจจับการเทเลพอร์ตย้ายตำแหน่งฉับพลัน (Teleport Check)
            if lastPositions[p.Name] then
                local dist = (root.Position - lastPositions[p.Name]).Magnitude
                if dist > TELE_LIMIT then
                    if not suspiciousLog[p.Name .. "_tele"] then
                        suspiciousLog[p.Name .. "_tele"] = true
                        AddLog("🔀 " .. p.Name .. " tele:" .. math.floor(dist) .. " studs", Color3.fromRGB(255, 80, 80))
                    end
                else 
                    suspiciousLog[p.Name .. "_tele"] = nil 
                end
            end

            -- 3. ตรวจจับการลอยตัวบนฟ้าหรือบิน (Fly Check)
            if lastHeights[p.Name] then
                local heightDiff = root.Position.Y - lastHeights[p.Name]
                local onGround = hum.FloorMaterial ~= Enum.Material.Air
                -- ลอยขึ้นโดยเท้ามารองรับ และไม่มีแรงฟิสิกส์ปกติ
                if not onGround and heightDiff > 5 and hum.Health > 0 then
                    if not suspiciousLog[p.Name .. "_fly"] then
                        suspiciousLog[p.Name .. "_fly"] = true
                        AddLog("🛸 " .. p.Name .. " flying detected", Color3.fromRGB(180, 100, 255))
                    end
                else 
                    suspiciousLog[p.Name .. "_fly"] = nil 
                end
            end

            -- 4. ตรวจจับการเดินผ่านสิ่งกีดขวาง (No-Clip Check)
            if lastPositions[p.Name] then
                local rayOrigin = lastPositions[p.Name]
                local rayDir = root.Position - rayOrigin
                local ray = workspace:Raycast(rayOrigin, rayDir)
                
                -- หากมีการย้ายจากพิกัดหนึ่งสู่อีกพิกัดโดยมีกำแพงปิดกั้นอยู่ตรงกลาง
                if ray and ray.Instance and not ray.Instance:IsDescendantOf(p.Character) and ray.Instance.CanCollide then
                    if not suspiciousLog[p.Name .. "_noclip"] then
                        suspiciousLog[p.Name .. "_noclip"] = true
                        AddLog("👻 " .. p.Name .. " no-clip passing walls", Color3.fromRGB(200, 100, 255))
                    end
                else 
                    suspiciousLog[p.Name .. "_noclip"] = nil 
                end
            end

            -- ทำการอัปเดตตำแหน่งล่าสุดสำหรับใช้เปรียบเทียบใน Frame ถัดไป
            lastPositions[p.Name] = root.Position
            lastHeights[p.Name] = root.Position.Y
        end
    end
end)

print("STELLAR v4.1 (Spectate + Detector) Loaded with Error Fixes! Safe, Creative, and Clean.")

```
