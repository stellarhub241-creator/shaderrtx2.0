ZoomOut.Font = Enum.Font.Code
ZoomOut.TextSize = 12
Instance.new("UICorner", ZoomOut).CornerRadius = UDim.new(0, 4)
ZoomOut.MouseButton1Click:Connect(function()
    orbitDistance = math.clamp(orbitDistance + 3, 5, 80)
end)

local ZoomIn = Instance.new("TextButton", Content)
ZoomIn.Size = UDim2.new(0.2, 0, 0, 22)
ZoomIn.Position = UDim2.new(0.7, 0, 0, 200)
