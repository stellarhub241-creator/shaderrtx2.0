ZoomIn.BackgroundColor3 = Color3.fromRGB(25, 35, 50)
ZoomIn.TextColor3 = Color3.new(1, 1, 1)
ZoomIn.Font = Enum.Font.Code
ZoomIn.TextSize = 12
Instance.new("UICorner", ZoomIn).CornerRadius = UDim.new(0, 4)
ZoomIn.MouseButton1Click:Connect(function()
    orbitDistance = math.clamp(orbitDistance - 3, 5, 80)
end)

-- [ 📊 หน้าต่างแสดงข้อมูลรายละเอียดเป้าหมาย (Player Profile HUD) ] --
