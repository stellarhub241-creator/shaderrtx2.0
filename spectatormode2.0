```lua
-- =====================================================================
-- -- [[ STELLAR: SPECTATE + DETECTOR v4.1 - ERROR FIXED EDITION ]] --
-- =====================================================================
-- แก้ไข: เพิ่มระบบตรรกะตรวจจับพิกัดเก็บ UI ป้องกัน Error จากการเรียกใช้งาน CoreGui (Line 11-15)
-- หากรันบนสภาพแวดล้อมที่ล็อก CoreGui ระบบจะสลับไปวางใน PlayerGui ทันทีเพื่อความปลอดภัย

if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")

-- [ 🛡️ ระบบแก้ไข ERROR LINE 11: ตรวจจับและสลับตำแหน่งวาง UI ] --
local TargetGuiParent = nil
local success, err = pcall(function()
    TargetGuiParent = game:GetService("CoreGui")
end)

if not success or not TargetGuiParent then
    -- หากไม่มีสิทธิ์เข้าถึง CoreGui ให้ใช้ PlayerGui แทนโดยไม่แจ้ง Error
    TargetGuiParent = LocalPlayer:WaitForChild("PlayerGui")
end

-- [ SETTINGS & CONFIGURATION ] --
local SpectateTarget = nil
local SpectateMode = "OFF"
local FreeCamCFrame = CFrame.new(0,50,0)
local FreeCamSpeed = 1.2

-- ขีดจำกัดความเร็ว/ความสูงสำหรับการตรวจจับผิดปกติ (ปรับแต่งได้)
local SPEED_LIMIT = 200
local TELE_LIMIT = 200
local lastPositions = {}
local lastHeights = {}
local suspiciousLog = {}
local targetIndex = 0
local orbitAngleX, orbitAngleY, orbitDistance = 0, 20, 15
local lastTouchPos = nil
local camButtons = {Forward = false, Back = false, Left = false, Right = false, Up = false, Down = false}

-- เคลียร์อินเตอร์เฟสเก่าออกก่อนรันตัวใหม่
if TargetGuiParent:FindFirstChild("STELLAR_SPEC_DETECTOR_V4") then 
    TargetGuiParent:FindFirstChild("STELLAR_SPEC_DETECTOR_V4"):Destroy() 
end

local ScreenGui = Instance.new("ScreenGui", TargetGuiParent)
ScreenGui.Name = "STELLAR_SPEC_DETECTOR_V4"
ScreenGui.IgnoreGuiInset = true

-- [ 🌌 ระบบออร่าเรืองแสงติดตาม (Target Tracker Highlight) ] --
local SpecHighlight = Instance.new("Highlight")
SpecHighlight.FillColor = Color3.fromRGB(0, 180, 255)
SpecHighlight.FillTransparency = 0.5
SpecHighlight.OutlineColor = Color3.fromRGB(255, 255, 255)
SpecHighlight.OutlineTransparency = 0.1
SpecHighlight.Enabled = false

-- [ 💻 ฟังก์ชันลากย้ายหน้าต่างแบบสมูท (สมบูรณ์แบบบนมือถือและ PC) ] --
local function makeDraggable(frame, dragHandle)
    local dragToggle = false
    local dragStart, startPos
    local handle = dragHandle or frame
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragToggle = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragToggle = false end
            end)
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggle then
            local delta = input.Position - dragStart
            local tweenInfo = TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            TweenService:Create(frame, tweenInfo, {Position = targetPos}):Play()
        end
    end)
end

-- [ 🛠️ การจัดการอินพุตทัชสำหรับการหมุน Orbit Cam ] --
UIS.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch then
        lastTouchPos = Vector2.new(i.Position.X, i.Position.Y)
    end
end)

UIS.InputChanged:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch and lastTouchPos and SpectateMode == "FOLLOW" then
        local d = Vector2.new(i.Position.X, i.Position.Y) - lastTouchPos
        orbitAngleX = orbitAngleX - (d.X * 0.4)
        orbitAngleY = math.clamp(orbitAngleY - (d.Y * 0.3), 5, 80)
        lastTouchPos = Vector2.new(i.Position.X, i.Position.Y)
    end
end)

UIS.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch then
        lastTouchPos = nil
    end
end)

-- [ 🎨 หน้าต่างควบคุมหลัก (Main Dashboard Panel) ] --
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 160, 0, 310)
MainFrame.Position = UDim2.new(0.05, 0, 0.3, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(10, 12, 18)
MainFrame.BackgroundTransparency = 0.15
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
makeDraggable(MainFrame)

local MainCorner = Instance.new("UICorner", MainFrame)
MainCorner.CornerRadius = UDim.new(0, 10)

local MainStroke = Instance.new("UIStroke", MainFrame)
MainStroke.Thickness = 1.5
MainStroke.Color = Color3.fromRGB(0, 180, 255)

local TitleBar = Instance.new("Frame", MainFrame)
TitleBar.Size = UDim2.new(1, 0, 0, 32)
TitleBar.BackgroundColor3 = Color3.fromRGB(15, 25, 40)
TitleBar.BorderSizePixel = 0

local TitleCorner = Instance.new("UICorner", TitleBar)
TitleCorner.CornerRadius = UDim.new(0, 10)

local TitleLabel = Instance.new("TextLabel", TitleBar)
TitleLabel.Size = UDim2.new(0.7, 0, 1, 0)
TitleLabel.Position = UDim2.new(0.08, 0, 0, 0)
TitleLabel.BackgroundTransparency = 1
TitleLabel.TextColor3 = Color3.fromRGB(0, 220, 255)
TitleLabel.TextSize = 11
TitleLabel.Font = Enum.Font.Code
TitleLabel.Text = "STELLAR v4.1"
TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

local MinBtn = Instance.new("TextButton", TitleBar)
MinBtn.Size = UDim2.new(0, 26, 0, 22)
MinBtn.Position = UDim2.new(1, -32, 0.5, -11)
MinBtn.Text = "—"
MinBtn.BackgroundColor3 = Color3.fromRGB(20, 45, 75)
MinBtn.TextColor3 = Color3.new(1, 1, 1)
MinBtn.Font = Enum.Font.Code
MinBtn.TextSize = 11
Instance.new("UICorner", MinBtn).CornerRadius = UDim.new(0, 5)

local Content = Instance.new("Frame", MainFrame)
Content.Size = UDim2.new(1, 0, 1, -32)
Content.Position = UDim2.new(0, 0, 0, 32)
Content.BackgroundTransparency = 1

local Status = Instance.new("TextLabel", Content)
Status.Size = UDim2.new(1, 0, 0, 20)
Status.Position = UDim2.new(0, 0, 0, 4)
Status.BackgroundTransparency = 1
Status.TextColor3 = Color3.fromRGB(180, 180, 180)
Status.TextSize = 10
Status.Font = Enum.Font.Code
Status.Text = "Mode: OFF"

local minimized = false
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    Content.Visible = not minimized
    MinBtn.Text = minimized and "+" or "—"
    TweenService:Create(MainFrame, TweenInfo.new(0.2), {
        Size = minimized and UDim2.new(0, 160, 0, 32) or UDim2.new(0, 160, 0, 310)
    }):Play()
end)

local function MakeBtn(txt, y, color, callback)
    local btn = Instance.new("TextButton", Content)
    btn.Size = UDim2.new(0.9, 0, 0, 28)
    btn.Position = UDim2.new(0.05, 0, 0, y)
    btn.Text = txt
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 10
    btn.Font = Enum.Font.Code
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- เพิ่ม/สลับเป้าหมายผู้เล่นคนถัดไป
MakeBtn("⏭ Next Player", 28, Color3.fromRGB(20, 55, 110), function()
    local plrs = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then table.insert(plrs, p) end
    end
    if #plrs == 0 then return end
    targetIndex = (targetIndex % #plrs) + 1
    SpectateTarget = plrs[targetIndex]
    Status.Text = "Target: " .. SpectateTarget.Name
end)

-- โหมดกล้องวงโคจรรอบเป้าหมาย
MakeBtn("👁 Orbit Cam", 62, Color3.fromRGB(0, 100, 70), function()
    if not SpectateTarget then Status.Text = "Select Target!" return end
    SpectateMode = "FOLLOW"
    Camera.CameraType = Enum.CameraType.Scriptable
    Status.Text = "Orbiting..."
end)

-- โหมดกล้องมองตรงล็อกพิกัด
MakeBtn("🎯 Lock On", 96, Color3.fromRGB(110, 50, 10), function()
    if not SpectateTarget then Status.Text = "Select Target!" return end
    SpectateMode = "LOCKON"
    Camera.CameraType = Enum.CameraType.Scriptable
    Status.Text = "Locking..."
end)

-- โหมดบินกล้องอิสระ
MakeBtn("🚁 Free Cam", 130, Color3.fromRGB(75, 15, 100), function()
    SpectateMode = "FREECAM"
    Camera.CameraType = Enum.CameraType.Scriptable
    FreeCamCFrame = Camera.CFrame
    Status.Text = "FreeCam"
end)

-- ปุ่มรีเซ็ตการทำงาน
MakeBtn("↩ Reset Cam", 164, Color3.fromRGB(130, 40, 40), function()
    SpectateMode = "OFF"
    SpectateTarget = nil
    Camera.CameraType = Enum.CameraType.Custom
    Status.Text = "Mode: OFF"
    SpecHighlight.Enabled = false
    SpecHighlight.Parent = nil
end)

-- [ 🔍 แถบควบคุมขนาดการซูม (Zoom Control UI) ] --
local ZoomLabel = Instance.new("TextLabel", Content)
ZoomLabel.Size = UDim2.new(0.4, 0, 0, 22)
ZoomLabel.Position = UDim2.new(0.05, 0, 0, 200)
